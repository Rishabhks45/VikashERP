<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MobileApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MobileApp"
    xmlns:views="clr-namespace:MobileApp.Views"
    FlyoutBehavior="Disabled"
    Title="Vikash ERP">

    <!-- Login Flow (Initial Startup) -->
    <ShellItem Route="LoginFlow">
        <ShellContent
            ContentTemplate="{DataTemplate views:LoginPage}"
            Route="LoginPage" />
    </ShellItem>

    <!-- Main App Flow (Accessible after successful authentication) -->
    <TabBar Route="MainFlow">
        <Tab Title="Dashboard">
            <ShellContent
                ContentTemplate="{DataTemplate local:MainPage}"
                Route="MainPage" />
        </Tab>
    </TabBar>

</Shell>
