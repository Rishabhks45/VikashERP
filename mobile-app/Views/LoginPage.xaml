<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.syncfusion.com/maui/toolkit"
             xmlns:viewmodels="clr-namespace:MobileApp.ViewModels"
             x:Class="MobileApp.Views.LoginPage"
             x:DataType="viewmodels:LoginViewModel"
             BackgroundColor="#080B11"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <!-- ═════════════════════════════════════════════ BACKGROUND GRADIENT ═══ -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#080C14" Offset="0.0" />
                <GradientStop Color="#0F172A" Offset="0.5" />
                <GradientStop Color="#05080F" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Aurora Glow (Top Left) -->
        <Ellipse WidthRequest="320" HeightRequest="320"
                 HorizontalOptions="Start" VerticalOptions="Start"
                 TranslationX="-100" TranslationY="-100"
                 Opacity="0.25">
            <Ellipse.Fill>
                <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                    <GradientStop Color="#6366F1" Offset="0.0" />
                    <GradientStop Color="Transparent" Offset="1.0" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Aurora Glow (Bottom Right) -->
        <Ellipse WidthRequest="380" HeightRequest="380"
                 HorizontalOptions="End" VerticalOptions="End"
                 TranslationX="120" TranslationY="120"
                 Opacity="0.2">
            <Ellipse.Fill>
                <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                    <GradientStop Color="#3B82F6" Offset="0.0" />
                    <GradientStop Color="Transparent" Offset="1.0" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- ════════════════════════════════════════════════ MAIN CONTENT ═══ -->
        <Grid Padding="24" RowDefinitions="Auto, *, Auto" RowSpacing="15" MaximumWidthRequest="450" VerticalOptions="Fill">
                
                <!-- Company Branding / Logo Area -->
                <VerticalStackLayout Grid.Row="0" HorizontalOptions="Center" Spacing="8" Margin="0,35,0,10">
                    <!-- Premium Logo Container -->
                    <Border BackgroundColor="#1E293B" 
                            StrokeShape="RoundRectangle 18"
                            HeightRequest="80" 
                            WidthRequest="80" 
                            HorizontalOptions="Center"
                            Padding="8">
                        <Border.Stroke>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#6366F1" Offset="0.0" />
                                <GradientStop Color="#3B82F6" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Stroke>
                        <Image Source="vikash_logo.png" 
                               Aspect="AspectFit"
                               HeightRequest="64"
                               WidthRequest="64" />
                    </Border>
                    
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="6" Margin="0,8,0,0">
                        <Label Text="VIKASH" 
                               TextColor="#FFFFFF" 
                               FontSize="28" 
                               FontAttributes="Bold" 
                               CharacterSpacing="1" />
                        <Label Text="ERP" 
                               TextColor="#6366F1" 
                               FontSize="28" 
                               FontAttributes="Bold" 
                               CharacterSpacing="1" />
                    </HorizontalStackLayout>
                    
                    <Label Text="Steel Trading Solutions" 
                           TextColor="#94A3B8" 
                           FontSize="13" 
                           HorizontalOptions="Center"
                           CharacterSpacing="0.5" />
                </VerticalStackLayout>

                <!-- Glassmorphic Card Container -->
                <Border Grid.Row="1"
                        StrokeThickness="1" 
                        StrokeShape="RoundRectangle 24"
                        Padding="20"
                        Margin="0,0,0,10"
                        BackgroundColor="#111A2E"
                        Opacity="0.95"
                        VerticalOptions="Center">
                    <Border.Stroke>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#3F4F6A" Offset="0.0" />
                            <GradientStop Color="#1E293B" Offset="0.5" />
                            <GradientStop Color="#4F46E5" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Stroke>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,12" Radius="20" Opacity="0.75" />
                    </Border.Shadow>
                    
                    <VerticalStackLayout Spacing="14">
                        
                        <!-- Header -->
                        <Label Text="Welcome Back" 
                               TextColor="#FFFFFF" 
                               FontSize="22" 
                               FontAttributes="Bold" />
                               
                        <Label Text="Sign in to continue to your account" 
                               TextColor="#94A3B8" 
                               FontSize="13" 
                               Margin="0,-12,0,8" />

                        <!-- User ID Label & Input -->
                        <VerticalStackLayout Spacing="2">
                            <Label Text="User ID" 
                                   TextColor="#FFFFFF" 
                                   FontSize="13" 
                                   FontAttributes="Bold" />
                            <toolkit:SfTextInputLayout 
                                ContainerType="Outlined"
                                OutlineCornerRadius="12"
                                ShowHint="False"
                                HeightRequest="50"
                                ContainerBackground="#070C18"
                                InputViewPadding="38,0,12,0"
                                ReserveSpaceForAssistiveLabels="False">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroupList>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal">
                                                <VisualState.Setters>
                                                    <Setter Property="Stroke" Value="#334155" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="Focused">
                                                <VisualState.Setters>
                                                    <Setter Property="Stroke" Value="#6366F1" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateGroupList>
                                </VisualStateManager.VisualStateGroups>
                                <toolkit:SfTextInputLayout.LeadingView>
                                    <Grid WidthRequest="30" HeightRequest="18" VerticalOptions="Center" Margin="8,0,0,0">
                                        <Path Data="M 12 2 C 6.48 2 2 6.48 2 12 C 2 17.52 6.48 22 12 22 C 17.52 22 22 17.52 22 12 C 22 6.48 17.52 2 12 2 Z M 12 6 C 13.93 6 15.5 7.57 15.5 9.5 C 15.5 11.43 13.93 13 12 13 C 10.07 13 8.5 11.43 8.5 9.5 C 8.5 7.57 10.07 6 12 6 Z M 12 20 C 9.08 20 6.55 18.52 5.09 16.28 C 5.14 13.98 9.7 12.7 12 12.7 C 14.29 12.7 18.85 13.98 18.91 16.28 C 17.45 18.52 14.92 20 12 20 Z" 
                                              Fill="#6366F1" 
                                              Aspect="Uniform"
                                              HeightRequest="18" 
                                              WidthRequest="18" 
                                              HorizontalOptions="Center"
                                              VerticalOptions="Center" />
                                    </Grid>
                                </toolkit:SfTextInputLayout.LeadingView>
                                
                                <Entry Text="{Binding Email}" 
                                       Placeholder="Enter your User ID"
                                       PlaceholderColor="#64748B"
                                       TextColor="#FFFFFF"
                                       BackgroundColor="Transparent"
                                       VerticalOptions="Center"
                                       FontSize="15" />
                            </toolkit:SfTextInputLayout>
                        </VerticalStackLayout>

                        <!-- Password Label & Input -->
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Password" 
                                   TextColor="#FFFFFF" 
                                   FontSize="13" 
                                   FontAttributes="Bold" />
                            <toolkit:SfTextInputLayout 
                                ContainerType="Outlined"
                                OutlineCornerRadius="12"
                                ShowHint="False"
                                EnablePasswordVisibilityToggle="True"
                                HeightRequest="50"
                                ContainerBackground="#070C18"
                                InputViewPadding="38,0,40,0"
                                ReserveSpaceForAssistiveLabels="False">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroupList>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal">
                                                <VisualState.Setters>
                                                    <Setter Property="Stroke" Value="#334155" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="Focused">
                                                <VisualState.Setters>
                                                    <Setter Property="Stroke" Value="#6366F1" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateGroupList>
                                </VisualStateManager.VisualStateGroups>
                                <toolkit:SfTextInputLayout.LeadingView>
                                    <Grid WidthRequest="30" HeightRequest="18" VerticalOptions="Center" Margin="8,0,0,0">
                                        <Path Data="M 18 8 L 17 8 L 17 6 C 17 3.24 14.76 1 12 1 C 9.24 1 7 3.24 7 6 L 7 8 L 6 8 C 4.9 8 4 8.9 4 10 L 4 20 C 4 21.1 4.9 22 6 22 L 18 22 C 19.1 22 20 21.1 20 20 L 20 10 C 20 8.9 19.1 8 18 8 Z M 9 6 C 9 4.34 10.34 3 12 3 C 13.66 3 15 4.34 15 6 L 15 8 L 9 8 L 9 6 Z M 12 17 C 10.9 17 10 16.1 10 15 C 10 13.9 10.9 13 12 13 C 13.1 13 14 13.9 14 15 C 14 16.1 13.1 17 12 17 Z" 
                                              Fill="#6366F1" 
                                              Aspect="Uniform"
                                              HeightRequest="18" 
                                              WidthRequest="18" 
                                              HorizontalOptions="Center"
                                              VerticalOptions="Center" />
                                    </Grid>
                                </toolkit:SfTextInputLayout.LeadingView>
                                
                                <Entry Text="{Binding Password}" 
                                       IsPassword="True" 
                                       Placeholder="Enter your password"
                                       PlaceholderColor="#64748B"
                                       TextColor="#FFFFFF"
                                       BackgroundColor="Transparent"
                                       VerticalOptions="Center"
                                       FontSize="15" />
                            </toolkit:SfTextInputLayout>
                        </VerticalStackLayout>

                        <!-- Remember me & Forgot Password -->
                        <Grid ColumnDefinitions="*, *" VerticalOptions="Center" Margin="0,2,0,2">
                            <HorizontalStackLayout Grid.Column="0" Spacing="6" VerticalOptions="Center">
                                <CheckBox IsChecked="True" Color="#6366F1" HeightRequest="30" WidthRequest="30" VerticalOptions="Center" />
                                <Label Text="Remember me" TextColor="#94A3B8" FontSize="13" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            
                            <Label Grid.Column="1" 
                                   Text="Forgot Password?" 
                                   TextColor="#6366F1" 
                                   FontSize="13" 
                                   FontAttributes="Bold" 
                                   HorizontalOptions="End" 
                                   VerticalOptions="Center" />
                        </Grid>

                        <!-- Buttons Row -->
                        <Grid ColumnDefinitions="*, 48" ColumnSpacing="12" Margin="0,4,0,0" HeightRequest="48">
                            <!-- Submit Button -->
                            <Border Grid.Column="0"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12"
                                    IsVisible="{Binding IsNotBusy}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#6366F1" Offset="0.0" />
                                        <GradientStop Color="#4F46E5" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding LoginCommand}" />
                                </Border.GestureRecognizers>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroupList>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal" />
                                            <VisualState x:Name="Pressed">
                                                <VisualState.Setters>
                                                    <Setter Property="Opacity" Value="0.8" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateGroupList>
                                </VisualStateManager.VisualStateGroups>
                                <HorizontalStackLayout HorizontalOptions="Center" Spacing="8" VerticalOptions="Center">
                                    <Path Data="M 11 7 L 9.6 8.4 L 12.2 11 L 2 11 L 2 13 L 12.2 13 L 9.6 15.6 L 11 17 L 16 12 L 11 7 Z M 20 4 L 20 20 L 18 20 L 18 22 L 20 22 C 21.1 22 22 21.1 22 20 L 22 4 C 22 2.9 21.1 2 20 2 L 18 2 L 18 4 L 20 4 Z" 
                                          Fill="#FFFFFF" 
                                          HeightRequest="18" 
                                          WidthRequest="18" 
                                          VerticalOptions="Center" />
                                    <Label Text="Sign In" 
                                           TextColor="#FFFFFF" 
                                           FontSize="16" 
                                           FontAttributes="Bold" 
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Border>

                            <!-- Fingerprint Button -->
                            <Border Grid.Column="1"
                                    Stroke="#2D3A55"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="#131F37"
                                    IsVisible="{Binding IsNotBusy}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer />
                                </Border.GestureRecognizers>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroupList>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal" />
                                            <VisualState x:Name="Pressed">
                                                <VisualState.Setters>
                                                    <Setter Property="Opacity" Value="0.8" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateGroupList>
                                </VisualStateManager.VisualStateGroups>
                                <Path Data="M12,2C6.5,2,2,6.5,2,12c0,2.2,0.7,4.2,1.9,5.9l1.4-1.4C4.5,15.2,4,13.7,4,12c0-4.4,3.6-8,8-8s8,3.6,8,8c0,1.7-0.5,3.2-1.3,4.5l1.4,1.4c1.2-1.7,1.9-3.7,1.9-5.9C22,6.5,17.5,2,12,2z M12,6c-3.3,0-6,2.7-6,6c0,1.3,0.4,2.5,1.1,3.5l1.4-1.4C8.2,13.4,8,12.7,8,12c0-2.2,1.8-4,4-4s4,1.8,4,4c0,0.7-0.2,1.4-0.5,2.1l1.4,1.4C17.6,14.5,18,13.3,18,12C18,8.7,15.3,6,12,6z M12,10c-1.1,0-2,0.9-2,2c0,0.4,0.1,0.8,0.4,1.1l1.4-1.4C11.9,12.2,12,12.1,12,12c0-0.6,0.4-1,1-1s1,0.4,1,1c0,0.1-0.1,0.2-0.2,0.3l1.4,1.4C15.9,12.8,16,12.4,16,12C16,10.9,15.1,10,12,10z" 
                                      Fill="#38BDF8" 
                                      HeightRequest="22" 
                                      WidthRequest="22" 
                                      HorizontalOptions="Center"
                                      VerticalOptions="Center" />
                            </Border>
                            
                            <ActivityIndicator 
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                IsRunning="{Binding IsBusy}" 
                                IsVisible="{Binding IsBusy}" 
                                Color="#6366F1" 
                                HorizontalOptions="Center" 
                                VerticalOptions="Center" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Footer Secure Info -->
                <VerticalStackLayout Grid.Row="2" HorizontalOptions="Center" Spacing="6" Margin="0,10,0,10" VerticalOptions="End">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                        <Path Data="M12 2L4 5v6.09c0 5.05 3.41 9.76 8 10.91 4.59-1.15 8-5.86 8-10.91V5l-8-3zm0 10.92l-3-3 1.41-1.41L12 11.09l4.59-4.59L18 7.92l-6 6z" 
                              Fill="#6366F1" 
                              HeightRequest="16" 
                              WidthRequest="16" 
                              VerticalOptions="Center" />
                        <Label Text="Secure • Reliable • Trusted" 
                               TextColor="#94A3B8" 
                               FontSize="13" 
                               FontAttributes="Bold" 
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    
                    <Label Text="All your data is encrypted and secure" 
                           TextColor="#64748B" 
                           FontSize="11" 
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>
    </Grid>
</ContentPage>
