@implements IDisposable

<style>
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;  /* IE and Edge */
        scrollbar-width: none;  /* Firefox */
    }

    /* Premium Nav Links Styling */
    .premium-sidebar .mud-nav-link {
        margin: 2px 10px !important;
        border-radius: 8px !important;
        padding: 8px 14px !important;
        color: #334155 !important;
        font-weight: 600 !important;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1) !important;
        min-height: 40px !important;
    }
    
    .premium-sidebar .mud-nav-link:hover {
        background-color: #f1f5f9 !important;
        color: #0f172a !important;
        transform: translateX(4px);
    }
    
    .premium-sidebar .mud-nav-link .mud-nav-link-text {
        font-size: 0.9rem !important;
        letter-spacing: 0.2px;
    }
    
    .premium-sidebar .mud-nav-link .mud-icon-root {
        color: #64748b !important;
        margin-right: 12px !important;
        font-size: 1.2rem !important;
        transition: all 0.2s ease-in-out !important;
    }
    
    .premium-sidebar .mud-nav-link.active {
        background-color: #E6F1FB !important; /* Brand subtle blue */
        color: #0C447C !important;            /* Brand deep blue */
        font-weight: 700 !important;
        box-shadow: 0 2px 8px rgba(24, 95, 165, 0.08) !important;
    }
    
    .premium-sidebar .mud-nav-link.active .mud-icon-root {
        color: #185FA5 !important;
    }
    
    .premium-sidebar .mud-nav-link:hover .mud-icon-root {
        color: #185FA5 !important;
    }

    /* Section headers */
    .premium-sidebar .mud-typography-caption {
        font-size: 0.65rem !important;
        font-weight: 800 !important;
        color: #94a3b8 !important;
        letter-spacing: 1px !important;
        padding-left: 14px !important;
        margin-top: 10px !important;
        margin-bottom: 2px !important;
        text-transform: uppercase;
    }
</style>

<MudDrawer Open="@Open" OpenChanged="@OnDrawerOpenChanged" Elevation="0" Variant="@DrawerVariant.Temporary" Width="280px" Class="premium-sidebar">

    @* ===== User profile header ===== *@
    <div style="padding: 16px; margin: 12px 10px 8px; background: linear-gradient(135deg, #185FA5, #0B3A68); border-radius: 12px; color: white; box-shadow: 0 4px 12px rgba(24, 95, 165, 0.2);">
        <div style="display: flex; align-items: center; gap: 12px;">
            @if (!string.IsNullOrEmpty(_profilePictureUrl))
            {
                <MudAvatar Style="height: 42px; width: 42px; border: 2px solid rgba(255,255,255,0.2);">
                    <MudImage Src="@GetImageUrl(_profilePictureUrl)" Style="width: 100%; height: 100%; object-fit: cover;" />
                </MudAvatar>
            }
            else
            {
                <div style="width: 42px; height: 42px; border-radius: 50%; background: rgba(255,255,255,0.2); border: 2px solid rgba(255,255,255,0.3); display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 700; color: #fff;">
                    @GetInitials(CurrentUserName)
                </div>
            }
            <div style="flex: 1;">
                <div style="font-size: 14px; font-weight: 700; line-height: 1.2; text-shadow: 0 1px 2px rgba(0,0,0,0.2);">@CurrentUserName</div>
                <div style="font-size: 10px; color: rgba(255,255,255,0.85); margin-top: 3px; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">@CurrentUserRole</div>
            </div>
        </div>
    </div>

    @* ===== Scrollable menu sections ===== *@
    <div class="no-scrollbar" style="flex: 1; overflow-y: auto; padding: 6px 4px 20px;">

        @* ---- Dashboard section (visible to Manager, Admin, SuperAdmin) ---- *@
        <AuthorizeView Roles="Manager,Super Admin">
            <Authorized>
                <MudText Typo="Typo.caption" Class="px-2 mud-text-secondary" Style="letter-spacing:0.5px;">DASHBOARD</MudText>
                <MudNavMenu Class="mb-3">
                    <MudNavLink Href="/manager-dashboard" Icon="@Icons.Material.Filled.Dashboard" Match="NavLinkMatch.All">
                        Manager dashboard
                    </MudNavLink>
                    <MudNavLink Href="/godown-dashboard" Icon="@Icons.Material.Filled.Warehouse">
                        Godown dashboard
                    </MudNavLink>
                </MudNavMenu>
            </Authorized>
        </AuthorizeView>

        @* ---- Employee-only dashboard link ---- *@
        <AuthorizeView Roles="Employee">
            <Authorized>
                <MudText Typo="Typo.caption" Class="px-2 mud-text-secondary" Style="letter-spacing:0.5px;">DASHBOARD</MudText>
                <MudNavMenu Class="mb-3">
                    <MudNavLink Href="/attendance" Icon="@Icons.Material.Filled.EventAvailable">My attendance</MudNavLink>
                    <MudNavLink Href="/salary-slip" Icon="@Icons.Material.Filled.ReceiptLong">Salary slip</MudNavLink>
                    <MudNavLink Href="/tasks" Icon="@Icons.Material.Filled.Checklist">My tasks</MudNavLink>
                </MudNavMenu>
            </Authorized>
        </AuthorizeView>

        @* ---- Sales section ---- *@
        <AuthorizeView Roles="Manager,Super Admin,Administrator">
            <Authorized>
                <MudText Typo="Typo.caption" Class="px-2 mud-text-secondary" Style="letter-spacing:0.5px;">SALES</MudText>
                <MudNavMenu Class="mb-3">
                    <MudNavLink Href="/profiles" Icon="@Icons.Material.Filled.Groups">
                        Customers
                    </MudNavLink>
                    <MudNavLink Href="/sales" Icon="@Icons.Material.Filled.ReceiptLong">
                        Sales invoices
                    </MudNavLink>
                    <MudNavLink Href="/quick-payments" Icon="@Icons.Material.Filled.Payments">
                        Quick payments
                    </MudNavLink>
                    <MudNavLink Href="/broker-payments" Icon="@Icons.Material.Filled.Groups">
                        Broker payments
                    </MudNavLink>
                </MudNavMenu>
            </Authorized>
        </AuthorizeView>

        @* ---- Inventory section ---- *@
        <AuthorizeView Roles="Manager,Super Admin,Back Office User">
            <Authorized>
                <MudText Typo="Typo.caption" Class="px-2 mud-text-secondary" Style="letter-spacing:0.5px;">INVENTORY</MudText>
                <MudNavMenu Class="mb-3">
                    <MudNavLink Href="/purchases" Icon="@Icons.Material.Filled.LocalShipping">
                        Purchases
                    </MudNavLink>
                    <MudNavLink Href="/material-catalog" Icon="@Icons.Material.Filled.Inventory2">
                        Material catalog
                    </MudNavLink>
                </MudNavMenu>
            </Authorized>
        </AuthorizeView>

        @* ---- Team section ---- *@
        <AuthorizeView Roles="Manager,Super Admin">
            <Authorized>
                <MudText Typo="Typo.caption" Class="px-2 mud-text-secondary" Style="letter-spacing:0.5px;">TEAM</MudText>
                <MudNavMenu Class="mb-3">
                    <MudNavLink Href="/labour-attendance" Icon="@Icons.Material.Filled.People">
                        Labour attendance
                    </MudNavLink>
                    <AuthorizeView Roles="Super Admin,Administrator" Context="innerCtx">
                        <Authorized>
                            <MudNavLink Href="/admin/staff" Icon="@Icons.Material.Filled.Badge">
                                Staff accounts
                            </MudNavLink>
                            <MudNavLink Href="/admin/salary-config" Icon="@Icons.Material.Filled.Payments">
                                Salary config
                            </MudNavLink>
                        </Authorized>
                    </AuthorizeView>
                </MudNavMenu>
            </Authorized>
        </AuthorizeView>

        @* ---- Administration section ---- *@
        <AuthorizeView Roles="Super Admin,Administrator">
            <Authorized>
                <MudText Typo="Typo.caption" Class="px-2 mud-text-secondary mt-2" Style="letter-spacing:0.5px;">ADMINISTRATION</MudText>
                <MudNavMenu Class="mb-3">
                    <MudNavLink Href="/expenses" Icon="@Icons.Material.Filled.AccountBalanceWallet">
                        Daily expenses
                    </MudNavLink>
                    <MudNavLink Href="/admin/holidays" Icon="@Icons.Material.Filled.Event">
                        Holidays
                    </MudNavLink>
                    <MudNavLink Href="/admin/system" Icon="@Icons.Material.Filled.DisplaySettings">
                        System settings
                    </MudNavLink>
                </MudNavMenu>
            </Authorized>
        </AuthorizeView>

        @* ---- Employee quick links ---- *@
        <AuthorizeView Roles="Employee">
            <Authorized>
                <MudText Typo="Typo.caption" Class="px-2 mud-text-secondary" Style="letter-spacing:0.5px;">MY WORK</MudText>
                <MudNavMenu Class="mb-3">
                    <MudNavLink Href="/attendance" Icon="@Icons.Material.Filled.EventAvailable">
                        My attendance
                    </MudNavLink>
                    <MudNavLink Href="/salary-slip" Icon="@Icons.Material.Filled.ReceiptLong">
                        Salary slip
                    </MudNavLink>
                    <MudNavLink Href="/tasks" Icon="@Icons.Material.Filled.Checklist">
                        My tasks
                    </MudNavLink>
                </MudNavMenu>
            </Authorized>
        </AuthorizeView>

    </div>

    @* ===== Bottom pinned actions ===== *@
    <div style="border-top: 0.5px solid var(--mud-palette-lines-default); padding: 10px 12px;">
        <MudNavMenu>
            <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings">
                Settings
            </MudNavLink>
            <MudNavLink OnClick="LogoutAsync" Icon="@Icons.Material.Filled.Logout" IconColor="Color.Error"
                        Style="color: var(--mud-palette-error);">
                Log out
            </MudNavLink>
        </MudNavMenu>
    </div>

</MudDrawer>

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }

    private Task OnDrawerOpenChanged(bool value)
    {
        return OpenChanged.InvokeAsync(value);
    }

    [Parameter] public string CurrentUserName { get; set; } = "User";
    [Parameter] public string CurrentUserRole { get; set; } = "Role";

    [Inject] private IAuthService AuthService { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider { get; set; } = default!;
    [Inject] private VikashERP.Mobile.State.AppStateService AppState { get; set; } = default!;
    [Inject] private IHttpClientFactory HttpClientFactory { get; set; } = default!;

    private string? _profilePictureUrl;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            CurrentUserName = user.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "User";
            CurrentUserRole = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Employee";
            
            _profilePictureUrl = AppState.UserProfilePictureUrl;
            AppState.OnProfilePictureChanged += HandleProfilePictureChanged;
        }
    }

    private void HandleProfilePictureChanged(string? newUrl)
    {
        _profilePictureUrl = newUrl;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AppState.OnProfilePictureChanged -= HandleProfilePictureChanged;
    }

    private string GetImageUrl(string? path)
    {
        if (string.IsNullOrEmpty(path)) return "";
        if (path.StartsWith("http") || path.StartsWith("data:")) return path;
        
        if (path.StartsWith("/"))
            path = path.Substring(1);
            
        var client = HttpClientFactory.CreateClient("ApiClient");
        return $"{client.BaseAddress}{path}";
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        var parts = name.Trim().Split(' ');
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : parts[0][0].ToString().ToUpper();
    }

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
