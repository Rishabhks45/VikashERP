@page "/biometric-setup"
@using MudBlazor
@using VikashERP.Mobile.Services.Interfaces
@using Plugin.Fingerprint
@using Plugin.Fingerprint.Abstractions
@layout VikashERP.Mobile.Components.Layout.EmptyLayout
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject VikashERP.Mobile.State.AppStateService AppState

<div class="biometric-page-container d-flex flex-column">
    @* Background Image Decoration Top *@
    <div class="bg-decoration-top"></div>
    <div class="bg-decoration-bottom"></div>

    @* Top Bar *@
    <div class="d-flex px-4 py-2" style="position: relative; z-index: 10; flex-shrink: 0;">
        <MudIconButton Icon="@Icons.Material.Rounded.ArrowBack" Color="Color.Inherit" OnClick="GoBack" />
    </div>

    @* Logo Section *@
    <div class="brand-block d-flex flex-column align-center" style="position: relative; z-index: 10;">
        <svg width="48" height="48" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" class="mb-1">
            <path d="M15 25 L50 85 L38 85 L15 35 Z" fill="#4c1d95" />
            <path d="M15 25 L35 25 L50 85 L15 25" fill="#7c3aed" />
            <path d="M85 25 L50 85 L62 85 L85 35 Z" fill="#c4b5fd" />
            <path d="M85 25 L65 25 L50 85 L85 25" fill="#a78bfa" />
            <polygon points="35,25 65,25 50,55" fill="white" />
        </svg>
        <div style="text-align: center; line-height: 1.15;">
            <span class="brand-name">VIKASH</span><br/>
            <span class="brand-sub">— IRON & STEEL —</span>
        </div>
    </div>

    @* Content Section *@
    <div class="content-block d-flex flex-column align-center px-6" style="position: relative; z-index: 10;">
        
        @* Fingerprint Icon *@
        <div class="fingerprint-icon-container" style="position: relative;">
            <div class="icon-circle">
                <MudIcon Icon="@Icons.Material.Rounded.Fingerprint" Style="color: #6450f3; font-size: 2.8rem;" />
            </div>
            <div class="shield-badge">
                <MudIcon Icon="@Icons.Material.Rounded.Security" Style="color: white; font-size: 1rem;" />
            </div>
        </div>

        <MudText Typo="Typo.h5" Style="font-weight: 800; color: #1a2530;" Class="mt-4 mb-2">Biometric Setup</MudText>
        <MudText Typo="Typo.body2" Style="color: #666; text-align: center; max-width: 280px; font-weight: 500;" Class="mb-3">
            Secure your account with your fingerprint for faster and safer login
        </MudText>

        @* Benefits Card *@
        <MudPaper Class="benefits-card mt-3 mb-2" Elevation="0">
            <MudList T="string" Padding="false">
                <MudListItem Class="custom-list-item">
                    <div class="d-flex align-center py-2">
                        <div class="benefit-icon mr-4">
                            <MudIcon Icon="@Icons.Material.Rounded.VerifiedUser" Style="color: #6450f3;" Size="Size.Small" />
                        </div>
                        <div>
                            <MudText Typo="Typo.subtitle2" Style="font-weight: 700; color: #1a2530;">Enhanced Security</MudText>
                            <MudText Typo="Typo.caption" Style="color: #666; line-height: 1.3; display: block; font-weight: 500;">Your biometric data is encrypted<br/>and stored securely</MudText>
                        </div>
                    </div>
                </MudListItem>
                <MudDivider Style="opacity: 0.5;" />
                <MudListItem Class="custom-list-item">
                    <div class="d-flex align-center py-2">
                        <div class="benefit-icon mr-4">
                            <MudIcon Icon="@Icons.Material.Rounded.FlashOn" Style="color: #6450f3;" Size="Size.Small" />
                        </div>
                        <div>
                            <MudText Typo="Typo.subtitle2" Style="font-weight: 700; color: #1a2530;">Faster Access</MudText>
                            <MudText Typo="Typo.caption" Style="color: #666; line-height: 1.3; display: block; font-weight: 500;">Login quickly using your fingerprint</MudText>
                        </div>
                    </div>
                </MudListItem>
                <MudDivider Style="opacity: 0.5;" />
                <MudListItem Class="custom-list-item">
                    <div class="d-flex align-center py-2">
                        <div class="benefit-icon mr-4">
                            <MudIcon Icon="@Icons.Material.Rounded.Person" Style="color: #6450f3;" Size="Size.Small" />
                        </div>
                        <div>
                            <MudText Typo="Typo.subtitle2" Style="font-weight: 700; color: #1a2530;">Unique to You</MudText>
                            <MudText Typo="Typo.caption" Style="color: #666; line-height: 1.3; display: block; font-weight: 500;">Only your fingerprint can access<br/>your account</MudText>
                        </div>
                    </div>
                </MudListItem>
            </MudList>
        </MudPaper>

        @* Agreement Checkbox *@
        <div class="d-flex align-center mt-3 mb-2">
            <MudCheckBox @bind-Value="Agreed" Color="Color.Primary" Class="mr-2 custom-checkbox" />
            <MudText Typo="Typo.caption" Style="color: #666; line-height: 1.4; font-weight: 500;">
                I agree to use my fingerprint to login to<br/>
                <span style="color: #6450f3; font-weight: 700;">Vikash Iron & Steel</span> app.
            </MudText>
        </div>

        <div class="footer-block d-flex flex-column align-center" style="width: 100%;">
            @* Enable Button *@
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="enable-btn mb-2" OnClick="EnableBiometric" Disabled="!Agreed" Style="max-width: 320px;">
                <MudIcon Icon="@Icons.Material.Rounded.Fingerprint" Class="mr-3" />
                Enable Fingerprint
            </MudButton>

            @* Set up later *@
            <MudButton Variant="Variant.Text" Color="Color.Primary" Class="setup-later-btn" OnClick="SkipBiometric">
                Set up later
            </MudButton>
        </div>
    </div>
</div>

<style>
    .biometric-page-container {
        height: 100vh;
        height: 100dvh;
        max-height: 100dvh;
        background-color: #fcfcfd;
        position: relative;
        overflow: hidden;
        padding-top: env(safe-area-inset-top);
        padding-bottom: env(safe-area-inset-bottom);
        display: flex;
        flex-direction: column;
    }

    .brand-block {
        padding-top: clamp(4px, 1vh, 8px);
        padding-bottom: 4px;
        flex-shrink: 0;
    }
    .brand-name {
        font-weight: 800;
        font-size: 1.15rem;
        color: #4c1d95;
        letter-spacing: 1px;
    }
    .brand-sub {
        font-size: 0.55rem;
        font-weight: 700;
        color: #7c3aed;
        letter-spacing: 2px;
    }

    .footer-block {
        width: 100%;
        padding-bottom: 8px;
        flex-shrink: 0;
    }

    .content-block {
        flex: 1;
        min-height: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-evenly;
        width: 100%;
        padding-bottom: 8px;
    }
    
    .bg-decoration-top {
        position: absolute;
        top: -50px;
        right: -50px;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(139, 92, 246, 0.15) 0%, rgba(252, 252, 253, 0) 70%);
        z-index: 0;
        pointer-events: none;
    }

    .bg-decoration-bottom {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 150px;
        background: linear-gradient(to top, rgba(100, 80, 243, 0.08) 0%, rgba(252, 252, 253, 0) 100%);
        z-index: 0;
        pointer-events: none;
    }

    .icon-circle {
        width: clamp(55px, 8vh, 75px);
        height: clamp(55px, 8vh, 75px);
        border-radius: 50%;
        background-color: #f3f0ff;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 12px 24px rgba(100, 80, 243, 0.15);
    }

    .shield-badge {
        position: absolute;
        bottom: 0;
        right: 0;
        width: 28px;
        height: 28px;
        background-color: #6450f3;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 3px solid #fcfcfd;
        box-shadow: 0 2px 6px rgba(0,0,0,0.15);
    }

    .benefits-card {
        background-color: white !important;
        border-radius: 20px !important;
        border: 1px solid rgba(0, 0, 0, 0.04) !important;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.04) !important;
        width: 100%;
        padding: 8px 4px;
    }
    
    .custom-list-item {
        padding: 4px 16px !important;
    }

    .benefit-icon {
        width: clamp(35px, 5vh, 44px);
        height: clamp(35px, 5vh, 44px);
        border-radius: 12px;
        background-color: #f3f0ff;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .custom-checkbox {
        color: #6450f3 !important;
    }

    .enable-btn {
        background-color: #6450f3 !important;
        border-radius: 16px !important;
        height: 56px;
        font-weight: 800 !important;
        text-transform: none !important;
        font-size: 1.05rem !important;
        box-shadow: 0 8px 20px rgba(100, 80, 243, 0.3) !important;
        transition: all 0.2s ease;
    }
    .enable-btn:active {
        transform: scale(0.98);
        box-shadow: 0 4px 10px rgba(100, 80, 243, 0.2) !important;
    }
    .enable-btn.mud-button-disabled {
        background-color: #e5e5e5 !important;
        color: #a3a3a3 !important;
        box-shadow: none !important;
    }

    .setup-later-btn {
        font-weight: 700 !important;
        text-transform: none !important;
        font-size: 0.95rem !important;
        letter-spacing: 0.5px !important;
        color: #888 !important;
        margin-top: 4px;
    }
</style>

@code {
    [Inject] private IAuthService AuthService { get; set; } = default!;

    private bool Agreed { get; set; } = true;

    private async Task EnableBiometric()
    {
        try
        {
            var isAvailable = await CrossFingerprint.Current.IsAvailableAsync(true);
            if (!isAvailable)
            {
                Snackbar.Add("Biometric authentication is not available on this device.", Severity.Error);
                return;
            }

            var request = new AuthenticationRequestConfiguration("Enable Biometric", "Please authenticate to enable biometric login.");
            var result = await CrossFingerprint.Current.AuthenticateAsync(request);

            if (result.Authenticated)
            {
                await AuthService.EnableBiometricAsync(true);
                Snackbar.Add("Biometric enabled successfully!", Severity.Success);
                AppState.IsPinUnlocked = true;
                Navigation.NavigateTo("/manager-dashboard");
            }
            else
            {
                Snackbar.Add("Biometric authentication failed or was canceled.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private void SkipBiometric()
    {
        AppState.IsPinUnlocked = true;
        Navigation.NavigateTo("/manager-dashboard");
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/create-pin"); // or previous auth screen
    }
}
