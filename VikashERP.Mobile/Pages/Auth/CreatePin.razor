@page "/create-pin"
@using MudBlazor
@using VikashERP.Mobile.Services.Interfaces
@layout VikashERP.Mobile.Components.Layout.EmptyLayout

<div class="pin-page-container d-flex flex-column">

    <div class="brand-block d-flex flex-column align-center">
        <svg width="52" height="52" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2009/svg" class="mb-1">
            <path d="M15 25 L50 85 L38 85 L15 35 Z" fill="#144b82" />
            <path d="M15 25 L35 25 L50 85 L15 25" fill="#1e73be" />
            <path d="M85 25 L50 85 L62 85 L85 35 Z" fill="#9ea7b0" />
            <path d="M85 25 L65 25 L50 85 L85 25" fill="#3a4047" />
            <polygon points="35,25 65,25 50,55" fill="white" />
        </svg>
        <div style="text-align: center; line-height: 1.15;">
            <span class="brand-name">VIKASH</span><br/>
            <span class="brand-sub">— IRON & STEEL —</span>
        </div>
    </div>

    <div class="content-block d-flex flex-column align-center px-6">

        <div class="header-block d-flex flex-column align-center">
            <div class="d-flex align-center" style="gap:8px;">
                <MudIcon Icon="@Icons.Material.Filled.Lock" Style="color: #0066ff; font-size: 1.6rem;" />
                <MudText Typo="Typo.h5" Style="font-weight:700; color:#1a2530;">
                    Create New PIN
                </MudText>
            </div>
            <MudText Typo="Typo.body2" Style="color: #666; text-align: center; max-width: 260px;" Class="mt-1">
                Set a 4 digit PIN to secure your account
            </MudText>
        </div>

        <div class="pin-block d-flex flex-column align-center">
            <MudText Typo="Typo.body2" Style="font-weight: 700; color: #1a2530;" Class="mb-2">Create PIN</MudText>
            <div class="d-flex gap-4 mb-4">
                @for (int i = 0; i < 4; i++)
                {
                    var idx = i;
                    <div class="pin-dot @(PinCode.Length > idx ? "filled" : "")"></div>
                }
            </div>

            <MudText Typo="Typo.body2" Style="font-weight: 700; color: #1a2530;" Class="mb-2">Confirm PIN</MudText>
            <div class="d-flex gap-4">
                @for (int i = 0; i < 4; i++)
                {
                    var idx = i;
                    <div class="pin-dot @(ConfirmPin.Length > idx ? "filled" : "")"></div>
                }
            </div>
        </div>

        <div class="security-alert d-flex align-center pa-3">
            <MudIcon Icon="@Icons.Material.Outlined.VerifiedUser" Style="color: #0066ff; font-size: 1.4rem;" Class="mr-2" />
            <MudText Typo="Typo.body2" Style="color: #1a2530; line-height: 1.3; font-size: 0.82rem;">
                Your PIN keeps your account secure. Don't share it with anyone.
            </MudText>
        </div>

        <div class="keypad-block d-flex flex-column align-center">
            <div class="keypad-container">
                @for (int i = 1; i <= 9; i++)
                {
                    var num = i;
                    <MudButton Variant="Variant.Text" Class="keypad-btn" OnClick="@(() => KeyPressed(num))">@num</MudButton>
                }
                <div class="keypad-spacer"></div>
                <MudButton Variant="Variant.Text" Class="keypad-btn" OnClick="@(() => KeyPressed(0))">0</MudButton>
                <MudButton Variant="Variant.Text" Class="keypad-btn backspace-btn" OnClick="@Backspace">
                    <MudIcon Icon="@Icons.Material.Outlined.Backspace" Size="Size.Medium" />
                </MudButton>
            </div>
        </div>

        <div class="footer-block d-flex flex-column align-center">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="save-btn" OnClick="@SavePin" Disabled="@(!IsPinValid)" Style="max-width: 300px;">
                Save PIN
            </MudButton>

            <div class="d-flex align-center justify-center mt-2" style="opacity: 0.6;">
                <MudIcon Icon="@Icons.Material.Outlined.Security" Size="Size.Small" Style="color: #666;" Class="mr-1" />
                <MudText Typo="Typo.caption" Style="color: #666; font-size: 0.78rem;">Your information is safe with us</MudText>
            </div>
        </div>
    </div>
</div>

<style>
    .pin-page-container {
        height: 100vh;
        height: 100dvh; /* real visible viewport on mobile, avoids browser-chrome overflow */
        max-height: 100dvh;
        background-color: #fafbfc;
        position: relative;
        overflow-y: hidden; /* prevents scrolling */
        padding-top: env(safe-area-inset-top);
        padding-bottom: env(safe-area-inset-bottom);
        display: flex;
        flex-direction: column;
    }

    .brand-block {
        padding-top: clamp(10px, 3vh, 18px);
        padding-bottom: 6px;
        flex-shrink: 0;
    }
    .brand-name {
        font-weight: 800;
        font-size: 1.15rem;
        color: #144b82;
        letter-spacing: 1px;
    }
    .brand-sub {
        font-size: 0.55rem;
        font-weight: 600;
        color: #666;
        letter-spacing: 2px;
    }

    /* Even, deliberate rhythm between sections instead of one big gap.
       min-height:0 lets this block shrink inside the flex column so it
       never overflows top/bottom; gap scales slightly with viewport height. */
    .content-block {
        flex: 1;
        min-height: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: clamp(10px, 2.2vh, 18px);
        padding-top: 8px;
        padding-bottom: 12px;
    }

    .header-block { margin-bottom: 2px; }

    .pin-dot {
        width: 18px; height: 18px;
        border-radius: 50%;
        border: 2.5px solid #1a2530;
        background-color: transparent;
        transition: all 0.2s ease;
    }
    .pin-dot.filled {
        background-color: #0066ff;
        border-color: #0066ff;
    }

    .security-alert {
        background-color: #f0f5ff;
        border-radius: 10px;
        width: 100%;
        border: 1px solid rgba(0, 102, 255, 0.1);
    }

    .keypad-container {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        width: 100%;
        max-width: 350px;
    }
    .keypad-btn {
        background-color: white !important;
        border: none !important;
        border-radius: 50% !important;
        height: 75px !important;
        width: 75px !important;
        margin: 0 auto !important;
        min-width: 0 !important;
        font-size: 1.8rem !important;
        font-weight: 700 !important;
        color: #1a2530 !important;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08) !important;
        text-transform: none !important;
    }
    .backspace-btn {
        background-color: transparent !important;
        box-shadow: none !important;
    }
    .keypad-spacer { height: 65px; }

    .footer-block { width: 100%; }
    .save-btn {
        background-color: #005ce6 !important;
        border-radius: 10px !important;
        height: 48px;
        font-weight: 700 !important;
        text-transform: none !important;
        font-size: 1rem !important;
    }
    .save-btn.mud-button-disabled {
        background-color: #b3d1ff !important;
        color: white !important;
        opacity: 0.7;
    }
</style>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private IAuthService AuthService { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private string PinCode { get; set; } = "";
    private string ConfirmPin { get; set; } = "";

    private bool IsPinValid => PinCode.Length == 4 && ConfirmPin.Length == 4 && PinCode == ConfirmPin;

    private void KeyPressed(int num)
    {
        if (PinCode.Length < 4)
            PinCode += num.ToString();
        else if (ConfirmPin.Length < 4)
            ConfirmPin += num.ToString();
    }

    private void Backspace()
    {
        if (ConfirmPin.Length > 0)
            ConfirmPin = ConfirmPin[..^1];
        else if (PinCode.Length > 0)
            PinCode = PinCode[..^1];
    }

    private async Task SavePin()
    {
        if (IsPinValid)
        {
            try
            {
                await AuthService.SavePinAsync(PinCode);
                Navigation.NavigateTo("/biometric-setup");
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error saving PIN: {ex.Message}", Severity.Error);
            }
        }
    }

    private void GoBack() => Navigation.NavigateTo("/login");
}
