@page "/forgot-password"
@using MudBlazor
@layout VikashERP.Mobile.Components.Layout.EmptyLayout

<div class="forgot-page-container">
    @* Background Image Decoration Top Right *@
    <div class="bg-decoration-top"></div>

    @* Top Bar *@
    <div class="d-flex px-4 py-4" style="position: relative; z-index: 10;">
        <MudIconButton Icon="@Icons.Material.Rounded.ArrowBack" Color="Color.Inherit" OnClick="GoBack" />
    </div>

    @* Content Section *@
    <div class="content-block d-flex flex-column align-center justify-center px-6" style="position: relative; z-index: 10;">
        
        @* Icon Container *@
        <div class="icon-circle mb-6">
            <MudIcon Icon="@Icons.Material.Rounded.Email" Style="color: #6450f3; font-size: 2.8rem;" />
            <div class="lock-badge">
                <MudIcon Icon="@Icons.Material.Rounded.Lock" Style="color: white; font-size: 1rem;" />
            </div>
        </div>

        <MudText Typo="Typo.h5" Style="font-weight: 800; color: #1a2530;" Class="mb-3">Forgot Password?</MudText>
        <MudText Typo="Typo.body2" Style="color: #666; text-align: center; max-width: 280px; line-height: 1.5; font-weight: 500;" Class="mb-8">
            Enter your registered email address and we'll send you a link to reset your password.
        </MudText>

        @* Email Input *@
        <div class="w-100 mb-8">
            <MudText Typo="Typo.caption" Style="font-weight: 700; color: #1a2530; letter-spacing: 0.5px;" Class="mb-2 d-block pl-1">EMAIL ADDRESS</MudText>
            <div class="custom-input-container">
                <MudIcon Icon="@Icons.Material.Rounded.Mail" Class="input-icon" />
                <input type="email" placeholder="Enter your email address" class="custom-input" @bind="Email" />
            </div>
        </div>

        @* Action Buttons *@
        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="send-btn mb-4" OnClick="SendResetLink">
            Send Reset Link
        </MudButton>

        <MudButton Variant="Variant.Text" Color="Color.Primary" Class="back-login-btn" OnClick="GoBack">
            Back to Login
        </MudButton>
    </div>

    @* Background Image Decoration Bottom *@
    <div class="bg-decoration-bottom"></div>
</div>

<style>
    .forgot-page-container {
        height: 100vh;
        height: 100dvh;
        max-height: 100dvh;
        background-color: #fcfcfd;
        position: relative;
        overflow: hidden;
        padding-top: env(safe-area-inset-top);
        padding-bottom: env(safe-area-inset-bottom);
        display: flex;
        flex-direction: column;
    }
    
    .content-block {
        flex: 1;
        min-height: 0;
    }
    
    .bg-decoration-top {
        position: absolute;
        top: -50px;
        right: -50px;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(139, 92, 246, 0.15) 0%, rgba(252, 252, 253, 0) 70%);
        z-index: 0;
        pointer-events: none;
    }

    .bg-decoration-bottom {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 200px;
        background: linear-gradient(to top, rgba(100, 80, 243, 0.08) 0%, rgba(252, 252, 253, 0) 100%);
        z-index: 0;
        pointer-events: none;
    }

    .icon-circle {
        width: 88px;
        height: 88px;
        border-radius: 50%;
        background-color: #f3f0ff;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        box-shadow: 0 12px 24px rgba(100, 80, 243, 0.1);
    }

    .lock-badge {
        position: absolute;
        bottom: 0;
        right: 0;
        width: 28px;
        height: 28px;
        background-color: #6450f3;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 3px solid #fcfcfd;
        box-shadow: 0 2px 6px rgba(0,0,0,0.15);
    }

    .custom-input-container {
        display: flex;
        align-items: center;
        background-color: #f9f9f9;
        border: 2px solid transparent;
        border-radius: 16px;
        padding: 0 16px;
        height: 56px;
        transition: all 0.2s;
    }
    .custom-input-container:focus-within {
        border-color: #6450f3;
        background-color: white;
        box-shadow: 0 4px 12px rgba(100, 80, 243, 0.1);
    }
    .custom-input-container:focus-within .input-icon {
        color: #6450f3;
    }

    .input-icon {
        color: #888;
        font-size: 1.4rem;
        margin-right: 12px;
        transition: color 0.2s;
    }

    .custom-input {
        border: none;
        outline: none;
        flex: 1;
        height: 100%;
        font-size: 1rem;
        color: #1a2530;
        font-weight: 500;
        background: transparent;
    }
    .custom-input::placeholder {
        color: #aaa;
        font-weight: 400;
    }

    .send-btn {
        background-color: #6450f3 !important;
        border-radius: 16px !important;
        height: 56px;
        font-weight: 800 !important;
        text-transform: none !important;
        font-size: 1.05rem !important;
        box-shadow: 0 8px 20px rgba(100, 80, 243, 0.3) !important;
        transition: all 0.2s ease;
    }
    
    .send-btn:active {
        transform: scale(0.98);
        box-shadow: 0 4px 10px rgba(100, 80, 243, 0.2) !important;
    }

    .back-login-btn {
        font-weight: 700 !important;
        text-transform: none !important;
        font-size: 0.95rem !important;
        letter-spacing: 0.5px !important;
        color: #888 !important;
        margin-top: 8px;
    }
</style>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private string Email { get; set; } = "";

    private void SendResetLink()
    {
        if (!string.IsNullOrWhiteSpace(Email))
        {
            // Add password reset API logic here
            // Navigate to the 'Check Your Email' page
            Navigation.NavigateTo("/check-email");
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/login");
    }
}
