@page "/forgot-password"
@using MudBlazor
@layout VikashERP.Mobile.Components.Layout.EmptyLayout

<div class="login-page-container">
    <div class="gradient-mesh-bg">
        <div class="mesh-blob mesh-blob-1"></div>
        <div class="mesh-blob mesh-blob-2"></div>
        <div class="mesh-blob mesh-blob-3"></div>
    </div>

    <div class="brand-header d-flex flex-column align-center justify-center pt-8 pb-4">
        <div class="logo-circle">
            <MudIcon Icon="@Icons.Material.Rounded.LockReset" Class="logo-icon" />
        </div>
    </div>

    <div class="login-card-wrapper">
        <div class="login-card">
            <MudText Typo="Typo.h5" Class="welcome-title mb-2">Reset Password</MudText>
            <MudText Typo="Typo.body2" Class="welcome-subtitle mb-8" Style="padding: 0 10px;">
                Enter your registered email address and we'll send you a link to reset your password.
            </MudText>

            <div class="input-container mb-6">
                <span class="input-label">EMAIL ADDRESS</span>
                <MudTextField T="string" @bind-Value="Email" Placeholder="Enter your email" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Rounded.Mail" Immediate="true" Class="premium-input" />
            </div>

            <MudButton Variant="Variant.Filled" Class="premium-login-btn mb-6" OnClick="SendResetLink">
                <span>Send Reset Link</span>
                <MudIcon Icon="@Icons.Material.Rounded.Send" Size="Size.Small" Class="ml-2" />
            </MudButton>
            
            <div class="signup-prompt">
                <MudLink Href="/login" Class="forgot-link d-flex align-center justify-center" Underline="Underline.None">
                    <MudIcon Icon="@Icons.Material.Rounded.ArrowBack" Size="Size.Small" Class="mr-1" />
                    Back to Login
                </MudLink>
            </div>
        </div>
    </div>
    
    <div class="security-footer">
        <MudIcon Icon="@Icons.Material.Rounded.Security" Size="Size.Small" Class="security-icon mr-2" />
        <span>Your information is end-to-end encrypted</span>
    </div>
</div>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private string Email { get; set; } = "";

    private void SendResetLink()
    {
        if (!string.IsNullOrWhiteSpace(Email))
        {
            // Add password reset API logic here
            // Navigate to the 'Check Your Email' page
            Navigation.NavigateTo("/check-email");
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/login");
    }
}
