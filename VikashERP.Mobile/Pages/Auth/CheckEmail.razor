@page "/check-email"
@using MudBlazor
@layout VikashERP.Mobile.Components.Layout.EmptyLayout

<div class="login-page-container">
    <div class="gradient-mesh-bg">
        <div class="mesh-blob mesh-blob-1"></div>
        <div class="mesh-blob mesh-blob-2"></div>
        <div class="mesh-blob mesh-blob-3"></div>
    </div>

    <div class="brand-header d-flex flex-column align-center justify-center pt-8 pb-4">
        <div class="logo-circle">
            <MudIcon Icon="@Icons.Material.Rounded.MarkEmailUnread" Class="logo-icon" />
        </div>
    </div>

    <div class="login-card-wrapper">
        <div class="login-card">
            <MudText Typo="Typo.h5" Class="welcome-title mb-2">Check Your Email</MudText>
            <MudText Typo="Typo.body2" Class="welcome-subtitle mb-8" Style="padding: 0 10px;">
                We have sent a password reset link to<br/>
                <span style="color: #4f46e5; font-weight: 700;">vikash@email.com</span>
                <br/><br/>
                Please check your inbox and follow the instructions to reset your password.
            </MudText>

            <MudButton Variant="Variant.Filled" Class="premium-login-btn mb-6" OnClick="GoBack">
                <MudIcon Icon="@Icons.Material.Rounded.ArrowBack" Size="Size.Small" Class="mr-2" />
                <span>Back to Login</span>
            </MudButton>
            
            <div class="signup-prompt">
                <span>Didn't receive the email?</span>
                <MudLink Href="#" Class="signup-link" Underline="Underline.None" OnClick="ResendEmail">Resend</MudLink>
            </div>
        </div>
    </div>
    
    <div class="security-footer">
        <MudIcon Icon="@Icons.Material.Rounded.Security" Size="Size.Small" Class="security-icon mr-2" />
        <span>Your information is end-to-end encrypted</span>
    </div>
</div>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private void ResendEmail()
    {
        // Add resend logic here
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/login");
    }
}
