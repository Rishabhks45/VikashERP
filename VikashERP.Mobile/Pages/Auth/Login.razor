@page "/login"
@using MudBlazor
@using VikashERP.Mobile.Services.Interfaces
@using Microsoft.AspNetCore.Components.Authorization
@using VikashERP.Mobile.State
@layout VikashERP.Mobile.Components.Layout.EmptyLayout

<div class="login-page-container">
    <div class="gradient-mesh-bg">
        <div class="mesh-blob mesh-blob-1"></div>
        <div class="mesh-blob mesh-blob-2"></div>
        <div class="mesh-blob mesh-blob-3"></div>
    </div>

    <div class="brand-header d-flex flex-column align-center justify-center">
        <div class="logo-circle">
            <img src="images/dashboard_logo.svg" alt="App Logo" class="app-logo-img" />
        </div>
        <div class="brand-text">
            <span class="brand-title">VIKASH</span>
            <span class="brand-subtitle">IRON & STEEL</span>
        </div>
    </div>

    <div class="login-card-wrapper">
        <div class="login-card">
            <MudText Typo="Typo.h5" Class="welcome-title mb-1">Welcome Back!</MudText>
            <MudText Typo="Typo.body2" Class="welcome-subtitle mb-8">Sign in to your account</MudText>

            <div class="input-container mb-5">
                <span class="input-label">EMAIL OR PHONE</span>
                <MudTextField T="string" @bind-Value="Email" Placeholder="Enter your email" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Rounded.Mail" Immediate="true" Class="premium-input" />
            </div>

            <div class="input-container mb-2">
                <span class="input-label">PASSWORD</span>
                <MudTextField T="string" @bind-Value="Password" Placeholder="Enter your password" Variant="Variant.Outlined" InputType="@(ShowPassword ? InputType.Text : InputType.Password)" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Rounded.Lock" Immediate="true" Class="premium-input">
                    <AppendAdornment>
                        <MudIconButton Icon="@(ShowPassword ? Icons.Material.Rounded.Visibility : Icons.Material.Rounded.VisibilityOff)" OnClick="TogglePasswordVisibility" Size="Size.Small" Class="visibility-btn" />
                    </AppendAdornment>
                </MudTextField>
            </div>

            <div class="d-flex justify-end mb-8">
                <MudLink Href="/forgot-password" Class="forgot-link" Underline="Underline.None">Forgot Password?</MudLink>
            </div>

            <MudButton Variant="Variant.Filled" Class="premium-login-btn mb-6" OnClick="PerformLogin" Disabled="@IsLoading">
                @if (IsLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="color: white;" Class="mr-2" />
                    <span>Logging in...</span>
                }
                else
                {
                    <span>Login Securely</span>
                    <MudIcon Icon="@Icons.Material.Rounded.ArrowForward" Size="Size.Small" Class="ml-2" />
                }
            </MudButton>
            
            <div class="signup-prompt">
                <span>Don't have an account?</span>
                <MudLink Href="/signup" Class="signup-link" Underline="Underline.None">Sign up</MudLink>
            </div>
        </div>
    </div>
    
    <div class="security-footer">
        <MudIcon Icon="@Icons.Material.Rounded.Security" Size="Size.Small" Class="security-icon mr-2" />
        <span>Your information is end-to-end encrypted</span>
    </div>

    </div>
@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private IAuthService AuthService { get; set; } = default!;
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;
    [Inject] private AppStateService AppState { get; set; } = default!;

    private string Email { get; set; } = "";
    private string Password { get; set; } = "";
    private bool ShowPassword { get; set; } = false;
    private bool IsLoading { get; set; } = false;

    private void TogglePasswordVisibility()
    {
        ShowPassword = !ShowPassword;
    }

    private async Task PerformLogin()
    {
        if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Password))
        {
            Snackbar.Add("Please enter both email and password", Severity.Warning);
            return;
        }

        AppState.ShowLoader();
        try
        {
            var result = await AuthService.LoginAsync(Email, Password);
            if (result != null)
            {
                // Assuming you use the AuthState.cs implementation
                ((VikashERP.Mobile.State.CustomAuthStateProvider)AuthStateProvider).MarkUserAsAuthenticated(result.Token);
                Navigation.NavigateTo("/");
            }
            else
            {
                Snackbar.Add("Invalid email or password", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            AppState.HideLoader();
        }
    }
}
