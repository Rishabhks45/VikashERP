@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private IAuthService AuthService { get; set; } = default!;
    [Inject] private IUserProfileService UserProfileService { get; set; } = default!;
    [Inject] private Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;
    [Inject] private IHttpClientFactory HttpClientFactory { get; set; } = default!;

    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool _isEditing = false;
    private UserAccountDto? _profile;
    private UserAccountDto? _originalProfile;
    private Guid _currentUserId;

    private MudForm? _form;
    private bool _success;
    private string[] _errors = { };

    // Password Dialog State
    private bool _isPasswordDialogOpen = false;
    private bool _isChangingPassword = false;
    private string _newPassword = "";
    private string _confirmPassword = "";

    // Cropper State
    private bool _isCropperOpen = false;
    private string _tempImageUrl = "";
    private CropperComponent _cropperComponent = default!;
    private Options _cropperOptions = new Options
    {
        AspectRatio = 1,
        ViewMode = ViewMode.Vm1,
        DragMode = "move",
        AutoCropArea = 0.8m,
        Restore = false,
        Guides = true,
        Center = true,
        Highlight = true,
        CropBoxMovable = true,
        CropBoxResizable = true,
        ToggleDragModeOnDblclick = false
    };

    private bool _isBiometricEnabled = false;

    protected override async Task OnInitializedAsync()
    {
        _isBiometricEnabled = await AuthService.IsBiometricEnabledAsync();
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity != null && user.Identity.IsAuthenticated)
        {
            var nameIdentifier = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(nameIdentifier, out Guid parsedId))
            {
                _currentUserId = parsedId;
                await LoadProfile();
            }
            else
            {
                _isLoading = false;
                Snackbar.Add("Failed to parse user ID from token.", Severity.Error);
            }
        }
        else
        {
            Navigation.NavigateTo("/login", true);
        }
    }

    private string? _errorMessage;

    private async Task LoadProfile()
    {
        _isLoading = true;
        _errorMessage = null;
        AppState.ShowLoader();
        
        try 
        {
            _profile = await UserProfileService.GetProfileAsync(_currentUserId);
            if (_profile == null)
            {
                _errorMessage = "The service returned null. Check API endpoint or token.";
            }
            else
            {
                CloneOriginalProfile();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _profile = null;
        }
        finally
        {
            _isLoading = false;
            AppState.HideLoader();
        }
    }

    private void EnableEditMode()
    {
        _isEditing = true;
    }

    private void CancelEditMode()
    {
        _isEditing = false;
        // Restore original profile values
        if (_profile != null && _originalProfile != null)
        {
            _profile.FirstName = _originalProfile.FirstName;
            _profile.LastName = _originalProfile.LastName;
            _profile.Email = _originalProfile.Email;
            _profile.ProfilePictureUrl = _originalProfile.ProfilePictureUrl;
        }
    }

    private void CloneOriginalProfile()
    {
        if (_profile != null)
        {
            _originalProfile = new UserAccountDto
            {
                Id = _profile.Id,
                FirstName = _profile.FirstName,
                LastName = _profile.LastName,
                Email = _profile.Email,
                Role = _profile.Role,
                IsActive = _profile.IsActive,
                ProfilePictureUrl = _profile.ProfilePictureUrl,
                CreatedAt = _profile.CreatedAt
            };
        }
    }

    private async Task SaveProfile()
    {
        if (_form != null)
        {
            await _form.ValidateAsync();
            if (!_success || _profile == null) return;

            AppState.ShowLoader();
            _isSaving = true;

            var updateDto = new UpdateUserAccountDto
            {
                FirstName = _profile.FirstName,
                LastName = _profile.LastName,
                Email = _profile.Email,
                Role = _profile.Role,
                IsActive = _profile.IsActive,
                ProfilePictureUrl = _profile.ProfilePictureUrl
            };

            var result = await UserProfileService.UpdateProfileAsync(_currentUserId, updateDto);

            _isSaving = false;
            AppState.HideLoader();

            if (result.IsSuccess)
            {
                Snackbar.Add("Profile updated successfully!", Severity.Success);
                _isEditing = false;
                CloneOriginalProfile();
                
                // Notify the rest of the app (like BottomNav) to update the picture instantly
                if (_profile != null)
                {
                    AppState.UpdateProfilePicture(_profile.ProfilePictureUrl);
                }
            }
            else
            {
                Snackbar.Add($"Failed to update profile: {result.ErrorMessage}", Severity.Error);
            }
        }
    }

    private async Task UploadProfilePicture(InputFileChangeEventArgs e)
    {
        if (!_isEditing || _profile == null) return;

        var file = e.File;
        if (file != null)
        {
            try
            {

                AppState.ShowLoader(type: VikashERP.Mobile.Components.Shared.AdvanceLoader.LoaderType.Dots);


                await Task.Yield();
                
                // Reduced from 1024x1024 to 800x800 to significantly speed up processing on mobile devices
                var resizedImage = await file.RequestImageFileAsync("image/jpeg", 800, 800);
                
                using var stream = resizedImage.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                using var memoryStream = new System.IO.MemoryStream();
                await stream.CopyToAsync(memoryStream);
                var base64 = Convert.ToBase64String(memoryStream.ToArray());
                
                _tempImageUrl = $"data:image/jpeg;base64,{base64}";
                _isCropperOpen = true;
                
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Upload failed: {ex.Message}", Severity.Error);
            }
            finally
            {
                AppState.HideLoader();
            }
        }
    }

    private async Task SaveCroppedImage()
    {
        try
        {
            if (_cropperComponent != null)
            {
                var options = new GetCroppedCanvasOptions
                {
                    Width = 300,
                    Height = 300,
                    ImageSmoothingEnabled = true,
                    ImageSmoothingQuality = "high"
                };
                
                var croppedBase64 = await _cropperComponent.GetCroppedCanvasDataURLAsync(options, "image/jpeg", 0.85f);
                
                if (!string.IsNullOrEmpty(croppedBase64) && _profile != null)
                {
                    _profile.ProfilePictureUrl = croppedBase64;
                    Snackbar.Add("Image cropped! Click 'Save Changes' to upload.", Severity.Info);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Cropping failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            CancelCropper();
        }
    }

    private void CancelCropper()
    {
        _isCropperOpen = false;
        _tempImageUrl = "";
        StateHasChanged();
    }

    private string GetInitials()
    {
        if (_profile == null) return "U";
        var first = !string.IsNullOrWhiteSpace(_profile.FirstName) ? _profile.FirstName.Substring(0, 1).ToUpper() : "";
        var last = !string.IsNullOrWhiteSpace(_profile.LastName) ? _profile.LastName.Substring(0, 1).ToUpper() : "";
        return $"{first}{last}";
    }

    private void OpenPasswordDialog()
    {
        _newPassword = "";
        _confirmPassword = "";
        _isPasswordDialogOpen = true;
    }

    private void ClosePasswordDialog()
    {
        _isPasswordDialogOpen = false;
    }

    private async Task SubmitPasswordChange()
    {
        if (string.IsNullOrWhiteSpace(_newPassword))
        {
            Snackbar.Add("Password cannot be empty.", Severity.Warning);
            return;
        }

        if (_newPassword.Length < 6)
        {
            Snackbar.Add("Password must be at least 6 characters long.", Severity.Warning);
            return;
        }

        if (_newPassword != _confirmPassword)
        {
            Snackbar.Add("Passwords do not match.", Severity.Error);
            return;
        }

        _isChangingPassword = true;

        if (_profile != null)
        {
            var updateDto = new UpdateUserAccountDto
            {
                FirstName = _profile.FirstName,
                LastName = _profile.LastName,
                Email = _profile.Email,
                Role = _profile.Role,
                IsActive = _profile.IsActive,
                Password = _newPassword,
                ProfilePictureUrl = _profile.ProfilePictureUrl
            };

            var result = await UserProfileService.UpdateProfileAsync(_currentUserId, updateDto);
            
            if (result.IsSuccess)
            {
                Snackbar.Add("Password updated successfully!", Severity.Success);
                _isPasswordDialogOpen = false;
            }
            else
            {
                Snackbar.Add($"Failed to update password: {result.ErrorMessage}", Severity.Error);
            }
        }
        
        _isChangingPassword = false;
    }

    private async Task ToggleBiometric(bool value)
    {
        if (value)
        {
            try
            {
                var isAvailable = await CrossFingerprint.Current.IsAvailableAsync(true);
                if (!isAvailable)
                {
                    Snackbar.Add("Biometric authentication is not available on this device.", Severity.Error);
                    return;
                }

                var request = new AuthenticationRequestConfiguration("Enable Biometric", "Please authenticate to enable biometric login.");
                var result = await CrossFingerprint.Current.AuthenticateAsync(request);

                if (!result.Authenticated)
                {
                    Snackbar.Add("Biometric authentication failed or was canceled.", Severity.Warning);
                    return;
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
                return;
            }
        }

        _isBiometricEnabled = value;
        await AuthService.EnableBiometricAsync(value);
        Snackbar.Add(value ? "Biometric enabled." : "Biometric disabled.", Severity.Success);
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        ((VikashERP.Mobile.State.CustomAuthStateProvider)AuthStateProvider).MarkUserAsLoggedOut();
        Navigation.NavigateTo("/login", true);
    }
    
    private string GetImageUrl(string? path)
    {
        if (string.IsNullOrEmpty(path)) return "";
        if (path.StartsWith("http") || path.StartsWith("data:")) return path;
        
        // Remove leading slash if any
        if (path.StartsWith("/"))
            path = path.Substring(1);
            
        var client = HttpClientFactory.CreateClient("ApiClient");
        return $"{client.BaseAddress}{path}";
    }
}
