@page "/profile"
@using MudBlazor
@using Microsoft.AspNetCore.Authorization
@using VikashERP.Mobile.Components.Layout
@using VikashERP.Mobile.Models
@using VikashERP.Mobile.Services.Interfaces
@using Plugin.Fingerprint
@using Plugin.Fingerprint.Abstractions
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Forms
@inject VikashERP.Mobile.State.AppStateService AppState
@attribute [Authorize(Roles = "Super Admin,Back Office User,Manager,Employee,Customer")]

@if (_isLoading)
{
    <!-- Page is loading, the global AdvanceLoader is displayed via AppState -->
}
else if (_profile == null)
{
    <div class="d-flex flex-column justify-center align-center" style="height: 100vh;">
        <MudText Typo="Typo.h6" Color="Color.Error">Could not load profile.</MudText>
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudText Typo="Typo.body2" Color="Color.Error" Class="mb-4">@_errorMessage</MudText>
        }
        <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="LoadProfile">Retry</MudButton>
    </div>
}
else
{
    @* ---- Header Section ---- *@
    <div class="profile-header-container mb-6">
        <div class="profile-header-bg"></div>
        <div class="d-flex flex-column align-center pt-8 pb-4" style="position: relative; z-index: 2;">
            <div class="avatar-container mb-3">
                <label for="fileInput" style="@(_isEditing ? "cursor: pointer;" : "cursor: default;")">
                    <div class="avatar-wrapper">
                        @if (!string.IsNullOrEmpty(_profile.ProfilePictureUrl))
                        {
                            <MudAvatar Style="height: 88px; width: 88px; background-color: white; border: 3px solid white; box-shadow: 0 8px 24px rgba(0,0,0,0.15);">
                                <MudImage Src="@GetImageUrl(_profile.ProfilePictureUrl)" Style="width: 100%; height: 100%; object-fit: cover;" fetchpriority="high" />
                            </MudAvatar>
                        }
                        else
                        {
                            <MudAvatar Style="height: 88px; width: 88px; font-size: 2rem; font-weight: 700; background-color: white; color: #6450f3; border: 3px solid white; box-shadow: 0 8px 24px rgba(0,0,0,0.15);">
                                @GetInitials()
                            </MudAvatar>
                        }
                        @if (_isEditing)
                        {
                            <div class="edit-badge">
                                <MudIcon Icon="@Icons.Material.Filled.CameraAlt" Size="Size.Small" Style="color: white; font-size: 16px;" />
                            </div>
                        }
                    </div>
                </label>
                <InputFile id="fileInput" OnChange="UploadProfilePicture" style="display:none;" accept="image/*" disabled="@(!_isEditing)" />
            </div>

            <MudText Typo="Typo.h5" Style="font-weight: 800; color: white; line-height: 1.2; text-shadow: 0 2px 8px rgba(0,0,0,0.2);">@_profile.FirstName @_profile.LastName</MudText>
            <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.9); font-weight: 500;" Class="mb-3">@_profile.Role</MudText>
            <div class="user-id-chip">User ID: @_profile.Id.ToString().Substring(0, 8).ToUpper()</div>
        </div>
    </div>

    @* ---- Stats Grid ---- *@
    <MudGrid Spacing="3" Class="mb-6 px-4" Style="margin-top: -40px; position: relative; z-index: 3;">
        <MudItem xs="6">
            <MudPaper Class="stat-card d-flex flex-column align-center justify-center pa-4" Elevation="0">
                <MudText Typo="Typo.h6" Style="font-weight: 800; color: #1a2530;">@_profile.CreatedAt.ToString("MMM yyyy")</MudText>
                <MudText Typo="Typo.caption" Style="color: #888; font-weight: 600;">JOINED</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6">
            <MudPaper Class="stat-card d-flex flex-column align-center justify-center pa-4" Elevation="0">
                <MudText Typo="Typo.h6" Style="font-weight: 800; color: #1a2530;">@(_profile.IsActive ? "Active" : "Inactive")</MudText>
                <MudText Typo="Typo.caption" Style="color: #888; font-weight: 600;">STATUS</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <div class="px-4">
        @* ---- Edit Profile Form ---- *@
        <div class="d-flex align-center justify-space-between mb-3 px-1">
            <MudText Typo="Typo.caption" Style="color: #888; font-weight: 700; letter-spacing: 1px;">PERSONAL INFO</MudText>
            @if (!_isEditing)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" OnClick="EnableEditMode" Style="background: rgba(100, 80, 243, 0.1); color: #6450f3 !important; padding: 4px;" />
            }
        </div>

        <MudPaper Class="settings-card mb-6 pa-5" Elevation="0">
            <MudForm @ref="_form" @bind-IsValid="@_success" @bind-Errors="@_errors">
                <MudTextField @bind-Value="_profile.FirstName" Label="First Name" Required="true" RequiredError="First name is required!" Variant="Variant.Outlined" Class="mb-4 custom-input" ReadOnly="!_isEditing" />
                <MudTextField @bind-Value="_profile.LastName" Label="Last Name" Required="true" RequiredError="Last name is required!" Variant="Variant.Outlined" Class="mb-4 custom-input" ReadOnly="!_isEditing" />
                <MudTextField @bind-Value="_profile.Email" Label="Email Address" Variant="Variant.Outlined" Class="mb-4 custom-input" ReadOnly="true" Disabled="true" />
                
                @if (_isEditing)
                {
                    <div class="d-flex gap-3 mt-2">
                        <MudButton Variant="Variant.Filled" Color="Color.Default" FullWidth="true" OnClick="CancelEditMode" Class="py-3 cancel-btn">
                            Cancel
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="SaveProfile" Disabled="@_isSaving" Class="py-3 save-btn">
                            @if (_isSaving)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/> <span>Saving...</span>
                            }
                            else
                            {
                                <span>Save Changes</span>
                            }
                        </MudButton>
                    </div>
                }
            </MudForm>
        </MudPaper>

        @* ---- Account Settings ---- *@
        <MudText Typo="Typo.caption" Style="color: #888; font-weight: 700; letter-spacing: 1px;" Class="mb-3 d-block px-1">SECURITY & SETTINGS</MudText>
        <MudPaper Class="settings-card mb-8" Elevation="0">
            <MudList T="string" Padding="false">
                <MudListItem OnClick="OpenPasswordDialog" Class="custom-list-item">
                    <div class="d-flex align-center justify-space-between py-2">
                        <div class="d-flex align-center">
                            <div class="list-icon-wrapper" style="background-color: #fff4e5;">
                                <MudIcon Icon="@Icons.Material.Rounded.Lock" Size="Size.Small" Style="color: #ff9800;" />
                            </div>
                            <MudText Typo="Typo.body2" Style="color: #1a2530; font-weight: 700; margin-left: 12px;">Change Password</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Rounded.ChevronRight" Size="Size.Small" Style="color: #ccc;" />
                    </div>
                </MudListItem>
                <MudDivider Style="opacity: 0.5;" />
                <MudListItem OnClick='@(() => Navigation.NavigateTo("/create-pin"))' Class="custom-list-item">
                    <div class="d-flex align-center justify-space-between py-2">
                        <div class="d-flex align-center">
                            <div class="list-icon-wrapper" style="background-color: #e3f2fd;">
                                <MudIcon Icon="@Icons.Material.Rounded.Pin" Size="Size.Small" Style="color: #2196f3;" />
                            </div>
                            <MudText Typo="Typo.body2" Style="color: #1a2530; font-weight: 700; margin-left: 12px;">Update App PIN</MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Rounded.ChevronRight" Size="Size.Small" Style="color: #ccc;" />
                    </div>
                </MudListItem>
                <MudDivider Style="opacity: 0.5;" />
                <MudListItem Class="custom-list-item">
                    <div class="d-flex align-center justify-space-between py-1 w-100">
                        <div class="d-flex align-center">
                            <div class="list-icon-wrapper" style="background-color: #e8f5e9;">
                                <MudIcon Icon="@Icons.Material.Rounded.Fingerprint" Size="Size.Small" Style="color: #4caf50;" />
                            </div>
                            <MudText Typo="Typo.body2" Style="color: #1a2530; font-weight: 700; margin-left: 12px;">Biometric Login</MudText>
                        </div>
                        <MudSwitch T="bool" Value="@_isBiometricEnabled" ValueChanged="ToggleBiometric" Color="Color.Primary" />
                    </div>
                </MudListItem>
            </MudList>
        </MudPaper>

        @* ---- Log out ---- *@
        <MudButton Variant="Variant.Filled" FullWidth="true" Class="logout-btn mb-10 py-3" OnClick="Logout">
            <div class="d-flex align-center justify-center">
                <MudIcon Icon="@Icons.Material.Rounded.Logout" Class="mr-2" />
                <span>Sign Out</span>
            </div>
        </MudButton>
    </div>
}

@* ---- Password Change Dialog Overlay ---- *@
@if (_isPasswordDialogOpen)
{
    <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background-color: rgba(26, 37, 48, 0.4); backdrop-filter: blur(8px); z-index: 10000; display: flex; align-items: center; justify-content: center;">
        <MudPaper Class="pa-6" Style="width: 340px; max-width: 90vw; border-radius: 24px; box-shadow: 0 20px 40px rgba(0,0,0,0.2);">
            <div class="d-flex justify-center mb-4">
                <div class="list-icon-wrapper" style="background-color: #fff4e5; width: 48px; height: 48px; border-radius: 16px;">
                    <MudIcon Icon="@Icons.Material.Rounded.LockReset" Style="color: #ff9800; font-size: 28px;" />
                </div>
            </div>
            <MudText Typo="Typo.h6" Style="font-weight: 800; color: #1a2530; text-align: center;" Class="mb-1">Change Password</MudText>
            <MudText Typo="Typo.body2" Style="color: #888; text-align: center;" Class="mb-5">Enter your new secure password.</MudText>
            
            <MudTextField @bind-Value="_newPassword" Label="New Password" InputType="InputType.Password" Variant="Variant.Outlined" Class="mb-4 custom-input" />
            <MudTextField @bind-Value="_confirmPassword" Label="Confirm Password" InputType="InputType.Password" Variant="Variant.Outlined" Class="mb-5 custom-input" />
            
            <div class="d-flex justify-space-between gap-3">
                <MudButton Variant="Variant.Filled" Color="Color.Default" FullWidth="true" OnClick="ClosePasswordDialog" Class="cancel-btn py-3">Cancel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="SubmitPasswordChange" Disabled="@_isChangingPassword" Class="save-btn py-3">
                    @if(_isChangingPassword){ <MudProgressCircular Size="Size.Small" Indeterminate="true"/> } else { <span>Update</span> }
                </MudButton>
            </div>
        </MudPaper>
    </div>
}

@* ---- Image Cropper Overlay ---- *@
@if (_isCropperOpen)
{
    <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background-color: rgba(0,0,0,0.9); z-index: 10001; display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <div style="width: 90vw; height: 60vh; background: #000; position: relative; border-radius: 16px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
            <CropperComponent @ref="_cropperComponent" Src="@_tempImageUrl" Options="_cropperOptions" />
        </div>
        <div class="d-flex justify-center gap-4 mt-8">
            <MudButton Variant="Variant.Filled" Color="Color.Default" OnClick="CancelCropper" Style="border-radius: 12px; font-weight: 700; padding: 12px 24px;">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveCroppedImage" Style="border-radius: 12px; font-weight: 700; padding: 12px 24px; background: #6450f3;">Crop & Save</MudButton>
        </div>
    </div>
}

