@inherits LayoutComponentBase

<MudLayout Class="app-layout">
    <MudAppBar Elevation="0" Fixed="true" Class="app-topbar" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Class="app-topbar-menu"
                       OnClick="@DrawerToggle" />

        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            <MudIconButton Icon="@Icons.Material.Filled.Search" Class="app-topbar-icon" />
        </MudHidden>

        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <div class="appbar-search">
                <MudIcon Icon="@Icons.Material.Filled.Search" Class="appbar-search-icon" />
                <input type="text" placeholder="Search anything..." class="appbar-search-input" />
                <span class="appbar-search-kbd">⌘K</span>
            </div>
        </MudHidden>

        <MudSpacer />

        <div class="app-topbar-actions">
            <MudIconButton Icon="@(DarkModeService.IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Class="app-topbar-icon"
                           OnClick="@ToggleDarkMode" />

            <div class="notification-badge-container">
                <MudIconButton Icon="@Icons.Material.Filled.Notifications"
                               Color="Color.Inherit"
                               Class="app-topbar-icon"
                               AriaLabel="Notifications" />
                <span class="notification-badge">3</span>
            </div>

            <MudMenu AnchorOrigin="Origin.BottomRight"
                     TransformOrigin="Origin.TopRight"
                     PopoverClass="appbar-profile-popover"
                     Class="appbar-profile-menu"
                     ActivationEvent="MouseEvent.MouseOver"
                     Dense="true">
                <ActivatorContent>
                    <div class="user-avatar-trigger">
                        @if (!string.IsNullOrEmpty(_userProfilePictureUrl))
                        {
                            <img src="@_userProfilePictureUrl" class="user-avatar-img" alt="Profile" />
                        }
                        else
                        {
                            <MudAvatar Color="Color.Dark" Class="user-avatar">@_userInitials</MudAvatar>
                        }
                        <MudHidden Breakpoint="Breakpoint.SmAndDown">
                            <div class="user-profile-details">
                                <span class="user-profile-name">@_userName</span>
                                <span class="user-profile-role">@_displayRole</span>
                            </div>
                        </MudHidden>
                    </div>
                </ActivatorContent>
                <ChildContent>
                    <div class="menu-profile-header">
                        <MudText Typo="Typo.subtitle2" Class="menu-profile-username">@_userName</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@_displayRole</MudText>
                    </div>
                    <MudDivider />
                    <MudMenuItem Icon="@Icons.Material.Filled.Person" Href="/profile" Class="menu-item-text">
                        My Profile
                    </MudMenuItem>
                    <MudDivider />
                    <MudMenuItem Icon="@Icons.Material.Filled.Logout"
                                 Color="Color.Error"
                                 Class="menu-item-text"
                                 OnClick="@Logout">
                        Logout
                    </MudMenuItem>
                </ChildContent>
            </MudMenu>
        </div>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Elevation="0"
               Variant="DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Never"
               Breakpoint="Breakpoint.Md"
               Class="app-drawer">
        <div class="app-drawer-inner">
            <div class="app-drawer-header">
                <div class="app-drawer-brand-block">
                    <div class="app-drawer-logo-wrap">
                        <img src="logo.png" alt="Vikash Ironix" class="app-drawer-logo" />
                    </div>
                    <div class="app-drawer-brand-text">
                        <div class="app-drawer-brand">Vikash Ironix</div>
                        <div class="app-drawer-tagline">Enterprise ERP</div>
                    </div>
                </div>
            </div>

            <div class="app-drawer-nav">
                <NavMenu />
            </div>

            <div class="app-drawer-footer">
                <div class="app-drawer-help">
                    <div class="app-drawer-help-icon">
                        <MudIcon Icon="@Icons.Material.Filled.HelpOutline" />
                    </div>
                    <div>
                        <div class="app-drawer-help-title">Need Help?</div>
                        <div class="app-drawer-help-sub">
                            Check our documentation
                            <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Style="font-size: 12px;" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </MudDrawer>

    <MudMainContent Class="app-main">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="app-main-container">
            <div class="app-page">
                @Body
            </div>
        </MudContainer>
    </MudMainContent>
</MudLayout>
