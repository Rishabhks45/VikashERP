@inherits LayoutComponentBase
@inject IOrganizationBrandingService OrganizationBranding
@implements IDisposable

<div class="auth-page">
    <MudIconButton Icon="@(DarkModeService.IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                   Class="auth-dark-toggle"
                   Color="Color.Inherit"
                   AriaLabel="Toggle dark mode"
                   OnClick="@ToggleDarkMode" />
    <div class="auth-left" style="@OrganizationBranding.AuthPanelStyle">
        <div class="auth-brand">
            @if (!string.IsNullOrWhiteSpace(OrganizationBranding.LogoSrc))
            {
                <img src="@OrganizationBranding.LogoSrc" alt="@OrganizationBranding.Current.DisplayName" class="auth-brand-logo" />
            }
            else if (!string.IsNullOrWhiteSpace(OrganizationBranding.Current.DisplayName))
            {
                <div class="auth-brand-name">@OrganizationBranding.Current.DisplayName</div>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(OrganizationBranding.Current.Tagline))
        {
            <div class="auth-hero-title">@OrganizationBranding.Current.Tagline</div>
        }

        @if (!string.IsNullOrWhiteSpace(OrganizationBranding.Current.MetaDescription))
        {
            <div class="auth-hero-desc">@OrganizationBranding.Current.MetaDescription</div>
        }

        <div class="auth-feature-card">
            <div class="auth-feature-icon pink">
                <MudIcon Icon="@Icons.Material.Filled.Analytics" />
            </div>
            <div>
                <div class="auth-feature-title">Real-time Analytics</div>
                <div class="auth-feature-desc">Track revenue, stock & customers live</div>
            </div>
        </div>

        <div class="auth-feature-card">
            <div class="auth-feature-icon blue">
                <MudIcon Icon="@Icons.Material.Filled.Inventory2" />
            </div>
            <div>
                <div class="auth-feature-title">Smart Inventory</div>
                <div class="auth-feature-desc">Full material catalog with stock alerts</div>
            </div>
        </div>

        <div class="auth-feature-card">
            <div class="auth-feature-icon teal">
                <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" />
            </div>
            <div>
                <div class="auth-feature-title">Billing & Ledger</div>
                <div class="auth-feature-desc">Invoices, udhaar tracking & daily audits</div>
            </div>
        </div>

        <div class="auth-version">@(OrganizationBranding.Current.CopyrightText ?? "Enterprise ERP")</div>
    </div>

    <div class="auth-right">
        <div class="auth-right-inner app-page">
            @Body
        </div>
        <div class="auth-footer-links">
            @if (!string.IsNullOrWhiteSpace(OrganizationBranding.Current.Email))
            {
                <a href="mailto:@OrganizationBranding.Current.Email">Support</a>
            }
            @if (!string.IsNullOrWhiteSpace(OrganizationBranding.Current.WebsiteUrl))
            {
                <a href="@OrganizationBranding.Current.WebsiteUrl" target="_blank" rel="noopener">Website</a>
            }
        </div>
    </div>
</div>

@code {
    [Inject] private IDarkModeService DarkModeService { get; set; } = default!;

    protected override void OnInitialized()
    {
        DarkModeService.OnChange += HandleDarkModeChanged;
        OrganizationBranding.OnChange += HandleBrandingChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await OrganizationBranding.InitializeAsync();
    }

    private void HandleDarkModeChanged() => InvokeAsync(StateHasChanged);

    private void HandleBrandingChanged() => InvokeAsync(StateHasChanged);

    private Task ToggleDarkMode() => DarkModeService.ToggleAsync();

    public void Dispose()
    {
        DarkModeService.OnChange -= HandleDarkModeChanged;
        OrganizationBranding.OnChange -= HandleBrandingChanged;
    }
}
