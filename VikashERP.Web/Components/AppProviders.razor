@inject IDarkModeService DarkModeService
@inject IOrganizationBrandingService OrganizationBranding
@implements IDisposable

<PageTitle>@OrganizationBranding.PageTitle</PageTitle>
<HeadContent>
    @if (!string.IsNullOrWhiteSpace(OrganizationBranding.FaviconSrc))
    {
        <link rel="icon" type="image/png" href="@OrganizationBranding.FaviconSrc" />
    }
    @if (!string.IsNullOrWhiteSpace(OrganizationBranding.Current.MetaDescription))
    {
        <meta name="description" content="@OrganizationBranding.Current.MetaDescription" />
    }
</HeadContent>

<div class="org-branded-root" style="@OrganizationBranding.CssVariables">
    <MudThemeProvider Theme="@OrganizationBranding.GetTheme()"
                      IsDarkMode="@DarkModeService.IsDarkMode"
                      IsDarkModeChanged="OnDarkModeChanged" />
    <MudPopoverProvider />
    <MudDialogProvider />
    <MudSnackbarProvider />

    @ChildContent
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    protected override void OnInitialized()
    {
        DarkModeService.OnChange += HandleDarkModeChanged;
        OrganizationBranding.OnChange += HandleBrandingChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await DarkModeService.InitializeAsync();
        await OrganizationBranding.InitializeAsync();
    }

    private void HandleDarkModeChanged() => InvokeAsync(StateHasChanged);

    private void HandleBrandingChanged() => InvokeAsync(StateHasChanged);

    private Task OnDarkModeChanged(bool isDarkMode) =>
        DarkModeService.SetDarkModeAsync(isDarkMode);

    public void Dispose()
    {
        DarkModeService.OnChange -= HandleDarkModeChanged;
        OrganizationBranding.OnChange -= HandleBrandingChanged;
    }
}
