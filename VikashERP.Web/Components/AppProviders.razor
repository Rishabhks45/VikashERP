@inject IDarkModeService DarkModeService
@inject IOrganizationBrandingService OrganizationBranding
@implements IDisposable

<PageTitle>@OrganizationBranding.PageTitle</PageTitle>
<HeadContent>
    @if (!string.IsNullOrWhiteSpace(OrganizationBranding.FaviconSrc))
    {
        <link rel="icon" type="image/png" href="@OrganizationBranding.FaviconSrc" />
    }
    @if (OrganizationBranding.Current is not null && !string.IsNullOrWhiteSpace(OrganizationBranding.Current.MetaDescription))
    {
        <meta name="description" content="@OrganizationBranding.Current.MetaDescription" />
    }
</HeadContent>

<div class="@RootCssClass" style="@OrganizationBranding.CssVariables">
    <MudThemeProvider Theme="@OrganizationBranding.GetTheme()"
                      IsDarkMode="@DarkModeService.IsDarkMode"
                      IsDarkModeChanged="OnDarkModeChanged" />
    <MudPopoverProvider />
    <MudDialogProvider />
    <MudSnackbarProvider />

    @ChildContent
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool _disposed;

    private string RootCssClass =>
        DarkModeService?.IsDarkMode == true
            ? "org-branded-root app-dark-mode"
            : "org-branded-root app-light-mode";

    protected override void OnInitialized()
    {
        DarkModeService.OnChange += HandleDarkModeChanged;
        OrganizationBranding.OnChange += HandleBrandingChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await DarkModeService.InitializeAsync();
        await OrganizationBranding.InitializeAsync();
    }

    private void HandleDarkModeChanged()
    {
        if (_disposed) return;
        _ = InvokeAsync(() =>
        {
            try { StateHasChanged(); }
            catch { /* suppress render errors during dark mode change */ }
        });
    }

    private void HandleBrandingChanged()
    {
        if (_disposed) return;
        _ = InvokeAsync(() =>
        {
            try { StateHasChanged(); }
            catch { /* suppress render errors during branding change */ }
        });
    }

    private Task OnDarkModeChanged(bool isDarkMode) =>
        DarkModeService.SetDarkModeAsync(isDarkMode);

    public void Dispose()
    {
        _disposed = true;
        DarkModeService.OnChange -= HandleDarkModeChanged;
        OrganizationBranding.OnChange -= HandleBrandingChanged;
    }
}
