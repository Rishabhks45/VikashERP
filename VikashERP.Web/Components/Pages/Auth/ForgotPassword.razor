@page "/forgot-password"
@attribute [AllowAnonymous]
@using VikashERP.Web.Services
@inject IAuthService AuthService
@layout VikashERP.Web.Components.Layout.AuthLayout

<div class="login-title">Forgot password?</div>
<div class="login-subtitle">Enter your email and we will send you a reset link.</div>

@if (IsSubmitted)
{
    <MudAlert Severity="Severity.Success" Class="mb-4" Dense="true">
        If an account exists with that email, a reset link has been sent.
    </MudAlert>

    <div class="auth-form-footer">
        <a href="/login" class="forgot-link">Return to sign in</a>
    </div>
}
else
{
    <EditForm Model="@Model" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        <div style="margin-bottom: 24px;">
            <span class="field-label">Email address</span>
            <MudTextField @bind-Value="Model.Email"
                          Placeholder="your@email.com"
                          Variant="Variant.Filled"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Outlined.AlternateEmail"
                          Margin="Margin.Dense"
                          FullWidth="true"
                          For="@(() => Model.Email)" />
        </div>

        <MudButton ButtonType="ButtonType.Submit"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Large"
                   FullWidth="true"
                   Disabled="@IsLoading"
                   Style="border-radius: 10px; font-weight: 700; letter-spacing: 1px; height: 48px; font-size: 0.9rem;">
            @if (IsLoading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="margin-right: 8px;" />
                <span>SENDING...</span>
            }
            else
            {
                <span>SEND RESET LINK</span>
            }
        </MudButton>

        <div class="auth-form-footer">
            <a href="/login" class="forgot-link">Back to sign in</a>
        </div>
    </EditForm>
}

@code {
    private ForgotPasswordModel Model = new();
    private bool IsSubmitted;
    private bool IsLoading;

    private async Task HandleSubmit()
    {
        IsLoading = true;
        await AuthService.ForgotPasswordAsync(Model.Email);
        IsSubmitted = true;
        IsLoading = false;
    }

    public class ForgotPasswordModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Invalid email format")]
        public string Email { get; set; } = "";
    }
}
