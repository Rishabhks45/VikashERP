@page "/reset-password"
@attribute [AllowAnonymous]
@using VikashERP.Web.Services
@inject IAuthService AuthService
@layout VikashERP.Web.Components.Layout.AuthLayout

<MudText Typo="Typo.h5" HtmlTag="h1" Class="login-title">Reset password</MudText>
<div class="login-subtitle">Choose a new password for your account.</div>

@if (IsSuccess)
{
    <MudAlert Severity="Severity.Success" Class="mb-4" Dense="true">
        Your password has been successfully reset.
    </MudAlert>

    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               Size="Size.Large"
               FullWidth="true"
               Href="/login"
               Style="border-radius: 10px; font-weight: 700; letter-spacing: 1px; height: 48px; font-size: 0.9rem;">
        GO TO SIGN IN
    </MudButton>
}
else
{
    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@ErrorMessage</MudAlert>
    }

    <EditForm Model="@Model" OnValidSubmit="HandleSubmit" novalidate>
        <FluentValidationValidator />

        <div style="margin-bottom: 20px;">
            <span class="field-label">New password</span>
            <MudTextField @bind-Value="Model.Password"
                          Placeholder="••••••••"
                          Variant="Variant.Filled"
                          InputType="@_passwordInput"
                          Adornment="Adornment.End"
                          AdornmentIcon="@_passwordInputIcon"
                          OnAdornmentClick="TogglePasswordVisibility"
                          Margin="Margin.Dense"
                          FullWidth="true"
                          For="@(() => Model.Password)" />
        </div>

        <div style="margin-bottom: 24px;">
            <span class="field-label">Confirm password</span>
            <MudTextField @bind-Value="Model.ConfirmPassword"
                          Placeholder="••••••••"
                          Variant="Variant.Filled"
                          InputType="@_confirmPasswordInput"
                          Adornment="Adornment.End"
                          AdornmentIcon="@_confirmPasswordInputIcon"
                          OnAdornmentClick="ToggleConfirmPasswordVisibility"
                          Margin="Margin.Dense"
                          FullWidth="true"
                          For="@(() => Model.ConfirmPassword)" />
        </div>

        <MudButton ButtonType="ButtonType.Submit"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Large"
                   FullWidth="true"
                   Disabled="@IsLoading"
                   Style="border-radius: 10px; font-weight: 700; letter-spacing: 1px; height: 48px; font-size: 0.9rem;">
            @if (IsLoading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="margin-right: 8px;" />
                <span>UPDATING...</span>
            }
            else
            {
                <span>UPDATE PASSWORD</span>
            }
        </MudButton>

        <div class="auth-form-footer">
            <a href="/login" class="forgot-link">Back to sign in</a>
        </div>
    </EditForm>
}

@code {
    [SupplyParameterFromQuery]
    public string? Token { get; set; }

    private ResetPasswordFormModel Model = new();
    private bool IsSuccess;
    private bool IsLoading;
    private string ErrorMessage = string.Empty;

    private bool _passwordVisibility;
    private InputType _passwordInput = InputType.Password;
    private string _passwordInputIcon = Icons.Material.Outlined.VisibilityOff;

    private bool _confirmPasswordVisibility;
    private InputType _confirmPasswordInput = InputType.Password;
    private string _confirmPasswordInputIcon = Icons.Material.Outlined.VisibilityOff;

    protected override void OnParametersSet()
    {
        if (string.IsNullOrWhiteSpace(Token))
            ErrorMessage = "Reset token is missing. Please use the link from your email.";
    }

    private void TogglePasswordVisibility()
    {
        _passwordVisibility = !_passwordVisibility;
        _passwordInput = _passwordVisibility ? InputType.Text : InputType.Password;
        _passwordInputIcon = _passwordVisibility
            ? Icons.Material.Outlined.Visibility
            : Icons.Material.Outlined.VisibilityOff;
    }

    private void ToggleConfirmPasswordVisibility()
    {
        _confirmPasswordVisibility = !_confirmPasswordVisibility;
        _confirmPasswordInput = _confirmPasswordVisibility ? InputType.Text : InputType.Password;
        _confirmPasswordInputIcon = _confirmPasswordVisibility
            ? Icons.Material.Outlined.Visibility
            : Icons.Material.Outlined.VisibilityOff;
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(Token))
        {
            ErrorMessage = "Reset token is missing.";
            return;
        }

        IsLoading = true;
        ErrorMessage = string.Empty;

        var success = await AuthService.ResetPasswordAsync(Token, Model.Password);
        if (success)
            IsSuccess = true;
        else
            ErrorMessage = "Invalid or expired reset token. Please request a new link.";

        IsLoading = false;
    }
}
