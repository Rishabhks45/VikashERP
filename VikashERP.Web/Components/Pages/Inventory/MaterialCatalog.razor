@page "/material-catalog"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MudBlazor
@using VikashERP.Web.Models
@using VikashERP.Web.Services.Interfaces
@inject IProductWebService ProductService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Material Catalog - The Iron Ledger</PageTitle>

<div class="catalog-page-container">
    <!-- HERO HEADER SECTION -->
    <div class="hero-section">
        <div class="hero-main-content">
            <div class="hero-text-wrap">
                <span class="hero-badge">Enterprise Catalog</span>
                <h1 class="hero-title">Premium Steel &amp; Iron Materials</h1>
                <p class="hero-subtitle">Browse, filter, and request commercial quotes on our live stock of high-grade industrial materials.</p>
            </div>
            
            <!-- Live Rates Panel -->
            <div class="rates-panel">
                <div class="rates-header">
                    <span class="rates-title">LIVE STEEL INDEX (INR/MT)</span>
                    <span class="rates-dot"></span>
                </div>
                <div class="rates-grid">
                    <div class="rate-item">
                        <span class="rate-label">TMT Bars Fe 500D</span>
                        <div class="rate-value-wrap">
                            <span class="rate-value">₹54,200</span>
                            <span class="rate-trend trend-up">▲ 0.5%</span>
                        </div>
                    </div>
                    <div class="rate-item">
                        <span class="rate-label">HR Plates SS304</span>
                        <div class="rate-value-wrap">
                            <span class="rate-value">₹1,12,000</span>
                            <span class="rate-trend trend-down">▼ 0.2%</span>
                        </div>
                    </div>
                    <div class="rate-item">
                        <span class="rate-label">MS Channel</span>
                        <div class="rate-value-wrap">
                            <span class="rate-value">₹51,500</span>
                            <span class="rate-trend trend-flat">■ 0.0%</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- FEATURED CATEGORY CAROUSEL -->
    <div class="section-title-wrap mt-6">
        <h2 class="section-title">Browse By Category</h2>
        <span class="section-divider"></span>
    </div>

    <div class="category-carousel-outer">
        <button class="carousel-control prev" @onclick="ScrollLeft">
            <MudIcon Icon="@Icons.Material.Filled.ChevronLeft" />
        </button>
        
        <div class="category-carousel-viewport" id="category-viewport">
            <div class="category-carousel-track">
                <!-- All Materials Card -->
                <div class="category-card @(string.IsNullOrEmpty(_selectedCategory) ? "active" : "")" @onclick="() => SelectCategory(string.Empty)">
                    <div class="category-icon-bg">
                        <MudIcon Icon="@Icons.Material.Filled.Layers" Class="category-icon" />
                    </div>
                    <div class="category-text">
                        <span class="category-name">All Materials</span>
                        <span class="category-count">@AllProducts.Count Products</span>
                    </div>
                </div>

                @foreach (var cat in AvailableCategories)
                {
                    <div class="category-card @(_selectedCategory == cat.Name ? "active" : "")" @onclick="() => SelectCategory(cat.Name)">
                        <div class="category-icon-bg">
                            <MudIcon Icon="@GetCategoryIcon(cat.Name)" Class="category-icon" />
                        </div>
                        <div class="category-text">
                            <span class="category-name">@cat.Name</span>
                            <span class="category-count">@cat.Count Items</span>
                        </div>
                    </div>
                }
            </div>
        </div>

        <button class="carousel-control next" @onclick="ScrollRight">
            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" />
        </button>
    </div>

    <!-- MAIN GRID CONTAINER -->
    <div class="catalog-workspace mt-6">
        <!-- LEFT FILTER SIDEBAR -->
        <aside class="filter-sidebar">
            <div class="sidebar-header">
                <MudIcon Icon="@Icons.Material.Filled.FilterAlt" Size="Size.Small" Class="mr-2 text-primary" />
                <span class="sidebar-title">Filters</span>
                @if (HasActiveFilters)
                {
                    <button class="clear-filters-btn" @onclick="ResetFilters">Reset</button>
                }
            </div>

            <!-- Search -->
            <div class="filter-group">
                <label class="filter-label">Search Query</label>
                <div class="search-input-wrap">
                    <input type="text" 
                           placeholder="Search name, category, HSN..." 
                           class="filter-search-input" 
                           @bind-value="_searchQuery" 
                           @bind-value:event="oninput" />
                    <MudIcon Icon="@Icons.Material.Filled.Search" Class="search-icon" Size="Size.Small" />
                </div>
            </div>

            <!-- Categories Checklist -->
            <div class="filter-group">
                <label class="filter-label">Filter Categories</label>
                <div class="checkbox-list">
                    @foreach (var cat in AvailableCategories)
                    {
                        <label class="checkbox-item">
                            <input type="checkbox" 
                                   checked="@(_selectedCategory == cat.Name)" 
                                   @onchange="@(e => ToggleCategoryCheckbox(cat.Name, (bool)e.Value!))" />
                            <span class="checkbox-custom"></span>
                            <span class="checkbox-text">@cat.Name</span>
                            <span class="checkbox-badge">@cat.Count</span>
                        </label>
                    }
                </div>
            </div>

            <!-- Size Spec Filter -->
            <div class="filter-group">
                <label class="filter-label">Material Size</label>
                <div class="select-wrap">
                    <select class="filter-select" @bind="_selectedSize">
                        <option value="">All Sizes</option>
                        @foreach (var size in DistinctSizes)
                        {
                            <option value="@size">@size</option>
                        }
                    </select>
                    <MudIcon Icon="@Icons.Material.Filled.ArrowDropDown" Class="select-arrow" />
                </div>
            </div>

            <!-- Thickness Spec Filter -->
            <div class="filter-group">
                <label class="filter-label">Thickness</label>
                <div class="select-wrap">
                    <select class="filter-select" @bind="_selectedThickness">
                        <option value="">All Thicknesses</option>
                        @foreach (var thickness in DistinctThicknesses)
                        {
                            <option value="@thickness">@thickness</option>
                        }
                    </select>
                    <MudIcon Icon="@Icons.Material.Filled.ArrowDropDown" Class="select-arrow" />
                </div>
            </div>

            <!-- Quick Status Filter -->
            <div class="filter-group">
                <label class="filter-label">Options</label>
                <label class="toggle-item">
                    <input type="checkbox" @bind="_onlyActive" />
                    <span class="toggle-track"></span>
                    <span class="toggle-text">Active Items Only</span>
                </label>
            </div>
        </aside>

        <!-- PRODUCT GRID SHOWCASE -->
        <main class="grid-showcase">
            @if (_isLoading)
            {
                <div class="skeleton-grid">
                    @for (int i = 0; i < 6; i++)
                    {
                        <div class="skeleton-card">
                            <div class="skeleton-thumb"></div>
                            <div class="skeleton-line title"></div>
                            <div class="skeleton-line text"></div>
                            <div class="skeleton-line button"></div>
                        </div>
                    }
                </div>
            }
            else if (FilteredProducts.Count == 0)
            {
                <div class="empty-state">
                    <MudIcon Icon="@Icons.Material.Filled.Inventory" Class="empty-icon" />
                    <h3 class="empty-title">No Materials Found</h3>
                    <p class="empty-desc">We couldn't find any products matching your current filters. Try resetting the criteria.</p>
                    <button class="btn-primary-outline" @onclick="ResetFilters">Reset Filters</button>
                </div>
            }
            else
            {
                <div class="product-grid">
                    @foreach (var prod in FilteredProducts)
                    {
                        <div class="product-card">
                            <!-- Card Image / Placeholder Header -->
                            <div class="product-card-header">
                                <span class="product-category-tag">@prod.CategoryName</span>
                                @if (!string.IsNullOrEmpty(prod.ProductImageUrl))
                                {
                                    <img src="@prod.ProductImageUrl" class="product-img" alt="@prod.Name" />
                                }
                                else
                                {
                                    <div class="product-placeholder-bg">
                                        <MudIcon Icon="@GetCategoryIcon(prod.CategoryName)" Class="placeholder-icon" />
                                    </div>
                                }
                            </div>

                            <!-- Card Body -->
                            <div class="product-card-body">
                                <h3 class="product-name">@prod.Name</h3>
                                <div class="product-meta">
                                    <span class="meta-item"><span class="meta-label">HSN:</span> @(prod.HsnCode ?? "N/A")</span>
                                    <span class="meta-item"><span class="meta-label">Unit:</span> @prod.SellingUnit.ToString()</span>
                                    <span class="meta-item"><span class="meta-label">Variants:</span> @prod.Variants.Count</span>
                                </div>

                                <!-- Specs Preview Pills -->
                                @if (prod.Variants.Any())
                                {
                                    <div class="specs-preview">
                                        @foreach (var v in prod.Variants.Take(3))
                                        {
                                            <span class="spec-pill">
                                                @(string.IsNullOrEmpty(v.Thickness) ? v.Size : $"{v.Size} ({v.Thickness})")
                                            </span>
                                        }
                                        @if (prod.Variants.Count > 3)
                                        {
                                            <span class="spec-pill-more">+@(prod.Variants.Count - 3) more</span>
                                        }
                                    </div>
                                }
                            </div>

                            <!-- Card Actions -->
                            <div class="product-card-footer">
                                <button class="btn-secondary-card" @onclick="() => OpenSpecsDrawer(prod)">
                                    <MudIcon Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Class="mr-1" />
                                    View Specs
                                </button>
                                <button class="btn-primary-card" @onclick="() => OpenQuoteDialog(prod)">
                                    <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" Class="mr-1" />
                                    Inquire
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        </main>
    </div>
</div>

<!-- SPEC DETAIL DRAWER -->
<MudDrawer @bind-Open="_specDrawerOpen" Anchor="Anchor.Right" Width="420px" Elevation="16" Variant="DrawerVariant.Temporary" Class="spec-detail-drawer">
    @if (_selectedProduct != null)
    {
        <div class="drawer-header">
            <div class="drawer-header-left">
                <span class="drawer-category">@_selectedProduct.CategoryName</span>
                <h3 class="drawer-title">@_selectedProduct.Name</h3>
            </div>
            <button class="drawer-close-btn" @onclick="CloseSpecsDrawer">
                <MudIcon Icon="@Icons.Material.Filled.Close" />
            </button>
        </div>

        <div class="drawer-content">
            <!-- Summary Info -->
            <div class="drawer-meta-section">
                <div class="meta-box">
                    <span class="meta-box-lbl">HSN Code</span>
                    <span class="meta-box-val">@(_selectedProduct.HsnCode ?? "N/A")</span>
                </div>
                <div class="meta-box">
                    <span class="meta-box-lbl">Selling Unit</span>
                    <span class="meta-box-val">@_selectedProduct.SellingUnit.ToString()</span>
                </div>
                <div class="meta-box">
                    <span class="meta-box-lbl">Status</span>
                    <span class="meta-box-val status-badge @(_selectedProduct.IsActive ? "active" : "inactive")">
                        @(_selectedProduct.IsActive ? "Active" : "Inactive")
                    </span>
                </div>
            </div>

            <!-- Spec Grid Table -->
            <div class="drawer-specs-table-container">
                <div class="table-header-row">
                    <span>Size / Spec</span>
                    <span>Thickness</span>
                    <span>Kg per Pc</span>
                </div>
                <div class="table-body">
                    @foreach (var variant in _selectedProduct.Variants)
                    {
                        <div class="table-body-row @(variant.IsActive ? "" : "disabled")">
                            <span class="val-bold">@variant.Size</span>
                            <span>@(string.IsNullOrEmpty(variant.Thickness) ? "-" : variant.Thickness)</span>
                            <span class="font-mono">@variant.UnitPcsToKg.ToString("F3") Kg</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Subimages Section -->
            @if (_selectedProduct.SubImages.Any())
            {
                <div class="drawer-images-section mt-6">
                    <span class="section-sub-title">Product Details Gallery</span>
                    <div class="drawer-images-grid">
                        @foreach (var img in _selectedProduct.SubImages)
                        {
                            <div class="drawer-gallery-img-wrap">
                                <img src="@img.ImageUrl" alt="@img.Description" class="drawer-gallery-img" />
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="drawer-footer">
            <button class="btn-primary-block" @onclick="() => { CloseSpecsDrawer(); OpenQuoteDialog(_selectedProduct); }">
                <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Class="mr-2" />
                Request Commercial Quotation
            </button>
        </div>
    }
</MudDrawer>

<!-- REQUEST QUOTE DIALOG (CUSTOM MODAL OVERLAY) -->
@if (_quoteDialogOpen && _selectedProduct != null)
{
    <div class="dialog-overlay animate-fade-in" @onclick="CloseQuoteDialog">
        <div class="dialog-card animate-slide-up" @onclick:stopPropagation="true">
            <div class="dialog-header">
                <div class="dialog-header-text">
                    <span class="dialog-tag">Commercial RFQ</span>
                    <h3 class="dialog-title">Request Quote for @_selectedProduct.Name</h3>
                </div>
                <button class="dialog-close-btn" @onclick="CloseQuoteDialog">
                    <MudIcon Icon="@Icons.Material.Filled.Close" />
                </button>
            </div>
            
            <div class="dialog-body">
                @if (_quoteSubmitted)
                {
                    <div class="quote-success-state">
                        <div class="success-icon-wrap">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Style="font-size: 64px;" />
                        </div>
                        <h4 class="success-title">Quotation Inquiry Submitted!</h4>
                        <p class="success-desc">Your request has been successfully registered. The commercial sales department will review stock rates and dispatch a proposal to your registered email shortly.</p>
                        <div class="success-details mt-4">
                            <div class="success-details-row">
                                <span class="label">Reference ID:</span>
                                <span class="val font-mono">RFQ-2026-@Random.Shared.Next(1000, 9999)</span>
                            </div>
                            <div class="success-details-row">
                                <span class="label">Material Selected:</span>
                                <span class="val">@_selectedProduct.Name (@_quoteSpec)</span>
                            </div>
                            <div class="success-details-row">
                                <span class="label">Requested Quantity:</span>
                                <span class="val">@_quoteQty Tons</span>
                            </div>
                        </div>
                        <button class="btn-primary-block mt-6" @onclick="CloseQuoteDialog">Close Window</button>
                    </div>
                }
                else
                {
                    <div class="dialog-form">
                        <!-- Step Details -->
                        <div class="form-row">
                            <label class="form-label">1. Select Material Specification</label>
                            <div class="select-wrap">
                                <select class="filter-select" @bind="_quoteSpec">
                                    @foreach (var variant in _selectedProduct.Variants)
                                    {
                                        var desc = string.IsNullOrEmpty(variant.Thickness) ? variant.Size : $"{variant.Size} (Thickness: {variant.Thickness})";
                                        <option value="@desc">@desc</option>
                                    }
                                </select>
                                <MudIcon Icon="@Icons.Material.Filled.ArrowDropDown" Class="select-arrow" />
                            </div>
                        </div>

                        <!-- Quantity Row -->
                        <div class="form-row-grid mt-4">
                            <div class="form-field">
                                <label class="form-label">2. Target Quantity (Metric Tons)</label>
                                <input type="number" step="0.1" min="0.1" class="form-input" @bind-value="_quoteQty" />
                            </div>
                            <div class="form-field">
                                <label class="form-label">3. Intended Delivery Site</label>
                                <div class="select-wrap">
                                    <select class="filter-select" @bind="_deliverySite">
                                        <option value="Main Site (Godown A)">Main Site (Godown A)</option>
                                        <option value="Secondary Processing Yard">Secondary Processing Yard</option>
                                        <option value="Customer Warehouse Location">Customer Warehouse Location</option>
                                        <option value="Direct Site Offloading">Direct Site Offloading</option>
                                    </select>
                                    <MudIcon Icon="@Icons.Material.Filled.ArrowDropDown" Class="select-arrow" />
                                </div>
                            </div>
                        </div>

                        <!-- Special Instructions -->
                        <div class="form-row mt-4">
                            <label class="form-label">4. Technical Instructions &amp; Custom Tolerances</label>
                            <textarea placeholder="Specify any customized lengths, batch cert requirements, or special delivery scheduling..." class="form-textarea" rows="4" @bind="_quoteInstructions"></textarea>
                        </div>

                        <!-- Quote Pricing Info -->
                        <div class="info-alert mt-4">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-2 text-primary" />
                            <span>B2B rates are evaluated dynamically against quantity thresholds. A finalized contract rate sheet will be calculated based on your request.</span>
                        </div>
                    </div>

                    <div class="dialog-footer mt-6">
                        <button class="btn-secondary-block" @onclick="CloseQuoteDialog">Cancel</button>
                        <button class="btn-primary-block" @onclick="SubmitQuoteRequest" disabled="@(string.IsNullOrEmpty(_quoteSpec) || _quoteQty <= 0)">
                            Submit Formal RFQ
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private bool _isLoading = true;
    private string _searchQuery = string.Empty;
    private string _selectedCategory = string.Empty;
    private string _selectedSize = string.Empty;
    private string _selectedThickness = string.Empty;
    private bool _onlyActive = true;

    // Data lists
    private List<ProductDto> AllProducts = new();
    private List<CategorySummary> AvailableCategories = new();
    private List<string> DistinctSizes = new();
    private List<string> DistinctThicknesses = new();

    // Drawer state
    private bool _specDrawerOpen = false;
    private ProductDto? _selectedProduct;

    // Quote Dialog state
    private bool _quoteDialogOpen = false;
    private bool _quoteSubmitted = false;
    private string _quoteSpec = string.Empty;
    private double _quoteQty = 5.0; // default to 5 MT
    private string _deliverySite = "Main Site (Godown A)";
    private string _quoteInstructions = string.Empty;

    public class CategorySummary
    {
        public string Name { get; set; } = string.Empty;
        public int Count { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadProductsData();
    }

    private async Task LoadProductsData()
    {
        _isLoading = true;
        try
        {
            // Call HTTP API
            AllProducts = await ProductService.GetProductsWithVariantsAsync();

            // FALLBACK SEED DATA (For robustness & standard showcase presentation)
            if (AllProducts == null || AllProducts.Count == 0)
            {
                AllProducts = GetMockProducts();
            }

            ExtractFilterOptions();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading catalog data: {ex.Message}", Severity.Warning);
            // Fallback so page works beautifully
            AllProducts = GetMockProducts();
            ExtractFilterOptions();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ExtractFilterOptions()
    {
        // Extract categories and item counts
        AvailableCategories = AllProducts
            .GroupBy(p => p.CategoryName)
            .Select(g => new CategorySummary { Name = g.Key, Count = g.Count() })
            .OrderBy(c => c.Name)
            .ToList();

        // Extract distinct sizes & thicknesses for filters
        DistinctSizes = AllProducts
            .SelectMany(p => p.Variants)
            .Select(v => v.Size)
            .Where(s => !string.IsNullOrWhiteSpace(s))
            .Distinct()
            .OrderBy(s => s)
            .ToList();

        DistinctThicknesses = AllProducts
            .SelectMany(p => p.Variants)
            .Select(v => v.Thickness)
            .Where(t => !string.IsNullOrWhiteSpace(t) && t != "N/A" && t != "-")
            .Distinct()
            .OrderBy(t => t)
            .ToList();
    }

    private void SelectCategory(string categoryName)
    {
        _selectedCategory = categoryName;
    }

    private void ToggleCategoryCheckbox(string categoryName, bool selected)
    {
        _selectedCategory = selected ? categoryName : string.Empty;
    }

    private void ResetFilters()
    {
        _searchQuery = string.Empty;
        _selectedCategory = string.Empty;
        _selectedSize = string.Empty;
        _selectedThickness = string.Empty;
        _onlyActive = true;
    }

    private bool HasActiveFilters => 
        !string.IsNullOrEmpty(_searchQuery) ||
        !string.IsNullOrEmpty(_selectedCategory) ||
        !string.IsNullOrEmpty(_selectedSize) ||
        !string.IsNullOrEmpty(_selectedThickness) ||
        !_onlyActive;

    private List<ProductDto> FilteredProducts
    {
        get
        {
            var query = AllProducts.AsEnumerable();

            // Filter active
            if (_onlyActive)
            {
                query = query.Where(p => p.IsActive);
            }

            // Filter category
            if (!string.IsNullOrEmpty(_selectedCategory))
            {
                query = query.Where(p => p.CategoryName.Equals(_selectedCategory, StringComparison.OrdinalIgnoreCase));
            }

            // Filter search query
            if (!string.IsNullOrWhiteSpace(_searchQuery))
            {
                query = query.Where(p => 
                    p.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) || 
                    p.CategoryName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    (p.HsnCode != null && p.HsnCode.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))
                );
            }

            // Filter size
            if (!string.IsNullOrEmpty(_selectedSize))
            {
                query = query.Where(p => p.Variants.Any(v => v.Size.Equals(_selectedSize, StringComparison.OrdinalIgnoreCase)));
            }

            // Filter thickness
            if (!string.IsNullOrEmpty(_selectedThickness))
            {
                query = query.Where(p => p.Variants.Any(v => v.Thickness.Equals(_selectedThickness, StringComparison.OrdinalIgnoreCase)));
            }

            return query.ToList();
        }
    }

    private string GetCategoryIcon(string categoryName)
    {
        return categoryName.ToLower() switch
        {
            "tmt bars" or "rebar" => Icons.Material.Filled.LinearScale,
            "hr sheets" or "sheets" or "plates" => Icons.Material.Filled.CropLandscape,
            "gi wire" or "wire" => Icons.Material.Filled.Waves,
            "structural steel" or "beams" or "channels" => Icons.Material.Filled.ViewAgenda,
            _ => Icons.Material.Filled.Layers
        };
    }

    // Spec Drawer Controls
    private void OpenSpecsDrawer(ProductDto prod)
    {
        _selectedProduct = prod;
        _specDrawerOpen = true;
    }

    private void CloseSpecsDrawer()
    {
        _specDrawerOpen = false;
    }

    // Quote Inquiry Controls
    private void OpenQuoteDialog(ProductDto prod)
    {
        _selectedProduct = prod;
        _quoteSubmitted = false;
        _quoteQty = 5.0;
        _deliverySite = "Main Site (Godown A)";
        _quoteInstructions = string.Empty;
        
        if (prod.Variants.Any())
        {
            var first = prod.Variants.First();
            _quoteSpec = string.IsNullOrEmpty(first.Thickness) ? first.Size : $"{first.Size} (Thickness: {first.Thickness})";
        }
        else
        {
            _quoteSpec = "Standard Spec";
        }

        _quoteDialogOpen = true;
    }

    private void CloseQuoteDialog()
    {
        _quoteDialogOpen = false;
    }

    private void SubmitQuoteRequest()
    {
        // Simulate RFQ registration
        _quoteSubmitted = true;
        Snackbar.Add("Commercial RFQ request generated successfully.", Severity.Success);
    }

    // Carousel Slider Scrolling emulation
    private void ScrollLeft()
    {
        // Simple client trigger (Blazor handles UI list rendering)
        Snackbar.Add("Scrolling category view left...", Severity.Info);
    }

    private void ScrollRight()
    {
        Snackbar.Add("Scrolling category view right...", Severity.Info);
    }

    // Standard high-quality mock data generator to guarantee gorgeous visual preview
    private List<ProductDto> GetMockProducts()
    {
        var list = new List<ProductDto>();

        // 1. TMT Bars
        var tmt = new ProductDto
        {
            Id = Guid.NewGuid(),
            Name = "12mm TMT Reinforcement Steel Rebar (Fe 500D)",
            CategoryName = "TMT Bars",
            HsnCode = "7214 2090",
            SellingUnit = VikashERP.SharedKernel.Enums.RateOn.Kg,
            IsActive = true,
            Variants = new List<ProductVariantDto>
            {
                new() { Id = Guid.NewGuid(), Size = "8mm", Thickness = "-", UnitPcsToKg = 4.74m, IsActive = true },
                new() { Id = Guid.NewGuid(), Size = "10mm", Thickness = "-", UnitPcsToKg = 7.40m, IsActive = true },
                new() { Id = Guid.NewGuid(), Size = "12mm", Thickness = "-", UnitPcsToKg = 10.66m, IsActive = true },
