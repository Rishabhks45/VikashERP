@page "/godown-dashboard"
@using VikashERP.Web.Models
@using VikashERP.Web.Services.Interfaces
@inject IInventoryWebService InventoryService

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6 mb-12">
    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2rem;">
        <div>
            <MudText Typo="Typo.h4" Style="font-weight: 800; color: var(--mud-palette-text-primary); letter-spacing: -0.5px;">Godown Dashboard</MudText>
            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary); margin-top: 0.25rem;">Live inventory tracking and stock alerts</MudText>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadData" StartIcon="@Icons.Material.Filled.Refresh" Style="border-radius: 8px; font-weight: 600; text-transform: none; letter-spacing: 0.5px;">Refresh Stock</MudButton>
    </div>

    @if (isLoading)
    {
        <div style="display:flex; justify-content:center; padding: 4rem;">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </div>
    }
    else
    {
        <!-- Metrics Row -->
        <MudGrid Class="mb-6">
            <!-- Total Active Items -->
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="1" Style="padding: 1.5rem; border-radius: 16px; background: linear-gradient(135deg, rgba(99,102,241,0.05), rgba(99,102,241,0.1)); border: 1px solid rgba(99,102,241,0.2);">
                    <div style="display: flex; align-items: center; gap: 1rem;">
                        <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large" Style="box-shadow: 0 4px 12px rgba(99,102,241,0.3);">
                            <MudIcon Icon="@Icons.Material.Filled.Inventory" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; font-size: 0.75rem;">Active Items</MudText>
                            <MudText Typo="Typo.h4" Style="font-weight: 800; color: var(--mud-palette-text-primary); line-height: 1.2;">@stockList.Count</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>

            <!-- Low Stock -->
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="1" Style="padding: 1.5rem; border-radius: 16px; background: linear-gradient(135deg, rgba(245,158,11,0.05), rgba(245,158,11,0.1)); border: 1px solid rgba(245,158,11,0.2);">
                    <div style="display: flex; align-items: center; gap: 1rem;">
                        <MudAvatar Color="Color.Warning" Variant="Variant.Filled" Size="Size.Large" Style="box-shadow: 0 4px 12px rgba(245,158,11,0.3);">
                            <MudIcon Icon="@Icons.Material.Filled.Warning" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; font-size: 0.75rem;">Low Stock Alerts</MudText>
                            <MudText Typo="Typo.h4" Style="font-weight: 800; color: var(--mud-palette-text-primary); line-height: 1.2;">@stockList.Count(x => x.StockStatus == "Low Stock")</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>

            <!-- Out of Stock -->
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="1" Style="padding: 1.5rem; border-radius: 16px; background: linear-gradient(135deg, rgba(239,68,68,0.05), rgba(239,68,68,0.1)); border: 1px solid rgba(239,68,68,0.2);">
                    <div style="display: flex; align-items: center; gap: 1rem;">
                        <MudAvatar Color="Color.Error" Variant="Variant.Filled" Size="Size.Large" Style="box-shadow: 0 4px 12px rgba(239,68,68,0.3);">
                            <MudIcon Icon="@Icons.Material.Filled.Error" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; font-size: 0.75rem;">Out of Stock</MudText>
                            <MudText Typo="Typo.h4" Style="font-weight: 800; color: var(--mud-palette-text-primary); line-height: 1.2;">@stockList.Count(x => x.StockStatus == "Out of Stock")</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- Data Grid -->
        <MudPaper Elevation="2" Style="border-radius: 16px; overflow: hidden; background: var(--mud-palette-surface);">
            <div style="padding: 1rem 1.5rem; border-bottom: 1px solid var(--mud-palette-lines-default); background: var(--mud-palette-background-grey); display:flex; justify-content:space-between; align-items:center;">
                <MudText Typo="Typo.h6" Style="font-weight: 700; font-size: 1.1rem;">Live Inventory List</MudText>
                <MudTextField @bind-Value="searchString" Placeholder="Search products..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Style="width: 300px; background: white; border-radius: 8px;" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true"></MudTextField>
            </div>
            
            <MudDataGrid Items="@stockList" Filterable="true" SortMode="SortMode.Multiple" Groupable="true" Hideable="true" QuickFilter="@quickFilter" Hover="true" Elevation="0" Class="godown-grid">
                <Columns>
                    <PropertyColumn Property="x => x.CategoryName" Title="Category" Grouping="true" />
                    <PropertyColumn Property="x => x.ProductName" Title="Product" />
                    <PropertyColumn Property="x => x.Size" Title="Size" />
                    <PropertyColumn Property="x => x.Thickness" Title="Thickness" />
                    
                    <TemplateColumn Title="Current Stock (Pcs)" HeaderStyle="text-align: right; font-weight: 700;" CellStyle="text-align: right;">
                        <CellTemplate>
                            <span style="font-weight: 700; font-size: 1rem; color: var(--mud-palette-text-primary);">@context.Item.RunningPcs</span>
                        </CellTemplate>
                    </TemplateColumn>
                    
                    <TemplateColumn Title="Current Stock (Kg)" HeaderStyle="text-align: right; font-weight: 700;" CellStyle="text-align: right;">
                        <CellTemplate>
                            <span style="font-weight: 700; font-size: 1rem; color: var(--mud-palette-text-primary);">@context.Item.RunningWeightKg.ToString("N2")</span>
                        </CellTemplate>
                    </TemplateColumn>
                    
                    <TemplateColumn Title="Status" HeaderStyle="text-align: center;" CellStyle="text-align: center;">
                        <CellTemplate>
                            @if (context.Item.StockStatus == "In Stock")
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Filled" Style="font-weight: 600; letter-spacing: 0.5px;">IN STOCK</MudChip>
                            }
                            else if (context.Item.StockStatus == "Low Stock")
                            {
                                <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Filled" Style="font-weight: 600; letter-spacing: 0.5px;">LOW STOCK</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Filled" Style="font-weight: 600; letter-spacing: 0.5px;">OUT OF STOCK</MudChip>
                            }
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="GodownStockDto" />
                </PagerContent>
            </MudDataGrid>
        </MudPaper>
    }
</MudContainer>

<style>
    .godown-grid .mud-table-head th {
        font-weight: 700 !important;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-size: 0.75rem;
        color: var(--mud-palette-text-secondary) !important;
        background: var(--mud-palette-background-grey) !important;
        border-bottom: 2px solid var(--mud-palette-lines-default) !important;
    }
    .godown-grid .mud-table-row {
        transition: background-color 0.2s ease;
    }
    .godown-grid .mud-table-row:hover {
        background-color: rgba(99,102,241,0.04) !important;
    }
    .godown-grid .mud-table-cell {
        padding: 12px 16px !important;
        border-bottom: 1px solid var(--mud-palette-lines-default) !important;
    }
</style>

@code {
    private bool isLoading = true;
    private List<GodownStockDto> stockList = new();
    private string searchString = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        stockList = await InventoryService.GetGodownStockAsync();
        isLoading = false;
    }

    private Func<GodownStockDto, bool> quickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;

        if (x.ProductName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (x.CategoryName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
            
        if (x.Size.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    };
}
