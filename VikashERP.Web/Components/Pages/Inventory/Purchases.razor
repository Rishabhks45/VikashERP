@page "/purchases"
@using VikashERP.Web.Models
@using VikashERP.Web.Services.Interfaces
@inject IPurchaseWebService PurchaseService
@inject NavigationManager NavigationManager
@inject INotificationService NotificationService
@rendermode InteractiveServer

<PageTitle>Purchase Entries</PageTitle>

<div style="padding: 0 0 2rem 0;">
    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
        <div>
            <h2 style="margin: 0 0 0.3rem 0; font-size: 1.6rem; font-weight: 700; color: var(--mud-palette-text-primary);">
                <span style="background: linear-gradient(135deg, #6366f1, #8b5cf6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
                    Purchase Entries
                </span>
            </h2>
            <p style="margin: 0; color: var(--mud-palette-text-secondary); font-size: 0.875rem;">Manage incoming stock and supplier invoices</p>
        </div>
        <button @onclick="AddNewPurchase"
                style="background: linear-gradient(135deg, #6366f1, #8b5cf6); color: white; border: none; padding: 0.6rem 1.4rem; border-radius: 10px; font-weight: 600; font-size: 0.875rem; cursor: pointer; display: flex; align-items: center; gap: 0.5rem; box-shadow: 0 4px 15px rgba(99,102,241,0.35); transition: all 0.2s ease;">
            <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
            New Purchase Entry
        </button>
    </div>

    @if (purchases == null)
    {
        <!-- Loading -->
        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 5rem 0; gap: 1rem;">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <p style="color: var(--mud-palette-text-secondary); margin: 0;">Loading purchase entries...</p>
        </div>
    }
    else if (!purchases.Any())
    {
        <!-- Empty State -->
        <div style="border-radius: 16px; border: 1px solid var(--mud-palette-lines-default); padding: 4rem 2rem; text-align: center; background: var(--mud-palette-surface);">
            <div style="width: 80px; height: 80px; background: linear-gradient(135deg, rgba(99,102,241,0.1), rgba(139,92,246,0.1)); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem auto;">
                <MudIcon Icon="@Icons.Material.Outlined.Receipt" Style="font-size: 2.5rem; color: #6366f1;" />
            </div>
            <h4 style="margin: 0 0 0.5rem 0; color: var(--mud-palette-text-primary); font-weight: 600;">No Purchase Entries Found</h4>
            <p style="margin: 0 0 1.5rem 0; color: var(--mud-palette-text-secondary); font-size: 0.875rem;">Start managing your stock by adding your first purchase invoice.</p>
            <button @onclick="AddNewPurchase"
                    style="background: linear-gradient(135deg, #6366f1, #8b5cf6); color: white; border: none; padding: 0.6rem 1.4rem; border-radius: 10px; font-weight: 600; cursor: pointer;">
                + Add Purchase Entry
            </button>
        </div>
    }
    else
    {
        <!-- Table -->
        <div style="border-radius: 16px; border: 1px solid var(--mud-palette-lines-default); overflow: hidden; background: var(--mud-palette-surface); box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
            <table style="width: 100%; border-collapse: collapse; font-size: 0.875rem;">
                <thead>
                    <tr style="background: var(--mud-palette-background-grey);">
                        <th style="padding: 1rem 1.25rem; text-align: left; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--mud-palette-text-secondary); white-space: nowrap;">Entry No.</th>
                        <th style="padding: 1rem 1.25rem; text-align: left; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--mud-palette-text-secondary);">Date</th>
                        <th style="padding: 1rem 1.25rem; text-align: left; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--mud-palette-text-secondary);">Supplier</th>
                        <th style="padding: 1rem 1.25rem; text-align: left; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--mud-palette-text-secondary);">Invoice No.</th>
                        <th style="padding: 1rem 1.25rem; text-align: right; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--mud-palette-text-secondary);">Amount</th>
                        <th style="padding: 1rem 1.25rem; text-align: center; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--mud-palette-text-secondary);">Status</th>
                        <th style="padding: 1rem 1.25rem; text-align: right; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--mud-palette-text-secondary);">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var purchase in purchases)
                    {
                        <tr style="border-top: 1px solid var(--mud-palette-lines-default); transition: background 0.15s;"
                            @onmouseover="@(e => { })" @onmouseout="@(e => { })">
                            <td style="padding: 1rem 1.25rem; font-weight: 600; color: var(--mud-palette-text-primary);">@purchase.EntryNumber</td>
                            <td style="padding: 1rem 1.25rem; color: var(--mud-palette-text-secondary);">@purchase.InvoiceDate.ToString("dd MMM yyyy")</td>
                            <td style="padding: 1rem 1.25rem;">
                                <div style="display: flex; align-items: center; gap: 0.75rem;">
                                    <div style="width: 34px; height: 34px; border-radius: 50%; background: linear-gradient(135deg, rgba(99,102,241,0.15), rgba(139,92,246,0.15)); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.85rem; color: #6366f1; flex-shrink: 0;">
                                        @purchase.SupplierName.FirstOrDefault()
                                    </div>
                                    <span style="font-weight: 500; color: var(--mud-palette-text-primary);">@purchase.SupplierName</span>
                                </div>
                            </td>
                            <td style="padding: 1rem 1.25rem; color: var(--mud-palette-text-secondary);">@purchase.InvoiceNumber</td>
                            <td style="padding: 1rem 1.25rem; text-align: right; font-weight: 700; color: var(--mud-palette-text-primary);">₹@purchase.NetAmount.ToString("N2")</td>
                            <td style="padding: 1rem 1.25rem; text-align: center;">
                                @if (purchase.Status == VikashERP.SharedKernel.Enums.PurchaseEntryStatus.Approved)
                                {
                                    <span style="background: rgba(34,197,94,0.12); color: #16a34a; border: 1px solid rgba(34,197,94,0.25); border-radius: 20px; padding: 0.3rem 0.85rem; font-size: 0.75rem; font-weight: 600; white-space: nowrap;">
                                        ✓ Approved
                                    </span>
                                }
                                else
                                {
                                    <span style="background: rgba(234,179,8,0.12); color: #b45309; border: 1px solid rgba(234,179,8,0.25); border-radius: 20px; padding: 0.3rem 0.85rem; font-size: 0.75rem; font-weight: 600; white-space: nowrap;">
                                        ✎ Draft
                                    </span>
                                }
                            </td>
                            <td style="padding: 1rem 1.25rem; text-align: right;">
                                <div style="display: flex; justify-content: flex-end; gap: 0.5rem;">
                                    <MudIconButton Icon="@Icons.Material.Outlined.Visibility" Size="Size.Small" Color="Color.Primary"
                                                   OnClick="@(() => ViewPurchase(purchase.Id))" Title="View Details" />
                                    @if (purchase.Status == VikashERP.SharedKernel.Enums.PurchaseEntryStatus.Draft)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Outlined.CheckCircle" Size="Size.Small" Color="Color.Success"
                                                       OnClick="@(() => ApprovePurchase(purchase.Id))" Title="Approve" />
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<PurchaseEntryDto>? purchases;

    protected override async Task OnInitializedAsync()
    {
        await LoadPurchasesAsync();
    }

    private async Task LoadPurchasesAsync()
    {
        try
        {
            purchases = await PurchaseService.GetPurchaseEntriesAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Error($"Error loading purchases: {ex.Message}");
            purchases = new List<PurchaseEntryDto>();
        }
    }

    private void AddNewPurchase() => NavigationManager.NavigateTo("/purchases/new");
    private void ViewPurchase(Guid id) => NavigationManager.NavigateTo($"/purchases/view/{id}");

    private async Task ApprovePurchase(Guid id)
    {
        try
        {
            var success = await PurchaseService.ApprovePurchaseEntryAsync(id);
            if (success)
            {
                NotificationService.Success("Purchase entry approved successfully.");
                await LoadPurchasesAsync();
            }
            else
            {
                NotificationService.Error("Failed to approve purchase entry.");
            }
        }
        catch (Exception ex)
        {
            NotificationService.Error($"Error: {ex.Message}");
        }
    }
}
