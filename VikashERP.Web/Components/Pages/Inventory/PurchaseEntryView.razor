@page "/purchases/view/{Id:guid}"
@using VikashERP.Web.Models;
@using VikashERP.Web.Services.Interfaces
@using VikashERP.SharedKernel.Enums
@inject IPurchaseWebService PurchaseService
@inject NavigationManager NavigationManager
@inject INotificationService NotificationService
@rendermode InteractiveServer

<PageTitle>View Purchase Entry</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6 mb-16">
    <!-- Header Area -->
    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
        <div>
            <MudText Typo="Typo.h4" Class="fw-bold" Style="color: var(--mud-palette-primary-darken);">
                <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Size="Size.Large" Class="mr-2" Style="vertical-align: sub;" />
                Purchase Invoice @purchaseDto?.InvoiceNumber
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">View details of the purchase entry</MudText>
        </div>
        <div style="display: flex; gap: 0.5rem;">
            @if (purchaseDto != null && purchaseDto.Status == VikashERP.SharedKernel.Enums.PurchaseEntryStatus.Draft)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="ApprovePurchase" StartIcon="@Icons.Material.Filled.CheckCircle" Style="border-radius: 8px; font-weight: 600;">
                    Approve Entry
                </MudButton>
            }
            <MudButton Variant="Variant.Outlined" Color="Color.Dark" OnClick="GoBack" StartIcon="@Icons.Material.Filled.ArrowBack" Style="border-radius: 8px; font-weight: 600;">
                Back
            </MudButton>
        </div>
    </div>

    @if (purchaseDto == null)
    {
        if (isLoading)
        {
            <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 5rem 0;">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-4">Loading details...</MudText>
            </div>
        }
        else
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mt-4">Entry not found.</MudAlert>
        }
    }
    else
    {
        <MudGrid Spacing="3">
            <!-- Left Side: Summary -->
            <MudItem xs="12" md="4">
                <MudCard Elevation="2" Style="border-radius: 12px; height: 100%;">
                    <MudCardHeader Style="border-bottom: 1px solid var(--mud-palette-lines-default); padding-bottom: 8px;">
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Class="fw-bold">Invoice Summary</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 12px;">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Status</MudText>
                            @if (purchaseDto.Status == VikashERP.SharedKernel.Enums.PurchaseEntryStatus.Approved)
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Filled">Approved</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Filled">Draft</MudChip>
                            }
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 12px;">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Entry Number</MudText>
                            <MudText Typo="Typo.body2" Class="fw-bold">@purchaseDto.EntryNumber</MudText>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 12px;">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Supplier</MudText>
                            <MudText Typo="Typo.body2" Class="fw-bold">@purchaseDto.SupplierName</MudText>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 12px;">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Invoice No</MudText>
                            <MudText Typo="Typo.body2" Class="fw-bold">@purchaseDto.InvoiceNumber</MudText>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 12px;">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Invoice Date</MudText>
                            <MudText Typo="Typo.body2" Class="fw-bold">@purchaseDto.InvoiceDate.ToString("dd MMM yyyy")</MudText>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 12px;">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Vehicle No</MudText>
                            <MudText Typo="Typo.body2" Class="fw-bold">@(string.IsNullOrEmpty(purchaseDto.VehicleNumber) ? "-" : purchaseDto.VehicleNumber)</MudText>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 24px;">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Remarks</MudText>
                            <MudText Typo="Typo.body2" Class="fw-bold">@(string.IsNullOrEmpty(purchaseDto.Remarks) ? "-" : purchaseDto.Remarks)</MudText>
                        </div>
                        
                        <MudDivider Class="mb-4" />
                        
                        <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Items Total</MudText>
                            <MudText Typo="Typo.body2" Class="fw-bold">₹@purchaseDto.TotalAmount.ToString("N2")</MudText>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Freight</MudText>
                            <MudText Typo="Typo.body2" Class="fw-bold">₹@purchaseDto.FreightCharge.ToString("N2")</MudText>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 16px;">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Loading</MudText>
                            <MudText Typo="Typo.body2" Class="fw-bold">₹@purchaseDto.LoadingCharge.ToString("N2")</MudText>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Taxes (CGST+SGST)</MudText>
                            <MudText Typo="Typo.body2" Class="fw-bold">₹@((purchaseDto.CgstAmount + purchaseDto.SgstAmount).ToString("N2"))</MudText>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 16px;">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Rounding</MudText>
                            <MudText Typo="Typo.body2" Class="fw-bold">₹@purchaseDto.RoundingAmount.ToString("N2")</MudText>
                        </div>
                        
                        <div style="display: flex; justify-content: space-between; align-items: center; background: rgba(99,102,241,0.05); padding: 12px; border-radius: 8px;">
                            <MudText Typo="Typo.subtitle1" Class="fw-bold" Color="Color.Primary">Net Amount</MudText>
                            <MudText Typo="Typo.h6" Class="fw-bold" Color="Color.Primary">₹@purchaseDto.NetAmount.ToString("N2")</MudText>
                        </div>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Right Side: Items -->
            <MudItem xs="12" md="8">
                <MudCard Elevation="2" Style="border-radius: 12px; height: 100%;">
                    <MudCardHeader Style="border-bottom: 1px solid var(--mud-palette-lines-default); padding-bottom: 8px;">
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Class="fw-bold">Purchased Items</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        <MudTable Items="@purchaseDto.Items" Hover="true" Dense="false" Elevation="0">
                            <HeaderContent>
                                <MudTh><MudText Typo="Typo.subtitle2" Class="fw-bold text-muted">Product Variant</MudText></MudTh>
                                <MudTh Style="text-align: right;"><MudText Typo="Typo.subtitle2" Class="fw-bold text-muted">Qty (Pcs)</MudText></MudTh>
                                <MudTh Style="text-align: right;"><MudText Typo="Typo.subtitle2" Class="fw-bold text-muted">Weight (Kg)</MudText></MudTh>
                                <MudTh Style="text-align: right;"><MudText Typo="Typo.subtitle2" Class="fw-bold text-muted">Rate</MudText></MudTh>
                                <MudTh Style="text-align: right;"><MudText Typo="Typo.subtitle2" Class="fw-bold text-muted">Total Amount</MudText></MudTh>
                            </HeaderContent>
                            <RowTemplate Context="item">
                                <MudTd DataLabel="Product Variant">
                                    <MudText Typo="Typo.body2" Class="fw-bold">@item.ProductName</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@item.VariantSize</MudText>
                                </MudTd>
                                <MudTd DataLabel="Qty (Pcs)" Style="text-align: right;">
                                    @if (item.RateOn == RateOn.Pcs)
                                    {
                                        <MudText Typo="Typo.body2">@item.QuantityPcs</MudText>
                                    }
                                    else
                                    {
                                        <span style="opacity: 0.5;">-</span>
                                    }
                                </MudTd>
                                <MudTd DataLabel="Weight (Kg)" Style="text-align: right;">
                                    @if (item.RateOn == RateOn.Kg)
                                    {
                                        <MudText Typo="Typo.body2">@item.WeightKg</MudText>
                                    }
                                    else
                                    {
                                        <span style="opacity: 0.5;">-</span>
                                    }
                                </MudTd>
                                <MudTd DataLabel="Rate" Style="text-align: right;">
                                    <MudText Typo="Typo.body2">₹@item.Rate.ToString("N2") / @item.RateOn.ToString()</MudText>
                                </MudTd>
                                <MudTd DataLabel="Total Amount" Style="text-align: right;">
                                    <MudText Typo="Typo.body2" Class="fw-bold">₹@item.TotalPrice.ToString("N2")</MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private PurchaseEntryDto? purchaseDto;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadPurchaseAsync();
    }

    private async Task LoadPurchaseAsync()
    {
        try
        {
            isLoading = true;
            purchaseDto = await PurchaseService.GetPurchaseEntryByIdAsync(Id);
        }
        catch (Exception ex)
        {
            NotificationService.Error($"Error loading purchase details: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ApprovePurchase()
    {
        try
        {
            var success = await PurchaseService.ApprovePurchaseEntryAsync(Id);
            if (success)
            {
                NotificationService.Success("Purchase entry approved and posted to ledgers successfully.");
                await LoadPurchaseAsync();
            }
            else
            {
                NotificationService.Error("Failed to approve purchase entry.");
            }
        }
        catch (Exception ex)
        {
            NotificationService.Error($"Error: {ex.Message}");
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/purchases");
    }
}


