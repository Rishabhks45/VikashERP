    protected override async Task OnInitializedAsync()
    {
        var authState = await authStateTask;
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            _userName = authState.User.FindFirst(ClaimTypes.Name)?.Value 
                ?? authState.User.FindFirst("name")?.Value 
                ?? "Customer";
        }
    }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(TabQuery))
        {
            _currentTab = TabQuery;
        }
        else
        {
            _currentTab = "home";
        }

        if (SearchQuery != null)
        {
            _searchQuery = SearchQuery;
        }
    }

    private void ToggleTab(string tab)
    {
        _currentTab = tab;
        _quoteSubmitted = false;
    }

    private void ToggleTheme()
    {
        DarkModeService.ToggleAsync();
    }

    private void FilterByCategorySlider(string category)
    {
        _selectedCategorySlider = category;
        _selectedCategory = category;
    }

    private void ApplyFiltersTrigger()
    {
        Snackbar.Add("Filters Applied Successfully.", Severity.Success);
    }

    private void ResetFilters()
    {
        _selectedCategorySlider = string.Empty;
        _selectedCategory = string.Empty;
        _selectedGrade = string.Empty;
        _selectedSize = string.Empty;
        _selectedBrand = string.Empty;
        _maxPrice = 100000;
        _searchQuery = string.Empty;
        _showWishlistOnly = false;
        Snackbar.Add("All Filters Reset.", Severity.Info);
    }

    private List<CustomerProduct> FilteredCatalogProducts
    {
        get
        {
            var query = CatalogProducts.AsEnumerable();

            // Filter category
            if (!string.IsNullOrEmpty(_selectedCategory))
            {
                query = query.Where(p => p.Category.Equals(_selectedCategory, StringComparison.OrdinalIgnoreCase));
            }

            // Filter search query
            if (!string.IsNullOrWhiteSpace(_searchQuery))
            {
                query = query.Where(p => 
                    p.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    p.Category.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    p.Grade.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)
                );
            }

            // Filter grade
            if (!string.IsNullOrEmpty(_selectedGrade))
            {
                query = query.Where(p => p.Grade.Contains(_selectedGrade, StringComparison.OrdinalIgnoreCase));
            }

            // Filter size
            if (!string.IsNullOrEmpty(_selectedSize))
            {
                query = query.Where(p => p.Name.Contains(_selectedSize, StringComparison.OrdinalIgnoreCase));
            }

            // Filter price
            query = query.Where(p => p.Price <= _maxPrice);

            // Filter wishlist
            if (_showWishlistOnly)
            {
                query = query.Where(p => _wishlistedProductNames.Contains(p.Name));
            }

            // Sorting
            if (_sortOrder == "price-asc")
            {
                query = query.OrderBy(p => p.Price);
            }
            else if (_sortOrder == "price-desc")
            {
                query = query.OrderByDescending(p => p.Price);
            }

            return query.ToList();
        }
    }

    private void ToggleWishlist(string name)
    {
        if (_wishlistedProductNames.Contains(name))
        {
            _wishlistedProductNames.Remove(name);
            Snackbar.Add($"{name} removed from your wishlist.", Severity.Info);
        }
        else
        {
            _wishlistedProductNames.Add(name);
            Snackbar.Add($"{name} added to your wishlist.", Severity.Success);
        }
    }

    private void AddToCart(string name)
    {
        _cartCount++;
        Snackbar.Add($"{name} added to your inquiry cart.", Severity.Success);
    }

    private void OpenCartInfo()
    {
        Snackbar.Add($"Your cart has {_cartCount} inquiry items. Proceeding to Request Quote.", Severity.Info);
        ToggleTab("rfq");
    }

    private void OpenProductDetails(CustomerProduct prod)
    {
        _selectedProduct = prod;
        _detailsDrawerOpen = true;
    }

    private void CloseDetailsDrawer()
    {
        _detailsDrawerOpen = false;
    }

    private void BuyProductDirect(string name)
    {
        _detailsDrawerOpen = false;
        AddToCart(name);
        ToggleTab("rfq");
    }

    private void OnQuoteCategoryChanged(ChangeEventArgs e)
    {
        var category = e.Value?.ToString() ?? "TMT Bars";
        _quoteCategory = category;
        if (category == "TMT Bars")
            _quoteSpec = "12mm TMT Bar (Fe 500D)";
        else if (category == "MS Pipes")
            _quoteSpec = "MS Square Pipe 40x40 (IS 4923)";
        else if (category == "MS Angles")
            _quoteSpec = "MS Angle 50x50x6 (IS 2062)";
        else if (category == "CRC Sheets")
            _quoteSpec = "CRC Sheet 1.2mm (IS 513)";
        else
            _quoteSpec = "GI Corrugated Sheet (0.50mm)";
    }

    private void SubmitBulkQuote()
    {
        _quoteSubmitted = true;
        _randomRfqId = Random.Shared.Next(1000, 9999);
        Snackbar.Add("Bulk Quotation RFQ Generated Successfully.", Severity.Success);
    }

