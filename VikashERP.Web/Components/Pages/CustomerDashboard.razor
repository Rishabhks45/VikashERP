@page "/customer-dashboard"
@attribute [Authorize]
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using VikashERP.Web.Models
@using VikashERP.Web.Services.Interfaces
@inject IDarkModeService DarkModeService
@inject IProductWebService ProductService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Customer Storefront & Portal - Vikash Iron & Steel</PageTitle>

<div class="customer-portal-container">

    @if (_currentTab == "home")
    {
        <!-- ── HERO BANNER ── -->
        <section class="portal-hero">
            <img src="uploads/images/steel_pipes_banner.jpg" class="hero-bg-img" alt="Vikash Iron &amp; Steel Products" />
            <div class="hero-overlay-gradient"></div>
            <div class="hero-glow-bg"></div>
            <div class="hero-left-content">
                <span class="hero-trusted-badge">🛡️ Trusted Steel Partner</span>
                <h1 class="hero-title-main">Premium Steel Products<br />Direct From <span>Vikash Iron &amp; Steel</span></h1>
                <p class="hero-sub-text">High Quality • Best Prices • On Time Delivery</p>
                
                <div class="hero-badge-grid">
                    <div class="hero-badge-item">
                        <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Class="icon" />
                        <div class="txt">
                            <span class="main-lbl">Genuine Material</span>
                            <span class="sub-lbl">100% Certified</span>
                        </div>
                    </div>
                    <div class="hero-badge-item">
                        <MudIcon Icon="@Icons.Material.Filled.CurrencyExchange" Class="icon" />
                        <div class="txt">
                            <span class="main-lbl">Best Market Rates</span>
                            <span class="sub-lbl">Competitive Pricing</span>
                        </div>
                    </div>
                    <div class="hero-badge-item">
                        <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Class="icon" />
                        <div class="txt">
                            <span class="main-lbl">Fast Delivery</span>
                            <span class="sub-lbl">Pan India Delivery</span>
                        </div>
                    </div>
                    <div class="hero-badge-item">
                        <MudIcon Icon="@Icons.Material.Filled.Receipt" Class="icon" />
                        <div class="txt">
                            <span class="main-lbl">GST Billing</span>
                            <span class="sub-lbl">Invoice on Every Order</span>
                        </div>
                    </div>
                </div>

                <div class="hero-actions-row">
                    <button class="btn-hero-primary" @onclick="ScrollToProducts">
                        Explore Products <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                    </button>
                    <button class="btn-hero-secondary" @onclick='() => ToggleTab("rfq")'>
                        <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" /> Get Quotation
                    </button>
                </div>
            </div>
        </section>

        <!-- ── STATS COUNTER ROW ── -->
        <section class="stats-counter-row">
            <div class="stat-card-item">
                <div class="stat-icon-wrap">
                    <MudIcon Icon="@Icons.Material.Filled.Layers" Size="Size.Small" />
                </div>
                <div class="stat-text-wrap">
                    <span class="stat-value">1200+</span>
                    <span class="stat-lbl">Products</span>
                </div>
            </div>
            <div class="stat-card-item">
                <div class="stat-icon-wrap">
                    <MudIcon Icon="@Icons.Material.Filled.WorkspacePremium" Size="Size.Small" />
                </div>
                <div class="stat-text-wrap">
                    <span class="stat-value">50+</span>
                    <span class="stat-lbl">Brands</span>
                </div>
            </div>
            <div class="stat-card-item">
                <div class="stat-icon-wrap">
                    <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Small" />
                </div>
                <div class="stat-text-wrap">
                    <span class="stat-value">5000+</span>
                    <span class="stat-lbl">Happy Clients</span>
                </div>
            </div>
            <div class="stat-card-item">
                <div class="stat-icon-wrap">
                    <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Small" />
                </div>
                <div class="stat-text-wrap">
                    <span class="stat-value">Same Day</span>
                    <span class="stat-lbl">Dispatch</span>
                </div>
            </div>
            <div class="stat-card-item">
                <div class="stat-icon-wrap">
                    <MudIcon Icon="@Icons.Material.Filled.FactCheck" Size="Size.Small" />
                </div>
                <div class="stat-text-wrap">
                    <span class="stat-value">Quality</span>
                    <span class="stat-lbl">Assured</span>
                </div>
            </div>
            <div class="stat-card-item">
                <div class="stat-icon-wrap">
                    <MudIcon Icon="@Icons.Material.Filled.HeadsetMic" Size="Size.Small" />
                </div>
                <div class="stat-text-wrap">
                    <span class="stat-value">24x7</span>
                    <span class="stat-lbl">Support</span>
                </div>
            </div>
        </section>

        <!-- ── CATEGORY TAB SLIDER ── -->
        <section class="category-slider-row" id="product-listing-section">
            <button class="slider-tab-btn @(string.IsNullOrEmpty(_selectedCategorySlider) ? "active" : "")" @onclick="() => FilterByCategorySlider(string.Empty)">
                <span class="tab-icon">📋</span> All Products
            </button>
            <button class="slider-tab-btn @(_selectedCategorySlider == "TMT Bars" ? "active" : "")" @onclick='() => FilterByCategorySlider("TMT Bars")'>
                <span class="tab-icon">⛓️</span> TMT Bars
            </button>
            <button class="slider-tab-btn @(_selectedCategorySlider == "MS Pipes" ? "active" : "")" @onclick='() => FilterByCategorySlider("MS Pipes")'>
                <span class="tab-icon">🛢️</span> MS Pipes
            </button>
            <button class="slider-tab-btn @(_selectedCategorySlider == "MS Angles" ? "active" : "")" @onclick='() => FilterByCategorySlider("MS Angles")'>
                <span class="tab-icon">📐</span> MS Angles
            </button>
            <button class="slider-tab-btn @(_selectedCategorySlider == "MS Channels" ? "active" : "")" @onclick='() => FilterByCategorySlider("MS Channels")'>
                <span class="tab-icon">🧱</span> MS Channels
            </button>
            <button class="slider-tab-btn @(_selectedCategorySlider == "MS Flats" ? "active" : "")" @onclick='() => FilterByCategorySlider("MS Flats")'>
                <span class="tab-icon">📏</span> MS Flats
            </button>
            <button class="slider-tab-btn @(_selectedCategorySlider == "MS Plates" ? "active" : "")" @onclick='() => FilterByCategorySlider("MS Plates")'>
                <span class="tab-icon">🎴</span> MS Plates
            </button>
            <button class="slider-tab-btn @(_selectedCategorySlider == "GP Sheets" ? "active" : "")" @onclick='() => FilterByCategorySlider("GP Sheets")'>
                <span class="tab-icon">🗺️</span> GP Sheets
            </button>
            <button class="slider-tab-btn @(_selectedCategorySlider == "CRC Sheets" ? "active" : "")" @onclick='() => FilterByCategorySlider("CRC Sheets")'>
                <span class="tab-icon">💿</span> CRC Sheets
            </button>
            <button class="slider-tab-btn @(_selectedCategorySlider == "GI Pipes" ? "active" : "")" @onclick='() => FilterByCategorySlider("GI Pipes")'>
                <span class="tab-icon">🚰</span> GI Pipes
            </button>
            <button class="slider-tab-btn @(_selectedCategorySlider == "Wire & Rod" ? "active" : "")" @onclick='() => FilterByCategorySlider("Wire & Rod")'>
                <span class="tab-icon">🌀</span> Wire &amp; Rod
            </button>
        </section>

        <!-- ── MAIN CATALOG WORKSPACE ── -->
        <section class="catalog-workspace">
            <!-- Left Sidebar Filters -->
            <aside class="filter-sidebar">
                <div class="filter-title-row">
                    <span class="filter-title">Filters</span>
                    <button class="btn-clear-filters" @onclick="ResetFilters">Clear All</button>
                </div>

                <div class="filter-field-group">
                    <label>Category</label>
                    <select class="filter-input-select" @bind="_selectedCategory">
                        <option value="">All Categories</option>
                        <option value="TMT Bars">TMT Bars</option>
                        <option value="MS Pipes">MS Pipes</option>
                        <option value="MS Angles">MS Angles</option>
                        <option value="CRC Sheets">CRC Sheets</option>
                        <option value="GI Pipes">GI Pipes</option>
                        <option value="Wire & Rod">Wire &amp; Rod</option>
                    </select>
                </div>

                <div class="filter-field-group">
                    <label>Grade</label>
                    <select class="filter-input-select" @bind="_selectedGrade">
                        <option value="">All Grades</option>
                        <option value="Fe 500D">Fe 500D</option>
                        <option value="IS 4923 • YST 310">IS 4923 • YST 310</option>
                        <option value="IS 2062 • E250">IS 2062 • E250</option>
                        <option value="IS 513 • CRCA">IS 513 • CRCA</option>
                        <option value="IS 1239 • Grade E">IS 1239 • Grade E</option>
                        <option value="0.50mm • Zinc Coated">0.50mm • Zinc Coated</option>
                    </select>
                </div>

                <div class="filter-field-group">
                    <label>Size / Thickness</label>
                    <select class="filter-input-select" @bind="_selectedSize">
                        <option value="">All Sizes</option>
                        <option value="12mm">12mm</option>
                        <option value="40x40">40x40</option>
                        <option value="50x50x6">50x50x6</option>
                        <option value="1.2mm">1.2mm</option>
                        <option value="1 inch">1 inch</option>
                        <option value="Standard">Standard</option>
                    </select>
                </div>

                <div class="filter-field-group">
                    <label>Brand</label>
                    <select class="filter-input-select" @bind="_selectedBrand">
                        <option value="">All Brands</option>
                        <option value="Vikash Premium">Vikash Premium</option>
                        <option value="Tata Steel">Tata Steel</option>
                        <option value="SAIL">SAIL</option>
                        <option value="Jindal Star">Jindal Star</option>
                    </select>
                </div>

                <div class="filter-field-group">
                    <label>Price Range (₹/Ton)</label>
                    <input type="range" min="10000" max="120000" step="5000" @bind-value="_maxPrice" @bind-value:event="oninput" style="width: 100%; cursor: pointer;" />
                    <div class="price-range-text">
                        <span>₹ 10k</span>
                        <span>₹ @_maxPrice.ToString("N0")</span>
                    </div>
                </div>

                <div class="filter-field-group wishlist-filter-group">
                    <label class="wishlist-checkbox-label">
                        <input type="checkbox" @bind="_showWishlistOnly" class="wishlist-checkbox-input" />
                        <span>Show Wishlist Only</span>
                        <MudIcon Icon="@Icons.Material.Filled.Favorite" Size="Size.Small" Color="Color.Error" />
                    </label>
                </div>

                <button class="btn-apply-filters" @onclick="ApplyFiltersTrigger">Apply Filters</button>
            </aside>

            <!-- Right Content Area -->
            <main class="catalog-content-area">
                <div class="catalog-results-header">
                    <span class="results-count">All Products <span class="text-slate-500" style="font-weight: 500;">(@FilteredCatalogProducts.Count Products Found)</span></span>
                    
                    <div class="catalog-sort-wrap">
                        <span>Sort By</span>
                        <select class="sort-select" @bind="_sortOrder">
                            <option value="popular">Popularity</option>
                            <option value="price-asc">Price: Low to High</option>
                            <option value="price-desc">Price: High to Low</option>
                        </select>
                    </div>
                </div>

                @if (FilteredCatalogProducts.Count == 0)
                {
                    <div class="portal-empty-state">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory" Class="icon" />
                        <h3>No Products Found</h3>
                        <p>Try clearing or adjusting filters to discover premium steel products.</p>
                        <button class="btn-hero-secondary mt-2" @onclick="ResetFilters">Reset Filters</button>
                    </div>
                }
                else
                {
                    <div class="product-cards-grid">
                        @foreach (var prod in FilteredCatalogProducts)
                        {
                            <div class="product-display-card">
                                <!-- Image wrapper -->
                                <div class="card-image-wrap">
                                    @if (!string.IsNullOrEmpty(prod.Badge))
                                    {
                                        <span class="card-badge @prod.Badge.Replace(" ", "").ToLower()">@prod.Badge</span>
                                    }
                                    <button class="btn-wishlist @(_wishlistedProductNames.Contains(prod.Name) ? "active" : "")" @onclick="() => ToggleWishlist(prod.Name)">
                                        <MudIcon Icon="@(_wishlistedProductNames.Contains(prod.Name) ? Icons.Material.Filled.Favorite : Icons.Material.Filled.FavoriteBorder)" Size="Size.Small" />
                                    </button>
                                    
                                    @if (!string.IsNullOrEmpty(prod.ImageUrl))
                                    {
                                        <img src="@prod.ImageUrl" alt="@prod.Name" class="card-product-img" />
                                    }
                                    else
                                    {
                                        <div class="card-placeholder-bg">
                                            <MudIcon Icon="@Icons.Material.Filled.Hardware" Class="icon" />
                                        </div>
                                    }
                                </div>

                                <!-- Body -->
                                <div class="card-details-body">
                                    <h3 class="card-prod-title">@prod.Name</h3>
                                    <span class="card-prod-grade">@prod.Grade</span>

                                    <div class="card-price-row">
                                        <span class="card-price-value">₹ @prod.Price.ToString("N0")</span>
                                        <span class="card-price-unit">/ @prod.Unit</span>
                                    </div>

                                    <div class="card-stock-row">
                                        <span class="stock-dot @prod.StockStatus.Replace(" ", "").ToLower()"></span>
                                        <span class="stock-label @(prod.StockStatus == "Low Stock" ? "orange-text" : prod.StockStatus == "Out of Stock" ? "red-text" : "text-success")">@prod.StockStatus</span>
                                        <span class="stock-qty">(@prod.StockQtyText)</span>
                                    </div>
                                </div>

                                <!-- Actions -->
                                <div class="card-actions-row">
                                    <button class="btn-card-details" @onclick="() => OpenProductDetails(prod)">View Details</button>
                                    <button class="btn-card-cart" @onclick="() => AddToCart(prod.Name)">
                                        <MudIcon Icon="@Icons.Material.Filled.AddShoppingCart" Size="Size.Small" />
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </main>
        </section>

        <!-- ── BOTTOM MARKETING ROW ── -->
        <section class="bottom-marketing-row">
            <div class="marketing-item">
                <MudIcon Icon="@Icons.Material.Filled.CurrencyExchange" Class="marketing-icon" />
                <div class="marketing-text">
                    <span class="marketing-title">Best Market Price</span>
                    <span class="marketing-desc">Always Competitive</span>
                </div>
            </div>
            <div class="marketing-item">
                <MudIcon Icon="@Icons.Material.Filled.Verified" Class="marketing-icon" />
                <div class="marketing-text">
                    <span class="marketing-title">Genuine Quality</span>
                    <span class="marketing-desc">100% Certified Material</span>
                </div>
            </div>
            <div class="marketing-item">
                <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Class="marketing-icon" />
                <div class="marketing-text">
                    <span class="marketing-title">Timely Delivery</span>
                    <span class="marketing-desc">Pan India Network</span>
                </div>
            </div>
            <div class="marketing-item">
                <MudIcon Icon="@Icons.Material.Filled.Security" Class="marketing-icon" />
                <div class="marketing-text">
                    <span class="marketing-title">Secure Payments</span>
                    <span class="marketing-desc">100% Safe Transactions</span>
                </div>
            </div>
        </section>

        <!-- ── BULK QUOTE BANNER ── -->
        <section class="bulk-quote-banner">
            <div class="bulk-text-side">
                <span class="bulk-title">Need Bulk Quantity?</span>
                <span class="bulk-desc">Get special discounts for contractors &amp; bulk orders</span>
            </div>
            <button class="btn-bulk-quote" @onclick='() => ToggleTab("rfq")'>
                Request Bulk Quote <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
            </button>
        </section>
    }
    else if (_currentTab == "account")
    {
        <!-- ── MY ACCOUNT / LEDGER TAB ── -->
        <div class="portal-account-view">
            <div class="account-section-header">
                <h2 class="account-section-title">My Account &amp; Credit Ledger</h2>
                <p class="text-slate-500" style="margin-top: 2px;">Real-time overview of your financial statements &amp; orders</p>
            </div>

            <!-- KPI Cards Grid -->
            <div class="kpi-cards-grid">
                <div class="kpi-panel-card">
                    <div class="kpi-top-glow blue"></div>
                    <div class="kpi-header-row">
                        <span class="kpi-lbl-title">Total Credit Limit</span>
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Color="Color.Info" Size="Size.Small" />
                    </div>
                    <span class="kpi-val-display blue">₹ 5,00,000</span>
                    <span class="kpi-sub-text text-slate-500">Premium Account Tier</span>
                </div>

                <div class="kpi-panel-card">
                    <div class="kpi-top-glow red"></div>
                    <div class="kpi-header-row">
                        <span class="kpi-lbl-title">Outstanding Dues</span>
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Small" />
                    </div>
                    <span class="kpi-val-display red">₹ 1,24,500</span>
                    <span class="kpi-sub-text text-danger">Please clear pending dues.</span>
                </div>

                <div class="kpi-panel-card">
                    <div class="kpi-top-glow green"></div>
                    <div class="kpi-header-row">
                        <span class="kpi-lbl-title">Available Credit</span>
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                    </div>
                    <span class="kpi-val-display green">₹ 3,75,500</span>
                    <span class="kpi-sub-text text-success">75% Credit Limit Available</span>
                </div>
            </div>

            <!-- Split Grid -->
            <div class="account-split-grid">
                <!-- Left Column (Tables) -->
                <div class="account-left-column" style="display: flex; flex-direction: column; gap: 1.5rem;">
                    <!-- Recent Orders Table -->
                    <div class="account-table-card">
                        <h3 class="table-title">Recent Orders History</h3>
                        <div class="erp-table-responsive">
                            <table class="erp-data-table">
                                <thead>
                                    <tr>
                                        <th>Order No</th>
                                        <th>Date</th>
                                        <th>Material Details</th>
                                        <th>Amount</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in RecentOrders)
                                    {
                                        <tr>
                                            <td class="font-mono-bold text-color-primary">@order.OrderNo</td>
                                            <td>@order.Date.ToString("dd MMM yyyy")</td>
                                            <td class="text-slate-500">@order.Material</td>
                                            <td class="font-mono-bold">₹ @order.Amount.ToString("N0")</td>
                                            <td>
                                                <span class="status-badge" style="background: rgba(37,99,235,0.08); color: #2563eb; font-weight:800; font-size:0.68rem; padding: 2px 6px; border-radius:4px; text-transform:uppercase;">
                                                    @order.Status
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- My Wishlist Table -->
                    <div class="account-table-card">
                        <h3 class="table-title" style="display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--card-border); padding-bottom: 10px; margin-bottom: 12px;">
                            <span>My Wishlist</span>
                            <span class="badge badge-info" style="font-size: 0.75rem; background: rgba(37,99,235,0.08); color: #2563eb; padding: 2px 6px; border-radius: 4px;">@_wishlistedProductNames.Count Items</span>
                        </h3>
                        @if (_wishlistedProductNames.Count == 0)
                        {
                            <div style="text-align: center; padding: 2rem; color: var(--text-muted);">
                                <MudIcon Icon="@Icons.Material.Filled.FavoriteBorder" Style="font-size: 40px; margin-bottom: 8px; opacity: 0.5;" />
                                <p style="font-size: 0.85rem; margin: 0;">Your wishlist is empty. Start adding steel products from the storefront!</p>
                            </div>
                        }
                        else
                        {
                            <div class="erp-table-responsive">
                                <table class="erp-data-table">
                                    <thead>
                                        <tr>
                                            <th>Product</th>
                                            <th>Grade</th>
                                            <th>Price</th>
                                            <th>Stock</th>
                                            <th style="text-align: right;">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var prodName in _wishlistedProductNames)
                                        {
                                            var prod = CatalogProducts.FirstOrDefault(p => p.Name == prodName);
                                            if (prod != null)
                                            {
                                                <tr>
                                                    <td class="font-bold text-color-primary">
                                                        <div style="display: flex; align-items: center; gap: 8px;">
                                                            @if (!string.IsNullOrEmpty(prod.ImageUrl))
                                                            {
                                                                <img src="@prod.ImageUrl" alt="@prod.Name" style="width: 28px; height: 28px; border-radius: 4px; object-fit: cover; border: 1px solid var(--card-border-color);" />
                                                            }
                                                            <span>@prod.Name</span>
                                                        </div>
                                                    </td>
                                                    <td>@prod.Grade</td>
                                                    <td class="font-mono-bold">₹ @prod.Price.ToString("N0") / @prod.Unit</td>
                                                    <td>
                                                        <span class="status-badge" style="background: @(prod.StockStatus == "In Stock" ? "rgba(16,185,129,0.08)" : prod.StockStatus == "Low Stock" ? "rgba(245,158,11,0.08)" : "rgba(239,68,68,0.08)"); color: @(prod.StockStatus == "In Stock" ? "#10b981" : prod.StockStatus == "Low Stock" ? "#f59e0b" : "#ef4444"); font-weight:800; font-size:0.68rem; padding: 2px 6px; border-radius:4px; text-transform:none;">
                                                            @prod.StockStatus
                                                        </span>
                                                    </td>
                                                    <td style="text-align: right;">
                                                        <div style="display: inline-flex; gap: 6px; justify-content: flex-end; align-items: center;">
                                                            <button class="btn-card-cart" style="padding: 4px 8px; border-radius: 4px; background: #2563eb; color: white; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center;" title="Add to Cart" @onclick="() => AddToCart(prod.Name)">
                                                                <MudIcon Icon="@Icons.Material.Filled.AddShoppingCart" Size="Size.Small" />
                                                            </button>
                                                            <button class="btn-wishlist-delete-table" style="display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; border-radius: 4px; background: rgba(239, 68, 68, 0.1); color: #ef4444; border: none; cursor: pointer; transition: all 0.2s;" title="Remove from Wishlist" @onclick="() => ToggleWishlist(prod.Name)">
                                                                <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                                                            </button>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>

                <!-- Right: Quick Actions & Manager -->
                <div class="actions-sidebar-panel">
                    <h3 class="table-title">Account Actions</h3>
                    <div class="actions-list">
                        <button class="btn-quick-action primary-btn" @onclick="MakePaymentSim">
                            <MudIcon Icon="@Icons.Material.Filled.Payment" Size="Size.Small" /> Make a Payment
                        </button>
                        <button class="btn-quick-action" @onclick="DownloadLedgerSim">
                            <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" /> View Full Ledger
                        </button>
                        <button class="btn-quick-action" @onclick='() => ToggleTab("rfq")'>
                            <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Small" /> Request New Quote
                        </button>
                    </div>

                    <div class="manager-contact-section">
                        <span class="manager-title">Your Dedicated Manager</span>
                        <div class="manager-card-box">
                            <div class="manager-avatar">VS</div>
