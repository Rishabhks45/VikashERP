@page "/sales/create"
@using VikashERP.Web.Models
@using VikashERP.Web.Services
@using VikashERP.Web.Services.Interfaces
@inject ISalesWebService SalesService
@inject ICustomerWebService CustomerService
@inject IProductWebService ProductService
@inject ITimezoneService TimezoneService
@inject NavigationManager NavManager
@inject MudBlazor.ISnackbar Snackbar
@inject MudBlazor.IDialogService DialogService
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Transaction Audit</PageTitle>

<div class="sn-page">

    <!-- ─── HEADER ─────────────────────────────────────── -->
    <div class="sn-header">
        <div>
            <h1 class="sn-title">Transaction Audit</h1>
            <p class="sn-sub">Synchronized fiscal auditing &amp; warehouse allocation</p>
        </div>
        <div class="sn-header-btns">
            <MudButton Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.Storefront"
                       Class="g-btn-khudra"
                       Href="/sales/create?type=retail"
                       Target="_blank">
                RETAIL SALE (KHUDRA)
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Add"
                       Class="g-btn-new"
                       Href="/sales/create"
                       Target="_blank">
                NEW TRANSACTION
            </MudButton>
        </div>
    </div>

    @if (_isLoadingData)
    {
        <div class="d-flex justify-content-center align-items-center" style="min-height:300px;">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </div>
    }
    else
    {
        <EditForm Model="@_model" OnValidSubmit="SaveInvoiceAsync" novalidate>
            <DataAnnotationsValidator />

            <MudGrid Spacing="3">

                <!-- ══ LEFT COLUMN ══════════════════════════════════ -->
                <MudItem xs="12" md="8">

                    <!-- CUSTOMER / SHOP -->
                    <div class="sn-card">
                        <div class="sn-card-label">Customer / Shop</div>
                        <MudGrid Spacing="2">
                            <MudItem xs="12" md="8">
                                <MudSelect T="Guid"
                                           Placeholder="Search customer or shop..."
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Value="@_model.CustomerId"
                                           ValueChanged="OnCustomerChanged"
                                           Required="true"
                                           Adornment="Adornment.End"
                                           AdornmentIcon="@Icons.Material.Filled.Search">
                                    <MudSelectItem T="Guid" Value="Guid.Empty">-- Select Customer --</MudSelectItem>
                                    @foreach (var c in _customers)
                                    {
                                        <MudSelectItem T="Guid" Value="@c.Id">@c.CompanyName (@c.FirstName @c.LastName)</MudSelectItem>
                                    }
                                </MudSelect>
                                <div class="d-flex justify-content-end mt-1">
                                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" 
                                               StartIcon="@Icons.Material.Rounded.PersonAdd" 
                                               OnClick="AddNewCustomerProfile"
                                               Style="font-weight: 700; font-size: 0.75rem;">
                                        + Add New Profile
                                    </MudButton>
                                </div>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudDatePicker Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               @bind-Date="_invoiceDate"
                                               Required="true"
                                               Adornment="Adornment.End"
                                               AdornmentIcon="@Icons.Material.Filled.CalendarMonth"
                                               MinDate="DateTime.Today"
                                               DateFormat="dd/MM/yyyy" />
                            </MudItem>
                        </MudGrid>

                        @if (_selectedCustomer != null)
                        {
                            bool isKhudra = _selectedCustomer.FirstName.Contains("Cash", StringComparison.OrdinalIgnoreCase)
                                         || _selectedCustomer.CompanyName?.Contains("CASH", StringComparison.OrdinalIgnoreCase) == true
                                         || _selectedCustomer.CompanyName?.Contains("KHUDRA", StringComparison.OrdinalIgnoreCase) == true;
                            if (isKhudra)
                            {
                                <div class="khudra-details-container mt-3 pa-3" style="background-color: var(--mud-palette-background-grey); border-radius: 8px; border: 1px dashed var(--mud-palette-lines-default);">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span style="font-size: 0.75rem; font-weight: 700; color: var(--mud-palette-text-secondary); text-transform: uppercase;">Walk-in Customer Details</span>
                                    </div>
                                    <MudGrid Spacing="2">
                                        <MudItem xs="12" md="6">
                                            <MudTextField Variant="Variant.Outlined" Margin="Margin.Dense"
                                                          @bind-Value="_khudraName" Label="Customer Name *"
                                                          Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Rounded.PersonOutline" />
                                        </MudItem>
                                        <MudItem xs="12" md="6">
                                            <MudTextField Variant="Variant.Outlined" Margin="Margin.Dense"
                                                          @bind-Value="_khudraPhone" Label="Mobile Number"
                                                          Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Rounded.Phone" />
                                        </MudItem>
                                    </MudGrid>
                                    
                                    @if (_showAdvancedKhudra)
                                    {
                                        <MudGrid Spacing="2" Class="mt-0">
                                            <MudItem xs="12" md="6">
                                                <MudTextField Variant="Variant.Outlined" Margin="Margin.Dense"
                                                              @bind-Value="_khudraGstin" Label="GSTIN (Optional)" />
                                            </MudItem>
                                            <MudItem xs="12" md="6">
                                                <MudTextField Variant="Variant.Outlined" Margin="Margin.Dense"
                                                              @bind-Value="_khudraAddress" Label="Address/City (Optional)" />
                                            </MudItem>
                                        </MudGrid>
                                    }
                                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" Class="mt-2 px-1"
                                               OnClick="@(() => _showAdvancedKhudra = !_showAdvancedKhudra)"
                                               Style="font-weight: 600; font-size: 0.75rem;">
                                        @(_showAdvancedKhudra ? "- Hide Details" : "+ Add GST/Address")
                                    </MudButton>
                                </div>
                            }
                            else
                            {
                                <div class="sn-entity-chip mt-3">
                                    <MudAvatar Color="Color.Primary" Size="Size.Small" Style="font-weight:700;">
                                        @(_selectedCustomer.CompanyName?.FirstOrDefault() ?? _selectedCustomer.FirstName.FirstOrDefault())
                                    </MudAvatar>
                                    <div>
                                        <div class="sn-entity-name">@(_selectedCustomer.CompanyName ?? $"{_selectedCustomer.FirstName} {_selectedCustomer.LastName}")</div>
                                        <div class="sn-entity-meta">
                                            @_selectedCustomer.FirstName @_selectedCustomer.LastName &bull; @_selectedCustomer.Phone
                                            @if (!string.IsNullOrWhiteSpace(_selectedCustomer.Gstin))
                                            {
                                                <span>&nbsp;&bull; GSTIN: @_selectedCustomer.Gstin</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <!-- TRADE LEDGER -->
                    <div class="sn-card">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="sn-card-label mb-0">Trade Ledger</div>
                            <MudSwitch T="bool" Value="@_isGstApplied" ValueChanged="@((bool v) => OnGstToggled(v))"
                                       Color="Color.Primary" Label="GST (18%)" Size="Size.Small" />
                        </div>

                        <!-- Column Headers -->
                        <div class="sn-ledger-head">
                            <span>Resource</span>
                            <span>Quantity</span>
                            <span>Rate (₹)</span>
                            <span>Total (₹)</span>
                            <span></span>
                        </div>

                        @foreach (var item in _model.Items)
                        {
                            <div class="sn-ledger-row">
                                <!-- Resource -->
                                <div class="d-flex gap-1">
                                    <MudSelect T="Guid" Placeholder="Select Resource" Variant="Variant.Outlined" Margin="Margin.Dense"
                                               Value="@item.SelectedProductId" ValueChanged="@(async (Guid v) => await OnProductChanged(item, v))"
                                               Style="flex:1; min-width:0;">
                                        <MudSelectItem T="Guid" Value="Guid.Empty">-- Select Resource --</MudSelectItem>
                                        @foreach (var p in _products)
                                        {
                                            <MudSelectItem T="Guid" Value="@p.Id">@p.Name</MudSelectItem>
                                        }
                                    </MudSelect>
                                    @if (item.SelectedProductVariants?.Any() == true)
                                    {
                                        <MudSelect T="Guid" Placeholder="Variant" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                   Value="@item.VariantId" ValueChanged="@((Guid v) => OnVariantChanged(item, v))"
                                                   Style="flex:1; min-width:0;">
                                            <MudSelectItem T="Guid" Value="Guid.Empty">-- Variant --</MudSelectItem>
                                            @foreach (var v in item.SelectedProductVariants)
                                            {
                                                <MudSelectItem T="Guid" Value="@v.Id">@(v.Size == v.Thickness ? v.Size : $"{v.Size} {v.Thickness}")</MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                </div>

                                <!-- Quantity -->
                                @if (item.RateOn == VikashERP.SharedKernel.Enums.RateOn.Pcs)
                                {
                                    <MudNumericField T="int" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                     HideSpinButtons="true" Value="@item.QtyPcs"
                                                     ValueChanged="@((int v) => OnQtyChanged(item, v))"
                                                     Adornment="Adornment.End" AdornmentText="PCS"
                                                     Class="sn-num quantity-input" />
                                }
                                else
                                {
                                    <MudNumericField T="decimal" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                     HideSpinButtons="true" Format="N2" Value="@item.WeightKg"
                                                     ValueChanged="@((decimal v) => OnWeightChanged(item, v))"
                                                     Adornment="Adornment.End" AdornmentText="KG"
                                                     Class="sn-num quantity-input" />
                                }
                              

                                <!-- Rate -->
                                <MudNumericField T="decimal" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 HideSpinButtons="true" Format="N2" Value="@item.Rate"
                                                 ValueChanged="@((decimal v) => OnRateChanged(item, v))"
                                                 Class="sn-num" />

                                <!-- Total (read-only) -->
                                <div class="sn-total-cell">
                                    <span>₹</span>
                                    <MudNumericField T="decimal" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                     ReadOnly="true" HideSpinButtons="true" Format="N0"
                                                     Value="@item.TotalPrice" Class="sn-num" />
                                </div>

                                <!-- Delete -->
                                <div class="d-flex align-items-center justify-content-center">
                                    <MudIconButton Icon="@Icons.Material.Outlined.Delete"
                                                   Color="Color.Error" Size="Size.Small"
                                                   OnClick="@(() => RemoveItem(item))" />
                                </div>
                            </div>
                        }

                        <!-- Insert Line -->
                        <MudButton FullWidth="true" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Add"
                                   Color="Color.Primary" Class="sn-insert-btn mt-3" ButtonType="ButtonType.Button"
                                   OnClick="AddItem">
                            Insert Line
                        </MudButton>
                    </div>

                    <!-- OPERATIONAL LOGISTICS -->
                    <div class="sn-card">
                        <div class="sn-card-label">Operational Logistics</div>
                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <MudNumericField T="decimal" Label="Bhada (₹)"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 HideSpinButtons="true"
                                                 Value="@_model.FreightCharge"
                                                 ValueChanged="@((decimal v) => { _model.FreightCharge = v; CalculateTotals(); })" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField Label="GSTIN / Remarks"
                                              Variant="Variant.Outlined" Margin="Margin.Dense"
                                              @bind-Value="_model.Remarks"
                                              Placeholder="Enter GSTIN or remarks (optional)" />
                            </MudItem>
                        </MudGrid>
                    </div>

                    <!-- ACTION BUTTONS -->
                    <div class="d-flex gap-3 mb-4">
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled"
                                   StartIcon="@Icons.Material.Filled.Check"
                                   Class="g-btn-commit" Disabled="@_isSaving">
                            @(_isSaving ? "Processing..." : "COMMIT")
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.Folder"
                                   Class="g-btn-archive" OnClick="SaveAsDraftAsync" Disabled="@_isSaving">
                            ARCHIVE
                        </MudButton>
                    </div>

                    <!-- PENDING DRAFTS -->
                    <div class="sn-card sn-drafts-card">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <div class="sn-drafts-title">PENDING DRAFTS</div>
                                <div class="sn-drafts-sub">Unfinished fiscal audits in your queue.</div>
                            </div>
                            <MudButton Variant="Variant.Text" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Sync"
                                       Style="font-weight:700; font-size:.75rem; letter-spacing:.05em;">
                                SYNCHRONIZE QUEUE
                            </MudButton>
                        </div>

                        <div class="sn-drafts-head">
                            <span>Draft ID</span>
                            <span>Shop / Entity</span>
                            <span>Date</span>
                            <span>Total (₹)</span>
                            <span>Actions</span>
                        </div>

                        @if (!_drafts.Any())
                        {
                            <div class="sn-drafts-empty">
                                <MudIcon Icon="@Icons.Material.Filled.Description" Style="font-size:2.5rem; opacity:.35;" />
                                <div style="font-weight:700; margin-top:.5rem;">No pending drafts.</div>
                                <div style="font-size:.8rem; opacity:.55;">Unfinished fiscal audits in your queue.</div>
                            </div>
                        }
                        else
                        {
                            @foreach (var draft in _drafts)
                            {
                                <div class="sn-drafts-row">
                                    <span class="sn-draft-id">@draft.InvoiceNumber</span>
                                    <span>@draft.CustomerName</span>
                                    <span style="color:var(--mud-palette-text-secondary);">@draft.InvoiceDate.ToString("dd MMM yyyy")</span>
                                    <span style="color:var(--mud-palette-success); font-weight:700;">₹ @draft.TotalAmount.ToString("N0")</span>
                                    <div class="d-flex gap-1">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                       Color="Color.Primary" Variant="Variant.Outlined"
                                                       OnClick="@(() => LoadDraftAsync(draft.Id))" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                       Color="Color.Error" Variant="Variant.Outlined" />
                                    </div>
                                </div>
                            }
                        }
                    </div>

                </MudItem>

                <!-- ══ RIGHT COLUMN ══════════════════════════════════ -->
                <MudItem xs="12" md="4">

                    <!-- AUDIT SUMMARY -->
                    <div class="sn-card">
                        <div class="sn-card-label">Audit Summary</div>
                        <div class="sn-sum-row">
                            <span>Aggregate Base</span>
                            <span class="sn-sum-val">₹ @_model.Subtotal.ToString("N0")</span>
                        </div>
                        <div class="sn-sum-row">
                            <span>Logistics (Bhada)</span>
                            <span class="sn-sum-val">₹ @_model.FreightCharge.ToString("N0")</span>
                        </div>
                        <div class="sn-sum-row">
                            <span>Labour + Rounding</span>
                            <span class="sn-sum-val">₹ @((_model.LoadingCharge + _model.RoundingAmount).ToString("N0"))</span>
                        </div>
                        @if (_isGstApplied)
                        {
                            <div class="sn-sum-row" style="color:var(--mud-palette-primary);">
                                <span>CGST (9%) + SGST (9%)</span>
                                <span class="sn-sum-val">₹ @((_model.CgstAmount + _model.SgstAmount).ToString("N0"))</span>
                            </div>
                        }
                        <MudDivider Class="my-2" />
                        <div class="sn-final-row">
                            <div>
                                <div class="sn-final-label">FINAL VALUATION</div>
                                <div class="sn-final-amt">₹ @_model.TotalAmount.ToString("N0")</div>
                            </div>
                            <MudIcon Icon="@Icons.Material.Filled.BarChart" Color="Color.Default" Style="opacity:.4;" />
                        </div>
                    </div>

                    <!-- COLLECTION BREAKDOWN -->
                    <div class="sn-card">
                        <div class="sn-card-label">Collection Breakdown</div>

                        <!-- Cash row -->
                        <div class="sn-coll-row">
                            <div class="d-flex align-items-center gap-2">
                                <div class="sn-coll-icon sn-coll-cash">
                                    <MudIcon Icon="@Icons.Material.Filled.Payments" Size="Size.Small" />
                                </div>
                                <div>
                                    <div class="sn-coll-label">CASH PAYMENT (नकद)</div>
                                    <MudNumericField T="decimal" Variant="Variant.Text" Margin="Margin.None"
                                                     HideSpinButtons="true"
                                                     Value="@_cashPayment"
                                                     ValueChanged="@((decimal v) => { _cashPayment = v; UpdateModelPaymentInfo(); })"
                                                     Class="sn-coll-input" Placeholder="0" />
                                </div>
                            </div>
                            <span class="sn-coll-amount">₹ @_cashPayment.ToString("N0")</span>
                        </div>

                        <!-- A/C row -->
                        <div class="sn-coll-row">
                            <div class="d-flex align-items-center gap-2">
                                <div class="sn-coll-icon sn-coll-ac">
                                    <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Small" />
                                </div>
                                <div>
                                    <div class="sn-coll-label">A/C PAYMENT (उधार)</div>
                                    <MudNumericField T="decimal" Variant="Variant.Text" Margin="Margin.None"
                                                     HideSpinButtons="true"
                                                     Value="@_acPayment"
                                                     ValueChanged="@((decimal v) => { _acPayment = v; UpdateModelPaymentInfo(); })"
                                                     Class="sn-coll-input" Placeholder="0" />
                                </div>
                            </div>
                            <span class="sn-coll-amount">₹ @_acPayment.ToString("N0")</span>
                        </div>

                        <!-- Quick fill + Dues -->
                        <div class="d-flex align-items-center gap-1 mt-2">
                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                       OnClick="SetFullCash" Style="font-weight:800; font-size:.72rem; letter-spacing:.05em; padding:4px 8px;">
                                FULL CASH
                            </MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                       OnClick="SetFullAC" Style="font-weight:800; font-size:.72rem; letter-spacing:.05em; padding:4px 8px;">
                                FULL A/C
                            </MudButton>
                            <MudSpacer />
                            <div class="sn-dues-chip">TOTAL DUES: ₹ @_model.DueAmount.ToString("N0")</div>
                        </div>

                        <!-- UPI / QR -->
                        <div class="sn-upi-box">
                            <div class="sn-upi-label">Digital Settlement (UPI)</div>
                            <img src="@GetQrCodeUrl()" alt="UPI QR" class="sn-upi-qr" />
                            <div class="sn-upi-id">risham123sharma@ybl</div>
                            <div class="sn-upi-verified">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Style="font-size:14px;" />
                                Verified: Rishabh Kumar Sharma
                            </div>
                        </div>

                        <MudButton FullWidth="true" Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.Visibility" Class="g-btn-inspect mt-2">
                            INSPECT INVOICE
                        </MudButton>
                    </div>

                </MudItem>
            </MudGrid>
        </EditForm>
    }

    <!-- ─── FOOTER ─────────────────────────────────────── -->
    <div class="sn-footer">
        <div class="d-flex align-items-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Sync" Size="Size.Small" Style="opacity:.5;" />
            <span>Last updated: @DateTime.Now.ToString("dd MMM yyyy, hh:mm tt")</span>
        </div>
        <span>All amounts are in INR (₹)</span>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "draftId")]
    public Guid? DraftId { get; set; }

    [SupplyParameterFromQuery(Name = "type")]
    public string? Type { get; set; }

    private CreateInvoiceModel _model = new();
    private DateTime? _invoiceDate = DateTime.Today;
    private List<CustomerListDto> _customers = new();
    private CustomerListDto? _selectedCustomer;
    private List<ProductListDto> _products = new();
    private List<InvoiceListDto> _drafts = new();
    private bool _isLoadingData = true;
    private bool _isSaving = false;
    private bool _isGstApplied = false;
    
    // Khudra Details
    private string _khudraName = string.Empty;
    private string _khudraPhone = string.Empty;
    private string _khudraGstin = string.Empty;
    private string _khudraAddress = string.Empty;
    private bool _showAdvancedKhudra = false;
    
    private Guid? _editingDraftId = null;
    private decimal _cashPayment = 0;
    private decimal _acPayment = 0;

    private void AddNewCustomerProfile()
    {
        NavManager.NavigateTo("/customers/create");
    }

    protected override async Task OnInitializedAsync()
    {
        _isLoadingData = true;
        try
        {
            _customers = await CustomerService.GetCustomersAsync();
            _products = await ProductService.GetProductsAsync();
            var all = await SalesService.GetInvoicesAsync();
            _drafts = all.Where(i => i.Status == VikashERP.SharedKernel.Enums.SalesInvoiceStatus.Draft).ToList();
            if (!_model.Items.Any()) AddItem();

            if (DraftId.HasValue && DraftId.Value != Guid.Empty)
                await LoadDraftAsync(DraftId.Value);
            else if (Type == "retail")
            {
                var cash = _customers.FirstOrDefault(c =>
                    c.FirstName.Contains("Cash", StringComparison.OrdinalIgnoreCase) ||
                    c.CompanyName?.Contains("CASH", StringComparison.OrdinalIgnoreCase) == true ||
                    c.CompanyName?.Contains("KHUDRA", StringComparison.OrdinalIgnoreCase) == true);
                
                if (cash == null)
                {
                    // Create the default generic cash customer automatically
                    cash = await CustomerService.CreateCustomerAsync(new CreateCustomerDto
                    {
                        FirstName = "Cash",
                        LastName = "Customer",
                        Phone = "0000000000",
                        CompanyName = "CASH / KHUDRA",
                        DefaultPaymentMode = "Cash"
                    });
                    
                    if (cash != null)
                    {
                        _customers.Add(cash);
                    }
                }

                if (cash != null) OnCustomerChanged(cash.Id);
            }
        }
        finally { _isLoadingData = false; }
    }

    private void OnCustomerChanged(Guid id)
    {
        _model.CustomerId = id;
        _selectedCustomer = _customers.FirstOrDefault(c => c.Id == id);
        if (_selectedCustomer != null) 
        { 
            _model.FreightCharge = _selectedCustomer.DefaultFreightRate; 
            
            bool isKhudra = _selectedCustomer.FirstName.Contains("Cash", StringComparison.OrdinalIgnoreCase) ||
                 _selectedCustomer.CompanyName?.Contains("CASH", StringComparison.OrdinalIgnoreCase) == true ||
                 _selectedCustomer.CompanyName?.Contains("KHUDRA", StringComparison.OrdinalIgnoreCase) == true;
                 
            if (isKhudra)
            {
                if (string.IsNullOrWhiteSpace(_khudraName)) _khudraName = "KHUDRA Customer";
                if (string.IsNullOrWhiteSpace(_khudraPhone)) _khudraPhone = "1234567891";
            }
            
            CalculateTotals(); 
        }
    }

    private void AddItem() => _model.Items.Add(new CreateInvoiceItemModel());
    private void RemoveItem(CreateInvoiceItemModel item) { _model.Items.Remove(item); CalculateTotals(); }

    private async Task OnProductChanged(CreateInvoiceItemModel item, Guid pid)
    {
        item.SelectedProductId = pid; item.VariantId = Guid.Empty;
        item.SelectedVariant = null; item.SelectedProductVariants = null;
        if (pid != Guid.Empty)
        {
            var p = await ProductService.GetProductByIdAsync(pid);
            if (p != null) { item.SelectedProductVariants = p.Variants; item.RateOn = p.SellingUnit; }
        }
    }

    private void OnVariantChanged(CreateInvoiceItemModel item, Guid vid)
    {
        item.VariantId = vid;
        var v = item.SelectedProductVariants?.FirstOrDefault(x => x.Id == vid);
        if (v != null) { item.SelectedVariant = v; item.VariantName = v.Size == v.Thickness ? v.Size : $"{v.Size} {v.Thickness}"; item.Rate = v.LastPurchaseRate * (1 + v.DefaultMargin / 100m); CalculateItemTotal(item); }
    }

    private void OnWeightChanged(CreateInvoiceItemModel i, decimal w) { i.WeightKg = w; CalculateItemTotal(i); }
    private void OnQtyChanged(CreateInvoiceItemModel i, int q) { i.QtyPcs = q; CalculateItemTotal(i); }
    private void OnRateChanged(CreateInvoiceItemModel i, decimal r) { i.Rate = r; CalculateItemTotal(i); }

    private void CalculateItemTotal(CreateInvoiceItemModel item)
    {
        item.TotalPrice = item.RateOn == VikashERP.SharedKernel.Enums.RateOn.Pcs
            ? item.QtyPcs * item.Rate : item.WeightKg * item.Rate;
        CalculateTotals();
    }

    private void CalculateTotals()
    {
        _model.Subtotal = _model.Items.Sum(i => i.TotalPrice);
        decimal kg = _model.Items.Sum(i => i.WeightKg);
        _model.LoadingCharge = Math.Round(kg / 100m * 25m, 2);
        var taxable = _model.Subtotal + _model.FreightCharge + _model.LoadingCharge;
        if (_isGstApplied) { _model.CgstAmount = Math.Round(taxable * .09m, 2); _model.SgstAmount = Math.Round(taxable * .09m, 2); }
        else { _model.CgstAmount = 0; _model.SgstAmount = 0; }
        var pre = taxable + _model.CgstAmount + _model.SgstAmount;
        _model.TotalAmount = Math.Round(pre, 0);
        _model.RoundingAmount = Math.Round(_model.TotalAmount - pre, 2);
        UpdateModelPaymentInfo();
    }

    private void OnGstToggled(bool v) { _isGstApplied = v; CalculateTotals(); }
    private void SetFullCash() { _cashPayment = _model.TotalAmount; _acPayment = 0; UpdateModelPaymentInfo(); }
    private void SetFullAC() { _cashPayment = 0; _acPayment = _model.TotalAmount; UpdateModelPaymentInfo(); }

    private void UpdateModelPaymentInfo()
    {
        var paid = _cashPayment + _acPayment;
        _model.DueAmount = paid > _model.TotalAmount ? 0 : _model.TotalAmount - paid;
        _model.PaidAmount = paid;
        _model.PaymentMode = _cashPayment > 0 && _acPayment == 0 ? "Cash"
                           : _acPayment > 0 && _cashPayment == 0 ? "A/C"
                           : _cashPayment > 0 && _acPayment > 0 ? "Partial" : "Udhaar";
    }

    private async Task SaveInvoiceAsync() => await ProcessSaveAsync(VikashERP.SharedKernel.Enums.SalesInvoiceStatus.Approved);
    private async Task SaveAsDraftAsync() => await ProcessSaveAsync(VikashERP.SharedKernel.Enums.SalesInvoiceStatus.Draft);

    private async Task ProcessSaveAsync(VikashERP.SharedKernel.Enums.SalesInvoiceStatus status)
    {
        if (_model.CustomerId == Guid.Empty)
        { Snackbar.Add("Please select a Customer / Shop.", MudBlazor.Severity.Warning); return; }
        if (_invoiceDate.HasValue && _invoiceDate.Value.Date < DateTime.Today)
        { Snackbar.Add("Back-dated invoices are not allowed.", MudBlazor.Severity.Warning); return; }
        if (!_model.Items.Any() || _model.Items.All(i => i.SelectedProductId == Guid.Empty))
        { Snackbar.Add("Trade ledger cannot be empty.", MudBlazor.Severity.Warning); return; }

        _isSaving = true;
        try
        {
            bool isKhudra = _selectedCustomer != null &&
                (_selectedCustomer.FirstName.Contains("Cash", StringComparison.OrdinalIgnoreCase) ||
                 _selectedCustomer.CompanyName?.Contains("CASH", StringComparison.OrdinalIgnoreCase) == true ||
                 _selectedCustomer.CompanyName?.Contains("KHUDRA", StringComparison.OrdinalIgnoreCase) == true);
                 
            if (isKhudra && string.IsNullOrWhiteSpace(_khudraName))
            {
                Snackbar.Add("Walk-in Customer Name is required.", MudBlazor.Severity.Warning);
                _isSaving = false;
                return;
            }

            if (_model.DueAmount > 0)
            {
                bool? result = await DialogService.ShowMessageBoxAsync(
                    "Pending Dues Action", 
                    $"This bill has a pending due of ₹{_model.DueAmount:N0}.\nDo you want to register this amount in the account (Udhaar), or write it off (Maaf/Discount)?", 
                    yesText: "Register in Account", noText: "Write it off (Maaf)", cancelText: "Cancel / Enter Payment");
                    
                if (result == null) 
                {
                    _isSaving = false;
                    return;
                }

                if (result == false)
                {
                    // Write off
                    _model.RoundingAmount -= _model.DueAmount;
                    _model.TotalAmount -= _model.DueAmount;
                    _model.DueAmount = 0;
                }
                else if (result == true && isKhudra)
                {
                    // Register Khudra
                    if (_khudraName.Trim().Equals("KHUDRA Customer", StringComparison.OrdinalIgnoreCase))
                    {
                        Snackbar.Add("Cannot register credit for generic 'KHUDRA Customer'. Please enter the real name.", MudBlazor.Severity.Warning);
                        _isSaving = false;
                        return;
                    }

                    if (string.IsNullOrWhiteSpace(_khudraPhone) || _khudraPhone.Trim() == "1234567891")
                    {
                        Snackbar.Add("A valid Mobile Number is mandatory when allowing credit for a retail customer.", MudBlazor.Severity.Warning);
                        _isSaving = false;
                        return;
                    }

                    var nc = await CustomerService.CreateCustomerAsync(new CreateCustomerDto
                    { 
                        FirstName = _khudraName.Trim(), 
                        LastName = " (Retail)", 
                        Phone = _khudraPhone.Trim(),
                        Address = _khudraAddress?.Trim(),
                        Gstin = _khudraGstin?.Trim(),
                        DefaultPaymentMode = "Cash" 
                    });
                    if (nc != null) { _model.CustomerId = nc.Id; _khudraName = string.Empty; }
                }
            }

            // Append details to remarks if it was Khudra and NO profile was created
            if (isKhudra && !string.IsNullOrWhiteSpace(_khudraName))
            {
                string retailDetails = $"Retail: {_khudraName}";
                if (!string.IsNullOrWhiteSpace(_khudraPhone)) retailDetails += $", Ph: {_khudraPhone}";
                if (!string.IsNullOrWhiteSpace(_khudraGstin)) retailDetails += $", GST: {_khudraGstin}";
                if (!string.IsNullOrWhiteSpace(_khudraAddress)) retailDetails += $", Addr: {_khudraAddress}";
                
                if (string.IsNullOrWhiteSpace(_model.Remarks))
                    _model.Remarks = retailDetails;
                else
                    _model.Remarks = retailDetails + " | " + _model.Remarks;
            }

            var selectedDate = _invoiceDate ?? DateTime.UtcNow.Date;
            _model.InvoiceDate = _invoiceDate.HasValue 
                ? TimezoneService.ToUtcDate(_invoiceDate.Value)
                : DateTime.UtcNow.Date;
            _model.CashAmount = _cashPayment;
            _model.BankAmount = _acPayment;

            Guid id = _editingDraftId.HasValue
                ? await SalesService.UpdateInvoiceAsync(_editingDraftId.Value, _model)
                : await SalesService.CreateInvoiceAsync(_model);

            if (status == VikashERP.SharedKernel.Enums.SalesInvoiceStatus.Approved)
            { await SalesService.ApproveInvoiceAsync(id); Snackbar.Add("Transaction committed!", MudBlazor.Severity.Success); }
            else
            { Snackbar.Add("Saved as draft.", MudBlazor.Severity.Info); }

            NavManager.NavigateTo("/sales");
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", MudBlazor.Severity.Error); }
        finally { _isSaving = false; }
    }

    private string GetQrCodeUrl()
    {
        decimal amt = _model.DueAmount > 0 ? _model.DueAmount : _model.TotalAmount;
        string upi = "upi://pay?pa=risham123sharma@ybl&pn=Rishabh%20Kumar%20Sharma&cu=INR";
        if (amt > 0) upi += $"&am={amt}";
        return $"https://api.qrserver.com/v1/create-qr-code/?size=150x150&data={Uri.EscapeDataString(upi)}";
    }

    private async Task LoadDraftAsync(Guid id)
    {
        _isLoadingData = true;
        try
        {
            var d = await SalesService.GetInvoiceByIdAsync(id);
            if (d != null)
            {
                _editingDraftId = id;
                _model = new CreateInvoiceModel
                {
                    CustomerId = d.CustomerId,
                    CustomerName = d.CustomerName,
                    Subtotal = d.Subtotal,
                    FreightCharge = d.FreightCharge,
                    LoadingCharge = d.LoadingCharge,
                    CgstAmount = d.CgstAmount,
                    SgstAmount = d.SgstAmount,
                    IgstAmount = d.IgstAmount,
                    RoundingAmount = d.RoundingAmount,
                    TotalAmount = d.TotalAmount,
                    PaidAmount = d.PaidAmount,
                    CashAmount = d.CashAmount,
                    BankAmount = d.BankAmount,
                    DueAmount = d.DueAmount,
                    PaymentMode = d.PaymentMode,
                    VehicleNumber = d.VehicleNumber,
                    Remarks = d.Remarks,
                    Items = new()
                };
                foreach (var i in d.Items)
                {
                    var pd = await ProductService.GetProductByIdAsync(i.ProductId);
                    _model.Items.Add(new CreateInvoiceItemModel
                    {
                        VariantId = i.VariantId,
                        VariantName = i.VariantName,
                        QtyPcs = i.QtyPcs,
                        WeightKg = i.WeightKg,
                        Rate = i.Rate,
                        RateOn = Enum.TryParse<VikashERP.SharedKernel.Enums.RateOn>(i.RateOn, out var ro) ? ro : VikashERP.SharedKernel.Enums.RateOn.Kg,
                        CgstRate = i.CgstRate,
                        SgstRate = i.SgstRate,
                        TotalPrice = i.TotalPrice,
                        SelectedProductId = i.ProductId,
                        SelectedProductVariants = pd?.Variants,
                        SelectedVariant = pd?.Variants?.FirstOrDefault(v => v.Id == i.VariantId)
                    });
                }
                _selectedCustomer = _customers.FirstOrDefault(c => c.Id == d.CustomerId);
                _invoiceDate = d.InvoiceDate; _cashPayment = d.CashAmount; _acPayment = d.BankAmount;
                _isGstApplied = d.CgstAmount > 0;
                Snackbar.Add("Draft loaded.", MudBlazor.Severity.Success);
            }
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", MudBlazor.Severity.Error); }
        finally { _isLoadingData = false; }
    }
