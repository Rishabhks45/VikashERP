@page "/sales/print/{Id:guid}"
@layout BlankLayout
@using VikashERP.Web.Models
@using VikashERP.Web.Services
@inject ISalesWebService SalesService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

@if (_isLoading)
{
    <div class="loading-state">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        <MudText Class="mt-3">Loading Invoice PDF...</MudText>
    </div>
}
else if (_pdfBase64Url == null)
{
    <div class="error-state">
        <MudText Color="Color.Error">Invoice PDF could not be generated or found.</MudText>
    </div>
}
else
{
     <div class="pdf-container">
        <iframe src="@_pdfBase64Url" title="Invoice PDF" width="100%" height="100%" style="border: none;"></iframe>
    </div>

    <style>
        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            background-color: #525659; /* Standard PDF viewer background */
        }

        .no-print {
            display: flex;
        }
        
        .control-bar {
            background: #0f172a;
            color: white;
            padding: 14px 24px;
            position: sticky;
            top: 0;
            z-index: 1000;
            display: flex;
            justify-content: center;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
            font-family: 'Roboto', sans-serif;
            width: 100%;
            height: 64px;
        }

        .control-bar-content {
            width: 100%;
            max-width: 800px;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .control-actions {
            display: flex;
            gap: 12px;
        }

        .btn-control {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 10px 20px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            border: 1px solid transparent;
            transition: all 0.2s ease;
            color: white;
            text-decoration: none;
            background: rgba(255, 255, 255, 0.1);
        }

        .btn-print {
            background: #4f46e5;
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3);
        }

        .btn-print:hover {
            background: #4338ca;
            transform: translateY(-1px);
        }

        .btn-download {
            background: #0ea5e9;
            box-shadow: 0 4px 12px rgba(14, 165, 233, 0.3);
        }

        .btn-download:hover {
            background: #0284c7;
            transform: translateY(-1px);
        }

        .loading-state, .error-state {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background-color: white;
        }

        .pdf-container {
            width: 100%;
            height: calc(100vh - 64px);
            display: flex;
            justify-content: center;
        }
    </style>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private bool _isLoading = true;
    private string? _pdfBase64Url;
    private byte[]? _pdfBytes;
    private string _invoiceNumber = "Invoice";

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        
        try
        {
            var invoice = await SalesService.GetInvoiceByIdAsync(Id);
            if (invoice != null)
            {
                _invoiceNumber = invoice.InvoiceNumber;
            }

            var bytes = await SalesService.GetInvoicePdfAsync(Id);
            if (bytes != null)
            {
                _pdfBytes = bytes;
                _pdfBase64Url = $"data:application/pdf;base64,{Convert.ToBase64String(bytes)}";
            }
            else
            {
                Snackbar.Add("Could not load PDF from the server.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading PDF: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task PrintInvoice()
    {
        if (_pdfBase64Url == null) return;
        await JSRuntime.InvokeVoidAsync("printPdfBase64", _pdfBase64Url);
    }

    private async Task DownloadPdf()
    {
        if (_pdfBytes == null) return;

        var safeInvoiceNumber = _invoiceNumber.Replace("/", "-").Replace("\\", "-");
        var filename = $"Invoice_{safeInvoiceNumber}.pdf";

        using var streamRef = new DotNetStreamReference(new MemoryStream(_pdfBytes));
        await JSRuntime.InvokeVoidAsync("downloadFileFromStream", filename, streamRef);
    }
}
