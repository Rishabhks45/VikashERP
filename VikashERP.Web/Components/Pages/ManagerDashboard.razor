@using VikashERP.Web.Models
@inject ISnackbar Snackbar

<MudStack Class="dashboard-page" Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="dashboard-header">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5" HtmlTag="h1">Manager Dashboard</MudText>
            <MudText Typo="Typo.body2" Class="dashboard-subtitle">
                Operations monitoring, material dispatches, stock alerts, and team approvals.
            </MudText>
        </MudStack>

        <MudStack Row="true" AlignItems="AlignItems.Center" Class="dashboard-header-actions">
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.LocalShipping" Class="dashboard-action-secondary">
                Dispatch Status
            </MudButton>
            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.AddTask" Class="dashboard-action-primary">
                Assign Task
            </MudButton>
        </MudStack>
    </MudStack>

    <MudGrid Spacing="2" Class="dashboard-kpis">
        @foreach (var metric in Metrics)
        {
            <MudItem xs="12" sm="6" lg="3">
                <MudPaper Elevation="0" Class="dashboard-kpi">
                    <MudPaper Elevation="0" Class="@($"dashboard-kpi-icon {metric.IconClass}")">
                        <MudIcon Icon="@metric.Icon" />
                    </MudPaper>
                    <MudStack Spacing="0" Class="dashboard-kpi-body">
                        <MudText Typo="Typo.caption">@metric.Label</MudText>
                        <MudText Typo="Typo.h5" HtmlTag="strong">@metric.Value</MudText>
                        <MudText Typo="Typo.caption" Class="@metric.TrendClass">@metric.Trend</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>

    <MudGrid Spacing="2" Class="dashboard-grid">
        <!-- Pending Approvals & Tasks (Interactive) -->
        <MudItem xs="12" lg="8">
            <MudPaper Elevation="0" Class="dashboard-panel dashboard-panel-wide">
                <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="dashboard-panel-header">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h6" HtmlTag="h2">Pending Team Approvals</MudText>
                        <MudText Typo="Typo.caption">Requests requiring your action</MudText>
                    </MudStack>
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">Action Required</MudChip>
                </MudStack>

                <MudStack Spacing="2" Class="mt-2" Style="max-height: 340px; overflow-y: auto;">
                    @if (Approvals.Count == 0)
                    {
                        <MudStack AlignItems="AlignItems.Center" Class="py-6">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircleOutline" Color="Color.Success" Size="Size.Large" />
                            <MudText Typo="Typo.body1" Class="mt-2">All caught up! No pending approvals.</MudText>
                        </MudStack>
                    }
                    else
                    {
                        @foreach (var req in Approvals)
                        {
                            <MudPaper Elevation="0" Outlined="true" Class="pa-3 mb-2" Style="border-radius: 8px; border: 1px solid var(--mud-palette-divider);">
                                <MudGrid Spacing="1" AlignItems="AlignItems.Center">
                                    <MudItem xs="12" sm="8">
                                        <MudStack Spacing="0">
                                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                                <MudText Typo="Typo.subtitle2" Color="Color.Primary">@req.Id</MudText>
                                                <MudChip T="string" Size="Size.Small" Color="@req.CategoryColor" Variant="Variant.Text" Style="font-weight: 700;">@req.Category</MudChip>
                                            </MudStack>
                                            <MudText Typo="Typo.body2" Class="mt-1" Style="font-weight: 600;">@req.Title</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Requested by @req.RequestedBy on @req.Date.ToShortDateString()</MudText>
                                        </MudStack>
                                    </MudItem>
                                    <MudItem xs="12" sm="4">
                                        <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
                                            <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" OnClick="@(() => HandleApproval(req.Id, false))">Reject</MudButton>
                                            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success" OnClick="@(() => HandleApproval(req.Id, true))">Approve</MudButton>
                                        </MudStack>
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        }
                    }
                </MudStack>
            </MudPaper>
        </MudItem>

        <!-- Dispatch Queue -->
        <MudItem xs="12" lg="4">
            <MudPaper Elevation="0" Class="dashboard-panel">
                <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="dashboard-panel-header">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h6" HtmlTag="h2">Dispatch Queue</MudText>
                        <MudText Typo="Typo.caption">Loads waiting for movement</MudText>
                    </MudStack>
                    <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Class="dashboard-panel-icon" />
                </MudStack>

                <MudStack Spacing="2" Class="dispatch-list">
                    @foreach (var dispatch in Dispatches)
                    {
                        <MudPaper Elevation="0" Class="dispatch-item">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.subtitle2">@dispatch.Vehicle</MudText>
                                <MudText Typo="Typo.caption">@dispatch.Customer</MudText>
                            </MudStack>
                            <MudChip T="string" Size="Size.Small" Class="@dispatch.StatusClass">@dispatch.Status</MudChip>
                        </MudPaper>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>

        <!-- Low Stock Alerts -->
        <MudItem xs="12" lg="4">
            <MudPaper Elevation="0" Class="dashboard-panel">
                <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="dashboard-panel-header">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h6" HtmlTag="h2">Low Stock Alerts</MudText>
                        <MudText Typo="Typo.caption">Materials below safe level</MudText>
                    </MudStack>
                    <MudIcon Icon="@Icons.Material.Filled.WarningAmber" Class="dashboard-panel-icon warning" />
                </MudStack>

                <MudStack Spacing="0" Class="stock-list">
                    @foreach (var stock in LowStock)
                    {
                        <div class="stock-row">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.subtitle2">@stock.Material</MudText>
                                <MudText Typo="Typo.caption">@stock.Location</MudText>
                            </MudStack>
                            <MudProgressLinear Value="@stock.Percent"
                                               Rounded="true"
                                               Size="Size.Small"
                                               Class="stock-progress" />
                            <MudText Typo="Typo.caption" Class="stock-count">@stock.Quantity</MudText>
                        </div>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>

        <!-- Recent Billing / Invoice overview -->
        <MudItem xs="12" lg="8">
            <MudPaper Elevation="0" Class="dashboard-panel dashboard-panel-wide">
                <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="dashboard-panel-header">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h6" HtmlTag="h2">Recent Billing</MudText>
                        <MudText Typo="Typo.caption">Latest invoices generated</MudText>
                    </MudStack>
                    <MudButton Variant="Variant.Text" EndIcon="@Icons.Material.Filled.ArrowForward" Size="Size.Small">View all</MudButton>
                </MudStack>

                <MudTable Items="@Invoices" Dense="true" Hover="true" Elevation="0" Class="invoice-table" Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        <MudTh>Invoice</MudTh>
                        <MudTh>Customer</MudTh>
                        <MudTh>Amount</MudTh>
                        <MudTh>Status</MudTh>
                    </HeaderContent>
                    <RowTemplate Context="invoice">
                        <MudTd DataLabel="Invoice">@invoice.Number</MudTd>
                        <MudTd DataLabel="Customer">@invoice.Customer</MudTd>
                        <MudTd DataLabel="Amount">
                            <MudText Typo="Typo.body2" Class="invoice-amount">@invoice.Amount</MudText>
                        </MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Size="Size.Small" Class="@invoice.StatusClass">@invoice.Status</MudChip>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    private static readonly Metric[] Metrics =
    [
        new("Today's Sale", "Rs 3.12L", "+8.4% from yesterday", Icons.Material.Filled.Payments, "accent-green", "trend-up"),
        new("Pending Loads", "9 Vehicles", "5 ready for dispatch", Icons.Material.Filled.LocalShipping, "accent-blue", "trend-neutral"),
        new("Low Stock", "14 Items", "3 critical materials", Icons.Material.Filled.Inventory2, "accent-amber", "trend-alert"),
        new("Pending Approvals", "4 Requests", "Requires your attention", Icons.Material.Filled.RateReview, "accent-red", "trend-down")
    ];

    private static readonly DispatchItem[] Dispatches =
    [
        new("JH 05 CK 2841", "Mahadev Traders", "Loading", "chip-info"),
        new("JH 01 DP 7712", "Sinha Steel Works", "Ready", "chip-success"),
        new("WB 23 AT 9011", "Eastern Fabricators", "Hold", "chip-warning"),
        new("JH 09 BA 1190", "Om Construction", "Transit", "chip-info")
    ];

    private static readonly StockItem[] LowStock =
    [
        new("GI Pipe 1 inch 2mm", "Main Godown", 22, "118 pcs"),
        new("MS Angle 40x40", "Warehouse B", 34, "256 kg"),
        new("Flat Bar 25mm", "Main Godown", 18, "74 pcs"),
        new("TMT 12mm", "Yard Stock", 41, "1.2 t")
    ];

    private static readonly InvoiceItem[] Invoices =
    [
        new("INV-2026-0142", "Sinha Steel Works", "Rs 1,42,800", "Paid", "chip-success"),
        new("INV-2026-0141", "Mahadev Traders", "Rs 87,450", "Partial", "chip-warning"),
        new("INV-2026-0140", "Om Construction", "Rs 2,18,300", "Due", "chip-danger"),
        new("INV-2026-0139", "Eastern Fabricators", "Rs 64,920", "Paid", "chip-success")
    ];

    private List<ApprovalRequest> Approvals = new()
    {
        new("REQ-8012", "Leave Request", "Rajesh Kumar (Employee) - Casual Leave for 2 Days (19-20 Jun)", "Rajesh Kumar", DateTime.Now, Color.Info),
        new("REQ-8013", "Credit Limit", "Increase Credit Limit for Sinha Steel Works to ₹6,00,000", "Sinha Steel", DateTime.Now.AddDays(-1), Color.Warning),
        new("REQ-8014", "Attendance Correction", "Amit Singh (Driver) - Overtime correction (4 Hours, 15 Jun)", "Amit Singh", DateTime.Now.AddDays(-1), Color.Default),
        new("REQ-8015", "Expense Reimbursement", "Reimbursement request for Godown fuel: ₹3,200", "Godown Staff", DateTime.Now.AddDays(-2), Color.Success)
    };

    private void HandleApproval(string id, bool approved)
    {
        var req = Approvals.FirstOrDefault(x => x.Id == id);
        if (req != null)
        {
            Approvals.Remove(req);
            string action = approved ? "Approved" : "Rejected";
            Snackbar.Add($"Request {id} has been {action} successfully.", approved ? Severity.Success : Severity.Warning);
        }
    }

    private class ApprovalRequest
    {
        public string Id { get; }
        public string Category { get; }
        public string Title { get; }
        public string RequestedBy { get; }
        public DateTime Date { get; }
        public Color CategoryColor { get; }

        public ApprovalRequest(string id, string category, string title, string requestedBy, DateTime date, Color categoryColor)
        {
            Id = id;
            Category = category;
            Title = title;
            RequestedBy = requestedBy;
            Date = date;
            CategoryColor = categoryColor;
        }
    }
}
