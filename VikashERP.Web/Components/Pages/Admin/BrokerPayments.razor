@page "/broker-payments"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@implements IAsyncDisposable
@using System.Net.Http.Json
@using VikashERP.Web.Services
@using VikashERP.Web.Services.Interfaces
@using VikashERP.Web.Models.Brokers
@using VikashERP.Web.Validation
@using VikashERP.Web.Utils
@inject IBrokerWebService BrokerWebService
@inject INotificationService NotificationService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Broker Quick Payments & Commission</PageTitle>

<PageLoader IsVisible="@_loading" Text="Loading payments ledger..." />

<MudStack Class="payments-page" Spacing="4">
    <!-- Header Hero -->
    <div class="org-hero">
        <MudStack Spacing="0" Class="org-hero-copy">
            <MudText Typo="Typo.h5" HtmlTag="h1">Broker Payments & Commission</MudText>
            <MudText Typo="Typo.body2" Class="dashboard-subtitle org-subtitle">
                Record manual payouts and commission credits for brokers to maintain accurate ledger statements.
            </MudText>
        </MudStack>
        <MudButton Variant="Variant.Filled"
                   Class="dashboard-action-primary org-save-btn"
                   StartIcon="@Icons.Material.Filled.AddCard"
                   OnClick="OpenAddDrawer"
                   Disabled="@_loading">
            Record Transaction
        </MudButton>
    </div>

    @if (!_loading)
    {
        <!-- KPI Cards -->
        <MudGrid Spacing="2" Class="dashboard-kpis">
            <MudItem xs="12" sm="6" lg="3">
                <MudPaper Elevation="0" Class="dashboard-kpi">
                    <MudPaper Elevation="0" Class="dashboard-kpi-icon accent-blue">
                        <MudIcon Icon="@Icons.Material.Filled.Today" />
                    </MudPaper>
                    <MudStack Spacing="0" Class="dashboard-kpi-body">
                        <MudText Typo="Typo.caption">Total Payments (Today)</MudText>
                        <MudText Typo="Typo.h5" HtmlTag="strong">₹@TodayPayments.ToString("N0")</MudText>
                        <MudText Typo="Typo.caption" Class="trend-neutral">Today's payouts</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
            
            <MudItem xs="12" sm="6" lg="3">
                <MudPaper Elevation="0" Class="dashboard-kpi">
                    <MudPaper Elevation="0" Class="dashboard-kpi-icon accent-green">
                        <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" />
                    </MudPaper>
                    <MudStack Spacing="0" Class="dashboard-kpi-body">
                        <MudText Typo="Typo.caption">Total Payments (Monthly)</MudText>
                        <MudText Typo="Typo.h5" HtmlTag="strong">₹@MonthlyPayments.ToString("N0")</MudText>
                        <MudText Typo="Typo.caption" Class="trend-up">This month payouts</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" lg="3">
                <MudPaper Elevation="0" Class="dashboard-kpi">
                    <MudPaper Elevation="0" Class="dashboard-kpi-icon accent-amber">
                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" />
                    </MudPaper>
                    <MudStack Spacing="0" Class="dashboard-kpi-body">
                        <MudText Typo="Typo.caption">Total Commission (Monthly)</MudText>
                        <MudText Typo="Typo.h5" HtmlTag="strong">₹@MonthlyCommission.ToString("N0")</MudText>
                        <MudText Typo="Typo.caption" Class="trend-neutral">Commissions credited</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" lg="3">
                <MudPaper Elevation="0" Class="dashboard-kpi">
                    <MudPaper Elevation="0" Class="dashboard-kpi-icon accent-purple">
                        <MudIcon Icon="@Icons.Material.Filled.DonutLarge" />
                    </MudPaper>
                    <MudStack Spacing="0" Class="dashboard-kpi-body">
                        <MudText Typo="Typo.caption">Cash vs Digital Split</MudText>
                        <MudText Typo="Typo.h5" HtmlTag="strong" Style="font-size: 1.05rem; line-height: 1.6;">@PaymentSplit</MudText>
                        <MudText Typo="Typo.caption" Class="trend-neutral">Payout channel</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- Main Datagrid Panel -->
        <MudPaper Elevation="0" Class="org-tab-panel pa-6">
            <MudGrid Class="mb-4 d-flex align-center">
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_searchQuery"
                                   Placeholder="Search by broker name or remarks..."
                                   Adornment="Adornment.Start"
                                   AdornmentIcon="@Icons.Material.Filled.Search"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Class="search-bar-full"
                                   Immediate="true" />
                </MudItem>
                <MudItem xs="6" md="3">
                    <MudSelect T="string" @bind-Value="_transactionTypeFilter" Label="Transaction Type" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                        <MudSelectItem Value="@("")">All Types</MudSelectItem>
                        <MudSelectItem Value="@("Payment")">Payouts (Payment)</MudSelectItem>
                        <MudSelectItem Value="@("Commission")">Credits (Commission)</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="6" md="3">
                    <MudDateRangePicker Label="Date Range" @bind-DateRange="_dateRange" AutoClose="true" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" />
                </MudItem>
            </MudGrid>

            <MudDataGrid Items="@FilteredTransactions" Hover="true" Elevation="0" Style="background: transparent;" Dense="true" Filterable="true" Loading="@_loading" Class="invoice-table">
                <Columns>
                    <PropertyColumn Property="x => x.TransactionDate" Title="Date" Format="dd/MM/yyyy">
                        <CellTemplate>
                            <div style="font-weight: 500;">@context.Item.TransactionDate.ToKolkataTime().ToString("dd MMM yyyy")</div>
                        </CellTemplate>
                    </PropertyColumn>
                    <PropertyColumn Property="x => x.BrokerName" Title="Broker Name">
                        <CellTemplate>
                            <span style="font-weight: 700; color: var(--mud-palette-text-primary);">@context.Item.BrokerName</span>
                        </CellTemplate>
                    </PropertyColumn>
                    <PropertyColumn Property="x => x.TransactionType" Title="Type">
                        <CellTemplate>
                            <span class="payment-mode-chip @(context.Item.TransactionType == "Payment" ? "mode-cash" : "mode-netbanking")">
                                @(context.Item.TransactionType == "Payment" ? "Payout" : "Commission")
                            </span>
                        </CellTemplate>
                    </PropertyColumn>
                    <PropertyColumn Property="x => x.Amount" Title="Amount">
                        <CellTemplate>
                            <span style="font-weight: 700; color: @(context.Item.TransactionType == "Payment" ? "#ef4444" : "#10b981");">
                                ₹@context.Item.Amount.ToString("N2")
                            </span>
                        </CellTemplate>
                    </PropertyColumn>
                    <PropertyColumn Property="x => x.PaymentMode" Title="Payment Mode">
                        <CellTemplate>
                            <span class="payment-mode-chip @GetPaymentModeClass(context.Item.PaymentMode)">@context.Item.PaymentMode</span>
                        </CellTemplate>
                    </PropertyColumn>
                    <PropertyColumn Property="x => x.Remarks" Title="Remarks" />
                </Columns>
            </MudDataGrid>
        </MudPaper>
    }
</MudStack>

<!-- Slide-out Record Payout Drawer -->
@if (_drawerOpen)
{
    <div class="email-slide-overlay @(_drawerClosing ? "fade-out" : "fade-in")" @onclick="CloseDrawer">
        <div class="email-slide-panel @(_drawerClosing ? "slide-out-right" : "slide-in-right")" @onclick:stopPropagation="true">
            <div class="email-slide-panel-inner">
                <div class="et-drawer-header">
                    <div class="et-drawer-header-main">
                        <div class="et-drawer-header-icon">
                            <MudIcon Icon="@Icons.Material.Filled.Payments" />
                        </div>
                        <div class="et-drawer-header-copy">
                            <h2 class="et-drawer-header-title">Record Broker Transaction</h2>
                            <p class="et-drawer-header-sub">
                                Record a manual commission credit or a payout made to a broker.
                            </p>
                        </div>
                    </div>
                    <button type="button" class="et-drawer-close" aria-label="Close panel" @onclick="CloseDrawer">
                        <MudIcon Icon="@Icons.Material.Filled.Close" />
                    </button>
                </div>

                <div class="email-slide-panel-main">
                    <EditForm Model="@_editModel" OnValidSubmit="SaveTransactionAsync" Class="email-slide-panel-form" novalidate>
                        <FluentValidationValidator />
                        <div class="email-slide-panel-body" tabindex="-1">
                            <MudStack Spacing="4">
                                <MudDatePicker @bind-Date="_editModel.TransactionDate" Label="Transaction Date *" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _editModel.TransactionDate)" MaxDate="DateTime.Today" />

                                <MudAutocomplete T="BrokerListDto" @bind-Value="_editModel.SelectedBroker" Label="Broker *"
                                                 SearchFunc="SearchBrokers" ToStringFunc="@BrokerToString" CoerceText="true" CoerceValue="true" ResetValueOnEmptyText="true"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense" PopoverFixed="true" Required="true"
                                                 For="@(() => _editModel.SelectedBroker)" />
                                
                                @if (_editModel.SelectedBroker != null)
                                {
                                    <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Square="false" Dense="true" Class="rounded-lg">
                                        Current Balance: <strong>₹@_editModel.SelectedBroker.CurrentBalance.ToString("N2")</strong>
                                    </MudAlert>
                                }

                                <MudSelect T="string" @bind-Value="_editModel.TransactionType" Label="Transaction Type *" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _editModel.TransactionType)" PopoverFixed="true">
                                    <MudSelectItem Value="@("Payment")">Payout (Debit)</MudSelectItem>
                                    <MudSelectItem Value="@("Commission")">Commission Credit (Credit)</MudSelectItem>
                                </MudSelect>

                                <MudNumericField @bind-Value="_editModel.Amount" Label="Amount (₹) *" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _editModel.Amount)" HideSpinButtons="true" />

                                @if (_editModel.TransactionType == "Payment")
                                {
                                    <MudSelect T="string" @bind-Value="_editModel.PaymentMode" Label="Payment Mode *" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _editModel.PaymentMode)" PopoverFixed="true">
                                        @foreach (var mode in _paymentModes)
                                        {
                                            <MudSelectItem Value="@mode">@mode</MudSelectItem>
                                        }
                                    </MudSelect>
                                }

                                <MudTextField @bind-Value="_editModel.Remarks" Label="Remarks / Descriptions" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" For="@(() => _editModel.Remarks)" />
                            </MudStack>
                        </div>

                        <div class="email-slide-panel-footer">
                            <MudStack Row="true" Spacing="2">
                                <MudButton Variant="Variant.Text" Disabled="_saving" OnClick="CloseDrawer">Cancel</MudButton>
                                <MudSpacer />
                                <MudButton Variant="Variant.Filled"
                                           Class="dashboard-action-primary save-btn"
                                           ButtonType="ButtonType.Submit"
                                           Disabled="_saving">
                                    @(_saving ? "Recording..." : "Record Transaction")
                                </MudButton>
                            </MudStack>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<RecentBrokerTransactionDto> _transactions = [];
    private List<BrokerListDto> _brokers = [];
    private string _searchQuery = string.Empty;
    private string _transactionTypeFilter = string.Empty;
    private DateRange _dateRange = new DateRange(DateTime.Today.AddDays(-30), DateTime.Today);
    private bool _loading = true;
    private bool _saving = false;

    private bool _drawerOpen = false;
    private bool _drawerClosing = false;
    private bool _bodyScrollLocked = false;
    private BrokerTransactionFormModel _editModel = new();

    private string[] _paymentModes = new[] { "Cash", "UPI", "NetBanking" };

    private IEnumerable<RecentBrokerTransactionDto> FilteredTransactions
    {
        get
        {
            var query = _transactions.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(_searchQuery))
            {
                query = query.Where(t => 
                    t.BrokerName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) || 
                    (t.Remarks != null && t.Remarks.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)));
            }

            if (!string.IsNullOrWhiteSpace(_transactionTypeFilter))
            {
                query = query.Where(t => string.Equals(t.TransactionType, _transactionTypeFilter, StringComparison.OrdinalIgnoreCase));
            }

            if (_dateRange?.Start.HasValue == true)
            {
                query = query.Where(t => t.TransactionDate.Date >= _dateRange.Start.Value.Date);
            }

            if (_dateRange?.End.HasValue == true)
            {
                query = query.Where(t => t.TransactionDate.Date <= _dateRange.End.Value.Date);
            }

            return query;
        }
    }

    private decimal TodayPayments => _transactions
        .Where(t => t.TransactionType == "Payment" && t.TransactionDate.Date == DateTime.Today.Date)
        .Sum(t => t.Amount);

    private decimal MonthlyPayments => _transactions
        .Where(t => t.TransactionType == "Payment" && t.TransactionDate.Year == DateTime.Today.Year && t.TransactionDate.Month == DateTime.Today.Month)
        .Sum(t => t.Amount);

    private decimal MonthlyCommission => _transactions
        .Where(t => t.TransactionType == "Commission" && t.TransactionDate.Year == DateTime.Today.Year && t.TransactionDate.Month == DateTime.Today.Month)
        .Sum(t => t.Amount);

    private string PaymentSplit => GetPaymentSplit();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _brokers = await BrokerWebService.GetBrokersAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Error($"Failed to fetch brokers: {ex.Message}");
        }

        try
        {
            _transactions = await BrokerWebService.GetRecentBrokerTransactionsAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Error($"Failed to fetch transactions: {ex.Message}");
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private Func<BrokerListDto, string> BrokerToString = b => b == null 
        ? "" 
        : $"{b.Name} (Bal: ₹{b.CurrentBalance:N0})";

    private async Task<IEnumerable<BrokerListDto>> SearchBrokers(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value))
            return _brokers;
        return _brokers.Where(b => 
            b.Name.Contains(value, StringComparison.OrdinalIgnoreCase) || 
            b.Phone.Contains(value, StringComparison.OrdinalIgnoreCase));
    }

    private void OpenAddDrawer()
    {
        _editModel = new BrokerTransactionFormModel 
        { 
            TransactionDate = DateTime.Today,
            TransactionType = "Payment",
            PaymentMode = "Cash"
        };

        _drawerOpen = true;
    }

    private async Task CloseDrawer()
    {
        if (_drawerClosing)
            return;

        _drawerClosing = true;
        StateHasChanged();
        await Task.Delay(300);
        _drawerOpen = false;
        _drawerClosing = false;
        _editModel = new BrokerTransactionFormModel();
    }

    private async Task SaveTransactionAsync()
    {
        if (_editModel.SelectedBroker == null)
        {
            NotificationService.Warning("Please select a broker.");
            return;
        }

        _saving = true;
        StateHasChanged();
        try
        {
            var request = new CreateBrokerTransactionDto
            {
                BrokerId = _editModel.SelectedBroker.Id,
                Amount = _editModel.Amount,
                TransactionType = _editModel.TransactionType,
                PaymentMode = _editModel.TransactionType == "Payment" ? _editModel.PaymentMode : "N/A",
                Remarks = _editModel.Remarks,
                TransactionDate = _editModel.TransactionDate ?? DateTime.UtcNow
            };

            var success = await BrokerWebService.RecordBrokerTransactionAsync(request);
            if (success)
            {
                NotificationService.Success($"Transaction of ₹{request.Amount:N2} successfully recorded.");
                _drawerOpen = false;
                await LoadDataAsync();
            }
            else
            {
                NotificationService.Error("Failed to record transaction. Please try again.");
            }
        }
        catch (Exception ex)
        {
            NotificationService.Error($"API Connection Error: {ex.Message}");
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private string GetPaymentSplit()
    {
        var payouts = _transactions.Where(t => t.TransactionType == "Payment").ToList();
        if (!payouts.Any()) return "Cash: 0% | UPI: 0%";
        var cash = payouts.Where(p => string.Equals(p.PaymentMode, "Cash", StringComparison.OrdinalIgnoreCase)).Sum(p => p.Amount);
        var upi = payouts.Where(p => string.Equals(p.PaymentMode, "UPI", StringComparison.OrdinalIgnoreCase)).Sum(p => p.Amount);
        var net = payouts.Where(p => string.Equals(p.PaymentMode, "NetBanking", StringComparison.OrdinalIgnoreCase)).Sum(p => p.Amount);
        var total = cash + upi + net;
        if (total == 0) return "Cash: 0% | UPI: 0%";
        
        var cashPct = (cash / total) * 100;
        var upiPct = (upi / total) * 100;
        var netPct = (net / total) * 100;

        return $"Cash: {cashPct:0}% | UPI: {upiPct:0}% | Net: {netPct:0}%";
    }

    private string GetPaymentModeClass(string mode) => mode switch
    {
        "Cash" => "mode-cash",
        "UPI" => "mode-upi",
        "N/A" => "mode-netbanking",
        _ => "mode-netbanking"
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var shouldLock = _drawerOpen && !_drawerClosing;
        if (shouldLock == _bodyScrollLocked)
            return;

        _bodyScrollLocked = shouldLock;
        await JSRuntime.InvokeVoidAsync("eval", shouldLock
            ? "document.documentElement.classList.add('email-panel-open');document.body.classList.add('email-panel-open')"
            : "document.documentElement.classList.remove('email-panel-open');document.body.classList.remove('email-panel-open')");
    }

    public async ValueTask DisposeAsync()
    {
        if (!_bodyScrollLocked)
            return;

        try
        {
            await JSRuntime.InvokeVoidAsync("eval", "document.documentElement.classList.remove('email-panel-open');document.body.classList.remove('email-panel-open')");
        }
        catch
        {
            // Ignored if JS runtime is disconnected during disposal
        }
    }
}
