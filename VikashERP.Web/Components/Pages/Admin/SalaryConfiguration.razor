@page "/admin/salary-config"
@using MudBlazor
@using VikashERP.Web.Models
@using VikashERP.Web.Services
@using VikashERP.SharedKernel.Enums
@inject ISalaryConfigurationService SalaryService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "SuperAdmin, Super Admin, Admin, Manager")]

<PageTitle>Salary Setup - The Iron Ledger</PageTitle>

<MudStack Class="payments-page" Spacing="2">
    <!-- Header Hero -->
    <div class="org-hero">
        <MudStack Spacing="0" Class="org-hero-copy">
            <MudText Typo="Typo.h5" HtmlTag="h1">Salary Configuration</MudText>
            <MudText Typo="Typo.body2" Class="dashboard-subtitle org-subtitle">
                Manage staff basic salaries
            </MudText>
        </MudStack>
        <MudButton Variant="Variant.Filled"
                   Class="dashboard-action-primary org-save-btn"
                   StartIcon="@Icons.Material.Filled.AddCard"
                   OnClick="OpenAddForm"
                   Disabled="@_isLoading">
            New Configuration
        </MudButton>
    </div>

    <!-- KPI Cards -->
    <MudGrid Spacing="2" Class="dashboard-kpis">
        <MudItem xs="12" sm="6" lg="3">
            <MudPaper Elevation="0" Class="dashboard-kpi">
                <MudPaper Elevation="0" Class="dashboard-kpi-icon accent-blue">
                    <MudIcon Icon="@Icons.Material.Filled.People" />
                </MudPaper>
                <MudStack Spacing="0" Class="dashboard-kpi-body">
                    <MudText Typo="Typo.caption">Total Configured</MudText>
                    <MudText Typo="Typo.h5" HtmlTag="strong">@_configurations.Count</MudText>
                    <MudText Typo="Typo.caption" Class="trend-neutral">Active staff</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudPaper Elevation="0" Class="dashboard-kpi">
                <MudPaper Elevation="0" Class="dashboard-kpi-icon accent-green">
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" />
                </MudPaper>
                <MudStack Spacing="0" Class="dashboard-kpi-body">
                    <MudText Typo="Typo.caption">Total Basic Salary</MudText>
                    <MudText Typo="Typo.h5" HtmlTag="strong">₹@_configurations.Sum(c => c.BasicSalary).ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Class="trend-neutral">Monthly payout</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudPaper Elevation="0" Class="org-tab-panel pa-6">
        <MudGrid Class="mb-4 d-flex align-center">
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_searchString"
                               Placeholder="Search by name or role..."
                               Adornment="Adornment.Start"
                               AdornmentIcon="@Icons.Material.Filled.Search"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Class="search-bar-full"
                               Immediate="true" />
            </MudItem>
        </MudGrid>

        <MudDataGrid Items="@_configurations" Hover="true" Elevation="0" Style="background: transparent;" Dense="true" Filterable="true" Loading="@_isLoading" QuickFilter="@_quickFilter" Class="invoice-table">
            <Columns>
                <PropertyColumn Property="x => x.UserName" Title="User Name">
                    <CellTemplate>
                        <span style="font-weight: 700; color: var(--mud-palette-text-primary);">@context.Item.UserName</span>
                    </CellTemplate>
                </PropertyColumn>
                <PropertyColumn Property="x => x.UserRole" Title="Role" />
                <TemplateColumn Title="Basic Salary">
                    <CellTemplate>
                        <span style="font-weight: 700; color: #10b981;">₹@context.Item.BasicSalary.ToString("N0")</span>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Status">
                    <CellTemplate>
                        @if (context.Item.IsActive)
                        {
                            <span class="payment-mode-chip mode-cash">Active</span>
                        }
                        else
                        {
                            <span class="payment-mode-chip mode-netbanking">Inactive</span>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Actions" Sortable="false" Filterable="false">
                    <CellTemplate>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Default" Size="Size.Small" OnClick="@(() => OpenEditForm(context.Item))" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <PagerContent>
                <MudDataGridPager T="SalaryConfigDto" />
            </PagerContent>
        </MudDataGrid>
    </MudPaper>
</MudStack>

<!-- Slide-out Drawer -->
@if (_isFormOpen)
{
    <div class="email-slide-overlay @(_drawerClosing ? "fade-out" : "fade-in")" @onclick="CloseDrawer">
        <div class="email-slide-panel @(_drawerClosing ? "slide-out-right" : "slide-in-right")" @onclick:stopPropagation="true">
            <div class="email-slide-panel-inner">
                <div class="et-drawer-header">
                    <div class="et-drawer-header-main">
                        <div class="et-drawer-header-icon">
                            <MudIcon Icon="@(_isEditing ? Icons.Material.Filled.Edit : Icons.Material.Filled.AddCard)" />
                        </div>
                        <div class="et-drawer-header-copy">
                            <h2 class="et-drawer-header-title">@(_isEditing ? "Edit Salary" : "New Salary")</h2>
                            <p class="et-drawer-header-sub">
                                Configure basic salary for staff members.
                            </p>
                        </div>
                    </div>
                    <button type="button" class="et-drawer-close" aria-label="Close panel" @onclick="CloseDrawer">
                        <MudIcon Icon="@Icons.Material.Filled.Close" />
                    </button>
                </div>

                <div class="email-slide-panel-main">
                    <EditForm Model="@_editModel" OnValidSubmit="SaveConfig" class="email-slide-panel-form" novalidate>
                        <div class="email-slide-panel-body" tabindex="-1">
                            <MudStack Spacing="4">
                                @if (!_isEditing)
                                {
                                    <MudSelect T="string" @bind-Value="_selectedRole" @bind-Value:after="OnRoleChanged" Label="Role" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                                        <MudSelectItem Value="@("")" Disabled="true">Select Role</MudSelectItem>
                                        <MudSelectItem Value="@(UserRole.Employee.ToFriendlyName())">Employee</MudSelectItem>
                                        <MudSelectItem Value="@(UserRole.Manager.ToFriendlyName())">Manager</MudSelectItem>
                                        <MudSelectItem Value="@(UserRole.BackOfficeUser.ToFriendlyName())">Back Office User</MudSelectItem>
                                    </MudSelect>

                                    <MudSelect T="Guid?" @bind-Value="_editModel.UserId" Label="User" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(string.IsNullOrEmpty(_selectedRole) || !_availableUsers.Any())">
                                        <MudSelectItem T="Guid?" Value="@(null)" Disabled="true">Select User</MudSelectItem>
                                        @foreach (var u in _availableUsers)
                                        {
                                            <MudSelectItem T="Guid?" Value="@(u.Id)">@u.Name</MudSelectItem>
                                        }
                                    </MudSelect>
                                }
                                else
                                {
                                    <MudTextField Value="@_editUserName" Label="User" ReadOnly="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                }

                                <MudNumericField @bind-Value="_editModel.BasicSalary" Label="Basic Salary (₹)" Required="true" Min="0" Variant="Variant.Outlined" Margin="Margin.Dense" HideSpinButtons="true" />

                                <MudSwitch @bind-Value="_editModel.IsActive" Color="Color.Success" Label="Active Status" />
                            </MudStack>
                        </div>

                        <div class="email-slide-panel-footer">
                            <MudStack Row="true" Spacing="2">
                                @if (_isEditing)
                                {
                                    <MudButton Color="Color.Error" Disabled="@_isSaving" OnClick="DeleteConfig">Delete</MudButton>
                                }
                                <MudSpacer />
                                <MudButton Variant="Variant.Text" Disabled="_isSaving" OnClick="CloseDrawer">Cancel</MudButton>
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Class="save-btn"
                                           ButtonType="ButtonType.Submit"
                                           Disabled="_isSaving">
                                    @(_isSaving ? "Saving..." : (_isEditing ? "Update" : "Save"))
                                </MudButton>
                            </MudStack>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<style>
.email-slide-overlay {
    position: fixed;
    inset: 0;
    z-index: 1300;
    background: rgba(15, 23, 42, 0.45);
    backdrop-filter: blur(2px);
    overflow: hidden;
}

.email-slide-panel {
    position: fixed;
    top: 0;
    right: 0;
    height: 100%;
    height: 100dvh;
    width: 100%;
    max-width: 520px;
    background: var(--mud-palette-surface);
    border-left: 1px solid var(--mud-palette-lines-default);
    box-shadow: -12px 0 32px rgba(15, 23, 42, 0.12);
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

.email-slide-panel-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 0;
    overflow: hidden;
}

.email-slide-panel-main {
    display: flex;
    flex-direction: column;
    flex: 1 1 0;
    min-height: 0;
    overflow: hidden;
}

.email-slide-panel-main ::deep form.email-slide-panel-form {
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
    min-height: 0;
    height: 100%;
    overflow: hidden;
}

.et-drawer-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 20px 18px;
    background: linear-gradient(135deg, #102a43 0%, #243b53 48%, #10b981 100%);
    border-bottom: none;
    flex-shrink: 0;
    position: relative;
    z-index: 2;
}

.et-drawer-header::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: linear-gradient(180deg, #63e6be 0%, #10b981 100%);
    border-radius: 0 4px 4px 0;
}

.et-drawer-header-main {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    min-width: 0;
    padding-left: 6px;
}

.et-drawer-header-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.12);
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border: 1px solid rgba(255, 255, 255, 0.18);
}

.et-drawer-header-icon .mud-icon-root {
    font-size: 1.35rem !important;
}

.et-drawer-header-copy {
    min-width: 0;
}

.et-drawer-header-title {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 800;
    color: #ffffff;
    line-height: 1.25;
    letter-spacing: -0.02em;
}

.et-drawer-header-sub {
    margin: 6px 0 0;
    font-size: 0.8rem;
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.72);
}

.et-drawer-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.1);
    color: #ffffff;
    cursor: pointer;
    flex-shrink: 0;
    padding: 0;
    transition: background-color 0.12s ease, border-color 0.12s ease;
}

.et-drawer-close .mud-icon-root {
    font-size: 1.1rem !important;
}

.et-drawer-close:hover {
    background: rgba(255, 255, 255, 0.18);
    border-color: rgba(255, 255, 255, 0.35);
}

.email-slide-panel-body {
    flex: 1 1 0;
    min-height: 0;
    max-height: 100%;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 20px;
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
    touch-action: pan-y;
    scrollbar-width: none;
    -ms-overflow-style: none;
}

.email-slide-panel-body::-webkit-scrollbar {
    display: none;
}

.email-slide-panel-footer {
    flex-shrink: 0;
    padding: 16px 20px;
    border-top: 1px solid var(--mud-palette-lines-default);
    background: var(--mud-palette-surface);
    z-index: 2;
}

.save-btn {
    border-radius: 8px !important;
    font-weight: 700 !important;
    text-transform: none !important;
}

.fade-in {
    animation: emailFadeIn 0.25s ease-out forwards;
}

.fade-out {
    animation: emailFadeOut 0.25s ease-in forwards;
}

.slide-in-right {
    animation: emailSlideInRight 0.3s ease-out forwards;
}

.slide-out-right {
    animation: emailSlideOutRight 0.3s ease-in forwards;
}

@@keyframes emailFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

@@keyframes emailFadeOut {
    from { opacity: 1; }
    to { opacity: 0; }
}

@@keyframes emailSlideInRight {
    from { transform: translateX(100%); }
    to { transform: translateX(0); }
}

@@keyframes emailSlideOutRight {
    from { transform: translateX(0); }
    to { transform: translateX(100%); }
}

@@media (max-width: 640px) {
    .email-slide-panel {
        max-width: 100%;
    }
}

/* Dark mode styling */
.app-dark-mode .dashboard-kpi {
    background-color: #1e293b;
    border-color: #334155;
}

.app-dark-mode .dashboard-kpi strong {
    color: #f8fafc;
}

.app-dark-mode .dashboard-kpi-body span {
    color: #94a3b8;
}

.app-dark-mode .org-tab-panel {
    background-color: #1e293b;
    border-color: #334155;
}

.app-dark-mode .search-bar-full ::deep .mud-input {
    background-color: #0f172a;
}

.app-dark-mode .invoice-table ::deep th {
    background-color: #0f172a !important;
    color: #94a3b8 !important;
}

.app-dark-mode .invoice-table ::deep td {
    color: #cbd5e1 !important;
    border-bottom-color: #334155;
}

.app-dark-mode .drawer-header {
    background-color: #0f172a;
    border-bottom-color: #334155;
}

.app-dark-mode .drawer-title {
    color: #f8fafc !important;
}

.app-dark-mode .mode-cash {
    background-color: rgba(22, 163, 74, 0.15);
    color: #4ade80;
    border-color: rgba(34, 197, 94, 0.3);
}
.app-dark-mode .mode-upi {
    background-color: rgba(2, 132, 199, 0.15);
    color: #38bdf8;
    border-color: rgba(14, 165, 233, 0.3);
}
.app-dark-mode .mode-netbanking {
    background-color: rgba(124, 58, 237, 0.15);
    color: #c084fc;
    border-color: rgba(139, 92, 246, 0.3);
}

</style>

@code {
    private List<SalaryConfigDto> _configurations = new();
    private List<RoleUserDto> _availableUsers = new();
    
    private bool _isLoading = true;
    private bool _isSaving = false;
    
    private bool _drawerClosing = false;
    private bool _isFormOpen = false;
    private bool _isEditing = false;
    private Guid _editingId;
    private string _editUserName = "";
    
    private string _selectedRole = "";
    
    private class ConfigFormModel
    {
        public Guid? UserId { get; set; }
        public decimal BasicSalary { get; set; }
        public bool IsActive { get; set; } = true;
    }
    
    private ConfigFormModel _editModel = new();
    private DialogOptions _dialogOptions = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true, BackdropClick = false };
    private string _searchString = "";

    private Func<SalaryConfigDto, bool> _quickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;
        if (x.UserName.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (x.UserRole.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        StateHasChanged();
        
        _configurations = await SalaryService.GetConfigurationsAsync();
        
        _isLoading = false;
        StateHasChanged();
    }

    private async Task OnRoleChanged()
    {
        _availableUsers.Clear();
        _editModel.UserId = null;
        StateHasChanged();
        
        if (!string.IsNullOrEmpty(_selectedRole))
        {
            _availableUsers = await SalaryService.GetUsersByRoleAsync(_selectedRole);
        }
        StateHasChanged();
    }

    private async Task OpenAddForm()
    {
        _isEditing = false;
        _editModel = new ConfigFormModel { IsActive = true };
        _selectedRole = "";

        _availableUsers.Clear();
        _isFormOpen = true;
    }

    private void OpenEditForm(SalaryConfigDto config)
    {
        _isEditing = true;
        _editingId = config.Id;
        _editUserName = config.UserName;
        
        _editModel = new ConfigFormModel
        {
            UserId = config.UserId,
            BasicSalary = config.BasicSalary,
            IsActive = config.IsActive
        };
        
        _isFormOpen = true;
    }

    private async Task CloseDrawer()
    {
        _drawerClosing = true;
        StateHasChanged();
        await Task.Delay(250);
        _isFormOpen = false;
        _drawerClosing = false;
        StateHasChanged();
    }

    private async Task SaveConfig()
    {
        if (_editModel.UserId == null || _editModel.UserId == Guid.Empty || _editModel.BasicSalary < 0)
        {
            Snackbar.Add("Please select a user and enter a valid salary.", Severity.Warning);
            return;
        }

        _isSaving = true;
        StateHasChanged();

        if (_isEditing)
        {
            var request = new UpdateSalaryConfigDto
            {
                BasicSalary = _editModel.BasicSalary,
                IsActive = _editModel.IsActive
            };
            
            var success = await SalaryService.UpdateConfigurationAsync(_editingId, request);
            if (success)
            {
                Snackbar.Add("Salary updated", Severity.Success);
                await CloseDrawer();
                await LoadDataAsync();
            }
            else
            {
                Snackbar.Add("Failed to update salary", Severity.Error);
            }
        }
        else
        {
            var request = new CreateSalaryConfigDto
            {
                UserId = _editModel.UserId.Value,
                BasicSalary = _editModel.BasicSalary,
                IsActive = _editModel.IsActive
            };
            
            var success = await SalaryService.CreateConfigurationAsync(request);
            if (success)
            {
                Snackbar.Add("Salary configured", Severity.Success);
                await CloseDrawer();
                await LoadDataAsync();
            }
            else
            {
                Snackbar.Add("Failed or user already configured", Severity.Error);
            }
        }
        
        _isSaving = false;
        StateHasChanged();
    }
    
    private async Task DeleteConfig()
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Delete Configuration", 
            $"Are you sure you want to delete salary config for '{_editUserName}'?", 
            yesText: "Delete", cancelText: "Cancel");
            
        if (result == true)
        {
            _isSaving = true;
            StateHasChanged();
            
            var success = await SalaryService.DeleteConfigurationAsync(_editingId);
            if (success)
            {
                Snackbar.Add("Configuration deleted", Severity.Success);
                await CloseDrawer();
                await LoadDataAsync();
            }
            else
            {
                Snackbar.Add("Failed to delete", Severity.Error);
            }
            
            _isSaving = false;
            StateHasChanged();
        }
    }
}

