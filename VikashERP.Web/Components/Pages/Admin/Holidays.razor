@page "/admin/holidays"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@implements IAsyncDisposable
@using System.Net.Http.Json
@using VikashERP.Web.Services.Interfaces
@using VikashERP.Web.Models
@using VikashERP.Web.Validation
@inject IHolidayWebService HolidayWebService
@inject INotificationService NotificationService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Holiday Calendar</PageTitle>

<PageLoader IsVisible="@_loading" Text="Syncing calendar..." />

<MudStack Class="holidays-page" Spacing="4">
    <!-- Header Hero -->
    <div class="org-hero">
        <MudStack Spacing="0" Class="org-hero-copy">
            <MudText Typo="Typo.h5" HtmlTag="h1">Holiday Calendar</MudText>
            <MudText Typo="Typo.body2" Class="dashboard-subtitle org-subtitle">
                Define and manage company holidays, religious festivals, and official closures for payroll and attendance systems.
            </MudText>
        </MudStack>
        <MudButton Variant="Variant.Filled"
                   Class="dashboard-action-primary org-save-btn"
                   StartIcon="@Icons.Material.Filled.CalendarToday"
                   OnClick="OpenAddDrawer"
                   Disabled="@_loading">
            Add Holiday
        </MudButton>
    </div>

    @if (!_loading)
    {
        <!-- KPI Cards -->
        <MudGrid Spacing="2" Class="dashboard-kpis">
            <MudItem xs="12" sm="6" lg="3">
                <MudPaper Elevation="0" Class="dashboard-kpi">
                    <MudPaper Elevation="0" Class="dashboard-kpi-icon accent-blue">
                        <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" />
                    </MudPaper>
                    <MudStack Spacing="0" Class="dashboard-kpi-body">
                        <MudText Typo="Typo.caption">Total Holidays (This Year)</MudText>
                        <MudText Typo="Typo.h5" HtmlTag="strong">@TotalHolidaysThisYear</MudText>
                        <MudText Typo="Typo.caption" Class="trend-neutral">Current calendar</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
            
            <MudItem xs="12" sm="6" lg="3">
                <MudPaper Elevation="0" Class="dashboard-kpi">
                    <MudPaper Elevation="0" Class="dashboard-kpi-icon accent-green">
                        <MudIcon Icon="@Icons.Material.Filled.EventRepeat" />
                    </MudPaper>
                    <MudStack Spacing="0" Class="dashboard-kpi-body">
                        <MudText Typo="Typo.caption">Recurring Holidays</MudText>
                        <MudText Typo="Typo.h5" HtmlTag="strong">@RecurringHolidaysCount</MudText>
                        <MudText Typo="Typo.caption" Class="trend-neutral">Repeated annually</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" lg="3">
                <MudPaper Elevation="0" Class="dashboard-kpi">
                    <MudPaper Elevation="0" Class="dashboard-kpi-icon accent-amber">
                        <MudIcon Icon="@Icons.Material.Filled.HourglassTop" />
                    </MudPaper>
                    <MudStack Spacing="0" Class="dashboard-kpi-body">
                        <MudText Typo="Typo.caption">Upcoming Holidays</MudText>
                        <MudText Typo="Typo.h5" HtmlTag="strong">@UpcomingHolidaysCount</MudText>
                        <MudText Typo="Typo.caption" Class="trend-neutral">Left in the year</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" lg="3">
                <MudPaper Elevation="0" Class="dashboard-kpi">
                    <MudPaper Elevation="0" Class="dashboard-kpi-icon accent-purple">
                        <MudIcon Icon="@Icons.Material.Filled.Upcoming" />
                    </MudPaper>
                    <MudStack Spacing="0" Class="dashboard-kpi-body">
                        <MudText Typo="Typo.caption">Next Holiday</MudText>
                        <MudText Typo="Typo.h5" HtmlTag="strong" Style="font-size: 1.05rem; line-height: 1.6; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@NextHolidayText</MudText>
                        <MudText Typo="Typo.caption" Class="trend-neutral">Next event</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- Main Datagrid Panel -->
        <MudPaper Elevation="0" Class="org-tab-panel pa-6">
            <MudGrid Class="mb-4 d-flex align-center">
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_searchQuery"
                                   Placeholder="Search by holiday name or remarks..."
                                   Adornment="Adornment.Start"
                                   AdornmentIcon="@Icons.Material.Filled.Search"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Class="search-bar-full"
                                   Immediate="true" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudDateRangePicker Label="Filter by Date Range" @bind-DateRange="_dateRange" AutoClose="true" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" />
                </MudItem>
            </MudGrid>

            <MudDataGrid Items="@FilteredHolidays" Hover="true" Elevation="0" Style="background: transparent;" Dense="true" Filterable="true" Loading="@_loading" Class="invoice-table">
                <Columns>
                    <PropertyColumn Property="x => x.Date" Title="Date">
                        <CellTemplate>
                            <div style="font-weight: 500;">@context.Item.Date.ToKolkataTime().ToString("dd MMM yyyy")</div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Item.Date.ToKolkataTime().ToString("dddd")</MudText>
                        </CellTemplate>
                    </PropertyColumn>
                    <PropertyColumn Property="x => x.Name" Title="Holiday Name">
                        <CellTemplate>
                            <span style="font-weight: 700; color: var(--mud-palette-text-primary);">@context.Item.Name</span>
                        </CellTemplate>
                    </PropertyColumn>
                    <PropertyColumn Property="x => x.IsRecurring" Title="Type">
                        <CellTemplate>
                            <span class="@($"payment-mode-chip {(context.Item.IsRecurring ? "mode-upi" : "mode-cash")}")">
                                @(context.Item.IsRecurring ? "Annual Recurring" : "One-Time")
                            </span>
                        </CellTemplate>
                    </PropertyColumn>
                    <PropertyColumn Property="x => x.Description" Title="Description" />
                    <TemplateColumn Title="Actions" HeaderStyle="text-align: right;" CellStyle="text-align: right;">
                        <CellTemplate>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" OnClick="@(() => OpenEditDrawer(context.Item))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => ConfirmDeleteAsync(context.Item))" />
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
            </MudDataGrid>
        </MudPaper>
    }
</MudStack>

<!-- Slide-out Creation & Edit Drawer -->
@if (_drawerOpen)
{
    <div class="email-slide-overlay @(_drawerClosing ? "fade-out" : "fade-in")" @onclick="CloseDrawer">
        <div class="email-slide-panel @(_drawerClosing ? "slide-out-right" : "slide-in-right")" @onclick:stopPropagation="true">
            <div class="email-slide-panel-inner">
                <div class="et-drawer-header">
                    <div class="et-drawer-header-main">
                        <div class="et-drawer-header-icon">
                            <MudIcon Icon="@(_isNewHoliday ? Icons.Material.Filled.CalendarToday : Icons.Material.Filled.EditCalendar)" />
                        </div>
                        <div class="et-drawer-header-copy">
                            <h2 class="et-drawer-header-title">@(_isNewHoliday ? "Log Holiday" : "Modify Holiday details")</h2>
                            <p class="et-drawer-header-sub">
                                @(_isNewHoliday ? "Add a new calendar closure/holiday." : "Update details for this holiday configuration.")
                            </p>
                        </div>
                    </div>
                    <button type="button" class="et-drawer-close" aria-label="Close panel" @onclick="CloseDrawer">
                        <MudIcon Icon="@Icons.Material.Filled.Close" />
                    </button>
                </div>

                <div class="email-slide-panel-main">
                    <EditForm Model="@_editModel" OnValidSubmit="SaveHolidayAsync" Class="email-slide-panel-form" novalidate>
                        <FluentValidationValidator />
                        <div class="email-slide-panel-body" tabindex="-1">
                            <MudStack Spacing="4">
                                <MudTextField @bind-Value="_editModel.Name" Label="Holiday Name *" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _editModel.Name)" />

                                <MudDatePicker @bind-Date="_editModel.Date" Label="Holiday Date *" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _editModel.Date)" />

                                <MudSwitch T="bool" @bind-Value="_editModel.IsRecurring" Label="Repeats Annually (Recurring)" Color="Color.Primary" />

                                <MudTextField @bind-Value="_editModel.Description" Label="Remarks / Descriptions" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" For="@(() => _editModel.Description)" />

                                <MudSwitch T="bool" @bind-Value="_editModel.IsActive" Label="Is Active" Color="Color.Success" />
                            </MudStack>
                        </div>

                        <div class="email-slide-panel-footer">
                            <MudStack Row="true" Spacing="2">
                                <MudButton Variant="Variant.Text" Disabled="_saving" OnClick="CloseDrawer">Cancel</MudButton>
                                <MudSpacer />
                                <MudButton Variant="Variant.Filled"
                                           Class="dashboard-action-primary save-btn"
                                           ButtonType="ButtonType.Submit"
                                           Disabled="_saving">
                                    @(_saving ? "Processing..." : (_isNewHoliday ? "Save Holiday" : "Update Holiday"))
                                </MudButton>
                            </MudStack>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<ConfirmationModal IsVisible="@_showDeleteModal"
                   Title="Delete Holiday"
                   Message="Are you sure you want to permanently delete this holiday?"
                   SubMessage="@($"{_holidayToDelete?.Name} on {_holidayToDelete?.Date.ToKolkataTime().ToString("dd MMM yyyy")}")"
                   ConfirmButtonText="Delete Holiday"
                   CancelButtonText="Cancel"
                   IsProcessing="@_deletingProcess"
                   ProcessingText="Deleting..."
                   OnConfirm="ExecuteDeleteAsync"
                   OnCancel="CancelDelete" />

@code {
    private List<HolidayDto> _holidays = [];
    private string _searchQuery = string.Empty;
    private DateRange _dateRange = new DateRange(new DateTime(DateTime.Today.Year, 1, 1), new DateTime(DateTime.Today.Year, 12, 31));
    private bool _loading = true;
    private bool _saving = false;

    private bool _drawerOpen = false;
    private bool _drawerClosing = false;
    private bool _bodyScrollLocked = false;
    private bool _isNewHoliday = true;
    private HolidayFormModel _editModel = new();
    private Guid _editingHolidayId;

    private bool _showDeleteModal = false;
    private bool _deletingProcess = false;
    private HolidayDto? _holidayToDelete = null;

    private IEnumerable<HolidayDto> FilteredHolidays
    {
        get
        {
            var query = _holidays.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(_searchQuery))
            {
                query = query.Where(h =>
                    h.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    (h.Description != null && h.Description.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)));
            }

            if (_dateRange?.Start.HasValue == true)
            {
                query = query.Where(h => h.Date.Date >= _dateRange.Start.Value.Date);
            }

            if (_dateRange?.End.HasValue == true)
            {
                query = query.Where(h => h.Date.Date <= _dateRange.End.Value.Date);
            }

            return query;
        }
    }

    private int TotalHolidaysThisYear => _holidays
        .Count(h => h.Date.Year == DateTime.Today.Year);

    private int RecurringHolidaysCount => _holidays
        .Count(h => h.IsRecurring);

    private int UpcomingHolidaysCount => _holidays
        .Count(h => h.Date.Date >= DateTime.Today.Date);

    private string NextHolidayText => GetNextHolidayText();

    protected override async Task OnInitializedAsync()
    {
        await LoadHolidaysAsync();
    }

    private async Task LoadHolidaysAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _holidays = await HolidayWebService.GetHolidaysAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Error($"Failed to fetch holidays: {ex.Message}");
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private string GetNextHolidayText()
    {
        var next = _holidays
            .Where(h => h.Date.Date >= DateTime.Today.Date)
            .OrderBy(h => h.Date)
            .FirstOrDefault();

        return next != null 
            ? $"{next.Name} ({next.Date.ToKolkataTime().ToString("dd MMM")})" 
            : "No upcoming holidays";
    }

    private void OpenAddDrawer()
    {
        _editModel = new HolidayFormModel
        {
            Date = DateTime.Today,
            IsRecurring = false,
            IsActive = true
        };
        _isNewHoliday = true;
        _drawerOpen = true;
    }

    private void OpenEditDrawer(HolidayDto holiday)
    {
        _editModel = new HolidayFormModel
        {
            Name = holiday.Name,
            Date = holiday.Date,
            IsRecurring = holiday.IsRecurring,
            Description = holiday.Description,
            IsActive = holiday.IsActive
        };
        _editingHolidayId = holiday.Id;
        _isNewHoliday = false;
        _drawerOpen = true;
    }

    private async Task CloseDrawer()
    {
        if (_drawerClosing)
            return;

        _drawerClosing = true;
        StateHasChanged();
        await Task.Delay(300);
        _drawerOpen = false;
        _drawerClosing = false;
        _editModel = new HolidayFormModel();
    }

    private async Task SaveHolidayAsync()
    {
        _saving = true;
        StateHasChanged();
        try
        {
            if (_isNewHoliday)
            {
                var request = new CreateHolidayDto
                {
                    Name = _editModel.Name,
                    Date = _editModel.Date ?? DateTime.Today,
                    IsRecurring = _editModel.IsRecurring,
                    Description = _editModel.Description
                };

                var response = await HolidayWebService.CreateHolidayAsync(request);
                if (response != null)
                {
                    NotificationService.Success("Holiday created successfully.");
                    _drawerOpen = false;
                    await LoadHolidaysAsync();
                }
                else
                {
                    NotificationService.Error("Failed to record holiday. Please try again.");
                }
            }
            else
            {
                var request = new UpdateHolidayDto
                {
                    Name = _editModel.Name,
                    Date = _editModel.Date ?? DateTime.Today,
                    IsRecurring = _editModel.IsRecurring,
                    Description = _editModel.Description,
                    IsActive = _editModel.IsActive
                };

                var success = await HolidayWebService.UpdateHolidayAsync(_editingHolidayId, request);
                if (success)
                {
                    NotificationService.Success("Holiday details updated.");
                    _drawerOpen = false;
                    await LoadHolidaysAsync();
                }
                else
                {
                    NotificationService.Error("Failed to update holiday.");
                }
            }
        }
        catch (Exception ex)
        {
            NotificationService.Error($"API Error: {ex.Message}");
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private void ConfirmDeleteAsync(HolidayDto holiday)
    {
        _holidayToDelete = holiday;
        _showDeleteModal = true;
    }

    private void CancelDelete()
    {
        _showDeleteModal = false;
        _holidayToDelete = null;
    }

    private async Task ExecuteDeleteAsync()
    {
        if (_holidayToDelete is null) return;
        _deletingProcess = true;
        StateHasChanged();
        try
        {
            var success = await HolidayWebService.DeleteHolidayAsync(_holidayToDelete.Id);
            if (success)
            {
                NotificationService.Success("Holiday removed from calendar.");
                _showDeleteModal = false;
                _holidayToDelete = null;
                await LoadHolidaysAsync();
            }
            else
            {
                NotificationService.Error("Failed to delete holiday.");
            }
        }
        catch (Exception ex)
        {
            NotificationService.Error($"API execution error: {ex.Message}");
        }
        finally
        {
            _deletingProcess = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var shouldLock = _drawerOpen && !_drawerClosing;
        if (shouldLock == _bodyScrollLocked)
            return;

        _bodyScrollLocked = shouldLock;
        await JSRuntime.InvokeVoidAsync("eval", shouldLock
            ? "document.documentElement.classList.add('email-panel-open');document.body.classList.add('email-panel-open')"
            : "document.documentElement.classList.remove('email-panel-open');document.body.classList.remove('email-panel-open')");
    }

    public async ValueTask DisposeAsync()
    {
        if (!_bodyScrollLocked)
            return;

        try
        {
            await JSRuntime.InvokeVoidAsync("eval", "document.documentElement.classList.remove('email-panel-open');document.body.classList.remove('email-panel-open')");
        }
        catch
        {
            // Ignored if JS runtime is disconnected during disposal
        }
    }
}
