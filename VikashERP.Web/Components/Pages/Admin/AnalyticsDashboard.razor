@page "/"
@page "/analytics"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "SuperAdmin, Super Admin, Admin, Manager")]
@using MudBlazor
@rendermode InteractiveServer

<PageTitle>Analytics &amp; Insights - The Iron Ledger</PageTitle>

<style>
    /* Override MainLayout padding specifically for this page to make it full-bleed */
    .app-main-container {
        padding-left: 0 !important;
        padding-right: 0 !important;
        max-width: 100% !important;
    }
    .app-page {
        padding-top: 0 !important;
    }
</style>

<div class="analytics-page-container">
    <!-- TOP NAVBAR TITLE BAR -->
    <header class="analytics-header">
        <div class="header-left">
            <h1 class="header-title">Analytics &amp; Insights</h1>
            <p class="header-subtitle">Track your business performance in real-time</p>
        </div>

        <div class="header-right">
            <!-- Date Range Selector -->
            <div class="date-selector">
                <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small" Class="mr-2 text-slate-500" />
                <span class="date-text">16 Jun 2026 - 16 Jun 2026</span>
                <span class="divider"></span>
                <span class="compare-text text-slate-500">Compare: Previous Period</span>
                <MudIcon Icon="@Icons.Material.Filled.ArrowDropDown" Size="Size.Small" Class="ml-2 text-slate-500" />
            </div>

            <!-- Filters Button -->
            <button class="btn-filters">
                <MudIcon Icon="@Icons.Material.Filled.FilterAlt" Size="Size.Small" Class="mr-1" />
                Filters
            </button>

            <!-- Quick Export and Action Icons -->
            <button class="action-icon-btn">
                <MudIcon Icon="@Icons.Material.Filled.Download" Size="Size.Small" />
            </button>
            <button class="action-icon-btn">
                <MudIcon Icon="@Icons.Material.Filled.MoreHoriz" Size="Size.Small" />
            </button>

        </div>
    </header>

    <!-- KPI ROW (6 CARDS) -->
    <section class="kpi-row">
        <!-- Card 1: Total Sales -->
        <div class="kpi-card">
            <div class="kpi-card-header">
                <span class="kpi-title">Total Sales</span>
                <div class="kpi-icon-wrap kpi-blue">
                    <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" />
                </div>
            </div>
            <div class="kpi-card-body">
                <h2 class="kpi-value">₹ 12,45,300</h2>
                <div class="kpi-trend text-success">
                    <span class="trend-icon">▲</span>
                    <span class="trend-pct">15.3%</span>
                    <span class="trend-desc text-slate-500">vs prev. period</span>
                </div>
                <!-- Sparkline SVG -->
                <div class="sparkline-wrap">
                    <svg viewBox="0 0 100 30" class="sparkline sparkline-blue">
                        <path d="M0,25 Q15,10 30,22 T60,5 T90,15 T100,10" fill="none" stroke="#3b82f6" stroke-width="2" />
                    </svg>
                </div>
            </div>
        </div>

        <!-- Card 2: Total Purchases -->
        <div class="kpi-card">
            <div class="kpi-card-header">
                <span class="kpi-title">Total Purchases</span>
                <div class="kpi-icon-wrap kpi-blue">
                    <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Small" />
                </div>
            </div>
            <div class="kpi-card-body">
                <h2 class="kpi-value">₹ 8,32,600</h2>
                <div class="kpi-trend text-success">
                    <span class="trend-icon">▲</span>
                    <span class="trend-pct">10.1%</span>
                    <span class="trend-desc text-slate-500">vs prev. period</span>
                </div>
                <!-- Sparkline SVG -->
                <div class="sparkline-wrap">
                    <svg viewBox="0 0 100 30" class="sparkline sparkline-blue">
                        <path d="M0,20 Q20,10 40,25 T70,8 T90,18 T100,12" fill="none" stroke="#3b82f6" stroke-width="2" />
                    </svg>
                </div>
            </div>
        </div>

        <!-- Card 3: Gross Profit -->
        <div class="kpi-card">
            <div class="kpi-card-header">
                <span class="kpi-title">Gross Profit</span>
                <div class="kpi-icon-wrap kpi-green">
                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" />
                </div>
            </div>
            <div class="kpi-card-body">
                <h2 class="kpi-value">₹ 4,12,700</h2>
                <div class="kpi-trend text-success">
                    <span class="trend-icon">▲</span>
                    <span class="trend-pct">18.7%</span>
                    <span class="trend-desc text-slate-500">vs prev. period</span>
                </div>
                <!-- Sparkline SVG -->
                <div class="sparkline-wrap">
                    <svg viewBox="0 0 100 30" class="sparkline sparkline-green">
                        <path d="M0,22 Q10,12 30,24 T60,8 T80,14 T100,5" fill="none" stroke="#10b981" stroke-width="2" />
                    </svg>
                </div>
            </div>
        </div>

        <!-- Card 4: Expenses -->
        <div class="kpi-card">
            <div class="kpi-card-header">
                <span class="kpi-title">Expenses</span>
                <div class="kpi-icon-wrap kpi-orange">
                    <MudIcon Icon="@Icons.Material.Filled.Payments" Size="Size.Small" />
                </div>
            </div>
            <div class="kpi-card-body">
                <h2 class="kpi-value">₹ 1,24,350</h2>
                <div class="kpi-trend text-danger">
                    <span class="trend-icon">▼</span>
                    <span class="trend-pct">5.3%</span>
                    <span class="trend-desc text-slate-500">vs prev. period</span>
                </div>
                <!-- Sparkline SVG -->
                <div class="sparkline-wrap">
                    <svg viewBox="0 0 100 30" class="sparkline sparkline-orange">
                        <path d="M0,10 Q20,25 40,15 T70,22 T90,12 T100,28" fill="none" stroke="#f59e0b" stroke-width="2" />
                    </svg>
                </div>
            </div>
        </div>

        <!-- Card 5: Net Profit -->
        <div class="kpi-card">
            <div class="kpi-card-header">
                <span class="kpi-title">Net Profit</span>
                <div class="kpi-icon-wrap kpi-green">
                    <MudIcon Icon="@Icons.Material.Filled.BarChart" Size="Size.Small" />
                </div>
            </div>
            <div class="kpi-card-body">
                <h2 class="kpi-value">₹ 2,88,350</h2>
                <div class="kpi-trend text-success">
                    <span class="trend-icon">▲</span>
                    <span class="trend-pct">22.4%</span>
                    <span class="trend-desc text-slate-500">vs prev. period</span>
                </div>
                <!-- Sparkline SVG -->
                <div class="sparkline-wrap">
                    <svg viewBox="0 0 100 30" class="sparkline sparkline-green">
                        <path d="M0,26 Q15,14 30,22 T60,6 T90,12 T100,2" fill="none" stroke="#10b981" stroke-width="2" />
                    </svg>
                </div>
            </div>
        </div>

        <!-- Card 6: Outstanding (Due) -->
        <div class="kpi-card">
            <div class="kpi-card-header">
                <span class="kpi-title">Outstanding (Due)</span>
                <div class="kpi-icon-wrap kpi-red">
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
                </div>
            </div>
            <div class="kpi-card-body">
                <h2 class="kpi-value">₹ 6,75,140</h2>
                <div class="kpi-trend text-danger">
                    <span class="trend-icon">▲</span>
                    <span class="trend-pct">7.6%</span>
                    <span class="trend-desc text-slate-500">vs prev. period</span>
                </div>
                <!-- Sparkline SVG -->
                <div class="sparkline-wrap">
                    <svg viewBox="0 0 100 30" class="sparkline sparkline-red">
                        <path d="M0,12 Q20,18 40,8 T70,25 T95,12 T100,20" fill="none" stroke="#ef4444" stroke-width="2" />
                    </svg>
                </div>
            </div>
        </div>
    </section>

    <!-- MIDDLE ROW: SALES TREND, CATEGORY SPLIT, CUSTOMER SPLIT -->
    <section class="middle-row-grid mt-4">
        <!-- Sales Trend Line Chart -->
        <div class="chart-panel sales-trend-panel">
            <div class="panel-header">
                <span class="panel-title">Sales Trend</span>
                <div class="select-wrap">
                    <select class="panel-select">
                        <option value="daily">Daily</option>
                        <option value="weekly">Weekly</option>
                        <option value="monthly">Monthly</option>
                    </select>
                    <MudIcon Icon="@Icons.Material.Filled.ArrowDropDown" Class="select-arrow" Size="Size.Small" />
                </div>
            </div>
            <div class="panel-body">
                <!-- SVG Line Chart (Smooth Bezier) -->
                <div class="line-chart-container">
                    <svg viewBox="0 0 600 220" width="100%" height="100%">
                        <!-- Y-axis helper lines -->
                        <line x1="40" y1="30" x2="570" y2="30" class="chart-grid-line" />
                        <line x1="40" y1="80" x2="570" y2="80" class="chart-grid-line" />
                        <line x1="40" y1="130" x2="570" y2="130" class="chart-grid-line" />
                        <line x1="40" y1="180" x2="570" y2="180" class="chart-grid-line" />

                        <!-- Grid Y labels -->
                        <text x="30" y="34" fill="#94a3b8" font-size="9" text-anchor="end">2L</text>
                        <text x="30" y="84" fill="#94a3b8" font-size="9" text-anchor="end">1.5L</text>
                        <text x="30" y="134" fill="#94a3b8" font-size="9" text-anchor="end">1L</text>
                        <text x="30" y="184" fill="#94a3b8" font-size="9" text-anchor="end">50K</text>
                        <text x="30" y="215" fill="#94a3b8" font-size="9" text-anchor="end">0</text>

                        <!-- Chart Legend -->
                        <g transform="translate(40, 10)">
                            <circle cx="10" cy="5" r="4" fill="#3b82f6" />
                            <text x="20" y="9" class="chart-legend-text" font-size="9">Current Period</text>
                            
                            <circle cx="110" cy="5" r="4" fill="#94a3b8" />
                            <line x1="106" y1="5" x2="114" y2="5" stroke="#94a3b8" stroke-width="2" />
                            <text x="120" y="9" class="chart-legend-text" font-size="9">Previous Period</text>
                        </g>

                        <!-- Area Gradient -->
                        <defs>
                            <linearGradient id="chart-area-grad" x1="0" y1="0" x2="0" y2="1">
                                <stop offset="0%" stop-color="#3b82f6" stop-opacity="0.25" />
                                <stop offset="100%" stop-color="#3b82f6" stop-opacity="0.0" />
                            </linearGradient>
                        </defs>
                        
                        <!-- Smooth Previous Period Line -->
                        <path d="M60,160 C100,165 140,150 180,120 C220,90 260,110 300,140 C340,170 380,140 420,130 C460,120 500,145 540,110" 
                              fill="none" stroke="#475569" stroke-width="1.5" stroke-dasharray="3 3" />

                        <!-- Area under current line -->
                        <path d="M60,160 C100,155 140,110 180,125 C220,140 260,95 300,75 C340,55 380,105 420,70 C460,35 500,85 540,65 L540,180 L60,180 Z" 
                              fill="url(#chart-area-grad)" />

                        <!-- Smooth Current Period Line -->
                        <path d="M60,160 C100,155 140,110 180,125 C220,140 260,95 300,75 C340,55 380,105 420,70 C460,35 500,85 540,65" 
                              fill="none" stroke="#3b82f6" stroke-width="3" />

                        <!-- Node dots (Current Period) -->
                        <circle cx="60" cy="160" r="4" fill="#3b82f6" stroke="#0b1220" stroke-width="1.5" />
                        <circle cx="128" cy="132" r="4" fill="#3b82f6" stroke="#0b1220" stroke-width="1.5" />
                        <circle cx="196" cy="120" r="4" fill="#3b82f6" stroke="#0b1220" stroke-width="1.5" />
                        <circle cx="264" cy="105" r="4" fill="#3b82f6" stroke="#0b1220" stroke-width="1.5" />
                        <circle cx="332" cy="72" r="4" fill="#3b82f6" stroke="#0b1220" stroke-width="1.5" />
                        <circle cx="400" cy="88" r="4" fill="#3b82f6" stroke="#0b1220" stroke-width="1.5" />
                        <circle cx="468" cy="48" r="4" fill="#3b82f6" stroke="#0b1220" stroke-width="1.5" />
                        <circle cx="540" cy="65" r="4" fill="#3b82f6" stroke="#0b1220" stroke-width="1.5" />

                        <!-- X Axis labels -->
                        <text x="60" y="200" fill="#94a3b8" font-size="9" text-anchor="middle">10 Jun</text>
                        <text x="128" y="200" fill="#94a3b8" font-size="9" text-anchor="middle">11 Jun</text>
                        <text x="196" y="200" fill="#94a3b8" font-size="9" text-anchor="middle">12 Jun</text>
                        <text x="264" y="200" fill="#94a3b8" font-size="9" text-anchor="middle">13 Jun</text>
                        <text x="332" y="200" fill="#94a3b8" font-size="9" text-anchor="middle">14 Jun</text>
                        <text x="400" y="200" fill="#94a3b8" font-size="9" text-anchor="middle">15 Jun</text>
                        <text x="468" y="200" fill="#94a3b8" font-size="9" text-anchor="middle">16 Jun</text>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Sales by Category Donut Chart -->
        <div class="chart-panel donut-panel">
            <div class="panel-header">
                <span class="panel-title">Sales by Category</span>
            </div>
            <div class="panel-body flex-row-layout">
                <!-- Circular Chart -->
                <div class="donut-chart-wrap">
                    <svg viewBox="0 0 100 100" class="donut-svg">
                        <!-- Background Circle -->
                        <circle cx="50" cy="50" r="40" fill="none" stroke="rgba(255,255,255,0.02)" stroke-width="10" />
                        
                        <!-- Segments (Calculated percentages) -->
                        <!-- TMT Bars: 42.1% (Dash: 105.8, Offset: 0) -->
                        <circle cx="50" cy="50" r="40" fill="none" stroke="#10b981" stroke-width="10" 
                                stroke-dasharray="105.8 251.2" stroke-dashoffset="0" transform="rotate(-90 50 50)" />
                        <!-- MS Pipes: 22.9% (Dash: 57.5, Offset: -105.8) -->
                        <circle cx="50" cy="50" r="40" fill="none" stroke="#3b82f6" stroke-width="10" 
                                stroke-dasharray="57.5 251.2" stroke-dashoffset="-105.8" transform="rotate(-90 50 50)" />
                        <!-- MS Angles: 13.3% (Dash: 33.4, Offset: -163.3) -->
                        <circle cx="50" cy="50" r="40" fill="none" stroke="#ef4444" stroke-width="10" 
                                stroke-dasharray="33.4 251.2" stroke-dashoffset="-163.3" transform="rotate(-90 50 50)" />
                        <!-- Sheets: 10.8% (Dash: 27.1, Offset: -196.7) -->
                        <circle cx="50" cy="50" r="40" fill="none" stroke="#8b5cf6" stroke-width="10" 
                                stroke-dasharray="27.1 251.2" stroke-dashoffset="-196.7" transform="rotate(-90 50 50)" />
                        <!-- GI Products: 8.3% (Dash: 20.8, Offset: -223.8) -->
                        <circle cx="50" cy="50" r="40" fill="none" stroke="#f59e0b" stroke-width="10" 
                                stroke-dasharray="20.8 251.2" stroke-dashoffset="-223.8" transform="rotate(-90 50 50)" />
                        <!-- Others: 2.4% (Dash: 6.0, Offset: -244.6) -->
                        <circle cx="50" cy="50" r="40" fill="none" stroke="#64748b" stroke-width="10" 
                                stroke-dasharray="6.0 251.2" stroke-dashoffset="-244.6" transform="rotate(-90 50 50)" />

                        <!-- Center text -->
                        <text x="50" y="47" text-anchor="middle" class="donut-title" font-size="7" font-weight="700">Total</text>
                        <text x="50" y="58" text-anchor="middle" class="donut-value" font-size="9" font-weight="800">₹ 12.45L</text>
                    </svg>
                </div>

                <!-- Legends -->
                <div class="donut-legends">
                    <div class="legend-row">
                        <span class="legend-dot green"></span>
                        <span class="legend-label">TMT Bars</span>
                        <span class="legend-val">₹ 5,25,400 (42.1%)</span>
                    </div>
                    <div class="legend-row">
                        <span class="legend-dot blue"></span>
                        <span class="legend-label">MS Pipes</span>
                        <span class="legend-val">₹ 2,85,600 (22.9%)</span>
                    </div>
                    <div class="legend-row">
                        <span class="legend-dot red"></span>
                        <span class="legend-label">MS Angles</span>
                        <span class="legend-val">₹ 1,65,300 (13.3%)</span>
                    </div>
                    <div class="legend-row">
                        <span class="legend-dot purple"></span>
                        <span class="legend-label">Sheets</span>
                        <span class="legend-val">₹ 1,35,200 (10.8%)</span>
                    </div>
                    <div class="legend-row">
                        <span class="legend-dot orange"></span>
                        <span class="legend-label">GI Products</span>
                        <span class="legend-val">₹ 1,03,800 (8.3%)</span>
                    </div>
                    <div class="legend-row">
                        <span class="legend-dot gray"></span>
                        <span class="legend-label">Others</span>
                        <span class="legend-val">₹ 29,000 (2.4%)</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sales by Customer Type -->
        <div class="chart-panel donut-panel">
            <div class="panel-header">
                <span class="panel-title">Sales by Customer Type</span>
            </div>
            <div class="panel-body flex-row-layout">
                <!-- Circular Chart -->
                <div class="donut-chart-wrap">
                    <svg viewBox="0 0 100 100" class="donut-svg">
                        <circle cx="50" cy="50" r="40" fill="none" stroke="rgba(255,255,255,0.02)" stroke-width="10" />
                        <!-- Retail: 49.2% (Dash: 123.6, Offset: 0) -->
                        <circle cx="50" cy="50" r="40" fill="none" stroke="#3b82f6" stroke-width="10" 
                                stroke-dasharray="123.6 251.2" stroke-dashoffset="0" transform="rotate(-90 50 50)" />
                        <!-- Wholesale: 40.0% (Dash: 100.5, Offset: -123.6) -->
                        <circle cx="50" cy="50" r="40" fill="none" stroke="#f59e0b" stroke-width="10" 
                                stroke-dasharray="100.5 251.2" stroke-dashoffset="-123.6" transform="rotate(-90 50 50)" />
                        <!-- Project: 10.8% (Dash: 27.1, Offset: -224.1) -->
                        <circle cx="50" cy="50" r="40" fill="none" stroke="#ef4444" stroke-width="10" 
                                stroke-dasharray="27.1 251.2" stroke-dashoffset="-224.1" transform="rotate(-90 50 50)" />

                        <text x="50" y="47" text-anchor="middle" class="donut-title" font-size="7" font-weight="700">Total</text>
                        <text x="50" y="58" text-anchor="middle" class="donut-value" font-size="9" font-weight="800">₹ 12.45L</text>
                    </svg>
                </div>

                <!-- Legends -->
                <div class="donut-legends">
                    <div class="legend-row">
                        <span class="legend-dot blue"></span>
                        <span class="legend-label">Retail</span>
                        <span class="legend-val">₹ 6,12,400 (49.2%)</span>
                    </div>
                    <div class="legend-row">
                        <span class="legend-dot orange"></span>
                        <span class="legend-label">Wholesale</span>
                        <span class="legend-val">₹ 4,98,600 (40.0%)</span>
                    </div>
                    <div class="legend-row">
                        <span class="legend-dot red"></span>
                        <span class="legend-label">Project</span>
                        <span class="legend-val">₹ 1,34,300 (10.8%)</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- BOTTOM SECTION: BEST SELLING, LOW STOCK ALERTS, CASH FLOW -->
    <section class="bottom-row-grid mt-4">
        <!-- Top 10 Best Selling Products -->
        <div class="chart-panel list-table-panel">
            <div class="panel-header">
                <span class="panel-title">Top 10 Best Selling Products</span>
                <button class="view-all-btn">View All</button>
            </div>
            <div class="panel-body">
                <table class="dashboard-table">
                    <thead>
                        <tr>
                            <th style="width: 40px;">#</th>
                            <th>Product</th>
                            <th style="text-align: right;">Sales Qty</th>
                            <th style="text-align: right;">Sales Value (₹)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in BestSellers)
                        {
                            <tr>
                                <td class="text-slate-500">@p.Rank</td>
                                <td class="bold-td">@p.Name</td>
                                <td class="right-align mono-text text-slate-500">@p.Qty</td>
                                <td class="right-align mono-text">@p.Value</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Low Stock Alert (Top 10) -->
        <div class="chart-panel list-table-panel">
            <div class="panel-header">
                <span class="panel-title">Low Stock Alert (Top 10)</span>
                <button class="view-all-btn">View All</button>
            </div>
            <div class="panel-body">
                <table class="dashboard-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th style="text-align: right;">Stock</th>
                            <th style="text-align: right;">Reorder Level</th>
                            <th style="width: 80px; text-align: center;">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var alert in LowStockAlerts)
                        {
                            <tr>
                                <td class="bold-td">@alert.Product</td>
                                <td class="right-align mono-text @(alert.StatusColor + "-text")">@alert.Stock</td>
                                <td class="right-align mono-text text-slate-500">@alert.Reorder</td>
                                <td>
                                    <div class="badge-wrap">
                                        <span class="status-badge-mini @alert.StatusColor">@alert.Status</span>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Cash Flow Overview -->
        <div class="chart-panel list-table-panel">
            <div class="panel-header">
                <span class="panel-title">Cash Flow Overview</span>
                <div class="select-wrap">
                    <select class="panel-select">
                        <option value="monthly">Monthly</option>
                        <option value="weekly">Weekly</option>
                    </select>
                    <MudIcon Icon="@Icons.Material.Filled.ArrowDropDown" Class="select-arrow" Size="Size.Small" />
                </div>
            </div>
            <div class="panel-body flex-column-layout">
                <!-- Summary KPI items -->
                <div class="cashflow-kpis">
                    <div class="kpi-mini">
                        <span class="lbl text-slate-500">Cash In</span>
                        <span class="val text-success">₹ 14,25,600</span>
                    </div>
                    <div class="kpi-mini">
                        <span class="lbl text-slate-500">Cash Out</span>
                        <span class="val text-danger">₹ 9,82,350</span>
                    </div>
                    <div class="kpi-mini">
                        <span class="lbl text-slate-500">Net Cash Flow</span>
                        <span class="val text-blue">₹ 4,43,250</span>
                    </div>
                </div>

                <!-- Grouped Bar Chart SVG -->
                <div class="bar-chart-container mt-4">
                    <svg viewBox="0 0 320 120" width="100%" height="100%">
                        <!-- Y Grid helpers -->
                        <line x1="25" y1="20" x2="300" y2="20" class="chart-grid-line" />
                        <line x1="25" y1="50" x2="300" y2="50" class="chart-grid-line" />
                        <line x1="25" y1="80" x2="300" y2="80" class="chart-grid-line" />
                        <line x1="25" y1="110" x2="300" y2="110" class="chart-axis-line" />

                        <!-- Grid labels -->
