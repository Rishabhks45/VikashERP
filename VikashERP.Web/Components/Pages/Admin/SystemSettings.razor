@page "/admin/system"
@using System.Net.Http.Json
@using VikashERP.Web.Models.Forms
@using VikashERP.Web.Services.Interfaces
@inject IHttpClientFactory HttpClientFactory
@inject INotificationService NotificationService
@inject IOrganizationBrandingService OrganizationBranding
@inject IFileUploadService FileUploadService
@rendermode InteractiveServer

<PageTitle>System Settings</PageTitle>

@if (_loading || _saving)
{
    <div class="loader-overlay">
        <div class="spinner"></div>
        <p>@(_saving ? "Saving configuration..." : "Loading settings...")</p>
    </div>
}
<div class="settings-layout">
    <div class="minimal-header">
        <div class="header-titles">
            <MudText Typo="Typo.h5" HtmlTag="h1">System Dynamics</MudText>
            <MudText Typo="Typo.body2" Class="section-desc">Configure company profile, website branding, notifications, and regional defaults.</MudText>
        </div>
        <div class="header-actions">
            @if (_lastUpdated.HasValue && !_isEditing)
            {
                <span class="last-updated">
                    <span class="pulse-dot"></span> Last saved: @_lastUpdated.Value.ToLocalTime().ToString("MMM dd, yyyy - hh:mm tt")
                </span>
            }
            
            @if (!_isEditing)
            {
                <button class="btn-edit" @onclick="() => _isEditing = true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="action-icon"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                    Edit Settings
                </button>
            }
            else
            {
                <button class="btn-cancel" @onclick="CancelEdit">Cancel</button>
                <button class="btn-save" disabled="@(_loading || _saving || _loadError is not null)" @onclick="SaveAsync">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="action-icon"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                    @(_saving ? "Saving..." : "Save Changes")
                </button>
            }
        </div>
    </div>

    @if (_loadError is not null)
    {
        <div class="alert-error">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            @_loadError
        </div>
    }
    else if (!_loading)
    {
        <div class="settings-container">
            <!-- Horizontal Navigation Tabs -->
            <nav class="settings-tabs">
                <button class="nav-item @(_activeTab == "General" ? "active" : "")" @onclick="@(() => SetTab("General"))">General</button>
                <button class="nav-item @(_activeTab == "Contact" ? "active" : "")" @onclick="@(() => SetTab("Contact"))">Contact & Address</button>
                <button class="nav-item @(_activeTab == "Tax" ? "active" : "")" @onclick="@(() => SetTab("Tax"))">Tax & Bank Details</button>
                <button class="nav-item @(_activeTab == "Website" ? "active" : "")" @onclick="@(() => SetTab("Website"))">Website & SEO</button>
                <button class="nav-item @(_activeTab == "Automation" ? "active" : "")" @onclick="@(() => SetTab("Automation"))">Automation</button>
                <button class="nav-item @(_activeTab == "Regional" ? "active" : "")" @onclick="@(() => SetTab("Regional"))">Regional</button>
            </nav>

            <!-- Main Content Area -->
            <div class="settings-card">
                <div class="settings-section">
                    @if (_activeTab == "General")
                    {
                        <h2>Company Profile</h2>
                        <p class="section-desc">The primary identity of your organization used in invoices and reports.</p>
                        
                        <div class="form-grid">
                            <div class="form-group col-span-2">
                                <label>Legal Name</label>
                                <input type="text" @bind="Model.LegalName" class="custom-input" placeholder="Registered Company Name" />
                            </div>
                            <div class="form-group col-span-2">
                                <label>Display Name</label>
                                <input type="text" @bind="Model.DisplayName" class="custom-input" disabled="@(!_isEditing)" placeholder="Website Title" />
                            </div>
                            <div class="form-group col-span-2">
                                <label>Tagline</label>
                                <input type="text" @bind="Model.Tagline" class="custom-input" disabled="@(!_isEditing)" placeholder="Brief company description" />
                            </div>
                        </div>

                        <h3 class="mt-8 mb-4">Branding Assets</h3>
                        <div class="branding-grid">
                            <div class="branding-card">
                                <label>Logo URL</label>
                                <div class="file-input-group">
                                    <input type="text" @bind="Model.LogoUrl" class="custom-input" disabled="@(!_isEditing)" placeholder="https://" />
                                    <InputFile id="logo-file" OnChange="@((e) => UploadBrandingFileAsync(e, "logo"))" accept="image/*" style="display: none;" />
                                    <label for="logo-file" class="btn-upload">Upload</label>
                                </div>
                            </div>
                            <div class="branding-card">
                                <label>Favicon URL</label>
                                <div class="file-input-group">
                                    <input type="text" @bind="Model.FaviconUrl" class="custom-input" disabled="@(!_isEditing)" placeholder="https://" />
                                    <InputFile id="favicon-file" OnChange="@((e) => UploadBrandingFileAsync(e, "favicon"))" accept="image/*" style="display: none;" />
                                    <label for="favicon-file" class="btn-upload">Upload</label>
                                </div>
                            </div>
                            <div class="branding-card">
                                <label>Login Background</label>
                                <div class="file-input-group">
                                    <input type="text" @bind="Model.LoginBackgroundUrl" class="custom-input" disabled="@(!_isEditing)" placeholder="https://" />
                                    <InputFile id="bg-file" OnChange="@((e) => UploadBrandingFileAsync(e, "background"))" accept="image/*" style="display: none;" />
                                    <label for="bg-file" class="btn-upload" disabled="@(!_isEditing)">Upload</label>
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Primary Color</label>
                                <input type="color" @bind="Model.PrimaryColor" class="custom-input" disabled="@(!_isEditing)" style="padding: 0.2rem; height: 42px;" />
                            </div>
                            <div class="form-group">
                                <label>Secondary Color</label>
                                <input type="color" @bind="Model.SecondaryColor" class="custom-input" disabled="@(!_isEditing)" style="padding: 0.2rem; height: 42px;" />
                            </div>
                        </div>
                    }

                    @if (_activeTab == "Contact")
                    {
                        <h2>Contact Information</h2>
                        <p class="section-desc">Where customers can reach you.</p>
                        
                        <div class="form-grid">
                            <div class="form-group">
                                <label>Email Address</label>
                                <input type="email" @bind="Model.Email" class="custom-input" disabled="@(!_isEditing)" />
                            </div>
                            <div class="form-group">
                                <label>Phone Number</label>
                                <input type="text" @bind="Model.Phone" class="custom-input" disabled="@(!_isEditing)" />
                            </div>
                            <div class="form-group">
                                <label>WhatsApp Number</label>
                                <input type="text" @bind="Model.WhatsAppNumber" class="custom-input" disabled="@(!_isEditing)" />
                            </div>
                            <div class="form-group">
                                <label>Website URL</label>
                                <input type="text" @bind="Model.WebsiteUrl" class="custom-input" disabled="@(!_isEditing)" />
                            </div>
                        </div>

                        <h3 class="mt-8 mb-4">Corporate Address</h3>
                        <div class="form-grid">
                            <div class="form-group col-span-2">
                                <label>Address Line 1</label>
                                <input type="text" @bind="Model.AddressLine1" class="custom-input" disabled="@(!_isEditing)" />
                            </div>
                            <div class="form-group col-span-2">
                                <label>Address Line 2</label>
                                <input type="text" @bind="Model.AddressLine2" class="custom-input" disabled="@(!_isEditing)" />
                            </div>
                            <div class="form-group">
                                <label>City</label>
                                <input type="text" @bind="Model.City" class="custom-input" disabled="@(!_isEditing)" />
                            </div>
                            <div class="form-group">
                                <label>State / Province</label>
                                <input type="text" @bind="Model.State" class="custom-input" disabled="@(!_isEditing)" />
                            </div>
                            <div class="form-group">
                                <label>PIN / ZIP Code</label>
                                <input type="text" @bind="Model.PinCode" class="custom-input" disabled="@(!_isEditing)" />
                            </div>
                            <div class="form-group">
                                <label>Country</label>
                                <input type="text" @bind="Model.Country" class="custom-input" disabled="@(!_isEditing)" />
                            </div>
                        </div>
                    }

                    @if (_activeTab == "Tax")
                    {
                        <h2>Tax & Bank Details</h2>
                        <p class="section-desc">Financial identifiers used on invoices.</p>
                        
                        <div class="form-grid">
                            <div class="form-group">
                                <label>GSTIN</label>
                                <input type="text" @bind="Model.Gstin" class="custom-input uppercase" />
                            </div>
                            <div class="form-group">
                                <label>PAN</label>
                                <input type="text" @bind="Model.Pan" class="custom-input uppercase" />
                            </div>
                            <div class="form-group">
                                <label>Bank Name</label>
                                <input type="text" @bind="Model.BankName" class="custom-input" disabled="@(!_isEditing)" />
                            </div>
                            <div class="form-group">
                                <label>Account Holder Name</label>
                                <input type="text" @bind="Model.BankAccountName" class="custom-input" disabled="@(!_isEditing)" />
                            </div>
                            <div class="form-group">
                                <label>Account Number</label>
                                <input type="text" @bind="Model.BankAccountNumber" class="custom-input" disabled="@(!_isEditing)" />
                            </div>
                            <div class="form-group">
                                <label>IFSC Code</label>
                                <input type="text" @bind="Model.IfscCode" class="custom-input uppercase" />
                            </div>
                        </div>
                    }

                    @if (_activeTab == "Website")
                    {
                        <h2>Website & SEO</h2>
                        <p class="section-desc">Control how your portal appears on search engines and social media.</p>
                        
                        <div class="form-grid">
                            <div class="form-group col-span-2">
                                <label>Meta Title</label>
                                <input type="text" @bind="Model.MetaTitle" class="custom-input" disabled="@(!_isEditing)" />
                            </div>
                            <div class="form-group col-span-2">
                                <label>Meta Description</label>
                                <textarea @bind="Model.MetaDescription" class="custom-input" disabled="@(!_isEditing)" rows="3"></textarea>
                            </div>
                            <div class="form-group col-span-2">
                                <label>Footer Text</label>
                                <input type="text" @bind="Model.FooterText" class="custom-input" disabled="@(!_isEditing)" />
                            </div>
                            <div class="form-group">
                                <label>Facebook URL</label>
                                <input type="text" @bind="Model.SocialFacebookUrl" class="custom-input" disabled="@(!_isEditing)" />
                            </div>
                            <div class="form-group">
                                <label>Instagram URL</label>
                                <input type="text" @bind="Model.SocialInstagramUrl" class="custom-input" disabled="@(!_isEditing)" />
                            </div>
                            <div class="form-group">
                                <label>LinkedIn URL</label>
                                <input type="text" @bind="Model.SocialLinkedInUrl" class="custom-input" disabled="@(!_isEditing)" />
                            </div>
                            <div class="form-group">
                                <label>YouTube URL</label>
                                <input type="text" @bind="Model.SocialYoutubeUrl" class="custom-input" disabled="@(!_isEditing)" />
                            </div>

                            <div class="col-span-2 mt-4">
                                <h3>Footer Configurations</h3>
                            </div>
                            <div class="form-group col-span-2">
                                <label>Footer Text</label>
                                <textarea @bind="Model.FooterText" class="custom-input" rows="2" disabled="@(!_isEditing)"></textarea>
                            </div>
                            <div class="form-group col-span-2">
                                <label>Copyright Text</label>
                                <input type="text" @bind="Model.CopyrightText" class="custom-input" disabled="@(!_isEditing)" />
                            </div>
                        </div>
                    }

                    @if (_activeTab == "Automation")
                    {
                        <h2>Automation Preferences</h2>
                        <p class="section-desc">Toggle system-wide behaviors.</p>
                        
                        <div class="form-grid">
                            <div class="col-span-2">
                                <h3>Email Sender Identity</h3>
                            </div>
                            <div class="form-group">
                                <label>Sender Name</label>
                                <input type="text" @bind="Model.EmailFromName" class="custom-input" disabled="@(!_isEditing)" placeholder="Vikash Iron & Steel" />
                            </div>
                            <div class="form-group">
                                <label>Sender Address</label>
                                <input type="email" @bind="Model.EmailFromAddress" class="custom-input" disabled="@(!_isEditing)" placeholder="no-reply@vikashiron.com" />
                            </div>

                            <div class="col-span-2 mt-4">
                                <h3>System Toggles</h3>
                            </div>
                            <div class="col-span-2">
                                <label class="toggle-row @(_isEditing ? "" : "disabled")">
                                    <div class="toggle-info">
                                        <span class="toggle-title">Customer Portal</span>
                                        <span class="toggle-desc">Allow customers to sign in and view ledger.</span>
                                    </div>
                                    <div class="toggle-switch">
                                        <input type="checkbox" disabled="@(!_isEditing)" @bind="Model.EnableCustomerPortal" />
                                        <span class="slider"></span>
                                    </div>
                                </label>
                                
                                <label class="toggle-row @(_isEditing ? "" : "disabled")">
                                    <div class="toggle-info">
                                        <span class="toggle-title">Low Stock Alerts</span>
                                        <span class="toggle-desc">Notify when inventory falls below threshold.</span>
                                    </div>
                                    <div class="toggle-switch">
                                        <input type="checkbox" disabled="@(!_isEditing)" @bind="Model.EnableLowStockAlerts" />
                                        <span class="slider"></span>
                                    </div>
                                </label>

                                <label class="toggle-row @(_isEditing ? "" : "disabled")">
                                    <div class="toggle-info">
                                        <span class="toggle-title">Payment Reminders</span>
                                        <span class="toggle-desc">Send reminders for overdue balances.</span>
                                    </div>
                                    <div class="toggle-switch">
                                        <input type="checkbox" disabled="@(!_isEditing)" @bind="Model.EnablePaymentReminders" />
                                        <span class="slider"></span>
                                    </div>
                                </label>
                                <label class="toggle-row @(_isEditing ? "" : "disabled")">
                                    <div class="toggle-info">
                                        <span class="toggle-title">Daily Report Email</span>
                                        <span class="toggle-desc">Send automated daily summary reports to admins.</span>
                                    </div>
                                    <div class="toggle-switch">
                                        <input type="checkbox" disabled="@(!_isEditing)" @bind="Model.EnableDailyReportEmail" />
                                        <span class="slider"></span>
                                    </div>
                                </label>
                                <label class="toggle-row @(_isEditing ? "" : "disabled")">
                                    <div class="toggle-info">
                                        <span class="toggle-title">Trade Confirmations</span>
                                        <span class="toggle-desc">Automatically email trade confirmations to customers.</span>
                                    </div>
                                    <div class="toggle-switch">
                                        <input type="checkbox" disabled="@(!_isEditing)" @bind="Model.EnableTradeConfirmations" />
                                        <span class="slider"></span>
                                    </div>
                                </label>
                            </div>
                        </div>
                    }

                    @if (_activeTab == "Regional")
                    {
                        <h2>Regional Settings</h2>
                        <p class="section-desc">Localization defaults.</p>
                        
                        <div class="form-grid">
                            <div class="form-group">
                                <label>Primary Currency</label>
                                <select @bind="Model.DefaultCurrency" class="custom-select" disabled="@(!_isEditing)">
                                    <option value="INR">INR - Indian Rupee (₹)</option>
                                    <option value="USD">USD - US Dollar ($)</option>
                                    <option value="EUR">EUR - Euro (€)</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Weight Unit</label>
                                <select @bind="Model.DefaultWeightUnit" class="custom-select" disabled="@(!_isEditing)">
                                    <option value="KG">Kilograms (KG)</option>
                                    <option value="MT">Metric Tonnes (MT)</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Time Zone</label>
                                <input type="text" @bind="Model.TimeZone" class="custom-input" />
                            </div>
                            <div class="form-group">
                                <label>Date Format</label>
                                <input type="text" @bind="Model.DateFormat" class="custom-input" placeholder="dd-MM-yyyy" />
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private OrganizationFormModel Model { get; set; } = new();
    private OrganizationResponse? _originalDto;
    private bool _loading = true;
    private bool _saving = false;
    private bool _isEditing = false;
    private string? _loadError;
    private DateTime? _lastUpdated;
    
    private string _activeTab = "General";

    private void SetTab(string tab)
    {
        _activeTab = tab;
    }

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private void CancelEdit()
    {
        _isEditing = false;
        if (_originalDto is not null)
        {
            Model = MapFromResponse(_originalDto);
        }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;

        try
        {
            var client = HttpClientFactory.CreateClient("VikashERP.Api");
            var dto = await client.GetFromJsonAsync<OrganizationResponse>("api/organization");

            if (dto is null)
            {
                _loadError = "Organization settings not found.";
                return;
            }

            _originalDto = dto;
            Model = MapFromResponse(dto);
            _lastUpdated = dto.UpdatedAt;
        }
        catch (Exception ex)
        {
            _loadError = $"Could not load settings: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveAsync()
    {
        if (_saving) return;
        _saving = true;

        try
        {
            var client = HttpClientFactory.CreateClient("VikashERP.Api");
            var response = await client.PutAsJsonAsync("api/organization", Model);

            if (!response.IsSuccessStatusCode)
            {
                var error = await TryReadErrorAsync(response);
                NotificationService.Error(error ?? "Could not save organization settings.");
                return;
            }

            var saved = await response.Content.ReadFromJsonAsync<OrganizationResponse>();
            if (response.IsSuccessStatusCode)
            {
                if (saved is not null)
                {
                    _originalDto = saved;
                    Model = MapFromResponse(saved);
                    _lastUpdated = saved.UpdatedAt;
                }
                
                _isEditing = false;
            }

            NotificationService.Success("Settings updated successfully.");
            await OrganizationBranding.RefreshAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Error($"Save failed: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    private static OrganizationFormModel MapFromResponse(OrganizationResponse dto) => new()
    {
        LegalName = dto.LegalName,
        DisplayName = dto.DisplayName,
        Tagline = dto.Tagline,
        LogoUrl = dto.LogoUrl,
        FaviconUrl = dto.FaviconUrl,
        LoginBackgroundUrl = dto.LoginBackgroundUrl,
        PrimaryColor = dto.PrimaryColor,
        SecondaryColor = dto.SecondaryColor,
        AddressLine1 = dto.AddressLine1,
        AddressLine2 = dto.AddressLine2,
        City = dto.City,
        State = dto.State,
        PinCode = dto.PinCode,
        Country = dto.Country,
        Phone = dto.Phone,
        Email = dto.Email,
        WebsiteUrl = dto.WebsiteUrl,
        WhatsAppNumber = dto.WhatsAppNumber,
        Gstin = dto.Gstin,
        Pan = dto.Pan,
        BankName = dto.BankName,
        BankAccountName = dto.BankAccountName,
        BankAccountNumber = dto.BankAccountNumber,
        IfscCode = dto.IfscCode,
        EmailFromName = dto.EmailFromName,
        EmailFromAddress = dto.EmailFromAddress,
        MetaTitle = dto.MetaTitle,
        MetaDescription = dto.MetaDescription,
        MetaKeywords = dto.MetaKeywords,
        FooterText = dto.FooterText,
        CopyrightText = dto.CopyrightText,
        SocialFacebookUrl = dto.SocialFacebookUrl,
        SocialInstagramUrl = dto.SocialInstagramUrl,
        SocialLinkedInUrl = dto.SocialLinkedInUrl,
        SocialYoutubeUrl = dto.SocialYoutubeUrl,
        DefaultCurrency = dto.DefaultCurrency,
        DefaultWeightUnit = dto.DefaultWeightUnit,
        TimeZone = dto.TimeZone,
        DateFormat = dto.DateFormat,
        EnableCustomerPortal = dto.EnableCustomerPortal,
        EnableLowStockAlerts = dto.EnableLowStockAlerts,
        EnablePaymentReminders = dto.EnablePaymentReminders,
        EnableDailyReportEmail = dto.EnableDailyReportEmail,
        EnableTradeConfirmations = dto.EnableTradeConfirmations,
        IsActive = dto.IsActive
    };

    private static async Task<string?> TryReadErrorAsync(HttpResponseMessage response)
    {
        try
        {
            var payload = await response.Content.ReadFromJsonAsync<ApiErrorResponse>();
            return payload?.Message;
        }
        catch { return null; }
    }

    private async Task UploadBrandingFileAsync(InputFileChangeEventArgs e, string type)
    {
        try
        {
            var file = e.File;
            var validationResult = await FileUploadService.ValidateFileAsync(file);
            if (!validationResult.IsValid)
            {
                NotificationService.Error(validationResult.ErrorMessage);
                return;
            }

            var relativeUrl = await FileUploadService.HandleFileUploadAsync(file);
            
            if (type == "logo") Model.LogoUrl = relativeUrl;
            else if (type == "favicon") Model.FaviconUrl = relativeUrl;
            else if (type == "background") Model.LoginBackgroundUrl = relativeUrl;

            NotificationService.Success($"{type} uploaded.");
        }
        catch (Exception ex)
        {
            NotificationService.Error($"Upload failed: {ex.Message}");
        }
    }

    private sealed class OrganizationResponse : OrganizationFormModel
    {
        public Guid Id { get; set; }
        public DateTime UpdatedAt { get; set; }
    }

    private sealed class ApiErrorResponse { public string? Message { get; set; } }
}
