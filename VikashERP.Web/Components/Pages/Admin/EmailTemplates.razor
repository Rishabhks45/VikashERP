@page "/admin/email-templates"
@page "/notification-templates"
@using VikashERP.Web.Services.Interfaces
@inject IHttpClientFactory HttpClientFactory
@inject INotificationService NotificationService
@inject IConfiguration Configuration
@inject IJSRuntime JS
@implements IAsyncDisposable
@using VikashERP.SharedKernel.Enums
@using System.Text.RegularExpressions

<PageTitle>Email Templates</PageTitle>

<MudStack Class="email-templates-page" Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="dashboard-header">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4" HtmlTag="h1">Email / SMS Templates</MudText>
            <MudText Typo="Typo.body2" Class="dashboard-subtitle">
                Manage email templates for password reset, welcome messages, and other notifications.
            </MudText>
        </MudStack>

        <MudButton Variant="Variant.Filled"
                   Class="dashboard-action-primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Disabled="@(_loading || _saving || _deleting)"
                   OnClick="ShowCreatePanel">
            Add Template
        </MudButton>
    </MudStack>

    <MudPaper Elevation="0" Class="email-templates-panel">
        @if (_loading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="email-loading-state" Spacing="2">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Medium" />
                <MudText Typo="Typo.body2">Loading templates...</MudText>
            </MudStack>
        }
        else if (_loadError is not null)
        {
            <MudAlert Severity="Severity.Error">@_loadError</MudAlert>
        }
        else
        {
            <MudTable Items="@FilteredTemplates"
                      Hover="true"
                      Dense="true"
                      Breakpoint="Breakpoint.Sm"
                      Elevation="0"
                      Class="email-template-table">
                <ToolBarContent>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="email-toolbar-filters">
                        <MudTextField @bind-Value="_searchString"
                                      Placeholder="Search templates..."
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      IconSize="Size.Medium"
                                      Immediate="true"
                                      Margin="Margin.Dense"
                                      Class="email-search-field" />
                        <MudSelect T="string?"
                                   @bind-Value="_filterTemplateKey"
                                   Label="Template key"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Dense="true"
                                   Clearable="true"
                                   Placeholder="All templates"
                                   PopoverFixed="true"
                                   Class="email-key-filter">
                            @foreach (var templateType in Enum.GetValues<EmailTemplateType>())
                            {
                                <MudSelectItem T="string?" Value="@templateType.ToString()">@templateType.ToDisplayName()</MudSelectItem>
                            }
                        </MudSelect>
                    </MudStack>
                </ToolBarContent>

                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<EmailTemplateListItem, object>(x => GetChannelText(x.TemplateKey))">Notification Type</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<EmailTemplateListItem, object>(x => GetKeyDisplayName(x.TemplateKey))">Template Key</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<EmailTemplateListItem, object>(x => x.Subject)">Subject</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<EmailTemplateListItem, object>(x => x.IsActive)">Status</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<EmailTemplateListItem, object>(x => x.UpdatedAt)">Updated</MudTableSortLabel></MudTh>
                    <MudTh Class="email-table-actions-header">Action</MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd DataLabel="Notification Type">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info">
                            @GetChannelText(context.TemplateKey)
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Template Key">
                        <div class="email-template-list-name">@GetKeyDisplayName(context.TemplateKey)</div>
                        <div class="email-template-list-desc">@context.TemplateKey</div>
                    </MudTd>
                    <MudTd DataLabel="Subject">@context.Subject</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@(context.IsActive ? Color.Success : Color.Default)"
                                 Variant="Variant.Filled">
                            @(context.IsActive ? "Active" : "Inactive")
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Updated">@context.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</MudTd>
                    <MudTd DataLabel="Action" Class="email-table-actions">
                        <MudStack Row="true" Spacing="0" Justify="Justify.FlexEnd">
                            <MudTooltip Text="Preview">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                               Size="Size.Small"
                                               Color="Color.Info"
                                               Disabled="@(_previewLoading || _saving || _deleting)"
                                               OnClick="@(() => PreviewTemplateFromListAsync(context))" />
                            </MudTooltip>
                            <MudTooltip Text="Edit">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Size="Size.Small"
                                               Color="Color.Default"
                                               Disabled="@(_saving || _deleting)"
                                               OnClick="@(() => EditTemplateAsync(context))" />
                            </MudTooltip>
                            <MudTooltip Text="Delete">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               Disabled="@(_saving || _deleting)"
                                               OnClick="@(() => DeleteTemplateAsync(context))" />
                            </MudTooltip>
                        </MudStack>
                    </MudTd>
                </RowTemplate>

                <NoRecordsContent>
                    <MudStack AlignItems="AlignItems.Center" Class="email-empty-state" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Color="Color.Default" />
                        <MudText Typo="Typo.subtitle1">No templates found</MudText>
                        <MudText Typo="Typo.caption">Get started by adding your first template</MudText>
                    </MudStack>
                </NoRecordsContent>
            </MudTable>
        }
    </MudPaper>
</MudStack>

@if (_panelVisible)
{
    <div class="email-slide-overlay @(_panelClosing ? "fade-out" : "fade-in")" @onclick="HidePanel">
        <div class="email-slide-panel @(_panelClosing ? "slide-out-right" : "slide-in-right")" @onclick:stopPropagation="true">
            <div class="email-slide-panel-inner">
                <div class="email-slide-panel-header">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h6" HtmlTag="h2">@(_isCreate ? "Add Template" : "Update Template")</MudText>
                        <MudText Typo="Typo.caption">
                            @(_isCreate ? "Create a new email template with custom content." : "Update the template details below.")
                        </MudText>
                    </MudStack>
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                   Color="Color.Inherit"
                                   Disabled="_previewLoading"
                                   OnClick="PreviewFromFormAsync" />
                    <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="HidePanel" />
                </div>

                <EditForm Model="_upsertModel" OnValidSubmit="SaveTemplateAsync" Class="email-slide-panel-form">
                    <DataAnnotationsValidator />
                    <div class="email-slide-panel-body" tabindex="-1">
                        <MudStack Spacing="2">
                            <MudSelect T="NotificationType"
                                       @bind-Value="_upsertModel.NotificationType"
                                       Label="Notification type"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       PopoverFixed="true"
                                       Disabled="@(!_isCreate)">
                                @foreach (var channel in Enum.GetValues<NotificationType>().Where(x => x != NotificationType.None))
                                {
                                    <MudSelectItem T="NotificationType" Value="@channel">@channel</MudSelectItem>
                                }
                            </MudSelect>

                            @if (_isCreate)
                            {
                                <MudSelect T="string?"
                                           Value="@GetSelectedTemplateKey()"
                                           ValueChanged="OnTemplateKeySelected"
                                           Label="Template key"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Required="true"
                                           Placeholder="Select template key"
                                           PopoverFixed="true"
                                           HelperText="@GetTemplateKeyHelperText()">
                                    @foreach (var templateType in AvailableTemplateTypesForCreate)
                                    {
                                        <MudSelectItem T="string?" Value="@templateType.ToString()">@templateType.ToDisplayName()</MudSelectItem>
                                    }
                                </MudSelect>
                            }
                            else
                            {
                                <MudSelect T="string?"
                                           Value="@_upsertModel.TemplateKey"
                                           Label="Template key"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Disabled="true"
                                           PopoverFixed="true">
                                    <MudSelectItem T="string?" Value="@_upsertModel.TemplateKey">@GetKeyDisplayName(_upsertModel.TemplateKey)</MudSelectItem>
                                </MudSelect>
                            }

                            <MudTextField @bind-Value="_upsertModel.DisplayName"
                                          Label="Display name"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Required="true" />

                            <MudTextField @bind-Value="_upsertModel.Description"
                                          Label="Description"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Lines="2"
                                          Required="true" />

                            <MudTextField @bind-Value="_upsertModel.Subject"
                                          @bind-Value:after="ScheduleLivePreviewRefresh"
                                          Label="Subject"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Required="true"
                                          Immediate="true" />

                            <MudTextField @bind-Value="_upsertModel.Headline"
                                          @bind-Value:after="ScheduleLivePreviewRefresh"
                                          Label="Header headline"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Required="true"
                                          Immediate="true" />

                            <MudTextField @bind-Value="_upsertModel.Preheader"
                                          @bind-Value:after="ScheduleLivePreviewRefresh"
                                          Label="Preheader"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Immediate="true" />

                            <MudTextField @bind-Value="_upsertModel.AvailableTokensText"
                                          @bind-Value:after="ScheduleLivePreviewRefresh"
                                          Label="Token"
                                          Placeholder="{{UserName}}, {{LoginUrl}}"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          HelperText="Comma-separated placeholders used in this template" />

                            <MudTextField @bind-Value="_upsertModel.BodyHtml"
                                          @bind-Value:after="ScheduleLivePreviewRefresh"
                                          Label="Body HTML"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Lines="10"
                                          Required="true"
                                          Immediate="true" />

                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.caption" Class="@BodyCharacterCountClass">@BodyPlainTextLength / 5000 characters</MudText>
                            </MudStack>

                            <MudGrid Spacing="2">
                                <MudItem xs="12" sm="6">
                                    <MudTextField @bind-Value="_upsertModel.ButtonLabel"
                                                  @bind-Value:after="ScheduleLivePreviewRefresh"
                                                  Label="Button label"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Immediate="true" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudTextField @bind-Value="_upsertModel.ButtonLinkToken"
                                                  @bind-Value:after="ScheduleLivePreviewRefresh"
                                                  Label="Button link token"
                                                  Placeholder="{{LoginUrl}}"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Immediate="true" />
                                </MudItem>
                            </MudGrid>

                            <MudSwitch @bind-Value="_upsertModel.IsActive" Color="Color.Primary" Label="Active" />

                            @if (!_isCreate && _upsertModel.AvailableTokens.Count > 0)
                            {
                                <MudText Typo="Typo.caption" Class="email-token-hint">Available tokens</MudText>
                                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                    @foreach (var token in _upsertModel.AvailableTokens)
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@token</MudChip>
                                    }
                                </MudStack>
                            }

                        </MudStack>
                    </div>

                    <div class="email-slide-panel-footer">
                        <MudStack Row="true" Spacing="2">
                            <MudButton Variant="Variant.Text" Disabled="_saving" OnClick="HidePanel">Cancel</MudButton>
                            <MudSpacer />
                            <MudButton Variant="Variant.Filled"
                                       Class="dashboard-action-primary"
                                       ButtonType="ButtonType.Submit"
                                       Disabled="_saving || BodyPlainTextLength > 5000"
                                       StartIcon="@Icons.Material.Filled.Save">
                                @(_saving ? "Saving..." : (_isCreate ? "Save" : "Update"))
                            </MudButton>
                        </MudStack>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@if (_previewVisible)
{
    <div class="email-preview-overlay fade-in" @onclick="ClosePreview">
        <MudPaper Class="email-preview-dialog" Elevation="12" @onclick:stopPropagation="true">
            <div class="email-preview-dialog-header">
                <MudStack Spacing="0">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.h6" HtmlTag="h2">Email Preview</MudText>
                        @if (_previewLiveMode)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Live</MudChip>
                        }
                    </MudStack>
                    <MudText Typo="Typo.caption">@_previewSubject</MudText>
                </MudStack>
                <MudStack Row="true" Spacing="0" AlignItems="AlignItems.Center">
                    @if (_previewLiveMode)
                    {
                        <MudTooltip Text="Refresh preview">
                            <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                           Disabled="_previewLoading"
                                           OnClick="RefreshLivePreviewNowAsync" />
                        </MudTooltip>
                    }
                    <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="ClosePreview" />
                </MudStack>
            </div>
            <div class="email-preview-dialog-body">
                @if (_previewLoading && !_previewHasContent)
                {
                    <MudStack AlignItems="AlignItems.Center" Class="email-preview-loading" Spacing="2">
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Medium" />
                        <MudText Typo="Typo.body2">Loading preview...</MudText>
                    </MudStack>
                }
                else
                {
                    @if (_previewLoading)
                    {
                        <div class="email-preview-updating">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
                            <span>Updating preview...</span>
                        </div>
                    }
                    <iframe class="email-preview-frame email-preview-frame-dialog"
                            title="Email template preview"
                            srcdoc="@_previewHtml"
                            sandbox="allow-same-origin">
                    </iframe>
                }
            </div>
        </MudPaper>
    </div>
}

@if (_templateToDelete is not null)
{
    <div class="email-slide-overlay fade-in" @onclick="CancelDelete">
        <MudPaper Class="email-delete-dialog" Elevation="8" @onclick:stopPropagation="true">
            <MudText Typo="Typo.h6" HtmlTag="h2">Delete Email Template</MudText>
            <MudText Typo="Typo.body2" Class="email-delete-message">
                Are you sure you want to delete <strong>@_templateToDelete.DisplayName</strong>?
            </MudText>
            <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd" Class="email-delete-actions">
                <MudButton Variant="Variant.Text" Disabled="_deleting" OnClick="CancelDelete">Cancel</MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Error"
                           Disabled="_deleting"
                           OnClick="ConfirmDeleteAsync">
                    @(_deleting ? "Deleting..." : "Delete")
                </MudButton>
            </MudStack>
        </MudPaper>
    </div>
}

@code {
    private readonly List<EmailTemplateListItem> _templates = [];
    private UpsertEmailTemplateModel _upsertModel = new();
    private string _searchString = string.Empty;
    private string? _filterTemplateKey;
    private string _previewHtml = "<p style='padding:16px;font-family:sans-serif;color:#64748b;'>Preview will appear here.</p>";
    private bool _loading = true;
    private bool _saving;
    private bool _deleting;
    private bool _panelVisible;
    private bool _panelClosing;
    private bool _isCreate;
    private string? _loadError;
    private EmailTemplateListItem? _templateToDelete;
    private bool _bodyScrollLocked;
    private bool _previewVisible;
    private bool _previewLoading;
    private bool _previewLiveMode;
    private bool _previewHasContent;
    private string _previewSubject = string.Empty;
    private CancellationTokenSource? _previewDebounceCts;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var shouldLock = (_panelVisible && !_panelClosing) || _previewVisible;
        if (shouldLock == _bodyScrollLocked)
            return;

        _bodyScrollLocked = shouldLock;
        await JS.InvokeVoidAsync("eval", shouldLock
            ? "document.documentElement.classList.add('email-panel-open');document.body.classList.add('email-panel-open')"
            : "document.documentElement.classList.remove('email-panel-open');document.body.classList.remove('email-panel-open')");
    }

    public async ValueTask DisposeAsync()
    {
        _previewDebounceCts?.Cancel();
        _previewDebounceCts?.Dispose();

        if (!_bodyScrollLocked)
            return;

        await JS.InvokeVoidAsync("eval", "document.documentElement.classList.remove('email-panel-open');document.body.classList.remove('email-panel-open')");
    }

    private IEnumerable<EmailTemplateListItem> FilteredTemplates
    {
        get
        {
            IEnumerable<EmailTemplateListItem> query = _templates;

            if (!string.IsNullOrWhiteSpace(_filterTemplateKey))
                query = query.Where(t => t.TemplateKey.Equals(_filterTemplateKey, StringComparison.OrdinalIgnoreCase));

            if (string.IsNullOrWhiteSpace(_searchString))
                return query;

            return query.Where(t =>
                t.DisplayName.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
                t.Subject.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
                t.TemplateKey.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
                GetKeyDisplayName(t.TemplateKey).Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
                t.Description.Contains(_searchString, StringComparison.OrdinalIgnoreCase));
        }
    }

    private IEnumerable<EmailTemplateType> AvailableTemplateTypesForCreate =>
        Enum.GetValues<EmailTemplateType>().Where(type => !TemplateKeyExists(type.ToString()));

    private bool TemplateKeyExists(string key) =>
        _templates.Any(t => t.TemplateKey.Equals(key, StringComparison.OrdinalIgnoreCase));

    private string? GetSelectedTemplateKey() =>
        string.IsNullOrWhiteSpace(_upsertModel.TemplateKey) ? null : _upsertModel.TemplateKey;

    private string GetTemplateKeyHelperText() =>
        AvailableTemplateTypesForCreate.Any()
            ? "Select the notification template type"
            : "All template keys are already configured. Edit an existing template instead.";

    private Task OnTemplateKeySelected(string? key)
    {
        if (string.IsNullOrWhiteSpace(key))
            return Task.CompletedTask;

        OnTemplateKeyChanged(key);
        return Task.CompletedTask;
    }

    protected override async Task OnInitializedAsync() => await LoadTemplatesAsync();

    private async Task LoadTemplatesAsync()
    {
        _loading = true;
        _loadError = null;

        try
        {
            var client = HttpClientFactory.CreateClient("VikashERP.Api");
            var templates = await client.GetFromJsonAsync<List<EmailTemplateListItem>>("api/email-templates");
            _templates.Clear();

            if (templates is not null)
                _templates.AddRange(templates);
        }
        catch (Exception ex)
        {
            _loadError = $"Could not load templates: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void ShowCreatePanel()
    {
        _isCreate = true;
        _upsertModel = new UpsertEmailTemplateModel
        {
            IsActive = true,
            NotificationType = NotificationType.Email
        };
        _panelClosing = false;
        _panelVisible = true;
    }

    private void OnTemplateKeyChanged(string key)
    {
        _upsertModel.TemplateKey = key;
        _upsertModel.NotificationType = NotificationType.Email;

        if (Enum.TryParse<EmailTemplateType>(key, ignoreCase: true, out var templateType))
            _upsertModel.DisplayName = templateType.ToDisplayName();
    }

    private async Task EditTemplateAsync(EmailTemplateListItem item)
    {
        try
        {
            var client = HttpClientFactory.CreateClient("VikashERP.Api");
            var detail = await client.GetFromJsonAsync<EmailTemplateDetail>($"api/email-templates/{item.Id}");

            if (detail is null)
            {
                NotificationService.Warning("Template not found.");
                return;
            }

            _isCreate = false;
            _upsertModel = UpsertEmailTemplateModel.FromDetail(detail);
            _panelClosing = false;
            _panelVisible = true;
        }
        catch (Exception ex)
        {
            NotificationService.Error($"Could not load template: {ex.Message}");
        }
    }

    private async Task HidePanel()
    {
        if (_panelClosing)
            return;

        _panelClosing = true;
        StateHasChanged();
        await Task.Delay(300);
        _panelVisible = false;
        _panelClosing = false;
        _upsertModel = new UpsertEmailTemplateModel();
    }

    private async Task SaveTemplateAsync()
    {
        if (_saving || BodyPlainTextLength > 5000)
            return;

        if (_isCreate && (string.IsNullOrWhiteSpace(_upsertModel.TemplateKey) || TemplateKeyExists(_upsertModel.TemplateKey)))
        {
            NotificationService.Warning("Please select a template key.");
            return;
        }

        _saving = true;
        try
        {
            var client = HttpClientFactory.CreateClient("VikashERP.Api");

            if (_isCreate)
            {
                var response = await client.PostAsJsonAsync("api/email-templates", new CreateEmailTemplateRequest
                {
                    TemplateKey = _upsertModel.TemplateKey.Trim(),
                    DisplayName = _upsertModel.DisplayName.Trim(),
                    Description = _upsertModel.Description.Trim(),
                    Subject = _upsertModel.Subject.Trim(),
                    Headline = _upsertModel.Headline.Trim(),
                    BodyHtml = _upsertModel.BodyHtml,
                    Preheader = _upsertModel.Preheader,
                    ButtonLabel = _upsertModel.ButtonLabel,
                    ButtonLinkToken = _upsertModel.ButtonLinkToken,
                    AvailableTokens = _upsertModel.AvailableTokensText,
                    IsActive = _upsertModel.IsActive
                });

                if (!response.IsSuccessStatusCode)
                {
                    var error = await response.Content.ReadAsStringAsync();
                    NotificationService.Error(string.IsNullOrWhiteSpace(error) ? "Failed to create template." : error);
                    return;
                }

                NotificationService.Success("Email template created successfully.");
            }
            else
            {
                var response = await client.PutAsJsonAsync($"api/email-templates/{_upsertModel.Id}", new UpdateEmailTemplateRequest
                {
                    Id = _upsertModel.Id,
                    DisplayName = _upsertModel.DisplayName.Trim(),
                    Description = _upsertModel.Description.Trim(),
                    Subject = _upsertModel.Subject.Trim(),
                    Headline = _upsertModel.Headline.Trim(),
                    BodyHtml = _upsertModel.BodyHtml,
                    Preheader = _upsertModel.Preheader,
                    ButtonLabel = _upsertModel.ButtonLabel,
                    ButtonLinkToken = _upsertModel.ButtonLinkToken,
                    IsActive = _upsertModel.IsActive
                });

                if (!response.IsSuccessStatusCode)
                {
                    NotificationService.Error("Failed to update template.");
                    return;
                }

                NotificationService.Success("Email template updated successfully.");
            }

            await HidePanel();
            await LoadTemplatesAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Error($"Save failed: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    private void DeleteTemplateAsync(EmailTemplateListItem item) => _templateToDelete = item;

    private void CancelDelete() => _templateToDelete = null;

    private async Task ConfirmDeleteAsync()
    {
        if (_templateToDelete is null || _deleting)
            return;

        var item = _templateToDelete;
        _deleting = true;
        try
        {
            var client = HttpClientFactory.CreateClient("VikashERP.Api");
            var response = await client.DeleteAsync($"api/email-templates/{item.Id}");

            if (!response.IsSuccessStatusCode)
            {
                NotificationService.Error("Failed to delete template.");
                return;
            }

            NotificationService.Success("Email template deleted successfully.");
            _templateToDelete = null;
            await LoadTemplatesAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Error($"Delete failed: {ex.Message}");
        }
        finally
        {
            _deleting = false;
        }
    }

    private async Task PreviewFromFormAsync()
    {
        _previewLiveMode = true;
        _previewHasContent = false;
        _previewHtml = string.Empty;
        await RefreshLivePreviewNowAsync();
    }

    private async Task PreviewTemplateFromListAsync(EmailTemplateListItem item)
    {
        _previewLiveMode = false;
        _previewHasContent = false;
        _previewHtml = string.Empty;
        _previewLoading = true;
        _previewVisible = true;
        _previewSubject = item.Subject;
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient("VikashERP.Api");
            var detail = await client.GetFromJsonAsync<EmailTemplateDetail>($"api/email-templates/{item.Id}");

            if (detail is null)
            {
                NotificationService.Warning("Template not found.");
                ClosePreview();
                return;
            }

            await LoadPreviewContentAsync(
                detail.Subject,
                detail.Headline,
                detail.BodyHtml,
                detail.Preheader,
                detail.ButtonLabel,
                detail.ButtonLinkToken,
                detail.AvailableTokens);
        }
        catch (Exception ex)
        {
            NotificationService.Error($"Could not load preview: {ex.Message}");
            ClosePreview();
        }
    }

    private void ScheduleLivePreviewRefresh()
    {
        if (!_previewVisible || !_previewLiveMode)
            return;

        _previewDebounceCts?.Cancel();
        _previewDebounceCts?.Dispose();
        _previewDebounceCts = new CancellationTokenSource();
        var token = _previewDebounceCts.Token;
        _ = DebouncedLivePreviewRefreshAsync(token);
    }

    private async Task DebouncedLivePreviewRefreshAsync(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(450, cancellationToken);
            await RefreshLivePreviewNowAsync(cancellationToken);
        }
        catch (TaskCanceledException)
        {
            // Debounced — a newer edit superseded this refresh.
        }
        catch (OperationCanceledException)
        {
            // Request cancelled by a newer edit.
        }
    }

    private Task RefreshLivePreviewNowAsync() => RefreshLivePreviewNowAsync(CancellationToken.None);

    private async Task RefreshLivePreviewNowAsync(CancellationToken cancellationToken)
    {
        if (!_previewVisible)
        {
            _previewVisible = true;
            _previewLiveMode = true;
        }

        await LoadPreviewContentAsync(
            _upsertModel.Subject,
            _upsertModel.Headline,
            _upsertModel.BodyHtml,
            _upsertModel.Preheader,
            _upsertModel.ButtonLabel,
            _upsertModel.ButtonLinkToken,
            _upsertModel.TokenList,
            cancellationToken);
    }

    private async Task LoadPreviewContentAsync(
        string subject,
        string headline,
        string bodyHtml,
        string? preheader,
        string? buttonLabel,
        string? buttonLinkToken,
        IEnumerable<string> tokens,
        CancellationToken cancellationToken = default)
    {
        _previewLoading = true;
        _previewVisible = true;
        _previewSubject = string.IsNullOrWhiteSpace(subject) ? "Email template preview" : subject;
        StateHasChanged();

        try
        {
            var tokenMap = new Dictionary<string, string>();
            foreach (var token in tokens)
                tokenMap[token] = GetDefaultTokenValue(token);

            var client = HttpClientFactory.CreateClient("VikashERP.Api");
            var response = await client.PostAsJsonAsync("api/email-templates/preview", new PreviewEmailTemplateRequest
            {
                Subject = subject,
                Headline = headline,
                BodyHtml = bodyHtml,
                Preheader = preheader,
                ButtonLabel = buttonLabel,
                ButtonLinkToken = buttonLinkToken,
                Tokens = tokenMap
            }, cancellationToken);

            if (!response.IsSuccessStatusCode)
            {
                NotificationService.Error("Could not generate preview.");
                if (!_previewLiveMode)
                    ClosePreview();
                return;
            }

            var preview = await response.Content.ReadFromJsonAsync<EmailTemplatePreview>(cancellationToken);
            _previewHtml = preview?.HtmlBody
                ?? "<p style='padding:16px;font-family:sans-serif;color:#64748b;'>Preview unavailable.</p>";
            _previewSubject = preview?.Subject ?? _previewSubject;
            _previewHasContent = true;
        }
        catch (OperationCanceledException)
        {
            // Superseded by a newer preview request.
        }
        catch (Exception ex)
        {
            NotificationService.Error($"Preview failed: {ex.Message}");
            if (!_previewLiveMode)
                ClosePreview();
        }
        finally
        {
            if (!cancellationToken.IsCancellationRequested)
            {
                _previewLoading = false;
                StateHasChanged();
            }
        }
    }

    private void ClosePreview()
    {
        _previewDebounceCts?.Cancel();
        _previewDebounceCts?.Dispose();
        _previewDebounceCts = null;
        _previewVisible = false;
        _previewLoading = false;
        _previewLiveMode = false;
        _previewHasContent = false;
        _previewSubject = string.Empty;
        _previewHtml = "<p style='padding:16px;font-family:sans-serif;color:#64748b;'>Preview will appear here.</p>";
    }

    private int BodyPlainTextLength
    {
        get
        {
            if (string.IsNullOrEmpty(_upsertModel.BodyHtml))
                return 0;

            var plainText = Regex.Replace(_upsertModel.BodyHtml, "<.*?>", string.Empty);
            plainText = System.Net.WebUtility.HtmlDecode(plainText);
            return plainText.Length;
        }
    }

    private string BodyCharacterCountClass => BodyPlainTextLength switch
    {
        > 5000 => "email-char-over",
        > 4500 => "email-char-warn",
        > 4000 => "email-char-near",
        _ => "email-char-ok"
    };

    private static string GetDefaultTokenValue(string token) => token switch
    {
        "{{UserName}}" => "Rishabh Sharma",
        "{{ResetLink}}" => "https://localhost:7297/reset-password?token=sample",
        "{{LoginUrl}}" => "https://localhost:7297/login",
        "{{ExpiryMinutes}}" => "15",
        "{{ContactPhone}}" => "+91 98765 43210",
        "{{ContactEmail}}" => "support@vikashironix.com",
        _ => "sample-value"
    };

    private static string GetKeyDisplayName(string templateKey) =>
        Enum.TryParse<EmailTemplateType>(templateKey, ignoreCase: true, out var type)
            ? type.ToDisplayName()
            : templateKey;

    private static string GetChannelText(string templateKey) => NotificationType.Email.ToString();

    private static string GetTemplateIcon(string templateKey) => templateKey switch
    {
        "ForgotPassword" => Icons.Material.Filled.LockReset,
        "Welcome" => Icons.Material.Filled.WavingHand,
        "PasswordResetSuccess" => Icons.Material.Filled.VerifiedUser,
        _ => Icons.Material.Filled.Email
    };

