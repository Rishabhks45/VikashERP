    private MudBlazor.Color GetRandomColor(string input)
    {
        if (string.IsNullOrEmpty(input)) return MudBlazor.Color.Primary;
        int hash = input.GetHashCode();
        var values = Enum.GetValues(typeof(MudBlazor.Color));
        return (MudBlazor.Color)values.GetValue(Math.Abs(hash) % 5 + 1)!;
    }

    // ── Excel Download ──
    private async Task DownloadLedger()
    {
        try 
        {
            NotificationService.Success("Synthesizing Excel ledger...");
            
            ExcelPackage.License.SetNonCommercialOrganization("Vikash Ironix");
            using var package = new ExcelPackage();
            var sheet = package.Workbook.Worksheets.Add("Daily Revenue Audit");
            
            // Define Column Headers
            string[] headers = { "Invoice Number", "Customer Name", "Date", "Weight (KG)", "Grand Total (₹)", "Cash Paid (₹)", "Bank Paid (₹)", "Due Amount (₹)" };
            
            // Header Styling
            var headerRange = sheet.Cells[1, 1, 1, headers.Length];
            headerRange.Style.Font.Bold = true;
            headerRange.Style.Font.Color.SetColor(System.Drawing.Color.White);
            headerRange.Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
            headerRange.Style.Fill.BackgroundColor.SetColor(System.Drawing.ColorTranslator.FromHtml("#2c73d2"));
            headerRange.Style.HorizontalAlignment = OfficeOpenXml.Style.ExcelHorizontalAlignment.Center;
            headerRange.Style.VerticalAlignment = OfficeOpenXml.Style.ExcelVerticalAlignment.Center;

            for (int i = 0; i < headers.Length; i++)
            {
                sheet.Cells[1, i + 1].Value = headers[i];
            }

            // Data Population
            int row = 2;
            foreach (var b in FilteredInvoices)
            {
                sheet.Cells[row, 1].Value = b.InvoiceNumber;
                sheet.Cells[row, 2].Value = b.CustomerName;
                sheet.Cells[row, 3].Value = b.InvoiceDate.ToKolkataTime().ToString("dd/MM/yyyy");
                sheet.Cells[row, 4].Value = (double)b.TotalWeightKg;
                sheet.Cells[row, 5].Value = (double)b.TotalAmount;
                sheet.Cells[row, 6].Value = (double)b.CashAmount;
                sheet.Cells[row, 7].Value = (double)b.BankAmount;
                sheet.Cells[row, 8].Value = (double)b.DueAmount;

                // Striping
                if (row % 2 == 0)
                {
                    sheet.Cells[row, 1, row, headers.Length].Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                    sheet.Cells[row, 1, row, headers.Length].Style.Fill.BackgroundColor.SetColor(System.Drawing.ColorTranslator.FromHtml("#f8fafc"));
                }

                row++;
            }

            // Number Formatting
            sheet.Cells[2, 4, row - 1, 8].Style.Numberformat.Format = "#,##0.00";

            // Footer / Totalling
            int lastDataRow = row - 1;
            sheet.Cells[row, 3].Value = "Total";
            sheet.Cells[row, 3].Style.Font.Bold = true;
            sheet.Cells[row, 4].Formula = $"SUM(D2:D{lastDataRow})";
            sheet.Cells[row, 5].Formula = $"SUM(E2:E{lastDataRow})";
            sheet.Cells[row, 6].Formula = $"SUM(F2:F{lastDataRow})";
            sheet.Cells[row, 7].Formula = $"SUM(G2:G{lastDataRow})";
            sheet.Cells[row, 8].Formula = $"SUM(H2:H{lastDataRow})";
            
            var footerRange = sheet.Cells[row, 4, row, 8];
            footerRange.Style.Font.Bold = true;
            footerRange.Style.Numberformat.Format = "#,##0.00";
            
            // Auto-fit Columns
            sheet.Cells.AutoFitColumns();
            
            var bytes = package.GetAsByteArray();
            var base64 = Convert.ToBase64String(bytes);
            
            var filename = $"DailyRevenue_Audit_{SelectedDate?.ToString("yyyyMMdd") ?? "All"}.xlsx";
            await JSRuntime.InvokeVoidAsync("saveAsFile", filename, base64);
            
            NotificationService.Success("Excel Ledger downloaded successfully.");
        }
        catch (Exception ex)
        {
            NotificationService.Error($"Excel export failed: {ex.Message}");
        }
    }

