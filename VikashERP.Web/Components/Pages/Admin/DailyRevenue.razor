@page "/audit"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using VikashERP.Web.Models
@using VikashERP.Web.Services
@using VikashERP.SharedKernel.Enums
@inject ISalesWebService SalesService
@inject ICustomerWebService CustomerWebService
@inject INotificationService NotificationService
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthStateProvider
@using OfficeOpenXml
@using OfficeOpenXml.Style

<PageTitle>Daily Revenue Audit - The Iron Ledger</PageTitle>

<div class="revenue-audit-container">
    
    <!-- Title & Date Selector -->
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6 title-section">
        <div>
            <MudText Typo="Typo.h5" Class="page-title">Daily Revenue Audit</MudText>
            <MudText Typo="Typo.caption" Class="page-subtitle">Fiscal tracking for @(SelectedDate?.ToString("dd MMMM yyyy") ?? "all time")</MudText>
        </div>
        <div class="date-picker-wrapper">
            <MudDatePicker Label="Select Audit Date" @bind-Date="SelectedDate" Variant="Variant.Outlined" Margin="Margin.Dense" Rounded="true" Color="Color.Primary" />
        </div>
    </MudStack>

    @if (Loading)
    {
        <div class="d-flex flex-column align-center justify-center pa-10" style="min-height: 400px;">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Typo="Typo.body2" Class="mt-4 text-secondary">Loading financial audit records...</MudText>
        </div>
    }
    else
    {
        <!-- KPI Cards -->
        <MudGrid Spacing="3" Class="mb-6 kpi-grid">
            <MudItem xs="12" sm="6" md="2">
                <MudPaper Elevation="0" Class="kpi-card billing-card pa-5">
                    <div class="kpi-card-header">
                        <MudText Class="kpi-label">TOTAL BILLING</MudText>
                        <MudIcon Icon="@Icons.Material.Filled.Receipt" Class="kpi-icon" />
                    </div>
                    <MudText Typo="Typo.h5" Class="kpi-value mt-2">₹@FilteredInvoices.Sum(b => b.TotalAmount).ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Class="kpi-subtext">@FilteredInvoices.Count invoices</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudPaper Elevation="0" Class="kpi-card cash-card pa-5">
                    <div class="kpi-card-header">
                        <MudText Class="kpi-label">INVOICE (CASH)</MudText>
                        <MudIcon Icon="@Icons.Material.Filled.Payments" Class="kpi-icon" />
                    </div>
                    <MudText Typo="Typo.h5" Class="kpi-value mt-2">₹@FilteredInvoices.Sum(b => b.CashAmount).ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Class="kpi-subtext">At billing time</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudPaper Elevation="0" Class="kpi-card bank-card pa-5">
                    <div class="kpi-card-header">
                        <MudText Class="kpi-label">INVOICE (A/C)</MudText>
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Class="kpi-icon" />
                    </div>
                    <MudText Typo="Typo.h5" Class="kpi-value mt-2">₹@FilteredInvoices.Sum(b => b.BankAmount).ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Class="kpi-subtext">@GetCollectionEfficiency() efficiency</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudPaper Elevation="0" Class="kpi-card due-card pa-5">
                    <div class="kpi-card-header">
                        <MudText Class="kpi-label">OUTSTANDING (DUE)</MudText>
                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Class="kpi-icon" />
                    </div>
                    <MudText Typo="Typo.h5" Class="kpi-value mt-2">₹@FilteredInvoices.Sum(b => b.DueAmount).ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Class="kpi-subtext">Total receivables</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudPaper Elevation="0" Class="kpi-card pa-5" Style="background: linear-gradient(135deg, hsl(280,70%,20%) 0%, hsl(280,60%,15%) 100%); border: 1px solid hsl(280,60%,35%);">
                    <div class="kpi-card-header">
                        <MudText Class="kpi-label" Style="color: hsl(280,80%,85%);">QUICK COLLECTIONS</MudText>
                        <MudIcon Icon="@Icons.Material.Filled.FlashOn" Class="kpi-icon" Style="color: hsl(280,80%,75%);" />
                    </div>
                    <MudText Typo="Typo.h5" Class="kpi-value mt-2" Style="color: hsl(280,80%,85%);">₹@FilteredPayments.Sum(p => p.Amount).ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Style="color: hsl(280,60%,65%);">@FilteredPayments.Count due payments</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudPaper Elevation="0" Class="kpi-card pa-5" Style="background: linear-gradient(135deg, hsl(150,60%,15%) 0%, hsl(150,50%,10%) 100%); border: 1px solid hsl(150,60%,30%);">
                    <div class="kpi-card-header">
                        <MudText Class="kpi-label" Style="color: hsl(150,80%,75%);">TOTAL COLLECTED</MudText>
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="kpi-icon" Style="color: hsl(150,80%,65%);" />
                    </div>
                    <MudText Typo="Typo.h5" Class="kpi-value mt-2" Style="color: hsl(150,80%,75%);">₹@(FilteredInvoices.Sum(b => b.CashAmount + b.BankAmount) + FilteredPayments.Sum(p => p.Amount)).ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Style="color: hsl(150,60%,55%);">Invoice + Quick</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- Main Grid Snapshot -->
        <MudPaper Elevation="0" Class="table-panel pa-0 overflow-hidden">
            <div class="table-panel-header px-6 py-4">
                <div>
                    <MudText Typo="Typo.subtitle2" Class="table-title">Trade Ledger Snapshot</MudText>
                    <MudText Typo="Typo.caption" Class="table-subtitle">Realtime fiscal synchronization</MudText>
                </div>
                <MudStack Row="true" Spacing="2">
                    <MudButton StartIcon="@Icons.Material.Filled.Download" 
                               OnClick="DownloadLedger" 
                               Variant="Variant.Filled" 
                               Color="Color.Primary" 
                               Size="Size.Small"
                               Class="action-btn download-btn">Download Ledger</MudButton>
                    <MudButton StartIcon="@Icons.Material.Filled.Print" 
                               OnClick="PrintLedger" 
                               Variant="Variant.Outlined" 
                               Color="Color.Secondary" 
                               Size="Size.Small" 
                               Class="action-btn print-btn">Print</MudButton>
                </MudStack>
            </div>
            
            <MudTable Items="@FilteredInvoices" Hover="true" Elevation="0" Class="audit-table" Dense="true" Breakpoint="Breakpoint.None">
                <ColGroup>
                    <col style="width: 25%;" />
                    <col style="width: 10%;" />
                    <col style="width: 14%;" />
                    <col style="width: 14%;" />
                    <col style="width: 14%;" />
                    <col style="width: 14%;" />
                    <col style="width: 9%;" />
                </ColGroup>
                <HeaderContent>
                    <MudTh Class="table-header-cell">Invoice No / Customer</MudTh>
                    <MudTh Class="table-header-cell text-center">Weight (KG)</MudTh>
                    <MudTh Class="table-header-cell text-center">Total Bill (₹)</MudTh>
                    <MudTh Class="table-header-cell text-center accent-amber">Collected (Cash)</MudTh>
                    <MudTh Class="table-header-cell text-center accent-green">Collected (A/C)</MudTh>
                    <MudTh Class="table-header-cell text-center accent-red">Outstanding (Due)</MudTh>
                    <MudTh Class="table-header-cell text-right">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd Class="table-data-cell">
                        <div class="customer-info-wrapper">
                            <MudAvatar Color="@GetRandomColor(context.CustomerName)" Size="Size.Small" Class="customer-avatar">
                                @(string.IsNullOrEmpty(context.CustomerName) ? "?" : context.CustomerName.Substring(0, 1).ToUpper())
                            </MudAvatar>
                            <div class="customer-text">
                                <MudText Typo="Typo.body2" Class="customer-name">@context.CustomerName</MudText>
                                <MudText Typo="Typo.caption" Class="invoice-no">@context.InvoiceNumber</MudText>
                            </div>
                        </div>
                    </MudTd>
                    <MudTd Class="table-data-cell text-center numeric-font">@context.TotalWeightKg.ToString("N2")</MudTd>
                    <MudTd Class="table-data-cell text-center numeric-font bill-total">₹@context.TotalAmount.ToString("N2")</MudTd>
                    <MudTd Class="table-data-cell text-center numeric-font cash-paid">₹@context.CashAmount.ToString("N2")</MudTd>
                    <MudTd Class="table-data-cell text-center numeric-font bank-paid">₹@context.BankAmount.ToString("N2")</MudTd>
                    <MudTd Class="table-data-cell text-center numeric-font balance-due">₹@context.DueAmount.ToString("N2")</MudTd>
                    <MudTd Class="table-data-cell text-right">
                        <div class="actions-wrapper">
                            @if (CanModify(context))
                            {
                                <MudTooltip Text="Adjust Payment">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Info" OnClick="() => OpenEditPayment(context)" />
                                </MudTooltip>
                            }
                            else
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Default" Disabled="true" />
                            }
                            <MudTooltip Text="Audit Details">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Primary" OnClick="() => ViewInvoiceDetails(context.Id)" />
                            </MudTooltip>
                            <MudTooltip Text="Print Bill">
                                <MudIconButton Icon="@Icons.Material.Filled.Print" Size="Size.Small" Color="Color.Success" OnClick="() => PrintIndividualBill(context.Id)" />
                            </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <FooterContent>
                    <MudTd Class="table-footer-cell grand-total-label">GRAND TOTAL (कुल योग)</MudTd>
                    <MudTd Class="table-footer-cell text-center numeric-font footer-value">
                        @FilteredInvoices.Sum(b => b.TotalWeightKg).ToString("N2")
                    </MudTd>
                    <MudTd Class="table-footer-cell text-center numeric-font footer-value">
                        ₹@FilteredInvoices.Sum(b => b.TotalAmount).ToString("N2")
                    </MudTd>
                    <MudTd Class="table-footer-cell text-center numeric-font footer-value">
                        ₹@FilteredInvoices.Sum(b => b.CashAmount).ToString("N2")
                    </MudTd>
                    <MudTd Class="table-footer-cell text-center numeric-font footer-value">
                        ₹@FilteredInvoices.Sum(b => b.BankAmount).ToString("N2")
                    </MudTd>
                    <MudTd Class="table-footer-cell text-center numeric-font footer-value">
                        ₹@FilteredInvoices.Sum(b => b.DueAmount).ToString("N2")
                    </MudTd>
                    <MudTd Class="table-footer-cell"></MudTd>
                </FooterContent>
            </MudTable>
        </MudPaper>

        <!-- Quick Collections Section -->
        @if (FilteredPayments.Any())
        {
            <MudPaper Elevation="0" Class="table-panel pa-0 overflow-hidden mt-6">
                <div class="table-panel-header px-6 py-4" style="background: linear-gradient(135deg, hsl(280,60%,18%) 0%, hsl(280,50%,12%) 100%);">
                    <div>
                        <MudText Typo="Typo.subtitle2" Class="table-title">⚡ Quick Collections</MudText>
                        <MudText Typo="Typo.caption" Class="table-subtitle">Due payments received on @(SelectedDate?.ToString("dd MMM yyyy") ?? "all dates") · not tied to a specific invoice</MudText>
                    </div>
                    <MudChip T="string" Color="Color.Secondary" Size="Size.Small" Variant="Variant.Filled">₹@FilteredPayments.Sum(p => p.Amount).ToString("N0") collected</MudChip>
                </div>
                <MudTable Items="@FilteredPayments" Hover="true" Elevation="0" Class="audit-table" Dense="true" Breakpoint="Breakpoint.None">
                    <ColGroup>
                        <col style="width: 30%;" />
                        <col style="width: 20%;" />
                        <col style="width: 15%;" />
                        <col style="width: 20%;" />
                        <col style="width: 15%;" />
                    </ColGroup>
                    <HeaderContent>
                        <MudTh Class="table-header-cell">Customer</MudTh>
                        <MudTh Class="table-header-cell text-center">Time</MudTh>
                        <MudTh Class="table-header-cell text-center accent-amber">Mode</MudTh>
                        <MudTh Class="table-header-cell text-center accent-green">Amount Received (₹)</MudTh>
                        <MudTh Class="table-header-cell">Remarks</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd Class="table-data-cell">
                            <div class="customer-info-wrapper">
                                <MudAvatar Color="Color.Secondary" Size="Size.Small" Class="customer-avatar">
                                    @(string.IsNullOrEmpty(context.CustomerName) ? "?" : context.CustomerName.Substring(0, 1).ToUpper())
                                </MudAvatar>
                                <MudText Typo="Typo.body2" Class="customer-name">@context.CustomerName</MudText>
                            </div>
                        </MudTd>
                        <MudTd Class="table-data-cell text-center">
                            <MudText Typo="Typo.caption">@context.TransactionDate.ToKolkataTime().ToString("hh:mm tt")</MudText>
                        </MudTd>
                        <MudTd Class="table-data-cell text-center">
                            <MudChip T="string" Size="Size.Small" Color="@(context.PaymentMode == "Cash" ? Color.Warning : Color.Info)" Variant="Variant.Filled">
                                @context.PaymentMode
                            </MudChip>
                        </MudTd>
                        <MudTd Class="table-data-cell text-center numeric-font cash-paid" Style="font-weight: 700;">₹@context.Amount.ToString("N2")</MudTd>
                        <MudTd Class="table-data-cell">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@(context.Remarks ?? "-")</MudText>
                        </MudTd>
                    </RowTemplate>
                    <FooterContent>
                        <MudTd Class="table-footer-cell grand-total-label" colspan="3">TOTAL QUICK COLLECTIONS</MudTd>
                        <MudTd Class="table-footer-cell text-center numeric-font footer-value">₹@FilteredPayments.Sum(p => p.Amount).ToString("N2")</MudTd>
                        <MudTd Class="table-footer-cell"></MudTd>
                    </FooterContent>
                </MudTable>
            </MudPaper>
        }
        else
        {
            <MudPaper Elevation="0" Class="table-panel pa-4 mt-6" Style="border: 1px dashed hsl(280,40%,30%); text-align: center;">
                <MudIcon Icon="@Icons.Material.Filled.FlashOn" Color="Color.Secondary" Style="opacity: 0.3; font-size: 2rem;" />
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-2">No quick payments received on this date</MudText>
            </MudPaper>
        }
    }

    <!-- High-Performance Audit Overlay (Glassmorphism Styled) -->
    <MudOverlay @bind-Visible="ViewDialogVisible" DarkBackground="true" AutoClose="false" ZIndex="9999" LockScroll="true">
        <MudPaper Elevation="25" Class="audit-overlay-panel pa-8">
            <div class="overlay-header">
                <div>
                    <MudText Typo="Typo.h5" Class="overlay-title">FISCAL AUDIT</MudText>
                    <MudText Typo="Typo.caption" Class="overlay-subtitle">INVOICE ID: @ViewingInvoice?.InvoiceNumber</MudText>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Inherit" OnClick="() => { ViewDialogVisible = false; StateHasChanged(); }" />
            </div>

            @if (ViewingInvoice == null)
            {
                <div class="d-flex flex-column align-center pa-10">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                    <MudText Typo="Typo.caption" Class="mt-4 text-secondary">Retrieving Transaction Metadata...</MudText>
                </div>
            }
            else
            {
                <div class="overlay-meta-grid mb-6">
                    <div>
                        <MudText Typo="Typo.overline" Class="meta-label">Customer Node</MudText>
                        <MudText Typo="Typo.h6" Class="meta-value">@ViewingInvoice.CustomerName</MudText>
                    </div>
                    <div style="text-align: right;">
                        <MudText Typo="Typo.overline" Class="meta-label">Temporal Timestamp</MudText>
                        <MudText Typo="Typo.h6" Class="meta-value">@ViewingInvoice.InvoiceDate.ToKolkataTime().ToString("dd MMM yyyy")</MudText>
                        <MudText Typo="Typo.caption" Class="meta-time">@ViewingInvoice.InvoiceDate.ToKolkataTime().ToString("hh:mm tt")</MudText>
                    </div>
                </div>

                <div class="overlay-table-wrapper mb-6">
                    <table class="detail-items-table">
                        <thead>
                            <tr>
                                <th style="text-align:left;">Material</th>
                                <th style="text-align:center;">Qty (Pcs)</th>
                                <th style="text-align:center;">Weight (KG)</th>
                                <th style="text-align:right;">Rate</th>
                                <th style="text-align:right;">Total Price</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in ViewingInvoice.Items)
                            {
                                <tr>
                                    <td style="font-weight: 700;">@item.VariantName</td>
                                    <td style="text-align:center; font-family:monospace;">@item.QtyPcs</td>
                                    <td style="text-align:center; font-family:monospace;">@item.WeightKg.ToString("N2")</td>
                                    <td style="text-align:right; font-family:monospace;">₹@item.Rate.ToString("N2") / @item.RateOn</td>
                                    <td style="text-align:right; font-family:monospace; font-weight: 700;">₹@item.TotalPrice.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="overlay-summary-card p-6">
                    <div class="summary-notes">
                        <MudText Typo="Typo.overline" Class="meta-label">Notes & Logistics</MudText>
                        <MudText Typo="Typo.body2" Class="notes-text">@ViewingInvoice.Remarks</MudText>
                        <MudText Typo="Typo.body2" Class="notes-text mt-2"><strong>Vehicle No:</strong> @ViewingInvoice.VehicleNumber</MudText>
                    </div>
                    <MudStack Spacing="1" Class="summary-charges">
                        <div class="charge-row">
                            <MudText Typo="Typo.caption">Subtotal Ledger</MudText>
                            <MudText Typo="Typo.caption" Class="charge-val">₹@ViewingInvoice.Subtotal.ToString("N2")</MudText>
                        </div>
                        @if (ViewingInvoice.CgstAmount > 0 || ViewingInvoice.SgstAmount > 0)
                        {
                            <div class="charge-row">
                                <MudText Typo="Typo.caption">CGST (9%) & SGST (9%)</MudText>
                                <MudText Typo="Typo.caption" Class="charge-val">₹@((ViewingInvoice.CgstAmount + ViewingInvoice.SgstAmount).ToString("N2"))</MudText>
                            </div>
                        }
                        @if (ViewingInvoice.FreightCharge > 0)
                        {
                            <div class="charge-row">
                                <MudText Typo="Typo.caption">Freight (Bhada)</MudText>
                                <MudText Typo="Typo.caption" Class="charge-val">₹@ViewingInvoice.FreightCharge.ToString("N2")</MudText>
                            </div>
                        }
                        @if (ViewingInvoice.LoadingCharge > 0)
                        {
                            <div class="charge-row">
                                <MudText Typo="Typo.caption">Loading Charge</MudText>
                                <MudText Typo="Typo.caption" Class="charge-val">₹@ViewingInvoice.LoadingCharge.ToString("N2")</MudText>
                            </div>
                        }
                        @if (ViewingInvoice.RoundingAmount != 0)
                        {
                            <div class="charge-row">
                                <MudText Typo="Typo.caption">Rounding Adjustment</MudText>
                                <MudText Typo="Typo.caption" Class="charge-val">₹@ViewingInvoice.RoundingAmount.ToString("N2")</MudText>
                            </div>
                        }
                        <div class="grand-total-row mt-2 pt-2">
                            <MudText Typo="Typo.h6" Class="total-label">GRAND TOTAL</MudText>
                            <MudText Typo="Typo.h6" Class="total-value">₹@ViewingInvoice.TotalAmount.ToString("N2")</MudText>
                        </div>
                    </MudStack>
                </div>
            }
            
            <div class="overlay-footer-actions mt-6">
                <MudButton OnClick="() => { ViewDialogVisible = false; StateHasChanged(); }" Variant="Variant.Filled" Color="Color.Primary" DropShadow="false" Class="close-overlay-btn">CLOSE ARCHIVE</MudButton>
            </div>
        </MudPaper>
    </MudOverlay>

    <!-- Payment Adjustment Overlay -->
    <MudOverlay @bind-Visible="EditDialogVisible" DarkBackground="true" AutoClose="false" ZIndex="9999">
        <MudPaper Elevation="25" Class="payment-overlay-panel pa-8">
            <MudText Typo="Typo.h6" Class="payment-overlay-title">Realize Payment</MudText>
            <MudText Typo="Typo.caption" Class="payment-overlay-subtitle">ADJUSTING INVOICE: @EditingInvoice?.InvoiceNumber</MudText>
            
            <MudStack Spacing="4" Class="mt-6">
                <MudNumericField T="decimal" Label="CASH PAYMENT (नकद)" Value="EditCash" ValueChanged="OnEditCashChanged" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Payments" Class="cash-field" HideSpinButtons="true" />
                <MudNumericField T="decimal" Label="A/C PAYMENT (बैंक)" Value="EditAccount" ValueChanged="OnEditAccountChanged" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AccountBalance" Class="bank-field" HideSpinButtons="true" />
                
                <div class="payment-summary-box pa-4 mt-2">
                    <div class="d-flex justify-content-between mb-1">
                        <MudText Typo="Typo.caption">TOTAL BILL</MudText>
                        <MudText Typo="Typo.caption" Class="font-monospace font-bold">₹@EditingInvoice?.TotalAmount.ToString("N2")</MudText>
                    </div>
                    <div class="d-flex justify-content-between">
                        <MudText Typo="Typo.caption" Class="due-label">REMAINING DUE</MudText>
                        <MudText Typo="Typo.caption" Class="due-value font-monospace font-bold">₹@((EditingInvoice?.TotalAmount ?? 0) - (EditCash + EditAccount))</MudText>
                    </div>
                </div>

                <div class="payment-actions-wrapper mt-4">
                    <MudButton OnClick="() => { EditDialogVisible = false; StateHasChanged(); }" Variant="Variant.Text" FullWidth="true">Cancel</MudButton>
                    <MudButton OnClick="SaveEditPayment" Color="Color.Primary" Variant="Variant.Filled" DropShadow="false" FullWidth="true" Class="commit-btn">Commit</MudButton>
                </div>
            </MudStack>
        </MudPaper>
    </MudOverlay>
</div>

@code {
    private List<InvoiceListDto> _invoices = new();
    private List<RecentCustomerPaymentDto> _payments = new();
    private DateTime? SelectedDate = DateTime.Today;
    private bool Loading = true;
    private bool IsSuperAdmin = false;

    // Payment editing state
    private InvoiceListDto? EditingInvoice;
    private bool EditDialogVisible = false;
    private decimal EditCash;
    private decimal EditAccount;

    // Detailed audit overlay state
    private InvoiceDetailDto? ViewingInvoice;
    private bool ViewDialogVisible = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        Loading = true;
        try 
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            IsSuperAdmin = user.IsInRole("SuperAdmin") || user.IsInRole("Admin");

            _invoices = await SalesService.GetInvoicesAsync();
            _payments = await CustomerWebService.GetRecentPaymentsAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Error($"Error retrieving fiscal records: {ex.Message}");
        }
        finally
        {
            Loading = false;
        }
    }

    private bool CanModify(InvoiceListDto b)
    {
        if (IsSuperAdmin) return true;
        // Check if created within last 12 hours
        return (DateTime.UtcNow - b.InvoiceDate).TotalHours <= 12;
    }

    private List<InvoiceListDto> FilteredInvoices => SelectedDate.HasValue
        ? _invoices.Where(b => b.InvoiceDate.Date == SelectedDate.Value.Date).ToList()
        : _invoices;

    // Quick payments filtered by the date the payment was RECEIVED (TransactionDate)
    private List<RecentCustomerPaymentDto> FilteredPayments => SelectedDate.HasValue
        ? _payments.Where(p => p.TransactionDate.ToKolkataTime().Date == SelectedDate.Value.Date).ToList()
        : _payments;

    private string GetCollectionEfficiency()
    {
        var total = FilteredInvoices.Sum(b => b.TotalAmount);
        if (total == 0) return "0%";
        var paid = FilteredInvoices.Sum(b => b.BankAmount + b.CashAmount);
        return $"{(paid / total * 100m).ToString("N1")}%";
    }

    // ── Payment Editing ──
    private void OpenEditPayment(InvoiceListDto invoice)
    {
        EditingInvoice = invoice;
        EditCash = invoice.CashAmount;
        EditAccount = invoice.BankAmount;
        EditDialogVisible = true;
        StateHasChanged();
    }

    private void OnEditCashChanged(decimal val)
    {
        if (EditingInvoice == null) return;
        EditCash = val;
        EditAccount = EditingInvoice.TotalAmount - EditCash;
    }

    private void OnEditAccountChanged(decimal val)
    {
        if (EditingInvoice == null) return;
        EditAccount = val;
        EditCash = EditingInvoice.TotalAmount - EditAccount;
    }

    private async Task SaveEditPayment()
    {
        if (EditingInvoice == null) return;
        try
        {
            var success = await SalesService.UpdateInvoicePaymentAsync(EditingInvoice.Id, EditCash, EditAccount);
            if (success)
            {
                NotificationService.Success("Ledger updated. Payment distribution synchronized.");
                EditDialogVisible = false;
                await LoadDataAsync();
            }
            else
            {
                NotificationService.Error("Update failed. Please try again.");
            }
        }
        catch (Exception ex)
        {
            NotificationService.Error($"Update failed: {ex.Message}");
        }
    }

