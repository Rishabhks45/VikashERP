@page "/audit"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using VikashERP.Web.Models
@using VikashERP.Web.Services
@using VikashERP.SharedKernel.Enums
@inject ISalesWebService SalesService
@inject ICustomerWebService CustomerWebService
@inject INotificationService NotificationService
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthStateProvider
@using OfficeOpenXml
@using OfficeOpenXml.Style
@using System.Globalization

<PageTitle>Daily Revenue Audit - Vikash Iron &amp; Steel</PageTitle>

<div class="drv3-container">

    <!-- ═══════════════════════════════════════════════ HEADER TOOLBAR ═══ -->
    <div class="drv3-header">
        <div class="drv3-header-left">
            <h1 class="drv3-title">Daily Revenue Audit</h1>
            <p class="drv3-subtitle">Fiscal tracking for @(SelectedDate?.ToString("dd MMMM yyyy") ?? "all time")</p>
        </div>
        <div class="drv3-header-right">
            <div class="drv3-toolbar-controls">
                <div class="drv3-search-wrap">
                    <MudTextField T="string" Value="@_searchQuery" ValueChanged="OnSearchChanged"
                                   Placeholder="Search customer, invoice..."
                                   Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                                   Class="drv3-search" Immediate="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </div>
                <div class="drv3-date-wrap">
                    <MudDatePicker @bind-Date="SelectedDate" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   Color="Color.Primary" DateFormat="dd/MM/yyyy" Culture="@InCulture"
                                   Class="drv3-date" />
                </div>
                <MudMenu StartIcon="@Icons.Material.Filled.FileDownload" Label="Export" Variant="Variant.Filled"
                         Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowDropDown"
                         Size="Size.Small" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                         Class="drv3-export-btn">
                    <MudMenuItem OnClick="DownloadLedger" Icon="@Icons.Material.Filled.TableChart">Export Excel</MudMenuItem>
                    <MudMenuItem OnClick="PrintLedger" Icon="@Icons.Material.Filled.Print">Print Ledger</MudMenuItem>
                </MudMenu>
            </div>
        </div>
    </div>

    @if (Loading)
    {
        <div class="drv3-loader">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <p>Loading financial records...</p>
        </div>
    }
    else
    {
        <!-- ══════════════════════════════════════════════════ KPI CARDS ═══ -->
        <div class="drv3-kpi-grid">

            <!-- Total Daily Revenue -->
            <div class="drv3-kpi drv3-kpi-revenue">
                <div class="drv3-kpi-body">
                    <div class="drv3-kpi-badge drv3-badge-revenue">
                        <MudIcon Icon="@Icons.Material.Filled.ShowChart" Class="drv3-kpi-icon" />
                    </div>
                    <div class="drv3-kpi-info">
                        <span class="drv3-kpi-label">TOTAL DAILY REVENUE</span>
                        <span class="drv3-kpi-value">₹@Fmt(FilteredInvoices.Sum(b => b.TotalAmount) + FilteredPayments.Sum(p => p.Amount), "N0")</span>
                        <span class="drv3-kpi-sub">Billing + Quick Collections</span>
                    </div>
                </div>
            </div>

            <!-- Total Bill -->
            <div class="drv3-kpi drv3-kpi-billing">
                <div class="drv3-kpi-body">
                    <div class="drv3-kpi-badge drv3-badge-billing">
                        <MudIcon Icon="@Icons.Material.Filled.Description" Class="drv3-kpi-icon" />
                    </div>
                    <div class="drv3-kpi-info">
                        <span class="drv3-kpi-label">TOTAL BILL</span>
                        <span class="drv3-kpi-value">₹@Fmt(FilteredInvoices.Sum(b => b.TotalAmount), "N0")</span>
                        <span class="drv3-kpi-sub">@FilteredInvoices.Count @(FilteredInvoices.Count == 1 ? "Invoice" : "Invoices")</span>
                    </div>
                </div>
            </div>

            <!-- Total Due -->
            <div class="drv3-kpi drv3-kpi-due">
                <div class="drv3-kpi-body">
                    <div class="drv3-kpi-badge drv3-badge-due">
                        <MudIcon Icon="@Icons.Material.Filled.AccessTime" Class="drv3-kpi-icon" />
                    </div>
                    <div class="drv3-kpi-info">
                        <span class="drv3-kpi-label">TOTAL DUE</span>
                        <span class="drv3-kpi-value">₹@Fmt(FilteredInvoices.Sum(b => b.DueAmount), "N0")</span>
                        <span class="drv3-kpi-sub">Total receivables</span>
                    </div>
                </div>
            </div>

            <!-- Quick Collections -->
            <div class="drv3-kpi drv3-kpi-quick">
                <div class="drv3-kpi-body">
                    <div class="drv3-kpi-badge drv3-badge-quick">
                        <MudIcon Icon="@Icons.Material.Filled.FlashOn" Class="drv3-kpi-icon" />
                    </div>
                    <div class="drv3-kpi-info">
                        <span class="drv3-kpi-label">TOTAL QUICK COLLECTION</span>
                        <span class="drv3-kpi-value">₹@Fmt(FilteredPayments.Sum(p => p.Amount), "N0")</span>
                        <span class="drv3-kpi-sub">@FilteredPayments.Count Due payments</span>
                    </div>
                </div>
            </div>

            <!-- Collection Efficiency -->
            <div class="drv3-kpi drv3-kpi-efficiency">
                <div class="drv3-kpi-body">
                    <div class="drv3-kpi-badge drv3-badge-efficiency">
                        <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Class="drv3-kpi-icon" />
                    </div>
                    <div class="drv3-kpi-info">
                        <span class="drv3-kpi-label">COLLECTION EFFICIENCY</span>
                        <span class="drv3-kpi-value">@GetCollectionEfficiency().ToString("N0")%</span>
                        <span class="drv3-kpi-sub @GetEfficiencyClass(GetCollectionEfficiency())">@GetEfficiencyStatus(GetCollectionEfficiency())</span>
                    </div>
                </div>
            </div>

        </div>

        <!-- ═══════════════════════════════════════ TRADE LEDGER SNAPSHOT ═══ -->
        <div class="drv3-panel">
            <div class="drv3-panel-header">
                <div>
                    <h2 class="drv3-panel-title">TRADE LEDGER SNAPSHOT</h2>
                    <p class="drv3-panel-sub">Realtime fiscal synchronization</p>
                </div>
            </div>
            
            <MudTable @ref="_invoiceTable" Items="@FilteredInvoices" Hover="true" Elevation="0" Class="drv3-mud-table" Dense="true" Breakpoint="Breakpoint.None">
                <ColGroup>
                    <col style="width: 25%;" />
                    <col style="width: 10%;" />
                    <col style="width: 14%;" />
                    <col style="width: 14%;" />
                    <col style="width: 14%;" />
                    <col style="width: 14%;" />
                    <col style="width: 9%;" />
                </ColGroup>
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel SortBy="new Func<InvoiceListDto, object>(x => x.CustomerName)">
                            Invoice No / Customer
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh Class="ta-c">
                        <MudTableSortLabel InitialDirection="SortDirection.None" SortBy="new Func<InvoiceListDto, object>(x => x.TotalWeightKg)">
                            Weight (KG)
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh Class="ta-r">
                        <MudTableSortLabel InitialDirection="SortDirection.None" SortBy="new Func<InvoiceListDto, object>(x => x.TotalAmount)">
                            Total Bill (₹)
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh Class="ta-r drv3-th-cash">
                        <MudTableSortLabel InitialDirection="SortDirection.None" SortBy="new Func<InvoiceListDto, object>(x => x.CashAmount)">
                            Collected (Cash)
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh Class="ta-r drv3-th-bank">
                        <MudTableSortLabel InitialDirection="SortDirection.None" SortBy="new Func<InvoiceListDto, object>(x => x.BankAmount)">
                            Collected (A/C)
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh Class="ta-r drv3-th-due">
                        <MudTableSortLabel InitialDirection="SortDirection.None" SortBy="new Func<InvoiceListDto, object>(x => x.DueAmount)">
                            Outstanding (Due)
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh Class="ta-r">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    @{
                        var initials = string.IsNullOrEmpty(context.CustomerName) ? "?"
                            : context.CustomerName.Length >= 2
                                ? context.CustomerName.Substring(0, 2).ToUpper()
                                : context.CustomerName.Substring(0, 1).ToUpper();
                    }
                    <MudTd DataLabel="Invoice No / Customer">
                        <div class="drv3-customer">
                            <div class="drv3-avatar drv3-avatar-ledger">@initials</div>
                            <div class="drv3-cust-info">
                                <span class="drv3-cust-name">@context.CustomerName</span>
                                <span class="drv3-inv-num">@context.InvoiceNumber</span>
                            </div>
                        </div>
                    </MudTd>
                    <MudTd Class="ta-c drv3-mono" DataLabel="Weight (KG)">@Fmt(context.TotalWeightKg)</MudTd>
                    <MudTd Class="ta-r drv3-mono drv3-total-bill" DataLabel="Total Bill (₹)">₹@Fmt(context.TotalAmount)</MudTd>
                    <MudTd Class="ta-r drv3-mono drv3-cash" DataLabel="Collected (Cash)">₹@Fmt(context.CashAmount)</MudTd>
                    <MudTd Class="ta-r drv3-mono drv3-bank" DataLabel="Collected (A/C)">₹@Fmt(context.BankAmount)</MudTd>
                    <MudTd Class="ta-r drv3-mono drv3-due" DataLabel="Outstanding (Due)">₹@Fmt(context.DueAmount)</MudTd>
                    <MudTd Class="ta-r" DataLabel="Actions">
                        <div class="drv3-actions">
                            @if (CanModify(context))
                            {
                                <button class="drv3-btn drv3-btn-edit" title="Adjust Payment" @onclick="() => OpenEditPayment(context)">
                                    <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                                </button>
                            }
                            else
                            {
                                <button class="drv3-btn drv3-btn-lock" title="Locked" disabled>
                                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" />
                                </button>
                            }
                            <button class="drv3-btn drv3-btn-view" title="View Details" @onclick="() => ViewInvoiceDetails(context.Id)">
                                <MudIcon Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" />
                            </button>
                            <button class="drv3-btn drv3-btn-print" title="Print Bill" @onclick="() => PrintIndividualBill(context.Id)">
                                <MudIcon Icon="@Icons.Material.Filled.Print" Size="Size.Small" />
                            </button>
                        </div>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <div class="drv3-empty">
                        <MudIcon Icon="@Icons.Material.Filled.Inbox" />
                        <p>No trade ledger records found for this date.</p>
                    </div>
                </NoRecordsContent>
                <FooterContent>
                    <MudTd Class="drv3-grand-total-label">GRAND TOTAL (कुल योग)</MudTd>
                    <MudTd Class="drv3-grand-total-cell ta-c drv3-mono">@Fmt(FilteredInvoices.Sum(b => b.TotalWeightKg))</MudTd>
                    <MudTd Class="drv3-grand-total-cell ta-r drv3-mono">₹@Fmt(FilteredInvoices.Sum(b => b.TotalAmount))</MudTd>
                    <MudTd Class="drv3-grand-total-cell ta-r drv3-mono drv3-cash">₹@Fmt(FilteredInvoices.Sum(b => b.CashAmount))</MudTd>
                    <MudTd Class="drv3-grand-total-cell ta-r drv3-mono drv3-bank">₹@Fmt(FilteredInvoices.Sum(b => b.BankAmount))</MudTd>
                    <MudTd Class="drv3-grand-total-cell ta-r drv3-mono drv3-due">₹@Fmt(FilteredInvoices.Sum(b => b.DueAmount))</MudTd>
                    <MudTd Class="drv3-grand-total-cell"></MudTd>
                </FooterContent>
            </MudTable>
        </div>

        <!-- ═══════════════════════════════════════════ QUICK COLLECTIONS ═══ -->
        <div class="drv3-panel drv3-panel-quick">
            <div class="drv3-panel-header">
                <div>
                    <h2 class="drv3-panel-title">Quick Collections</h2>
                    <p class="drv3-panel-sub">Due payments received today</p>
                </div>
            </div>
            
            <MudTable Items="@FilteredPayments" Hover="true" Elevation="0" Class="drv3-mud-table" Dense="true" Breakpoint="Breakpoint.None">
                <ColGroup>
                    <col style="width: 30%;" />
                    <col style="width: 15%;" />
                    <col style="width: 10%;" />
                    <col style="width: 15%;" />
                    <col style="width: 15%;" />
                    <col style="width: 15%;" />
                    <col style="width: 0%;" />
                </ColGroup>
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel SortBy="new Func<RecentCustomerPaymentDto, object>(x => x.CustomerName)">
                            Customer
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh Class="ta-c">
                        <MudTableSortLabel InitialDirection="SortDirection.None" SortBy="new Func<RecentCustomerPaymentDto, object>(x => x.TransactionDate)">
                            Time
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh Class="ta-c">
                        <MudTableSortLabel InitialDirection="SortDirection.None" SortBy="new Func<RecentCustomerPaymentDto, object>(x => x.PaymentMode)">
                            Mode
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh Class="ta-r drv3-th-cash">
                        <MudTableSortLabel InitialDirection="SortDirection.None" SortBy="@(new Func<RecentCustomerPaymentDto, object>(x => string.Equals(x.PaymentMode, "Cash", StringComparison.OrdinalIgnoreCase) ? x.Amount : 0m))">
                            Collected (Cash)
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh Class="ta-r drv3-th-bank">
                        <MudTableSortLabel InitialDirection="SortDirection.None" SortBy="@(new Func<RecentCustomerPaymentDto, object>(x => !string.Equals(x.PaymentMode, "Cash", StringComparison.OrdinalIgnoreCase) ? x.Amount : 0m))">
                            Collected (A/C)
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh Class="ta-r">
                        <MudTableSortLabel InitialDirection="SortDirection.None" SortBy="@(new Func<RecentCustomerPaymentDto, object>(x => x.Amount))">
                            Total Received (₹)
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel InitialDirection="SortDirection.None" SortBy="@(new Func<RecentCustomerPaymentDto, object>(x => x.Remarks ?? ""))">
                            Remarks
                        </MudTableSortLabel>
                    </MudTh>
                </HeaderContent>
                <RowTemplate>
                    @{
                        var initials = string.IsNullOrEmpty(context.CustomerName) ? "?"
                            : context.CustomerName.Length >= 2
                                ? context.CustomerName.Substring(0, 2).ToUpper()
                                : context.CustomerName.Substring(0, 1).ToUpper();
                        var isCash = string.Equals(context.PaymentMode, "Cash", StringComparison.OrdinalIgnoreCase);
                        var modeClass = isCash ? "drv3-mode-cash" : "drv3-mode-bank";
                    }
                    <MudTd DataLabel="Customer">
                        <div class="drv3-customer">
                            <div class="drv3-avatar drv3-avatar-quick">@initials</div>
                            <span class="drv3-cust-name">@context.CustomerName</span>
                        </div>
                    </MudTd>
                    <MudTd Class="ta-c drv3-time" DataLabel="Time">@context.TransactionDate.ToKolkataTime().ToString("hh:mm tt")</MudTd>
                    <MudTd Class="ta-c" DataLabel="Mode">
                        <span class="drv3-mode @modeClass">@context.PaymentMode</span>
                    </MudTd>
                    <MudTd Class="ta-r drv3-mono drv3-cash" DataLabel="Collected (Cash)">₹@(isCash ? Fmt(context.Amount) : "0.00")</MudTd>
                    <MudTd Class="ta-r drv3-mono drv3-bank" DataLabel="Collected (A/C)">₹@(!isCash ? Fmt(context.Amount) : "0.00")</MudTd>
                    <MudTd Class="ta-r drv3-mono drv3-total-received" DataLabel="Total Received (₹)">₹@Fmt(context.Amount)</MudTd>
                    <MudTd Class="drv3-remarks" DataLabel="Remarks">@(context.Remarks ?? "-")</MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <div class="drv3-empty">
                        <MudIcon Icon="@Icons.Material.Filled.FlashOn" />
                        <p>No quick payments received on this date.</p>
                    </div>
                </NoRecordsContent>
                <FooterContent>
                    <MudTd Class="drv3-grand-total-label" Colspan="3">GRAND TOTAL (कुल योग)</MudTd>
                    <MudTd Class="drv3-grand-total-cell ta-r drv3-mono drv3-cash">₹@Fmt(FilteredPayments.Where(p => string.Equals(p.PaymentMode, "Cash", StringComparison.OrdinalIgnoreCase)).Sum(p => p.Amount))</MudTd>
                    <MudTd Class="drv3-grand-total-cell ta-r drv3-mono drv3-bank">₹@Fmt(FilteredPayments.Where(p => !string.Equals(p.PaymentMode, "Cash", StringComparison.OrdinalIgnoreCase)).Sum(p => p.Amount))</MudTd>
                    <MudTd Class="drv3-grand-total-cell ta-r drv3-mono drv3-total-received">₹@Fmt(FilteredPayments.Sum(p => p.Amount))</MudTd>
                    <MudTd Class="drv3-grand-total-cell"></MudTd>
                </FooterContent>
            </MudTable>
        </div>



        <!-- ══════════════════════════════════════ OVERALL RECONCILIATION ═══ -->
        <div class="drv3-panel drv3-reconcile-panel">
            <div class="drv3-panel-header">
                <h2 class="drv3-panel-title">OVERALL RECONCILIATION</h2>
            </div>
            <div class="drv3-reconcile-body">

                <!-- Cash Summary -->
                <div class="drv3-recon-side drv3-recon-cash-side">
                    <div class="drv3-recon-side-label drv3-recon-cash-label">CASH SUMMARY</div>
                    <div class="drv3-equation">
                        <div class="drv3-eq-block">
                            <span class="drv3-eq-label">Total Daily Revenue (Cash)</span>
                            <span class="drv3-eq-val drv3-cash">₹@Fmt(ReconInvCash)</span>
                        </div>
                        <span class="drv3-eq-op">+</span>
                        <div class="drv3-eq-block">
                            <span class="drv3-eq-label">Quick Collection (Cash)</span>
                            <span class="drv3-eq-val drv3-cash">₹@Fmt(ReconQkCash)</span>
                        </div>
                        <span class="drv3-eq-op">−</span>
                        <div class="drv3-eq-block">
                            <span class="drv3-eq-label">Daily Kharcha (Cash)</span>
                            <span class="drv3-eq-val">₹0.00</span>
                        </div>
                        <span class="drv3-eq-op">=</span>
                        <div class="drv3-eq-block drv3-eq-result drv3-eq-result-cash">
                            <span class="drv3-eq-label">Total Cash Surplus</span>
                            <span class="drv3-eq-val drv3-surplus-cash">₹@Fmt(ReconTotalCash)</span>
                        </div>
                    </div>
                </div>

                <div class="drv3-recon-divider"></div>

                <!-- A/C Summary -->
                <div class="drv3-recon-side drv3-recon-bank-side">
                    <div class="drv3-recon-side-label drv3-recon-bank-label">A/C SUMMARY</div>
                    <div class="drv3-equation">
                        <div class="drv3-eq-block">
                            <span class="drv3-eq-label">Total Daily Revenue (A/C)</span>
                            <span class="drv3-eq-val drv3-bank">₹@Fmt(ReconInvBank)</span>
                        </div>
                        <span class="drv3-eq-op">+</span>
                        <div class="drv3-eq-block">
                            <span class="drv3-eq-label">Quick Collection (A/C)</span>
                            <span class="drv3-eq-val drv3-bank">₹@Fmt(ReconQkBank)</span>
                        </div>
                        <span class="drv3-eq-op">−</span>
                        <div class="drv3-eq-block">
                            <span class="drv3-eq-label">Daily Kharcha (A/C)</span>
                            <span class="drv3-eq-val">₹0.00</span>
                        </div>
                        <span class="drv3-eq-op">=</span>
                        <div class="drv3-eq-block drv3-eq-result drv3-eq-result-bank">
                            <span class="drv3-eq-label">Total A/C Surplus</span>
                            <span class="drv3-eq-val drv3-surplus-bank">₹@Fmt(ReconTotalBank)</span>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Bill & Due Summary footer -->
            <div class="drv3-recon-footer">
                <div class="drv3-recon-footer-left">
                    <span class="drv3-footer-label">TOTAL BILL (कुल बिल)</span>
                    <span class="drv3-footer-val drv3-footer-bill">₹@Fmt(ReconTotalBill)</span>
                </div>
                <div class="drv3-recon-footer-divider"></div>
                <div class="drv3-recon-footer-right">
                    <span class="drv3-footer-label drv3-footer-due-lbl">TOTAL DUE (कुल बकाया)</span>
                    <span class="drv3-footer-val drv3-footer-due">₹@Fmt(ReconTotalDue)</span>
                </div>
            </div>
        </div>

    }

    <!-- Audit Timestamp Footer -->
    <div class="drv3-page-footer">
        <div>
            <MudIcon Icon="@Icons.Material.Filled.Sync" Style="font-size:0.95rem; margin-right:4px; vertical-align:middle;" />
            Last updated: @DateTime.Now.ToKolkataTime().ToString("dd MMM yyyy, hh:mm tt")
        </div>
        <div>All amounts are in INR (₹)</div>
    </div>

</div>



<!-- ════════════════════════════════════ PAYMENT ADJUSTMENT OVERLAY ═══ -->
<MudOverlay @bind-Visible="EditDialogVisible" DarkBackground="true" AutoClose="false" ZIndex="9999">
    <MudPaper Elevation="25" Class="drv3-pay-overlay pa-8">
        <MudText Typo="Typo.h6" Class="drv3-overlay-title">Realize Payment</MudText>
        <MudText Typo="Typo.caption" Class="drv3-overlay-caption">Adjusting Invoice: @EditingInvoice?.InvoiceNumber</MudText>
        <MudStack Spacing="4" Class="mt-6">
            <MudNumericField T="decimal" Label="CASH PAYMENT (नकद)" Value="EditCash" ValueChanged="OnEditCashChanged"
                             Variant="Variant.Outlined" Adornment="Adornment.Start"
                             AdornmentIcon="@Icons.Material.Filled.Payments" HideSpinButtons="true" Class="cash-field" />
            <MudNumericField T="decimal" Label="A/C PAYMENT (बैंक)" Value="EditAccount" ValueChanged="OnEditAccountChanged"
                             Variant="Variant.Outlined" Adornment="Adornment.Start"
                             AdornmentIcon="@Icons.Material.Filled.AccountBalance" HideSpinButtons="true" Class="bank-field" />
            <div class="drv3-pay-summary">
                <div class="drv3-pay-row"><span>Total Bill</span><span>₹@EditingInvoice?.TotalAmount.ToString("N2")</span></div>
                <div class="drv3-pay-row drv3-pay-due"><span>Remaining Due</span><span>₹@((EditingInvoice?.TotalAmount ?? 0) - (EditCash + EditAccount))</span></div>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-top:8px;">
                <MudButton OnClick="() => { EditDialogVisible = false; StateHasChanged(); }"
                           Variant="Variant.Text" FullWidth="true">Cancel</MudButton>
                <MudButton OnClick="SaveEditPayment" Color="Color.Primary" Variant="Variant.Filled"
                           DropShadow="false" FullWidth="true">Commit</MudButton>
            </div>
        </MudStack>
    </MudPaper>
</MudOverlay>

@code {
    private static readonly CultureInfo InCulture = CultureInfo.GetCultureInfo("en-IN");

    private static string Fmt(decimal value, string format = "N2") =>
        value.ToString(format, InCulture);

    private List<InvoiceListDto> _invoices = new();
    private List<RecentCustomerPaymentDto> _payments = new();
    private DateTime? SelectedDate = DateTime.Today;
    private bool Loading = true;
    private bool IsSuperAdmin = false;
    private string _searchQuery = "";
    private MudTable<InvoiceListDto>? _invoiceTable;


    private InvoiceListDto? EditingInvoice;
    private bool EditDialogVisible = false;
    private decimal EditCash;
    private decimal EditAccount;



    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        Loading = true;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            IsSuperAdmin = user.IsInRole("SuperAdmin") || user.IsInRole("Admin");
            _invoices = await SalesService.GetInvoicesAsync();
            _payments = await CustomerWebService.GetRecentPaymentsAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Error($"Error retrieving records: {ex.Message}");
        }
        finally
        {
            Loading = false;
        }
    }

    private bool CanModify(InvoiceListDto b)
    {
        if (IsSuperAdmin) return true;
        return (DateTime.UtcNow - b.InvoiceDate).TotalHours <= 12;
    }

    private void OnSearchChanged(string val)
    {
        _searchQuery = val;
        StateHasChanged();
    }

    private List<InvoiceListDto> FilteredInvoices => _invoices
        .Where(b => (!SelectedDate.HasValue || b.InvoiceDate.Date == SelectedDate.Value.Date) &&
                    (string.IsNullOrWhiteSpace(_searchQuery) ||
                     (b.InvoiceNumber != null && b.InvoiceNumber.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)) ||
                     (b.CustomerName != null && b.CustomerName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))))
        .ToList();

    private List<RecentCustomerPaymentDto> FilteredPayments => _payments
        .Where(p => (!SelectedDate.HasValue || p.TransactionDate.ToKolkataTime().Date == SelectedDate.Value.Date) &&
                    (string.IsNullOrWhiteSpace(_searchQuery) ||
                     (p.CustomerName != null && p.CustomerName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)) ||
                     (p.Remarks != null && p.Remarks.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)) ||
                     (p.PaymentMode != null && p.PaymentMode.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))))
        .ToList();


    // ── Reconciliation computed properties ──
    private decimal ReconInvCash   => FilteredInvoices.Sum(b => b.CashAmount);
    private decimal ReconInvBank   => FilteredInvoices.Sum(b => b.BankAmount);
    private decimal ReconQkCash    => FilteredPayments.Where(p => string.Equals(p.PaymentMode, "Cash", StringComparison.OrdinalIgnoreCase)).Sum(p => p.Amount);
    private decimal ReconQkBank    => FilteredPayments.Where(p => !string.Equals(p.PaymentMode, "Cash", StringComparison.OrdinalIgnoreCase)).Sum(p => p.Amount);
    private decimal ReconTotalCash => ReconInvCash + ReconQkCash;
    private decimal ReconTotalBank => ReconInvBank + ReconQkBank;
    private decimal ReconTotalBill => FilteredInvoices.Sum(b => b.TotalAmount);
    private decimal ReconTotalDue  => FilteredInvoices.Sum(b => b.DueAmount);

    private decimal GetCollectionEfficiency()
    {
        var total = FilteredInvoices.Sum(b => b.TotalAmount);
        if (total == 0) return 100m;
        var paid = FilteredInvoices.Sum(b => b.CashAmount + b.BankAmount);
        return Math.Min((paid / total) * 100m, 100m);
    }

    private string GetEfficiencyStatus(decimal pct)
    {
        if (pct >= 95) return "Excellent";
        if (pct >= 80) return "Good";
        if (pct >= 50) return "Average";
        return "Poor";
    }

    private string GetEfficiencyClass(decimal pct)
    {
        if (pct >= 95) return "drv3-eff-excellent";
        if (pct >= 80) return "drv3-eff-good";
        if (pct >= 50) return "drv3-eff-average";
        return "drv3-eff-poor";
    }

    private void OpenEditPayment(InvoiceListDto invoice)
    {
        EditingInvoice = invoice;
        EditCash = invoice.CashAmount;
        EditAccount = invoice.BankAmount;
        EditDialogVisible = true;
        StateHasChanged();
    }

    private void OnEditCashChanged(decimal val)
    {
        if (EditingInvoice == null) return;
        EditCash = val;
        EditAccount = EditingInvoice.TotalAmount - EditCash;
    }

    private void OnEditAccountChanged(decimal val)
    {
        if (EditingInvoice == null) return;
        EditAccount = val;
        EditCash = EditingInvoice.TotalAmount - EditAccount;
    }

    private async Task SaveEditPayment()
    {
        if (EditingInvoice == null) return;
        try
        {
            var success = await SalesService.UpdateInvoicePaymentAsync(EditingInvoice.Id, EditCash, EditAccount);
            if (success)
            {
                NotificationService.Success("Payment updated successfully.");
                EditDialogVisible = false;
                await LoadDataAsync();
            }
            else
            {
                NotificationService.Error("Update failed. Please try again.");
            }
        }
        catch (Exception ex)
        {
            NotificationService.Error($"Update failed: {ex.Message}");
        }
    }

    private async Task ViewInvoiceDetails(Guid id)
    {
        await JSRuntime.InvokeVoidAsync("open", $"/sales/print/{id}", "_blank");
    }

    // ── Excel Export ──
    private async Task DownloadLedger()
    {
        try
        {
            NotificationService.Success("Generating Excel report...");
            ExcelPackage.License.SetNonCommercialOrganization("Vikash Ironix");
            using var package = new ExcelPackage();
            var sheet = package.Workbook.Worksheets.Add("Daily Revenue");

            string[] headers = { "Invoice No", "Customer", "Date", "Weight (KG)", "Total Bill (₹)", "Cash (₹)", "A/C (₹)", "Due (₹)" };
            var headerRange = sheet.Cells[1, 1, 1, headers.Length];
            headerRange.Style.Font.Bold = true;
            headerRange.Style.Font.Color.SetColor(System.Drawing.Color.White);
            headerRange.Style.Fill.PatternType = ExcelFillStyle.Solid;
            headerRange.Style.Fill.BackgroundColor.SetColor(System.Drawing.ColorTranslator.FromHtml("#1e3a5f"));
            headerRange.Style.HorizontalAlignment = ExcelHorizontalAlignment.Center;

            for (int i = 0; i < headers.Length; i++)
                sheet.Cells[1, i + 1].Value = headers[i];

            int row = 2;
            foreach (var b in (_invoiceTable?.FilteredItems ?? FilteredInvoices))
            {
                sheet.Cells[row, 1].Value = b.InvoiceNumber;
                sheet.Cells[row, 2].Value = b.CustomerName;
                sheet.Cells[row, 3].Value = b.InvoiceDate.ToKolkataTime().ToString("dd/MM/yyyy");
                sheet.Cells[row, 4].Value = (double)b.TotalWeightKg;
                sheet.Cells[row, 5].Value = (double)b.TotalAmount;
                sheet.Cells[row, 6].Value = (double)b.CashAmount;
                sheet.Cells[row, 7].Value = (double)b.BankAmount;
                sheet.Cells[row, 8].Value = (double)b.DueAmount;
                if (row % 2 == 0)
                {
                    sheet.Cells[row, 1, row, headers.Length].Style.Fill.PatternType = ExcelFillStyle.Solid;
                    sheet.Cells[row, 1, row, headers.Length].Style.Fill.BackgroundColor.SetColor(System.Drawing.ColorTranslator.FromHtml("#f0f4f8"));
                }
                row++;
            }

            sheet.Cells[2, 4, row - 1, 8].Style.Numberformat.Format = "#,##0.00";
            sheet.Cells.AutoFitColumns();

            var bytes = package.GetAsByteArray();
            var base64 = Convert.ToBase64String(bytes);
            var filename = $"DailyRevenue_{SelectedDate?.ToString("yyyyMMdd") ?? "All"}.xlsx";
            await JSRuntime.InvokeVoidAsync("saveAsFile", filename, base64);
            NotificationService.Success("Excel downloaded successfully.");
        }
        catch (Exception ex)
        {
            NotificationService.Error($"Export failed: {ex.Message}");
        }
    }

    // ── Print ──
    private async Task PrintLedger()
    {
        var html = BuildPrintHtml();
        await JSRuntime.InvokeVoidAsync("vikashPrint", html);
    }

    private string BuildPrintHtml()
    {
        var sb = new System.Text.StringBuilder();
        sb.Append("<!DOCTYPE html><html><head><style>");
        sb.Append("body{font-family:'Segoe UI',sans-serif;padding:20px;color:#0f172a;}");
        sb.Append(".title{font-size:22px;font-weight:bold;color:#1e3a5f;border-bottom:2px solid #1e3a5f;padding-bottom:8px;margin-bottom:16px;}");
        sb.Append("table{width:100%;border-collapse:collapse;font-size:12px;}");
        sb.Append("th{background:#1e3a5f;color:#fff;padding:8px;text-align:left;}");
        sb.Append("td{padding:7px;border-bottom:1px solid #e2e8f0;}");
        sb.Append("tr:nth-child(even){background:#f8fafc;}");
        sb.Append(".totals{font-weight:bold;background:#dbeafe!important;}");
        sb.Append(".tr{text-align:right;}.tc{text-align:center;}");
        sb.Append("</style></head><body>");
        sb.Append($"<div class='title'>Daily Revenue Audit — {SelectedDate?.ToString("dd MMMM yyyy") ?? "All Time"}</div>");
        sb.Append("<table><thead><tr><th>Invoice No</th><th>Customer</th><th>Date</th><th class='tc'>Weight (KG)</th><th class='tr'>Total Bill</th><th class='tr'>Cash</th><th class='tr'>A/C</th><th class='tr'>Due</th></tr></thead><tbody>");
        foreach (var b in (_invoiceTable?.FilteredItems ?? FilteredInvoices))
        {
            sb.Append("<tr>");
            sb.Append($"<td>{b.InvoiceNumber}</td><td>{b.CustomerName}</td><td>{b.InvoiceDate.ToKolkataTime():dd/MM/yyyy}</td>");
            sb.Append($"<td class='tc'>{b.TotalWeightKg:N2}</td>");
            sb.Append($"<td class='tr'>₹{b.TotalAmount:N2}</td><td class='tr'>₹{b.CashAmount:N2}</td><td class='tr'>₹{b.BankAmount:N2}</td><td class='tr'>₹{b.DueAmount:N2}</td>");
            sb.Append("</tr>");
        }
        sb.Append($"<tr class='totals'><td colspan='3'>GRAND TOTAL (कुल योग)</td><td class='tc'>{FilteredInvoices.Sum(b => b.TotalWeightKg):N2}</td><td class='tr'>₹{FilteredInvoices.Sum(b => b.TotalAmount):N2}</td><td class='tr'>₹{FilteredInvoices.Sum(b => b.CashAmount):N2}</td><td class='tr'>₹{FilteredInvoices.Sum(b => b.BankAmount):N2}</td><td class='tr'>₹{FilteredInvoices.Sum(b => b.DueAmount):N2}</td></tr>");
        sb.Append("</tbody></table>");
        sb.Append($"<div style='margin-top:16px;font-size:10px;color:#64748b;'>Generated: {DateTime.Now:dd/MM/yyyy HH:mm}</div>");
        sb.Append("</body></html>");
        return sb.ToString();
    }

    private async Task PrintIndividualBill(Guid id)
    {
        await JSRuntime.InvokeVoidAsync("open", $"/sales/print/{id}", "_blank");
