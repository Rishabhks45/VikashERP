@page "/suppliers"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MudBlazor
@using VikashERP.Web.Models
@using VikashERP.Web.Models.Forms
@using VikashERP.Web.Services.Interfaces
@using Blazored.FluentValidation
@inject ISupplierWebService SupplierService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@rendermode InteractiveServer

<PageTitle>Suppliers</PageTitle>

<MudStack Class="suppliers-list-page" Spacing="4">
    <!-- Header Hero -->
    <div class="org-hero">
        <div class="org-hero-copy">
            <h1>Supplier Management</h1>
            <p class="org-subtitle">Manage your suppliers, contact details, and ledger balances.</p>
        </div>
        <MudButton Variant="Variant.Filled"
                   Class="dashboard-action-primary org-save-btn"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenAddSupplierDialog">
            Add Supplier
        </MudButton>
    </div>

    @if (!_isLoading)
    {
        <!-- KPI Cards -->
        <MudGrid Spacing="2" Class="dashboard-kpis">
            <MudItem xs="12" sm="6" lg="3">
                <MudPaper Elevation="0" Class="dashboard-kpi">
                    <MudPaper Elevation="0" Class="dashboard-kpi-icon accent-blue">
                        <MudIcon Icon="@Icons.Material.Filled.LocalShipping" />
                    </MudPaper>
                    <MudStack Spacing="0" Class="dashboard-kpi-body">
                        <MudText Typo="Typo.caption">Total Suppliers</MudText>
                        <MudText Typo="Typo.h5" HtmlTag="strong">@_suppliers.Count</MudText>
                        <MudText Typo="Typo.caption" Class="trend-neutral">Active contacts</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
            
            <MudItem xs="12" sm="6" lg="3">
                <MudPaper Elevation="0" Class="dashboard-kpi">
                    <MudPaper Elevation="0" Class="dashboard-kpi-icon accent-amber">
                        <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" />
                    </MudPaper>
                    <MudStack Spacing="0" Class="dashboard-kpi-body">
                        <MudText Typo="Typo.caption">Total Payables (Cr)</MudText>
                        <MudText Typo="Typo.h5" HtmlTag="strong">₹@TotalPayables.ToString("N2")</MudText>
                        <MudText Typo="Typo.caption" Class="trend-neutral">Our total debt</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" lg="3">
                <MudPaper Elevation="0" Class="dashboard-kpi">
                    <MudPaper Elevation="0" Class="dashboard-kpi-icon accent-red">
                        <MudIcon Icon="@Icons.Material.Filled.ArrowDownward" />
                    </MudPaper>
                    <MudStack Spacing="0" Class="dashboard-kpi-body">
                        <MudText Typo="Typo.caption">Total Receivables (Dr)</MudText>
                        <MudText Typo="Typo.h5" HtmlTag="strong">₹@TotalReceivables.ToString("N2")</MudText>
                        <MudText Typo="Typo.caption" Class="trend-neutral">Advances paid</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" lg="3">
                <MudPaper Elevation="0" Class="dashboard-kpi">
                    <MudPaper Elevation="0" Class="dashboard-kpi-icon accent-purple">
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" />
                    </MudPaper>
                    <MudStack Spacing="0" Class="dashboard-kpi-body">
                        <MudText Typo="Typo.caption">Net Position</MudText>
                        <MudText Typo="Typo.h5" HtmlTag="strong">@NetPositionFormatted</MudText>
                        <MudText Typo="Typo.caption" Class="trend-neutral">Net payables</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- Main Datagrid Panel -->
        <MudPaper Elevation="0" Class="org-tab-panel pa-6">
            <div class="mb-4 filter-bar">
                <MudTextField @bind-Value="_searchString"
                               Placeholder="Search suppliers..."
                               Adornment="Adornment.Start"
                               AdornmentIcon="@Icons.Material.Filled.Search"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Class="search-bar-full"
                               Immediate="true"
                               Clearable="true" />
                <MudTooltip Text="Refresh">
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="LoadDataAsync" Disabled="@_isLoading" />
                </MudTooltip>
            </div>

            <MudDataGrid T="SupplierListDto" Items="@_suppliers" 
                         Loading="@_isLoading" 
                         Filterable="true" 
                         SortMode="SortMode.Multiple" 
                         Groupable="false" 
                         Dense="true"
                         Hover="true"
                         Striped="false"
                         QuickFilter="@QuickFilter"
                         Class="supplier-table"
                         Style="background: transparent;">
                <Columns>
                    <PropertyColumn Property="x => x.Name" Title="Supplier Name">
                        <CellTemplate>
                            <span style="font-weight: 600;">@context.Item.Name</span>
                        </CellTemplate>
                    </PropertyColumn>
                    <PropertyColumn Property="x => x.CompanyName" Title="Company Name">
                        <CellTemplate>
                            <span style="font-weight: 500;">@context.Item.CompanyName</span>
                        </CellTemplate>
                    </PropertyColumn>
                    <PropertyColumn Property="x => x.Phone" Title="Phone">
                        <CellTemplate>
                            <span style="font-family: monospace;">@context.Item.Phone</span>
                        </CellTemplate>
                    </PropertyColumn>
                    <TemplateColumn Title="Balance" SortBy="x => x.CurrentBalance">
                        <CellTemplate>
                            @{
                                var bal = context.Item.CurrentBalance;
                                var text = bal == 0 ? "₹0.00" : (bal > 0 ? $"₹{bal:N2} (Cr)" : $"₹{Math.Abs(bal):N2} (Dr)");
                                var colorClass = bal == 0 ? "" : (bal > 0 ? "text-success" : "text-error");
                            }
                            <span class="@colorClass fw-bold">@text</span>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Actions" HeaderStyle="text-align: right;" CellStyle="text-align: right;" Sortable="false" Filterable="false">
                        <CellTemplate>
                            <MudIconButton Icon="@Icons.Material.Outlined.Edit" Size="Size.Small" Color="Color.Primary" OnClick="@(() => OpenEditSupplierDialog(context.Item))" />
                            <MudIconButton Icon="@Icons.Material.Outlined.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteSupplierAsync(context.Item))" />
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="SupplierListDto" />
                </PagerContent>
            </MudDataGrid>
        </MudPaper>
    }
</MudStack>

<MudDialog @bind-Visible="_dialogVisible" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(_supplierModel.IsNewSupplier ? Icons.Material.Filled.Add : Icons.Material.Filled.Edit)" Class="mr-3 mb-n1" />
            @(_supplierModel.IsNewSupplier ? "Add New Supplier" : "Edit Supplier")
        </MudText>
    </TitleContent>
    <DialogContent>
        <EditForm Model="@_supplierModel" OnValidSubmit="SaveSupplierAsync">
            <FluentValidationValidator />
            
            <MudTextField @bind-Value="_supplierModel.Name" Label="Supplier Name" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4" For="@(() => _supplierModel.Name)" />
            <MudTextField @bind-Value="_supplierModel.CompanyName" Label="Company Name" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4" For="@(() => _supplierModel.CompanyName)" />
            
            <div class="d-flex gap-4 mb-4">
                <MudTextField @bind-Value="_supplierModel.Phone" Label="Phone" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _supplierModel.Phone)" />
                <MudTextField @bind-Value="_supplierModel.Gstin" Label="GSTIN" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _supplierModel.Gstin)" />
            </div>

            <MudTextField @bind-Value="_supplierModel.Address" Label="Address" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" Class="mb-4" For="@(() => _supplierModel.Address)" />
            
            @if (_supplierModel.IsNewSupplier)
            {
                <MudNumericField @bind-Value="_supplierModel.OpeningBalance" Label="Opening Balance" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4" HelperText="Use negative for debit, positive for credit" />
            }

            <div class="d-flex justify-end mt-4">
                <MudButton OnClick="CloseDialog" Class="mr-2">Cancel</MudButton>
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="@_isSaving">
                    @if (_isSaving)
                    {
                        <MudProgressCircular Class="ms-n1 mr-2" Size="Size.Small" Indeterminate="true" />
                        <span>Saving...</span>
                    }
                    else
                    {
                        <span>Save</span>
                    }
                </MudButton>
            </div>
        </EditForm>
    </DialogContent>
</MudDialog>

@code {
    private List<SupplierListDto> _suppliers = new();
    private bool _isLoading = true;
    private bool _isSaving = false;
    private string _searchString = "";

    private decimal TotalPayables => _suppliers.Where(s => s.CurrentBalance > 0).Sum(s => s.CurrentBalance);
    private decimal TotalReceivables => _suppliers.Where(s => s.CurrentBalance < 0).Sum(s => Math.Abs(s.CurrentBalance));
    
    private string NetPositionFormatted
    {
        get
        {
            var net = _suppliers.Sum(s => s.CurrentBalance);
            if (net == 0) return "₹0.00";
            return net > 0 ? $"₹{net:N2} (Cr)" : $"₹{Math.Abs(net):N2} (Dr)";
        }
    }
    
    private bool _dialogVisible = false;
    private readonly DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
    private SupplierFormModel _supplierModel = new();
    private Guid? _editingSupplierId = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        try
        {
            _suppliers = await SupplierService.GetSuppliersAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading suppliers: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private bool QuickFilter(SupplierListDto supplier)
    {
        if (string.IsNullOrWhiteSpace(_searchString)) return true;
        if (supplier.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (supplier.CompanyName?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (supplier.Phone.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) return true;
        return false;
    }

    private void OpenAddSupplierDialog()
    {
        _supplierModel = new SupplierFormModel { IsNewSupplier = true };
        _editingSupplierId = null;
        _dialogVisible = true;
    }

    private async Task OpenEditSupplierDialog(SupplierListDto supplier)
    {
        var fullSupplier = await SupplierService.GetSupplierByIdAsync(supplier.Id);
        if (fullSupplier != null)
        {
            _supplierModel = new SupplierFormModel
            {
                Name = fullSupplier.Name,
                CompanyName = fullSupplier.CompanyName,
                Phone = fullSupplier.Phone,
                Gstin = fullSupplier.Gstin,
                Address = fullSupplier.Address,
                OpeningBalance = 0, // Cannot edit opening balance later in simple form
                IsNewSupplier = false
            };
            _editingSupplierId = fullSupplier.Id;
            _dialogVisible = true;
        }
        else
        {
            Snackbar.Add("Failed to load supplier details.", Severity.Error);
        }
    }

    private void CloseDialog()
    {
        _dialogVisible = false;
    }

    private async Task SaveSupplierAsync()
    {
        _isSaving = true;
        try
        {
            if (_supplierModel.IsNewSupplier)
            {
                var result = await SupplierService.CreateSupplierAsync(_supplierModel);
                if (result != null)
                {
                    Snackbar.Add("Supplier created successfully", Severity.Success);
                    _dialogVisible = false;
                    await LoadDataAsync();
                }
                else
                {
                    Snackbar.Add("Failed to create supplier. Duplicate name or GSTIN?", Severity.Error);
                }
            }
            else if (_editingSupplierId.HasValue)
            {
                var result = await SupplierService.UpdateSupplierAsync(_editingSupplierId.Value, _supplierModel);
                if (result != null)
                {
                    Snackbar.Add("Supplier updated successfully", Severity.Success);
                    _dialogVisible = false;
                    await LoadDataAsync();
                }
                else
                {
                    Snackbar.Add("Failed to update supplier. Duplicate details?", Severity.Error);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving supplier: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteSupplierAsync(SupplierListDto supplier)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Delete Supplier", 
            $"Are you sure you want to delete the supplier '{supplier.Name}'?", 
            yesText: "Delete", cancelText: "Cancel");

        if (result == true)
        {
            var success = await SupplierService.DeleteSupplierAsync(supplier.Id);
            if (success)
            {
                Snackbar.Add("Supplier deleted successfully", Severity.Success);
                await LoadDataAsync();
            }
            else
            {
                Snackbar.Add("Failed to delete supplier.", Severity.Error);
            }
        }
    }
}
